{
  "groups": [
    "structural",
    "sources",
    "pipeline",
    "query-read",
    "query-write",
    "subcommands",
    "advanced"
  ],
  "exercises": [
    {
      "name": "help-main",
      "group": "structural",
      "description": "Main help screen",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--help"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "polylogue"
        ]
      },
      "tier": 0
    },
    {
      "name": "help-mark-candidates",
      "group": "structural",
      "description": "Mark candidate assertions help",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "mark",
          "candidates",
          "--help"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "candidates"
        ]
      },
      "tier": 0
    },
    {
      "name": "version",
      "group": "structural",
      "description": "Version output",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--version"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "polylogue"
        ]
      },
      "tier": 0
    },
    {
      "name": "completions-bash",
      "group": "sources",
      "description": "Bash shell completions",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "config",
          "completions",
          "--shell",
          "bash"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "complete"
        ]
      },
      "tier": 0
    },
    {
      "name": "stats-default",
      "group": "query-read",
      "description": "Default archive statistics",
      "assertion": {
        "stdout_contains": [
          "Archive"
        ]
      },
      "needs_data": true,
      "execution": {
        "kind": "polylogue",
        "argv": []
      }
    },
    {
      "name": "stats-verbose",
      "group": "query-read",
      "description": "Verbose statistics",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "-v"
        ]
      },
      "needs_data": true
    },
    {
      "name": "query-list",
      "group": "query-read",
      "description": "List sessions",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "read",
          "--all",
          "-n",
          "1"
        ]
      },
      "assertion": {
        "stdout_min_lines": 1
      },
      "needs_data": true
    },
    {
      "name": "query-list-json",
      "group": "query-read",
      "description": "List sessions as JSON",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "read",
          "--all",
          "-n",
          "1",
          "-f",
          "json"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "is_valid_json_array"
        }
      },
      "needs_data": true,
      "output_ext": ".json"
    },
    {
      "name": "query-list-csv",
      "group": "query-read",
      "description": "List sessions as CSV",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "read",
          "--all",
          "-n",
          "1",
          "-f",
          "csv"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "id"
        ]
      },
      "needs_data": true,
      "output_ext": ".csv"
    },
    {
      "name": "query-list-yaml",
      "group": "query-read",
      "description": "List sessions as YAML",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "read",
          "--all",
          "-n",
          "1",
          "-f",
          "yaml"
