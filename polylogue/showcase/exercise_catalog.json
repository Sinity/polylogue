    {
      "name": "run-preview",
      "group": "pipeline",
      "description": "Preview pipeline plan (seeded fixtures)",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--preview",
          "--source",
          "inbox"
        ]
      },
      "env": "seeded",
      "vhs_capture": true
    },
    {
      "name": "run-preview-reparse",
      "group": "pipeline",
      "description": "Preview force-reparse planning (seeded fixtures)",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--preview",
          "--reparse",
          "--source",
          "inbox",
          "parse"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "Reparse requested."
        ]
      },
      "env": "seeded",
      "origin": "authored.showcase-catalog",
      "path_targets": [
        "raw-reparse-loop"
      ],
      "artifact_targets": [
        "raw_validation_state",
        "validation_backlog",
        "parse_backlog",
        "parse_quarantine"
      ],
      "operation_targets": [
        "plan-validation-backlog",
        "plan-parse-backlog"
      ],
      "tags": [
        "pipeline",
        "reparse",
        "maintenance"
      ]
    },
    {
      "name": "run-preview-live",
      "group": "pipeline",
      "description": "Preview pipeline against live sources",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--preview"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "Preview"
        ]
      },
      "env": "live",
      "timeout_s": 600.0
    },
    {
      "name": "run-all",
      "group": "pipeline",
      "description": "Run full pipeline (seeded fixtures)",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--source",
          "inbox"
        ]
      },
      "writes": true,
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "run-stage-render",
      "group": "pipeline",
      "description": "Run render stage only",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--source",
          "inbox",
          "render"
        ]
      },
      "writes": true,
      "depends_on": "run-all",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "run-stage-index",
