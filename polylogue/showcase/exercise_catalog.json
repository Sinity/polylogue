    {
      "name": "count-baseline",
      "group": "query-write",
      "description": "Baseline count before mutations",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "analyze",
          "--count"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "is_integer"
        }
      },
      "needs_data": true,
      "writes": true,
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "tag-add",
      "group": "query-write",
      "description": "Add tag to latest session",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--latest",
          "--add-tag",
          "showcase-test"
        ]
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "count-baseline",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "tag-verify",
      "group": "query-write",
      "description": "Verify tag was added",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "-t",
          "showcase-test",
          "count"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "is_integer"
        }
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "tag-add",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "tags-after-add",
      "group": "query-write",
      "description": "List tags after add",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "ops",
          "state",
          "tags"
        ]
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "tag-add",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "set-meta",
      "group": "query-write",
      "description": "Set metadata on session",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--latest",
          "--set",
          "note",
          "exercise"
        ]
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "count-baseline",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "delete-dry-run",
      "group": "query-write",
      "description": "Dry-run delete",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "-p",
          "chatgpt",
          "--latest",
          "delete",
          "--dry-run"
        ]
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "count-baseline",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "delete-one",
      "group": "query-write",
      "description": "Delete one session",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "-p",
          "chatgpt",
          "-n",
          "1",
          "delete",
          "--force"
        ]
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "count-baseline",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "count-decreased",
      "group": "query-write",
      "description": "Verify count decreased after delete",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "analyze",
          "--count"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "is_integer"
        }
      },
      "needs_data": true,
      "writes": true,
      "depends_on": "delete-one",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "doctor-readiness",
