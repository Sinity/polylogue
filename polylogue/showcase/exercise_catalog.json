    {
      "name": "run-preview",
      "group": "pipeline",
      "description": "Preview pipeline plan (seeded fixtures)",
      "args": [
        "run",
        "--preview",
        "--source",
        "inbox"
      ],
      "env": "seeded",
      "vhs_capture": true
    },
    {
      "name": "run-preview-live",
      "group": "pipeline",
      "description": "Preview pipeline against live sources",
      "args": [
        "run",
        "--preview"
      ],
      "validation": {
        "stdout_contains": [
          "Preview"
        ]
      },
      "env": "live",
      "timeout_s": 600.0
    },
    {
      "name": "run-all",
      "group": "pipeline",
      "description": "Run full pipeline (seeded fixtures)",
      "args": [
        "run",
        "--source",
        "inbox"
      ],
      "writes": true,
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "run-stage-render",
      "group": "pipeline",
      "description": "Run render stage only",
      "args": [
        "run",
        "--source",
        "inbox",
        "render"
      ],
      "writes": true,
      "depends_on": "run-all",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "run-stage-index",
      "group": "pipeline",
      "description": "Run index stage only",
      "args": [
        "run",
        "--source",
        "inbox",
        "index"
      ],
      "writes": true,
      "depends_on": "run-all",
      "tier": 2,
      "env": "seeded"
    },
    {
      "name": "stats-default",
