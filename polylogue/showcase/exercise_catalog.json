  "exercises": [
    {
      "name": "help-main",
      "group": "structural",
      "description": "Main help screen",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--help"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "polylogue"
        ]
      },
      "tier": 0,
      "vhs_capture": true
    },
    {
      "name": "help-run",
      "group": "structural",
      "description": "Run subcommand help",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "run",
          "--help"
        ]
      },
      "assertion": {
        "stdout_contains": [
          "COMMAND1"
        ]
      },
      "tier": 0
    },
