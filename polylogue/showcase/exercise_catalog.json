    {
      "name": "fields-selector",
      "group": "advanced",
      "description": "Select specific JSON fields",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "list",
          "-f",
          "json",
          "--fields",
          "id,title,provider"
        ]
      },
      "assertion": {
        "custom": {
