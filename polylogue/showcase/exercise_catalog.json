  "exercises": [
    {
      "name": "help-main",
      "group": "structural",
      "description": "Main help screen",
      "args": [
        "--help"
      ],
      "validation": {
        "stdout_contains": [
          "polylogue"
        ]
      },
      "tier": 0,
      "vhs_capture": true
    },
    {
      "name": "help-run",
      "group": "structural",
      "description": "Run subcommand help",
      "args": [
        "run",
        "--help"
      ],
      "validation": {
        "stdout_contains": [
          "COMMAND1"
        ]
      },
      "tier": 0
    },
    {
