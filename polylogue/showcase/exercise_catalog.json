        "kind": "polylogue",
        "argv": [
          "doctor",
          "--format",
          "json"
        ]
      },
      "assertion": {
        "stdout_is_valid_json": true
      },
      "needs_data": true,
      "output_ext": ".json"
    },
    {
      "name": "doctor-verbose",
      "group": "subcommands",
      "description": "Verbose readiness check",
      "execution": {
        "kind": "polylogue",
        "argv": [
