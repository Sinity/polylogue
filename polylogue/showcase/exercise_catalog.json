    {
      "name": "exclude-provider",
      "group": "advanced",
      "description": "Exclude a provider",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--exclude-provider",
          "gemini",
          "count"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "is_integer"
        }
      },
      "needs_data": true,
      "tier": 2
    },
    {
      "name": "fields-selector",
      "group": "advanced",
      "description": "Select specific JSON fields",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "list",
          "-f",
          "json",
          "--fields",
          "id,title,provider"
        ]
      },
      "assertion": {
        "custom": {
          "kind": "json_only_fields",
          "allowed": [
            "id",
            "title",
            "provider"
          ]
        }
      },
      "needs_data": true,
      "output_ext": ".json",
      "tier": 2
    },
    {
      "name": "transform-strip",
      "group": "advanced",
      "description": "Strip tool calls from output",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--latest",
          "--transform",
          "strip-all"
        ]
      },
      "needs_data": true,
      "tier": 2,
      "timeout_s": 300.0
    },
    {
      "name": "sample-random",
      "group": "advanced",
      "description": "Random sample of sessions",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "--sample",
          "2",
          "list"
        ]
      },
      "needs_data": true,
      "tier": 2
    },
    {
      "name": "query-search-term",
      "group": "advanced",
      "description": "Full-text search",
      "execution": {
        "kind": "polylogue",
        "argv": [
          "implementation",
          "list"
        ]
      },
      "assertion": {
        "exit_code": null,
        "custom": {
          "kind": "search_exit_ok"
        }
      },
      "needs_data": true,
      "tier": 2
    }
  ]
}
