          <span class="nav-breadcrumb">chatgpt / snap-conv-01...</span>
      </nav>
  
      <main class="container">
          <header class="conversation-header">
              <h1>Linear Conversation</h1>
              <div class="conversation-meta">
                  <span class="badge">chatgpt</span>
                  <span class="meta-item">2 messages</span>
                  
              </div>
          </header>
  
          <div class="messages">
              
              <article class="message message-user" id="msg-1">
                  <div class="message-avatar">
                      <span class="avatar-icon">US</span>
                  </div>
                  <div class="message-content">
                      <header class="message-header">
                          <span class="role-label">user</span>
                          
                      </header>
                      <div class="message-body">
                          <p>Hello there</p>
  
                      </div>
                      
                  </div>
              </article>
              
              <article class="message message-assistant" id="msg-2">
                  <div class="message-avatar">
                      <span class="avatar-icon">AS</span>
                  </div>
                  <div class="message-content">
                      <header class="message-header">
                          <span class="role-label">assistant</span>
                          
                      </header>
                      <div class="message-body">
                          <p>Hi!</p>
  
                      </div>
                      
                  </div>
              </article>
              
          </div>
      </main>
  
      <aside class="toc">
          <h3>Messages</h3>
          <ol class="toc-list">
              
              <li>
                  <a href="#msg-1">
                      user: Hello there
                  </a>
              </li>
              
              <li>
                  <a href="#msg-2">
                      assistant: Hi!
                  </a>
              </li>
              
          </ol>
