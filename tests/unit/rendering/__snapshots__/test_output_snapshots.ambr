  <body>
      <nav class="nav-header">
          <a href="../index.html" class="nav-back">← Back</a>
          <span class="nav-breadcrumb">chatgpt / snap-conv-01...</span>
      </nav>
  
      <main class="container">
          <header class="conversation-header">
              <h1>Followup After Branch</h1>
              <div class="conversation-meta">
                  <span class="badge">chatgpt</span>
                  <span class="meta-item">3 messages</span>
                  
              </div>
          </header>
  
          <div class="messages">
              
              <article class="message message-user" id="msg-1">
                  <div class="message-avatar">
                      <span class="avatar-icon">US</span>
                  </div>
                  <div class="message-content">
                      <header class="message-header">
                          <span class="role-label">user</span>
                          
                      </header>
                      <div class="message-body">
                          <p>Q</p>
  
                      </div>
                      
                  </div>
              </article>
              
              <article class="message message-assistant" id="msg-2">
                  <div class="message-avatar">
                      <span class="avatar-icon">AS</span>
                  </div>
                  <div class="message-content">
                      <header class="message-header">
                          <span class="role-label">assistant</span>
                          
                      </header>
                      <div class="message-body">
                          <p>A1</p>
  
                      </div>
                      
                      <details class="branches">
                          <summary>1 alternative</summary>
                          
                          <div class="branch-message message-assistant">
                              <div class="message-content">
                                  <div class="branch-label">Branch 1</div>
                                  <header class="message-header">
                                      <span class="role-label">assistant</span>
                                      
                                  </header>
                                  <div class="message-body">
                                      <p>A2 alt</p>
  
                                  </div>
                              </div>
                          </div>
                          
                      </details>
                      
                  </div>
              </article>
              
              <article class="message message-user" id="msg-3">
                  <div class="message-avatar">
                      <span class="avatar-icon">US</span>
                  </div>
                  <div class="message-content">
                      <header class="message-header">
                          <span class="role-label">user</span>
                          
                      </header>
                      <div class="message-body">
                          <p>Follow-up</p>
  
                      </div>
                      
                  </div>
              </article>
              
          </div>
      </main>
  
      <aside class="toc">
          <h3>Messages</h3>
          <ol class="toc-list">
              
              <li>
                  <a href="#msg-1">
                      user: Q
                  </a>
              </li>
              
              <li>
                  <a href="#msg-2">
                      assistant: A1
                  </a>
              </li>
              
              <li>
                  <a href="#msg-3">
                      user: Follow-up
                  </a>
              </li>
              
          </ol>
      </aside>
  </body>
  </html>
