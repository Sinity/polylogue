{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polylogue.dev/schemas/demo-packet-v2.schema.json",
  "title": "Polylogue Demo Packet v2",
  "description": "A falsifiable, evidence-resolvable contract for deterministic and field demo findings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "packet_id",
    "title",
    "mode",
    "primary_construct",
    "claim",
    "oracle",
    "baseline",
    "controls",
    "falsifier",
    "results",
    "receipts",
    "non_claims",
    "reproduction",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "packet_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$"
    },
    "title": {"type": "string", "minLength": 3},
    "mode": {"enum": ["public", "private", "fixture", "anti-demo"]},
    "primary_construct": {"$ref": "#/$defs/primaryConstruct"},
    "claim": {"$ref": "#/$defs/claim"},
    "oracle": {"$ref": "#/$defs/oracle"},
    "baseline": {"$ref": "#/$defs/arm"},
    "controls": {"$ref": "#/$defs/controls"},
    "falsifier": {"$ref": "#/$defs/falsifier"},
    "results": {"$ref": "#/$defs/results"},
    "receipts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/receipt"}
    },
    "non_claims": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 12}
    },
    "reproduction": {"$ref": "#/$defs/reproduction"},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "jsonValue": {},
    "primaryConstruct": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "product_primitives"],
      "properties": {
        "id": {"type": "string", "minLength": 3},
        "statement": {"type": "string", "minLength": 12},
        "product_primitives": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 2}
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["statement", "declared_before_execution", "scope", "status", "receipts"],
      "properties": {
        "statement": {"type": "string", "minLength": 12},
        "declared_before_execution": {"const": true},
        "scope": {"type": "string", "minLength": 8},
        "status": {"enum": ["supported", "refuted", "inconclusive", "not_supported"]},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "oracle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["independent", "description", "method", "expected", "receipts"],
      "properties": {
        "independent": {"const": true},
        "description": {"type": "string", "minLength": 12},
        "method": {"type": "string", "minLength": 8},
        "expected": {"$ref": "#/$defs/jsonValue"},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "arm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "method", "result", "receipts"],
      "properties": {
        "name": {"type": "string", "minLength": 3},
        "method": {"type": "string", "minLength": 8},
        "result": {"$ref": "#/$defs/jsonValue"},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "purpose", "expected", "observed", "passed", "receipts"],
      "properties": {
        "id": {"type": "string", "minLength": 3},
        "purpose": {"type": "string", "minLength": 8},
        "expected": {"$ref": "#/$defs/jsonValue"},
        "observed": {"$ref": "#/$defs/jsonValue"},
        "passed": {"type": "boolean"},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["negative", "missing_evidence"],
      "properties": {
        "negative": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/control"}
        },
        "missing_evidence": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/control"}
        }
      }
    },
    "falsifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "evaluation_method", "triggered", "result", "receipts"],
      "properties": {
        "condition": {"type": "string", "minLength": 12},
        "evaluation_method": {"type": "string", "minLength": 8},
        "triggered": {"type": "boolean"},
        "result": {"enum": ["pass", "fail", "inconclusive"]},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "measurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "unit", "receipts"],
      "properties": {
        "name": {"type": "string", "minLength": 2},
        "value": {"$ref": "#/$defs/jsonValue"},
        "unit": {"type": "string", "minLength": 1},
        "receipts": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/refString"}
        }
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "summary", "measurements"],
      "properties": {
        "status": {"enum": ["pass", "fail", "inconclusive", "not_supported"]},
        "summary": {"type": "string", "minLength": 12},
        "measurements": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/measurement"}
        }
      }
    },
    "refString": {
      "type": "string",
      "pattern": "^(session|message|block|action|query|artifact|demo|file|assertion|run|event|context-snapshot):.+$"
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "kind", "description", "artifact_path", "resolved", "sha256"],
      "properties": {
        "ref": {"$ref": "#/$defs/refString"},
        "kind": {
          "enum": [
            "session",
            "message",
            "block",
            "action",
            "query",
            "artifact",
            "demo",
            "file",
            "assertion",
            "run",
            "event",
            "context-snapshot"
          ]
        },
        "description": {"type": "string", "minLength": 8},
        "artifact_path": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
        },
        "resolved": {"const": true},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "reproduction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fixture", "deterministic", "private_data", "commands"],
      "properties": {
        "fixture": {"type": "string", "minLength": 3},
        "deterministic": {"type": "boolean"},
        "private_data": {"type": "boolean"},
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 3}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archive_cursor",
        "measure_version",
        "commit_sha",
        "sample_frame_predicate",
        "run_date"
      ],
      "properties": {
        "archive_cursor": {"type": "string", "minLength": 3},
        "measure_version": {"type": "string", "minLength": 3},
        "commit_sha": {"type": "string", "minLength": 7},
        "sample_frame_predicate": {"type": "string", "minLength": 8},
        "run_date": {"type": "string", "format": "date"}
      }
    }
  }
}
