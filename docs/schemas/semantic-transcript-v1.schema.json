{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polylogue.local/schemas/semantic-transcript-v1.schema.json",
  "title": "Polylogue semantic transcript",
  "type": "object",
  "required": [
    "schema_version",
    "session_id",
    "entries"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "semantic-transcript.v1"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "card": {
      "type": "object",
      "required": [
        "schema_version",
        "kind",
        "title",
        "source",
        "fields",
        "previews",
        "caveats"
      ],
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": "semantic-card.v1"
        },
        "kind": {
          "enum": [
            "shell",
            "file_read",
            "file_edit",
            "search",
            "web",
            "task",
            "mcp",
            "lineage",
            "attachment",
            "fallback"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "source": {
          "type": "object",
          "required": [
            "session_id",
            "provider_family"
          ],
          "additionalProperties": false,
          "properties": {
            "session_id": {
              "type": "string",
              "minLength": 1
            },
            "provider_family": {
              "type": "string",
              "minLength": 1
            },
            "origin": {
              "type": "string"
            },
            "message_id": {
              "type": "string"
            },
            "block_id": {
              "type": "string"
            },
            "block_index": {
              "type": "integer",
              "minimum": 0
            },
            "tool_name": {
              "type": "string"
            },
            "tool_id": {
              "type": "string"
            },
            "attachment_id": {
              "type": "string"
            },
            "material_origin": {
              "type": "string"
            },
            "occurred_at": {
              "type": "string"
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "parent_message_id": {
              "type": "string"
            },
            "variant_index": {
              "type": "integer",
              "minimum": 0
            },
            "is_active_path": {
              "type": "boolean"
            },
            "is_active_leaf": {
              "type": "boolean"
            },
            "inherited_prefix": {
              "type": "boolean"
            },
            "result_message_id": {
              "type": "string"
            },
            "result_block_id": {
              "type": "string"
            },
            "result_block_index": {
              "type": "integer",
              "minimum": 0
            },
            "result_duration_ms": {
              "type": "integer",
              "minimum": 0
            },
            "result_material_origin": {
              "type": "string"
            },
            "result_inherited_prefix": {
              "type": "boolean"
            }
          }
        },
        "outcome": {
          "type": "object",
          "required": [
            "state"
          ],
          "additionalProperties": false,
          "properties": {
            "state": {
              "enum": [
                "succeeded",
                "failed",
                "unknown"
              ]
            },
            "is_error": {
              "type": "boolean"
            },
            "exit_code": {
              "type": "integer"
            }
          }
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "label",
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            }
          }
        },
        "previews": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/card/$defs/preview"
          }
        },
        "raw_evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tool_input": {
              "type": "object"
            },
            "tool_input_raw": {
              "type": "string"
            },
            "result_preview": {
              "$ref": "#/$defs/card/$defs/preview"
            }
          }
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "$defs": {
        "preview": {
          "type": "object",
          "required": [
            "kind",
            "text",
            "line_count",
            "omitted_lines",
            "omitted_characters",
            "truncated",
            "strategy",
            "encoding_replacements"
          ],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "line_count": {
              "type": "integer",
              "minimum": 0
            },
            "omitted_lines": {
              "type": "integer",
              "minimum": 0
            },
            "omitted_characters": {
              "type": "integer",
              "minimum": 0
            },
            "truncated": {
              "type": "boolean"
            },
            "strategy": {
              "enum": [
                "full",
                "head_tail",
                "character_bounded"
              ]
            },
            "encoding_replacements": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "prose": {
      "type": "object",
      "required": [
        "message_id",
        "role",
        "message_type",
        "provider_family",
        "material_origin",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "message_type": {
          "type": "string"
        },
        "provider_family": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string"
        },
        "material_origin": {
          "type": "string"
        },
        "block_id": {
          "type": "string"
        },
        "block_index": {
          "type": "integer",
          "minimum": 0
        },
        "block_type": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "parent_message_id": {
          "type": "string"
        },
        "variant_index": {
          "type": "integer",
          "minimum": 0
        },
        "is_active_path": {
          "type": "boolean"
        },
        "is_active_leaf": {
          "type": "boolean"
        },
        "inherited_prefix": {
          "type": "boolean"
        },
        "text": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      }
    },
    "notice_source": {
      "type": "object",
      "required": [
        "message_id",
        "block_index",
        "block_type",
        "role",
        "message_type",
        "provider_family",
        "material_origin"
      ],
      "additionalProperties": false,
      "properties": {
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string"
        },
        "message_type": {
          "type": "string"
        },
        "provider_family": {
          "type": "string",
          "minLength": 1
        },
        "origin": {
          "type": "string"
        },
        "material_origin": {
          "type": "string"
        },
        "block_id": {
          "type": "string"
        },
        "block_index": {
          "type": "integer",
          "minimum": 0
        },
        "block_type": {
          "type": "string"
        },
        "occurred_at": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "parent_message_id": {
          "type": "string"
        },
        "variant_index": {
          "type": "integer",
          "minimum": 0
        },
        "is_active_path": {
          "type": "boolean"
        },
        "is_active_leaf": {
          "type": "boolean"
        },
        "inherited_prefix": {
          "type": "boolean"
        }
      }
    },
    "notice": {
      "type": "object",
      "required": [
        "kind",
        "count",
        "sources"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "empty_thinking"
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/notice_source"
          }
        }
      }
    },
    "entry": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "entry_type",
            "card"
          ],
          "additionalProperties": false,
          "properties": {
            "entry_type": {
              "const": "card"
            },
            "card": {
              "$ref": "#/$defs/card"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "entry_type",
            "prose"
          ],
          "additionalProperties": false,
          "properties": {
            "entry_type": {
              "const": "prose"
            },
            "prose": {
              "$ref": "#/$defs/prose"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "entry_type",
            "notice"
          ],
          "additionalProperties": false,
          "properties": {
            "entry_type": {
              "const": "notice"
            },
            "notice": {
              "$ref": "#/$defs/notice"
            }
          }
        }
      ]
    }
  }
}
