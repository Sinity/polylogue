{
  "$defs": {
    "ToolCountFiltersPayload": {
      "additionalProperties": false,
      "description": "Filters applied to `polylogue analyze tools --format json`.",
      "properties": {
        "action_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Action Kind"
        },
        "basis": {
          "enum": [
            "tool-use-blocks",
            "observed-events",
            "actions"
          ],
          "title": "Basis",
          "type": "string"
        },
        "days": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Days"
        },
        "detail_patterns": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Detail Patterns",
          "type": "array"
        },
        "limit": {
          "title": "Limit",
          "type": "integer"
        },
        "mcp_server": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Mcp Server"
        },
        "origin": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Origin"
        },
        "tool": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tool"
        }
      },
      "required": [
        "basis",
        "limit"
      ],
      "title": "ToolCountFiltersPayload",
      "type": "object"
    },
    "ToolCountPayload": {
      "additionalProperties": false,
      "description": "Structured output for `polylogue analyze tools --format json`.",
      "properties": {
        "archive_root": {
          "title": "Archive Root",
          "type": "string"
        },
        "detail_level": {
          "enum": [
            "tool_use_block_call_counts",
            "tool_finished_observed_events",
            "canonical_action_evidence_counts"
          ],
          "title": "Detail Level",
          "type": "string"
        },
        "filters": {
          "$ref": "#/$defs/ToolCountFiltersPayload"
        },
        "items": {
          "items": {
            "$ref": "#/$defs/ToolCountRowPayload"
          },
          "title": "Items",
          "type": "array"
        },
        "kind": {
          "enum": [
            "tool_call_counts",
            "tool_observed_event_counts",
            "tool_action_evidence_counts"
          ],
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "detail_level",
        "archive_root",
        "filters",
        "items"
      ],
      "title": "ToolCountPayload",
      "type": "object"
    },
    "ToolCountRowPayload": {
      "additionalProperties": false,
      "description": "One grouped tool count row from a declared archive projection basis.",
      "properties": {
        "action_kind": {
          "title": "Action Kind",
          "type": "string"
        },
        "call_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Call Count"
        },
        "error_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Error Count"
        },
        "event_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Event Count"
        },
        "evidence_kind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Evidence Kind"
        },
        "matched_by": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Matched By"
        },
        "nonzero_exit_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Nonzero Exit Count"
        },
        "normalized_tool_name": {
          "title": "Normalized Tool Name",
          "type": "string"
        },
        "origin": {
          "title": "Origin",
          "type": "string"
        },
        "session_count": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Session Count"
        },
        "source_name": {
          "title": "Source Name",
          "type": "string"
        },
        "status": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Status"
        }
      },
      "required": [
        "source_name",
        "origin",
        "normalized_tool_name",
        "action_kind"
      ],
      "title": "ToolCountRowPayload",
      "type": "object"
    }
  },
  "$id": "https://polylogue.dev/schemas/cli-output/tool-family-comparison.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Multi-basis evidence comparison for `polylogue analyze tools --compare-family ... --format json`. Each nested basis keeps its own filters and counts so observed-event outcomes, raw tool-use blocks, and canonical action/detail evidence are not merged into one misleading dataset.\n\nGenerated from `polylogue.surfaces.payloads.ToolFamilyComparisonPayload` by `devtools render cli-output-schemas`. Do not edit by hand.",
  "properties": {
    "archive_root": {
      "title": "Archive Root",
      "type": "string"
    },
    "bases": {
      "items": {
        "$ref": "#/$defs/ToolCountPayload"
      },
      "title": "Bases",
      "type": "array"
    },
    "caveats": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Caveats",
      "type": "array"
    },
    "family": {
      "title": "Family",
      "type": "string"
    },
    "kind": {
      "const": "tool_family_evidence_comparison",
      "title": "Kind",
      "type": "string"
    }
  },
  "required": [
    "kind",
    "archive_root",
    "family",
    "bases"
  ],
  "title": "Tool Family Comparison",
  "type": "object",
  "x-polylogue-cli-surfaces": [
    "polylogue analyze tools --compare-family FAMILY --format json"
  ],
  "x-polylogue-source-model": "ToolFamilyComparisonPayload"
}
