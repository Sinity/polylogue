        {
          "type": "null"
        }
      ],
      "default": null
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "message_count": {
      "default": 0,
      "title": "Message Count",
      "type": "integer"
    },
    "origin": {
      "title": "Origin",
      "type": "string"
    },
    "repo": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Repo"
    },
    "summary": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Summary"
    },
    "tags": {
      "default": [],
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "target_ref": {
      "anyOf": [
        {
          "$ref": "#/$defs/TargetRefPayload"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "title": {
      "title": "Title",
      "type": "string"
    },
    "updated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "words": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Words"
    }
  },
  "required": [
    "id",
    "origin",
    "title"
  ],
  "title": "Session List Row",
  "type": "object",
  "x-polylogue-cli-surfaces": [
    "polylogue list --format json",
    "polylogue list --format ndjson",
    "polylogue list --format yaml"
