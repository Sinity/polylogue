  "additionalProperties": false,
  "description": "Terminal row envelope for explicit `messages/actions/blocks/assertions/files/runs/observed-events/context-snapshots where ...` query-unit expressions. Shared by CLI JSON output, Python API, MCP, and daemon HTTP.\n\nGenerated from `polylogue.surfaces.payloads.QueryUnitEnvelope` by `devtools render cli-output-schemas`. Do not edit by hand.",
  "properties": {
    "items": {
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/MessageQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ActionQueryRowPayload"
          },
          {
            "$ref": "#/$defs/BlockQueryRowPayload"
          },
          {
            "$ref": "#/$defs/AssertionQueryRowPayload"
          },
          {
            "$ref": "#/$defs/FileQueryRowPayload"
          },
          {
            "$ref": "#/$defs/RunQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ObservedEventQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ContextSnapshotQueryRowPayload"
          }
        ]
      },
      "title": "Items",
      "type": "array"
    },
    "limit": {
      "title": "Limit",
      "type": "integer"
    },
    "mode": {
      "const": "query-unit",
      "default": "query-unit",
      "title": "Mode",
      "type": "string"
    },
    "next_offset": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Next Offset"
    },
    "offset": {
      "title": "Offset",
      "type": "integer"
    },
    "pipeline_stages": {
      "default": [],
      "items": {
        "additionalProperties": true,
        "properties": {
          "field": {
            "type": "string"
          },
          "kind": {
            "enum": [
              "session_scope",
              "sort",
              "limit",
              "offset",
              "group",
              "count"
            ],
            "type": "string"
          },
          "metric": {
            "enum": [
              "count"
            ],
            "type": "string"
          },
          "predicate": {
            "type": "object"
          },
          "sort": {
            "type": "object"
          },
          "value": {
            "type": "integer"
          }
        },
        "required": [
          "kind"
        ],
        "type": "object"
      },
      "title": "Pipeline Stages",
      "type": "array"
    },
    "query": {
      "title": "Query",
      "type": "string"
    },
    "total": {
      "title": "Total",
