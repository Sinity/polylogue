  "$id": "https://polylogue.dev/schemas/cli-output/query-unit-envelope.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Terminal row envelope for explicit `messages/actions/blocks/assertions/observed-events/context-snapshots where ...` query-unit expressions. Shared by CLI JSON output, Python API, MCP, and daemon HTTP.\n\nGenerated from `polylogue.surfaces.payloads.QueryUnitEnvelope` by `devtools render cli-output-schemas`. Do not edit by hand.",
  "properties": {
    "items": {
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/MessageQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ActionQueryRowPayload"
          },
          {
            "$ref": "#/$defs/BlockQueryRowPayload"
          },
          {
            "$ref": "#/$defs/AssertionQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ObservedEventQueryRowPayload"
          },
          {
            "$ref": "#/$defs/ContextSnapshotQueryRowPayload"
          }
        ]
      },
      "title": "Items",
      "type": "array"
    },
    "limit": {
      "title": "Limit",
      "type": "integer"
    },
    "mode": {
      "const": "query-unit",
      "default": "query-unit",
      "title": "Mode",
      "type": "string"
    },
    "next_offset": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Next Offset"
    },
    "offset": {
      "title": "Offset",
      "type": "integer"
    },
    "query": {
      "title": "Query",
      "type": "string"
    },
    "total": {
      "title": "Total",
      "type": "integer"
    },
    "unit": {
      "enum": [
        "message",
        "action",
        "block",
        "assertion",
        "observed-event",
        "context-snapshot"
      ],
      "title": "Unit",
      "type": "string"
    }
  },
  "required": [
    "unit",
    "query",
    "items",
    "total",
    "limit",
    "offset"
  ],
  "title": "Query Unit Envelope",
  "type": "object",
  "x-polylogue-cli-surfaces": [
    "polylogue --format json messages where ...",
    "polylogue --format json actions where ...",
    "polylogue --format json blocks where ...",
    "polylogue --format json assertions where ...",
    "polylogue --format json observed-events where ...",
    "polylogue --format json context-snapshots where ...",
    "Polylogue.query_units(...)",
    "MCP query_units",
    "GET /api/query-units?expression=..."
  ],
  "x-polylogue-source-model": "QueryUnitEnvelope"
