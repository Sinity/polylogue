  "$id": "https://polylogue.dev/schemas/cli-output/conversation-neighbor-candidate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Semantic-neighbor candidate for `polylogue neighbors`: conversation identity plus per-reason evidence and rank.\n\nGenerated from `polylogue.surfaces.payloads.ConversationNeighborCandidatePayload` by `devtools render-cli-output-schemas`. Do not edit by hand.",
