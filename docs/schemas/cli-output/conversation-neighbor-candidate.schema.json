    },
    "query": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Query"
    },
    "rank": {
      "title": "Rank",
      "type": "integer"
    },
    "reasons": {
      "items": {
        "$ref": "#/$defs/ConversationNeighborReasonPayload"
      },
      "title": "Reasons",
      "type": "array"
    },
    "score": {
      "title": "Score",
      "type": "number"
    },
    "source_conversation_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Conversation Id"
    }
  },
  "required": [
    "conversation",
    "rank",
    "score",
    "reasons"
  ],
  "title": "Conversation Neighbor Candidate",
  "type": "object",
  "x-polylogue-cli-surfaces": [
    "polylogue neighbors --format json"
  ],
  "x-polylogue-source-model": "ConversationNeighborCandidatePayload"
}
