#!/usr/bin/env bash
set -euo pipefail

repo="${POLYLOGUE_REPO:-/realm/project/polylogue}"
packet="${POLYLOGUE_CONDUCTOR_PACKET:-$repo/.agent/conductor-devloop}"

mkdir -p "$packet"
mkdir -p "$packet/scripts"

"$repo/.agent/scripts/devloop-refresh-events" >/dev/null

if [ -f "$repo/.agent/README.md" ]; then
  cp -p "$repo/.agent/README.md" "$packet/agent.README.md"
fi
if [ -f "$repo/.agent/scratch/README.md" ]; then
  cp -p "$repo/.agent/scratch/README.md" "$packet/scratch.README.md"
fi
for script in "$repo"/.agent/scripts/devloop-*; do
  if [ -f "$script" ]; then
    cp -p "$script" "$packet/scripts/$(basename "$script")"
  fi
done

{
  printf '# Polylogue Conductor Packet\n\n'
  printf 'Synced: %s\n\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
  printf 'Canonical dir: `%s`\n\n' "$packet"
  printf 'Included files:\n\n'
  find "$packet" -maxdepth 1 -type f -printf '- %f\n' | sort
  printf '\nIncluded scripts:\n\n'
  find "$packet/scripts" -maxdepth 1 -type f -printf '- scripts/%f\n' | sort
} > "$packet/MANIFEST.md"

printf 'refreshed conductor packet at %s\n' "$packet"
