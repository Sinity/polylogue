#!/usr/bin/env bash
set -euo pipefail

repo="${POLYLOGUE_REPO:-/realm/project/polylogue}"
demo_root="${POLYLOGUE_DEMO_ROOT:-$repo/.agent/demos}"
mode="write"
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat <<'EOF'
Usage: .agent/scripts/devloop-refresh-demos [--check]

Refresh or verify the current-curated .agent/demos indexes:
MANIFEST.readable.json, SUMMARY_INDEX.json, and CURATED_CATALOG.md.
EOF
  exit 0
fi
if [ "${1:-}" = "--check" ]; then
  mode="check"
fi

mkdir -p "$demo_root"

python3 - "$demo_root" "$mode" <<'PY'
from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path

root = Path(sys.argv[1]).resolve()
mode = sys.argv[2]
root.mkdir(parents=True, exist_ok=True)

ignored_dirs = {".git", "__pycache__"}
readable_suffixes = {
    ".csv",
    ".err",
    ".json",
    ".jsonl",
    ".md",
    ".out",
    ".stderr",
    ".stdout",
    ".txt",
    ".yaml",
    ".yml",
}


def is_readable(path: Path) -> bool:
    if path.name.startswith("."):
        return False
    if path.suffix in readable_suffixes:
        return True
    return os.access(path, os.X_OK) and path.suffix in {".sh", ""}


def first_heading(path: Path) -> str:
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            match = re.match(r"^#\s+(.+)$", line)
            if match:
                return match.group(1).strip()
    except OSError:
        return ""
    return ""


files: list[dict[str, object]] = []
generated_index_files = {
    "CURATED_CATALOG.md",
    "MANIFEST.readable.json",
    "README.md",
    "SUMMARY_INDEX.json",
}
for path in sorted(root.rglob("*")):
    if not path.is_file():
        continue
    if any(part in ignored_dirs for part in path.relative_to(root).parts):
        continue
    rel = path.relative_to(root).as_posix()
    if rel in generated_index_files:
        continue
    files.append(
        {
            "path": rel,
            "bytes": path.stat().st_size,
            "readable": is_readable(path),
        }
    )

records: list[dict[str, object]] = []
for entry in sorted(path for path in root.iterdir() if path.is_dir() and not path.name.startswith(".")):
    readme = entry / "README.md"
    if not readme.exists():
        readme = entry / "current" / "README.md"
    analysis = entry / "ANALYSIS.md"
    if not analysis.exists():
        analysis = entry / "current" / "ANALYSIS.md"
    title = first_heading(readme) or first_heading(analysis) or entry.name.replace("-", " ").title()
    entry_files = [record for record in files if str(record["path"]).startswith(f"{entry.name}/")]
    readable_count = sum(1 for record in entry_files if record["readable"])
    records.append(
        {
            "id": entry.name,
            "title": title,
            "readme": readme.relative_to(root).as_posix() if readme.exists() else None,
            "analysis": analysis.relative_to(root).as_posix() if analysis.exists() else None,
            "file_count": len(entry_files),
            "readable_count": readable_count,
        }
    )

manifest = {
    "contract": "current-curated-demo-set",
    "root": str(root),
    "packaging": "Use devtools workspace read-package or Chisel for portable readable bundles; this helper only writes indexes.",
    "curation_policy": "This is not append-only. Keep the best current demos here; replace, consolidate, or move stale demos out.",
    "file_count": len(files),
    "readable_count": sum(1 for record in files if record["readable"]),
    "files": files,
}
summary = {
    "root": str(root),
    "summary_count": len(records),
    "records": records,
}
readme_lines = [
    "# Polylogue Current Demo Shelf",
    "",
    "Generated by `.agent/scripts/devloop-refresh-demos`.",
    "",
    "This shelf contains the best current Polylogue demos for the active devloop.",
    "It is not append-only. Replace, consolidate, or move stale demos out when a",
    "better demo supersedes them.",
    "",
    "## Current Entries",
    "",
]
if records:
    for record in records:
        readme_lines.append(f"- `{record['id']}` — {record['title']}")
        if record["readme"]:
            readme_lines.append(f"  - readme: `{record['readme']}`")
        if record["analysis"]:
            readme_lines.append(f"  - analysis: `{record['analysis']}`")
        readme_lines.append(
            f"  - files: {record['file_count']} ({record['readable_count']} readable)"
        )
else:
    readme_lines.append("No demo entries found.")
readme_lines.extend(
    [
        "",
        "Retired demo material belongs under `.agent/archive/retired-demos/`, not here.",
        "",
    ]
)

catalog_lines = [
    "# Polylogue Demo Catalog",
    "",
    "Generated by `.agent/scripts/devloop-refresh-demos`.",
    "",
]
if records:
    for record in records:
        catalog_lines.append(f"## {record['title']}")
        catalog_lines.append("")
        catalog_lines.append(f"- id: `{record['id']}`")
        if record["readme"]:
            catalog_lines.append(f"- readme: `{record['readme']}`")
        if record["analysis"]:
            catalog_lines.append(f"- analysis: `{record['analysis']}`")
        catalog_lines.append(f"- files: {record['file_count']} ({record['readable_count']} readable)")
        catalog_lines.append("")
else:
    catalog_lines.append("No demo entries found.")
    catalog_lines.append("")

outputs = {
    root / "README.md": "\n".join(readme_lines),
    root / "MANIFEST.readable.json": json.dumps(manifest, indent=2, sort_keys=True) + "\n",
    root / "SUMMARY_INDEX.json": json.dumps(summary, indent=2, sort_keys=True) + "\n",
    root / "CURATED_CATALOG.md": "\n".join(catalog_lines),
}

if mode == "check":
    drifted = []
    for path, expected in outputs.items():
        if not path.exists():
            drifted.append(f"missing {path.relative_to(root)}")
            continue
        actual = path.read_text(encoding="utf-8")
        if actual != expected:
            drifted.append(f"out-of-sync {path.relative_to(root)}")
    if drifted:
        for item in drifted:
            print(item, file=sys.stderr)
        raise SystemExit(1)
    print(f"demo indexes sync OK: {root} ({len(records)} demo entries, {len(files)} files)")
else:
    for path, content in outputs.items():
        path.write_text(content, encoding="utf-8")
    print(f"refreshed {root} ({len(records)} demo entries, {len(files)} files)")
PY
