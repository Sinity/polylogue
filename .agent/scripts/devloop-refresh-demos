#!/usr/bin/env bash
set -euo pipefail

repo="${POLYLOGUE_REPO:-/realm/project/polylogue}"
demo_root="${POLYLOGUE_DEMO_ROOT:-$repo/.agent/demos}"

mkdir -p "$demo_root"

python3 - "$demo_root" <<'PY'
from __future__ import annotations

import json
import os
import re
import sys
from pathlib import Path

root = Path(sys.argv[1]).resolve()
root.mkdir(parents=True, exist_ok=True)

ignored_dirs = {".git", "__pycache__"}
readable_suffixes = {
    ".csv",
    ".json",
    ".jsonl",
    ".md",
    ".txt",
    ".yaml",
    ".yml",
}


def is_readable(path: Path) -> bool:
    if path.name.startswith("."):
        return False
    if path.suffix in readable_suffixes:
        return True
    return os.access(path, os.X_OK) and path.suffix in {".sh", ""}


def first_heading(path: Path) -> str:
    try:
        for line in path.read_text(encoding="utf-8", errors="replace").splitlines():
            match = re.match(r"^#\s+(.+)$", line)
            if match:
                return match.group(1).strip()
    except OSError:
        return ""
    return ""


files: list[dict[str, object]] = []
for path in sorted(root.rglob("*")):
    if not path.is_file():
        continue
    if any(part in ignored_dirs for part in path.relative_to(root).parts):
        continue
    rel = path.relative_to(root).as_posix()
    files.append(
        {
            "path": rel,
            "bytes": path.stat().st_size,
            "readable": is_readable(path),
        }
    )

records: list[dict[str, object]] = []
for entry in sorted(path for path in root.iterdir() if path.is_dir() and not path.name.startswith(".")):
    readme = entry / "README.md"
    analysis = entry / "ANALYSIS.md"
    title = first_heading(readme) or first_heading(analysis) or entry.name.replace("-", " ").title()
    entry_files = [record for record in files if str(record["path"]).startswith(f"{entry.name}/")]
    readable_count = sum(1 for record in entry_files if record["readable"])
    records.append(
        {
            "id": entry.name,
            "title": title,
            "readme": f"{entry.name}/README.md" if readme.exists() else None,
            "analysis": f"{entry.name}/ANALYSIS.md" if analysis.exists() else None,
            "file_count": len(entry_files),
            "readable_count": readable_count,
        }
    )

manifest = {
    "contract": "current-curated-demo-set",
    "root": str(root),
    "packaging": "Use devtools workspace read-package or Chisel for portable readable bundles; this helper only writes indexes.",
    "curation_policy": "This is not append-only. Keep the best current demos here; replace, consolidate, or move stale demos out.",
    "file_count": len(files),
    "readable_count": sum(1 for record in files if record["readable"]),
    "files": files,
}
summary = {
    "root": str(root),
    "summary_count": len(records),
    "records": records,
}
catalog_lines = [
    "# Polylogue Demo Catalog",
    "",
    "Generated by `.agent/scripts/devloop-refresh-demos`.",
    "",
]
if records:
    for record in records:
        catalog_lines.append(f"## {record['title']}")
        catalog_lines.append("")
        catalog_lines.append(f"- id: `{record['id']}`")
        if record["readme"]:
            catalog_lines.append(f"- readme: `{record['readme']}`")
        if record["analysis"]:
            catalog_lines.append(f"- analysis: `{record['analysis']}`")
        catalog_lines.append(f"- files: {record['file_count']} ({record['readable_count']} readable)")
        catalog_lines.append("")
else:
    catalog_lines.append("No demo entries found.")
    catalog_lines.append("")

(root / "MANIFEST.readable.json").write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n", encoding="utf-8")
(root / "SUMMARY_INDEX.json").write_text(json.dumps(summary, indent=2, sort_keys=True) + "\n", encoding="utf-8")
(root / "CURATED_CATALOG.md").write_text("\n".join(catalog_lines), encoding="utf-8")
print(f"refreshed {root} ({len(records)} demo entries, {len(files)} files)")
PY
