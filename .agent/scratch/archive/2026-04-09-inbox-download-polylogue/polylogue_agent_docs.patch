diff --git a/devtools/generate_agents_md.py b/devtools/generate_agents_md.py
new file mode 100644
index 00000000..ec5d5670
--- /dev/null
+++ b/devtools/generate_agents_md.py
@@ -0,0 +1,77 @@
+"""Generate AGENTS.md by resolving CLAUDE.md @imports.
+
+This lets Codex-style agents consume roughly the same project memory that
+Claude Code receives through native transclusion.
+"""
+
+from __future__ import annotations
+
+import argparse
+import os
+import re
+from pathlib import Path
+
+ROOT = Path(__file__).resolve().parents[1]
+DEFAULT_SOURCE = ROOT / "CLAUDE.md"
+DEFAULT_TARGET = ROOT / "AGENTS.md"
+IMPORT_RE = re.compile(r"^\s*@(.+?)\s*$")
+
+
+def _resolve_include(base_file: Path, include: str) -> Path:
+    include_path = Path(os.path.expanduser(include))
+    if not include_path.is_absolute():
+        include_path = (base_file.parent / include_path).resolve()
+    return include_path
+
+
+def expand_file(path: Path, *, stack: tuple[Path, ...] = ()) -> str:
+    path = path.resolve()
+    if path in stack:
+        chain = " -> ".join(p.name for p in (*stack, path))
+        return f"\n<!-- circular import skipped: {chain} -->\n"
+    try:
+        text = path.read_text(encoding="utf-8")
+    except OSError as exc:
+        return f"\n<!-- failed to read {path}: {exc} -->\n"
+
+    out: list[str] = []
+    in_fence = False
+    for raw_line in text.splitlines():
+        stripped = raw_line.strip()
+        if stripped.startswith("```"):
+            in_fence = not in_fence
+            out.append(raw_line)
+            continue
+        if not in_fence:
+            match = IMPORT_RE.match(raw_line)
+            if match:
+                include_path = _resolve_include(path, match.group(1))
+                out.append(expand_file(include_path, stack=(*stack, path)))
+                continue
+        out.append(raw_line)
+    return "\n".join(out).rstrip() + "\n"
+
+
+def main() -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--source", type=Path, default=DEFAULT_SOURCE)
+    parser.add_argument("--output", type=Path, default=DEFAULT_TARGET)
+    parser.add_argument("--stdout", action="store_true")
+    args = parser.parse_args()
+
+    expanded = expand_file(args.source)
+    banner = (
+        "<!-- Generated from CLAUDE.md by devtools/generate_agents_md.py. "
+        "Edit CLAUDE.md and imported files, then regenerate. -->\n\n"
+    )
+    payload = banner + expanded
+
+    if args.stdout:
+        print(payload, end="")
+    else:
+        args.output.write_text(payload, encoding="utf-8")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
