+"""Runtime manifest generated from the registered FastMCP surface."""
+
+from __future__ import annotations
+
+from typing import Any, cast
+
+from polylogue.agent_integration.assets import agent_asset_metadata
+from polylogue.agent_integration.spec import CAPABILITY_FAMILIES, MCPRole, RECIPES, ROLE_ORDER, ROLES
+from polylogue.version import POLYLOGUE_VERSION
+
+
+def _surface_names(manager: object, attribute: str) -> list[str]:
+    value = getattr(manager, attribute, None)
+    if not isinstance(value, dict):
+        return []
+    return sorted(str(name) for name in value)
+
+
+def build_live_manifest(role: MCPRole = "read") -> dict[str, object]:
+    """Build the role-scoped server and enumerate its actual registered surface."""
+    if role not in ROLES:
+        raise ValueError(f"unknown MCP role: {role}")
+    from polylogue.mcp.server import build_server
+
+    server = build_server(role=role)
+    tool_manager = getattr(server, "_tool_manager", None)
+    resource_manager = getattr(server, "_resource_manager", None)
+    prompt_manager = getattr(server, "_prompt_manager", None)
+    tools = _surface_names(tool_manager, "_tools")
+    resources = _surface_names(resource_manager, "_resources")
+    templates = _surface_names(resource_manager, "_templates")
+    prompts = _surface_names(prompt_manager, "_prompts")
+    allowed_recipes = [recipe.id for recipe in RECIPES if ROLE_ORDER[role] >= ROLE_ORDER[recipe.minimum_role]]
+    metadata = agent_asset_metadata()
+    return {
+        "schema_version": 1,
+        "package_version": POLYLOGUE_VERSION,
+        "role": role,
+        "asset": metadata,
+        "tools": tools,
+        "resources": resources,
+        "resource_templates": templates,
+        "prompts": prompts,
+        "counts": {
+            "tools": len(tools),
+            "resources": len(resources),
+            "resource_templates": len(templates),
+            "prompts": len(prompts),
+        },
+        "capability_families": [family.id for family in CAPABILITY_FAMILIES],
+        "available_recipes": allowed_recipes,
+    }
+
+
+def manifest_name_sets(payload: dict[str, object]) -> dict[str, set[str]]:
+    """Return typed name sets for executable validation."""
+    return {
+        key: {str(item) for item in cast(list[Any], payload.get(key, []))}
+        for key in ("tools", "resources", "resource_templates", "prompts")
+    }
+
+
+__all__ = ["build_live_manifest", "manifest_name_sets"]
