diff --git a/devtools/render_agent_manual.py b/devtools/render_agent_manual.py
new file mode 100644
index 0000000000000000000000000000000000000000..b6e40e8e44d6394327fb0c6e1421eeac32fa16ac
--- /dev/null
+++ b/devtools/render_agent_manual.py
@@ -0,0 +1,85 @@
+"""Render/check packaged agent integration JSON and documentation mirrors."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import sys
+from pathlib import Path
+
+_REPO_ROOT = str(Path(__file__).resolve().parents[1])
+if sys.path[0] != _REPO_ROOT:
+    sys.path.insert(0, _REPO_ROOT)
+
+from polylogue.agent_integration.spec import integration_spec_payload, recipe_payload
+
+REPO_ROOT = Path(__file__).resolve().parents[1]
+DATA_DIR = REPO_ROOT / "polylogue" / "agent_integration" / "data"
+DOC_TARGETS = {
+    DATA_DIR / "standing-manual.md": REPO_ROOT / "docs" / "agent-manual.md",
+    DATA_DIR / "deep-reference.md": REPO_ROOT / "docs" / "agent-integration-reference.md",
+}
+
+
+def _json_text(value: object) -> str:
+    return json.dumps(value, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
+
+
+def _static_manifest() -> dict[str, object]:
+    spec = integration_spec_payload()
+    recipes = recipe_payload()
+    families = spec["capability_families"]
+    recipe_rows = recipes["recipes"]
+    assert isinstance(families, list)
+    assert isinstance(recipe_rows, list)
+    return {
+        "schema_version": 1,
+        "content_version": spec["content_version"],
+        "description": (
+            "Static packaged manifest. Use `polylogue agent manifest --role ROLE` "
+            "for the live registered surface."
+        ),
+        "default_role": "read",
+        "clients": spec["clients"],
+        "resources": spec["resources"],
+        "capability_families": [row["id"] for row in families if isinstance(row, dict)],
+        "recipe_ids": [row["id"] for row in recipe_rows if isinstance(row, dict)],
+    }
+
+
+def expected_outputs() -> dict[Path, str]:
+    """Return every generated target and its expected UTF-8 text."""
+    outputs = {
+        DATA_DIR / "recipes.json": _json_text(recipe_payload()),
+        DATA_DIR / "integration-spec.json": _json_text(integration_spec_payload()),
+        DATA_DIR / "integration-manifest.json": _json_text(_static_manifest()),
+    }
+    for source, target in DOC_TARGETS.items():
+        outputs[target] = source.read_text(encoding="utf-8")
+    return outputs
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--check", action="store_true", help="Fail when a generated target differs.")
+    args = parser.parse_args(argv)
+    drift: list[str] = []
+    for path, expected in expected_outputs().items():
+        actual = path.read_text(encoding="utf-8") if path.exists() else None
+        if actual == expected:
+            continue
+        if args.check:
+            drift.append(str(path.relative_to(REPO_ROOT)))
+            continue
+        path.parent.mkdir(parents=True, exist_ok=True)
+        path.write_text(expected, encoding="utf-8")
+        print(f"rendered {path.relative_to(REPO_ROOT)}")
+    if drift:
+        for path in drift:
+            print(f"out of date: {path}")
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
diff --git a/devtools/verify_agent_integration.py b/devtools/verify_agent_integration.py
