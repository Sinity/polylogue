@@ -0,0 +1,319 @@
+"""Typed authority for the packaged agent integration contract."""
+
+from __future__ import annotations
+
+from dataclasses import asdict, dataclass
+from typing import Literal
+
+
+ASSET_VERSION = "2026-07-17.4"
+MCPRole = Literal["read", "write", "review", "admin"]
+AgentClient = Literal["claude-code", "codex", "gemini", "hermes"]
+GuidanceMode = Literal["full", "mcp-only", "off"]
+QuerySurface = Literal["session", "terminal"]
+
+CLIENTS: tuple[AgentClient, ...] = ("claude-code", "codex", "gemini", "hermes")
+ROLES: tuple[MCPRole, ...] = ("read", "write", "review", "admin")
+GUIDANCE_MODES: tuple[GuidanceMode, ...] = ("full", "mcp-only", "off")
+ROLE_ORDER: dict[MCPRole, int] = {"read": 0, "write": 1, "review": 2, "admin": 3}
+
+
+@dataclass(frozen=True, slots=True)
+class CapabilityFamily:
+    """One stable reason for an agent to invoke Polylogue."""
+
+    id: str
+    title: str
+    minimum_role: MCPRole
+    first_route: str
+
+
+@dataclass(frozen=True, slots=True)
+class CheckedQuery:
+    """A query expression and the compiler surface that owns it."""
+
+    expression: str
+    surface: QuerySurface
+    purpose: str
+
+
+@dataclass(frozen=True, slots=True)
+class Recipe:
+    """Executable workflow recipe referenced by the standing manual."""
+
+    id: str
+    title: str
+    intent: str
+    family: str
+    minimum_role: MCPRole
+    queries: tuple[CheckedQuery, ...]
+    cli_routes: tuple[str, ...]
+    tools: tuple[str, ...]
+    resources: tuple[str, ...] = ()
+    prompts: tuple[str, ...] = ()
+
+
+CAPABILITY_FAMILIES: tuple[CapabilityFamily, ...] = (
+    CapabilityFamily("readiness", "Archive identity, readiness, freshness, and coverage", "read", "readiness_check"),
+    CapabilityFamily("continuity", "Resume and handoff reconstruction", "read", "find_resume_candidates"),
+    CapabilityFamily("search", "Cross-session search and terminal row queries", "read", "search/query_units"),
+    CapabilityFamily("lineage", "Logical sessions, branches, lineage, and related work", "read", "get_session_tree"),
+    CapabilityFamily("workflow", "Workflow, orchestration, tasks, attempts, and effects", "read", "query_units"),
+    CapabilityFamily("postmortem", "Failures, diagnostics, and postmortems", "read", "get_postmortem_bundle"),
+    CapabilityFamily("files", "File-touch and implementation-history reconstruction", "read", "query_units"),
+    CapabilityFamily("decisions", "Decisions, assertions, corrections, and judgment", "read", "list_assertion_claims"),
+    CapabilityFamily("cost", "Usage, latency, and cost analysis", "read", "provider_usage"),
+    CapabilityFamily("coordination", "Agent coordination and active-work awareness", "read", "agent_coordination"),
