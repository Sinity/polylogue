index 0000000000000000000000000000000000000000..862336c4c87793236e7df9dad4983818bb2c6c65
--- /dev/null
+++ b/devtools/verify_agent_integration.py
@@ -0,0 +1,574 @@
+"""Verify executable agent-manual, query, MCP, installer, and packaging contracts."""
+
+from __future__ import annotations
+
+import argparse
+import ast
+import contextlib
+import io
+import json
+import re
+import shlex
+import stat
+import tempfile
+import time
+from collections.abc import Callable, Mapping
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Literal, cast
+
+import click
+
+from devtools.render_agent_manual import REPO_ROOT, expected_outputs
+from polylogue.agent_integration.assets import ALL_ASSETS, agent_asset_metadata, read_agent_asset, read_agent_json
+from polylogue.agent_integration.installer import AgentIntegrationManager, InstallOptions
+from polylogue.agent_integration.spec import RECIPES, ROLES, AgentClient, MCPRole
+
+LaneStatus = Literal["pass", "fail", "unverified"]
+
+
+@dataclass(frozen=True, slots=True)
+class LaneResult:
+    name: str
+    status: LaneStatus
+    detail: dict[str, object]
+
+    def to_dict(self) -> dict[str, object]:
+        return {"name": self.name, "status": self.status, **self.detail}
+
+
+def _pass(name: str, **detail: object) -> LaneResult:
+    return LaneResult(name, "pass", detail)
+
+
+def _fail(name: str, error: BaseException | str, **detail: object) -> LaneResult:
+    message = str(error)
+    return LaneResult(name, "fail", {"error": message, **detail})
+
+
+def _unverified(name: str, reason: BaseException | str, **detail: object) -> LaneResult:
+    return LaneResult(name, "unverified", {"reason": str(reason), **detail})
+
+
+def _generated_assets_lane() -> LaneResult:
+    name = "generated-assets"
+    try:
+        drift = [str(path.relative_to(REPO_ROOT)) for path, expected in expected_outputs().items() if path.read_text() != expected]
+        if drift:
+            return _fail(name, "generated agent surfaces are out of date", drift=drift)
+        metadata = agent_asset_metadata()
+        recipes = read_agent_json("recipes.json")
+        spec = read_agent_json("integration-spec.json")
+        manual = read_agent_asset("standing-manual.md")
+        reference = read_agent_asset("deep-reference.md")
+        missing_recipe_ids = [recipe.id for recipe in RECIPES if f"(`{recipe.id}`)" not in reference]
+        if missing_recipe_ids:
+            return _fail(name, "reference omits typed recipes", missing_recipe_ids=missing_recipe_ids)
+        if [row["id"] for row in cast(list[dict[str, object]], recipes["recipes"])] != [r.id for r in RECIPES]:
+            return _fail(name, "recipes.json differs from typed authority")
+        if set(cast(list[str], spec["clients"])) != {"claude-code", "codex", "gemini", "hermes"}:
+            return _fail(name, "integration-spec.json has incomplete client coverage")
+        required_manual_sections = (
+            "## Cold-start route",
+            "## Archive identity, authority, and uncertainty",
+            "## Query, read, get, and explain algebra",
+            "## Evidence and answer discipline",
+            "## Authority and MCP roles",
+            "## Degraded states and recovery",
+            "## Native-client delivery and opt-down behavior",
+        )
+        missing_sections = [section for section in required_manual_sections if section not in manual]
+        if missing_sections:
+            return _fail(name, "standing manual omits required sections", missing_sections=missing_sections)
+        return _pass(
+            name,
+            assets=list(ALL_ASSETS),
+            asset_digest=metadata["asset_digest"],
+            standing_manual_bytes=metadata["standing_manual_bytes"],
+            deep_reference_bytes=metadata["deep_reference_bytes"],
+            capability_families=metadata["capability_family_count"],
+            recipes=metadata["recipe_count"],
+        )
+    except Exception as exc:
+        return _fail(name, exc)
+
+
+
+
+_QUERY_SOURCE_PREFIXES = (
+    "sessions where ",
+    "messages where ",
+    "actions where ",
+    "files where ",
+    "assertions where ",
+    "runs where ",
+    "observed-events where ",
+    "context-snapshots where ",
+    "delegations where ",
+)
+_NEGATIVE_QUERY_EXPRESSIONS = {"sessions where repo:polylogue | count"}
+
+
+def _documented_query_expressions() -> tuple[set[str], set[str]]:
+    expressions: set[str] = set()
+    notation: set[str] = set()
+    for asset_name in ("standing-manual.md", "deep-reference.md"):
+        text = read_agent_asset(asset_name)
+        for code in re.findall(r"`([^`]+)`", text):
+            if code.startswith(("polylogue ", "polylogued ", "polylogue-mcp ")):
+                continue
+            if not (code.startswith(_QUERY_SOURCE_PREFIXES) or code.startswith(("repo:", "tag:", "origin:", "~\""))):
+                continue
+            if "..." in code or "<unit>" in code:
+                notation.add(code)
+                continue
+            expressions.add(code)
+    return expressions, notation
+
+
+def _query_catalog_lane() -> LaneResult:
+    name = "query-catalog"
+    try:
+        from polylogue.archive.query.expression import ExpressionCompileError, compile_expression, parse_unit_source_expression
+    except ModuleNotFoundError as exc:
+        return _unverified(name, exc, production_dependency="locked query-parser runtime dependencies")
+    try:
+        typed_surfaces = {
+            query.expression: query.surface
+            for recipe in RECIPES
+            for query in recipe.queries
+        }
+        documented, notation = _documented_query_expressions()
+        expressions = set(typed_surfaces) | documented
+        session_count = 0
+        terminal_count = 0
+        negative_count = 0
+        for expression in sorted(expressions):
+            if expression in _NEGATIVE_QUERY_EXPRESSIONS:
+                try:
+                    compile_expression(expression)
+                except ExpressionCompileError:
+                    negative_count += 1
+                    continue
+                return _fail(name, f"documented negative query unexpectedly compiled: {expression}")
+            surface = typed_surfaces.get(expression)
+            parsed = parse_unit_source_expression(expression)
+            if surface == "terminal" or parsed is not None:
+                if parsed is None:
+                    return _fail(name, f"terminal query did not lower: {expression}")
+                terminal_count += 1
+            else:
+                compile_expression(expression)
+                session_count += 1
+        unsafe = "sessions where repo:polylogue | actions where action:file_edit | limit 1"
+        try:
+            compile_expression(unsafe)
+        except ExpressionCompileError:
+            negative_count += 1
+        else:
+            return _fail(name, "session compiler silently accepted a terminal pipeline")
+        return _pass(
+            name,
+            session_queries=session_count,
+            terminal_queries=terminal_count,
+            negative_boundaries=negative_count,
+            documented_notation=len(notation),
+            unique_expressions=len(expressions),
+        )
+    except Exception as exc:
+        return _fail(name, exc)
+
+
+def _documented_cli_routes() -> list[str]:
+    routes: list[str] = []
+    for asset_name in ("standing-manual.md", "deep-reference.md"):
+        text = read_agent_asset(asset_name)
+        for route in re.findall(r"`((?:polylogue|polylogued|polylogue-mcp)(?: [^`]*)?)`", text):
+            normalized = route.replace("CLIENT", "claude-code").replace("ROLE", "read")
+            if normalized not in routes:
+                routes.append(normalized)
+    return routes
+
+
+def _root_click_command(executable: str) -> click.Command:
+    if executable == "polylogue":
+        from polylogue.cli.click_app import cli
+
+        return cli
+    if executable == "polylogued":
+        from polylogue.daemon.cli import main
+
+        return main
+    if executable == "polylogue-mcp":
+        from polylogue.mcp.cli import main
+
+        return main
+    raise ValueError(f"unknown Polylogue executable: {executable}")
+
+
+def _parse_click_route(route: str) -> None:
+    tokens = shlex.split(route)
+    if not tokens:
+        raise ValueError("empty CLI route")
+    command: click.Command = _root_click_command(tokens[0])
+    parent: click.Context | None = None
+    command_name = tokens[0]
+    remaining = tokens[1:]
+    while True:
+        try:
+            with contextlib.redirect_stdout(io.StringIO()), contextlib.redirect_stderr(io.StringIO()):
+                context = command.make_context(command_name, remaining, parent=parent, resilient_parsing=False)
+        except click.exceptions.Exit as exc:
+            if exc.exit_code == 0:
+                return
+            raise
+        if not isinstance(command, click.Group):
+            if context.args:
+                raise click.UsageError(f"unexpected trailing arguments: {context.args}")
+            return
+        protected = list(getattr(context, "protected_args", ()))
+        unresolved = [*protected, *context.args]
+        if not unresolved:
+            return
+        next_name, next_command, next_args = command.resolve_command(context, unresolved)
+        if next_command is None:
+            raise click.UsageError(f"could not resolve command in route: {route}")
+        parent = context
+        command = next_command
+        command_name = next_name or next_command.name or ""
+        remaining = next_args
+
+
+def _cli_command_contract_lane() -> LaneResult:
+    name = "cli-command-contract"
+    routes = list(dict.fromkeys(
+        [route for recipe in RECIPES for route in recipe.cli_routes]
+        + _documented_cli_routes()
+        + [
+            "polylogue agent install --client claude-code --role read --guidance full --format json",
+            "polylogue agent status --format json",
+            "polylogue agent doctor --format json",
+            "polylogue agent uninstall --client claude-code --format json",
+            "polylogue agent manual --kind reference --format json",
+        ]
+    ))
+    checked: list[str] = []
+    unavailable: list[dict[str, str]] = []
+    for route in routes:
+        try:
+            _parse_click_route(route)
+            checked.append(route)
+        except ModuleNotFoundError as exc:
+            unavailable.append({"route": route, "dependency": exc.name or str(exc)})
+        except Exception as exc:
+            return _fail(name, exc, route=route, checked=len(checked))
+    if unavailable:
+        return _unverified(
+            name,
+            "some lazy command modules require locked runtime dependencies unavailable in this shell",
+            checked=len(checked),
+            total=len(routes),
+            unavailable=unavailable,
+        )
+    return _pass(name, checked=len(checked), routes=routes)
+
+
+def _literal_expected_mcp_names() -> dict[str, set[str]]:
+    source = (REPO_ROOT / "tests" / "infra" / "mcp.py").read_text()
+    tree = ast.parse(source)
+    values: dict[str, set[str]] = {}
+    wanted = {
+        "EXPECTED_TOOL_NAMES": "tools",
+        "EXPECTED_RESOURCE_URIS": "resources",
+        "EXPECTED_RESOURCE_TEMPLATE_URIS": "resource_templates",
+        "EXPECTED_PROMPT_NAMES": "prompts",
+    }
+    for node in tree.body:
+        if not isinstance(node, ast.Assign):
+            continue
+        for target in node.targets:
+            if isinstance(target, ast.Name) and target.id in wanted:
+                literal = ast.literal_eval(node.value)
+                if isinstance(literal, set):
+                    values[wanted[target.id]] = {str(item) for item in literal}
+    resource_source = (REPO_ROOT / "polylogue" / "mcp" / "server_resources.py").read_text()
+    resource_tree = ast.parse(resource_source)
+    for node in ast.walk(resource_tree):
+        if not isinstance(node, ast.Call) or not isinstance(node.func, ast.Attribute):
+            continue
+        if node.func.attr != "resource" or not node.args:
+            continue
+        try:
+            uri = ast.literal_eval(node.args[0])
+        except (ValueError, TypeError):
+            continue
+        if not isinstance(uri, str):
+            continue
+        target = "resource_templates" if "{" in uri else "resources"
+        values.setdefault(target, set()).add(uri)
+    return values
+
+
+
+
+_NON_MCP_SNAKE_IDENTIFIERS = {
+    "acted_on",
+    "agent_integration",
+    "census_id",
+    "conv_id",
+    "delivery_state",
+    "file_edit",
+    "mapping_state",
+    "next_cursor",
+    "record_id",
+    "session_start",
+}
+_NEGATIVE_MCP_NAMES = {"get_recovery_report", "get_session"}
+
+
+def _documented_mcp_identifiers() -> set[str]:
+    identifiers: set[str] = set()
+    for asset_name in ("standing-manual.md", "deep-reference.md"):
+        text = read_agent_asset(asset_name)
+        identifiers.update(
+            re.findall(r"(?<![A-Za-z0-9])[a-z][a-z0-9]*(?:_[a-z0-9]+)+(?![A-Za-z0-9])", text)
+        )
+    return identifiers - _NON_MCP_SNAKE_IDENTIFIERS
+
+
+def _validate_recipe_names(role_manifests: Mapping[MCPRole, dict[str, object]]) -> list[str]:
+    problems: list[str] = []
+    for recipe in RECIPES:
+        manifest = role_manifests[recipe.minimum_role]
+        tools = set(cast(list[str], manifest["tools"]))
+        resources = set(cast(list[str], manifest["resources"])) | set(cast(list[str], manifest["resource_templates"]))
+        prompts = set(cast(list[str], manifest["prompts"]))
+        for tool in recipe.tools:
+            if tool not in tools:
+                problems.append(f"{recipe.id}: missing {recipe.minimum_role}-role tool {tool}")
+        for resource in recipe.resources:
+            if resource not in resources:
+                problems.append(f"{recipe.id}: missing resource {resource}")
+        for prompt in recipe.prompts:
+            if prompt not in prompts:
+                problems.append(f"{recipe.id}: missing prompt {prompt}")
+    return problems
+
+
+def _mcp_role_surface_lane() -> LaneResult:
+    name = "mcp-role-surface"
+    static_names = _literal_expected_mcp_names()
+    static_problems = []
+    static_all_names = set().union(*static_names.values())
+    documented_names = _documented_mcp_identifiers()
+    unknown_documented = documented_names - static_all_names - _NEGATIVE_MCP_NAMES
+    if unknown_documented:
+        static_problems.extend(f"unknown documented MCP identifier: {name}" for name in sorted(unknown_documented))
+    missing_negative_names = _NEGATIVE_MCP_NAMES - documented_names
+    if missing_negative_names:
+        static_problems.extend(
+            f"missing deliberate negative MCP identifier: {name}" for name in sorted(missing_negative_names)
+        )
+    for recipe in RECIPES:
+        for tool in recipe.tools:
+            if tool not in static_names.get("tools", set()):
+                static_problems.append(f"unknown tool in static contract: {tool}")
+        for resource in recipe.resources:
+            if resource not in static_names.get("resources", set()) | static_names.get("resource_templates", set()):
+                static_problems.append(f"unknown resource in static contract: {resource}")
+        for prompt in recipe.prompts:
+            if prompt not in static_names.get("prompts", set()):
+                static_problems.append(f"unknown prompt in static contract: {prompt}")
+    if static_problems:
+        return _fail(name, "recipe names fail static MCP contract", problems=static_problems)
+    try:
+        from polylogue.agent_integration.manifest import build_live_manifest
+
+        manifests = {role: build_live_manifest(role) for role in ROLES}
+    except ModuleNotFoundError as exc:
+        return _unverified(
+            name,
+            exc,
+            static_contract="pass",
+            static_counts={key: len(value) for key, value in static_names.items()},
+            documented_names=len(documented_names - _NEGATIVE_MCP_NAMES),
+            deliberate_negative_names=sorted(_NEGATIVE_MCP_NAMES),
+            production_dependency="mcp SDK and locked runtime dependencies",
+        )
+    except ImportError as exc:
+        return _unverified(name, exc, static_contract="pass")
+    problems = _validate_recipe_names(manifests)
+    previous: set[str] = set()
+    counts: dict[str, object] = {}
+    for role in ROLES:
+        tools = set(cast(list[str], manifests[role]["tools"]))
+        if not previous.issubset(tools):
+            problems.append(f"{role} role dropped tools available to the preceding role")
+        previous = tools
+        counts[role] = cast(dict[str, object], manifests[role]["counts"])
+    read_tools = set(cast(list[str], manifests["read"]["tools"]))
+    for stale in ("get_session", "get_recovery_report"):
+        if stale in read_tools:
+            problems.append(f"stale tool is unexpectedly registered: {stale}")
+    if problems:
+        return _fail(name, "live MCP surface contract failed", problems=problems, counts=counts)
+    return _pass(
+        name,
+        counts=counts,
+        recipes_checked=len(RECIPES),
+        documented_names=len(documented_names - _NEGATIVE_MCP_NAMES),
+        deliberate_negative_names=sorted(_NEGATIVE_MCP_NAMES),
+    )
+
+
+def _make_executable(path: Path) -> None:
+    path.write_text("#!/bin/sh\nexit 0\n")
+    path.chmod(stat.S_IRUSR | stat.S_IWUSR | stat.S_IXUSR)
+
+
+def _native_installer_lane() -> LaneResult:
+    name = "native-installer-roundtrip"
+    try:
+        with tempfile.TemporaryDirectory(prefix="polylogue-agent-verify-") as temporary:
+            root = Path(temporary)
+            home = root / "home"
+            home.mkdir()
+            bin_dir = root / "bin"
+            bin_dir.mkdir()
+            polylogue = bin_dir / "polylogue"
+            server = bin_dir / "polylogue-mcp"
+            _make_executable(polylogue)
+            _make_executable(server)
+            manager = AgentIntegrationManager(home=home, environment={"HOME": str(home), "PATH": str(bin_dir)})
+            options = InstallOptions(
+                clients=cast(tuple[AgentClient, ...], ("claude-code", "codex", "gemini", "hermes")),
+                role="read",
+                archive_root=root / "archive",
+                config_path=root / "polylogue.toml",
+                server_command=str(server),
+                polylogue_command=str(polylogue),
+            )
+            first = manager.install(options)
+            files = [path for path in home.rglob("*") if path.is_file()]
+            mtimes = {path: path.stat().st_mtime_ns for path in files}
+            time.sleep(0.002)
+            second = manager.install(options)
+            unchanged = all(path.stat().st_mtime_ns == mtimes[path] for path in files)
+            upgraded = manager.install(
+                InstallOptions(
+                    clients=options.clients,
+                    role="review",
+                    archive_root=root / "archive-2",
+                    config_path=root / "polylogue-2.toml",
+                    server_command=str(server),
+                    polylogue_command=str(polylogue),
+                )
+            )
+            doctor = manager.doctor()
+            uninstall = manager.uninstall()
+            clean_home = list(home.iterdir()) == []
+            if not all(
+                (
+                    first["ok"] is True,
+                    second["ok"] is True,
+                    upgraded["ok"] is True,
+                    doctor["ok"] is True,
+                    uninstall["ok"] is True,
+                    unchanged,
+                    clean_home,
+                )
+            ):
+                return _fail(
+                    name,
+                    "installer round trip failed",
+                    first=first,
+                    second=second,
+                    upgraded=upgraded,
+                    doctor=doctor,
+                    uninstall=uninstall,
+                    no_rewrite=unchanged,
+                    clean_home=clean_home,
+                )
+            return _pass(
+                name,
+                clients=list(options.clients),
+                no_rewrite_idempotence=True,
+                role_archive_upgrade=True,
+                doctor=True,
+                exact_clean_uninstall=True,
+            )
+    except Exception as exc:
+        return _fail(name, exc)
+
+
+def _packaging_home_manager_lane() -> LaneResult:
+    name = "packaging-and-home-manager"
+    try:
+        missing = [asset for asset in ALL_ASSETS if not read_agent_asset(asset)]
+        module = REPO_ROOT / "nix" / "agent-integration-module.nix"
+        flake = (REPO_ROOT / "flake.nix").read_text()
+        module_text = module.read_text()
+        required = (
+            "programs.polylogueAgent",
+            'types.enum [ "claude-code" "codex" "gemini" "hermes" ]',
+            'types.enum [ "read" "write" "review" "admin" ]',
+            '"agent"',
+            '"install"',
+            '"${cfg.package}/bin/polylogue"',
+        )
+        absent = [token for token in required if token not in module_text]
+        if "homeManagerModules.agentIntegration" not in flake:
+            absent.append("flake export homeManagerModules.agentIntegration")
+        if missing or absent:
+            return _fail(name, "packaging/Home Manager contract incomplete", missing_assets=missing, missing_tokens=absent)
+        if "polylogued run" in module_text or "systemd.user.services.polylogued" in module_text:
+            return _fail(name, "agent module improperly owns the Polylogue daemon")
+        return _pass(name, package_assets=len(ALL_ASSETS), home_manager_module=str(module.relative_to(REPO_ROOT)), daemon_owned=False)
+    except Exception as exc:
+        return _fail(name, exc)
+
+
+LANES: tuple[tuple[str, Callable[[], LaneResult]], ...] = (
+    ("generated-assets", _generated_assets_lane),
+    ("query-catalog", _query_catalog_lane),
+    ("cli-command-contract", _cli_command_contract_lane),
+    ("mcp-role-surface", _mcp_role_surface_lane),
+    ("native-installer-roundtrip", _native_installer_lane),
+    ("packaging-and-home-manager", _packaging_home_manager_lane),
+)
+
+
+def run_verification(selected: set[str] | None = None) -> dict[str, object]:
+    results = [lane() for lane_name, lane in LANES if selected is None or lane_name in selected]
+    counts = {status: sum(result.status == status for result in results) for status in ("pass", "fail", "unverified")}
+    return {
+        "ok": counts["fail"] == 0,
+        "complete": counts["fail"] == 0 and counts["unverified"] == 0,
+        "counts": counts,
+        "lanes": [result.to_dict() for result in results],
+    }
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--lane", action="append", choices=[name for name, _ in LANES])
+    parser.add_argument("--json", action="store_true")
+    parser.add_argument("--require-live", action="store_true", help="Treat unverified dependency-bound lanes as failure.")
+    args = parser.parse_args(argv)
+    report = run_verification(set(args.lane) if args.lane else None)
+    if args.json:
+        print(json.dumps(report, indent=2, sort_keys=True))
+    else:
+        for lane in cast(list[dict[str, object]], report["lanes"]):
+            print(f"{lane['name']:<32} {str(lane['status']).upper()}")
+            if lane["status"] != "pass":
+                print(f"  {lane.get('error') or lane.get('reason')}")
+    if report["ok"] is not True:
+        return 1
+    if args.require_live and report["complete"] is not True:
+        return 1
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
