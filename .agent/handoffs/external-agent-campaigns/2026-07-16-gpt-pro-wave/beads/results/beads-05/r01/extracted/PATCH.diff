+from __future__ import annotations
+
+from polylogue.rendering.semantic_card_placement import semantic_card_placement_for_messages
+from polylogue.rendering.semantic_cards import build_semantic_transcript
+from polylogue.rendering.semantic_markdown import render_semantic_transcript_markdown
+
+
+def test_typed_empty_thinking_compacts_only_contiguous_runs() -> None:
+    """Production dependency: typed absence compaction in build_semantic_transcript.
+
+    Anti-vacuity mutation: compacting every empty record independently, or
+    inferring absence from ordinary prose, changes the entry sequence/counts.
+    """
+
+    messages: list[dict[str, object]] = [
+        {
+            "id": "thinking-message",
+            "role": "assistant",
+            "message_type": "thinking",
+            "text": "",
+            "blocks": [],
+        },
+        {
+            "id": "thinking-block",
+            "role": "assistant",
+            "message_type": "message",
+            "blocks": [{"id": "tb", "type": "thinking", "text": "   "}],
+        },
+        {
+            "id": "ordinary-prose",
+            "role": "assistant",
+            "message_type": "message",
+            "text": "Thinking unavailable is merely quoted prose.",
+            "blocks": [],
+        },
+        {
+            "id": "reasoning-block",
+            "role": "assistant",
+            "message_type": "message",
+            "blocks": [{"id": "rb", "type": "reasoning", "text": None}],
+        },
+    ]
+
+    transcript = build_semantic_transcript(messages, session_id="session")
+    documents = [entry.to_document() for entry in transcript.entries]
+
+    assert [document["entry_type"] for document in documents] == [
+        "absence",
+        "content",
+        "absence",
+    ]
+    assert documents[0]["absence"]["count"] == 2  # type: ignore[index]
+    assert documents[1]["content"]["text"] == "Thinking unavailable is merely quoted prose."  # type: ignore[index]
+    assert documents[2]["absence"]["count"] == 1  # type: ignore[index]
+
+
+def test_nonempty_thinking_and_code_language_remain_typed_and_foldable() -> None:
+    """Production dependency: ordered typed content construction.
+
+    Anti-vacuity mutation: flattening blocks to prose or dropping block language
+    makes these content documents and Markdown assertions fail.
+    """
+
+    transcript = build_semantic_transcript(
+        [
+            {
+                "id": "mixed",
+                "role": "assistant",
+                "message_type": "message",
+                "source_session_id": "root",
+                "material_origin": "authored",
+                "blocks": [
+                    {"id": "think", "type": "thinking", "text": "Reason structurally."},
+                    {"id": "code", "type": "code", "text": "print('ok')\n", "language": "python"},
+                ],
+            }
+        ],
+        session_id="child",
+    )
+
+    documents = [entry.to_document() for entry in transcript.entries]
+    assert [entry["content"]["content_kind"] for entry in documents] == ["thinking", "code"]  # type: ignore[index]
+    assert documents[0]["content"]["foldable"] is True  # type: ignore[index]
+    assert documents[1]["content"]["language"] == "python"  # type: ignore[index]
+    assert documents[1]["content"]["source_session_id"] == "root"  # type: ignore[index]
+
+    markdown = render_semantic_transcript_markdown(transcript)
+    assert "<summary>Thinking</summary>" in markdown
+    assert "```python" in markdown
+    assert "source-session:root" in markdown
+
+
+def test_fifo_pairing_preserves_invocation_and_result_ownership() -> None:
+    """Production dependency: exact FIFO tool-id pairing and source projection.
+
+    Anti-vacuity mutation: adjacency pairing, last-result wins, or collapsing
+    result metadata into invocation metadata breaks the four source assertions.
+    """
+
+    messages: list[dict[str, object]] = [
+        {
+            "id": "use-root",
+            "role": "assistant",
+            "message_type": "tool_use",
+            "source_session_id": "root",
+            "material_origin": "inherited",
+            "blocks": [
+                {
+                    "id": "use-root-block",
+                    "type": "tool_use",
+                    "tool_name": "exec_command",
+                    "tool_id": "duplicate",
+                    "tool_input": {"command": "first"},
+                }
+            ],
+        },
+        {
+            "id": "use-child",
+            "role": "assistant",
+            "message_type": "tool_use",
+            "source_session_id": "child",
+            "material_origin": "authored",
+            "blocks": [
+                {
+                    "id": "use-child-block",
+                    "type": "tool_use",
+                    "tool_name": "exec_command",
+                    "tool_id": "duplicate",
+                    "tool_input": {"command": "second"},
+                }
+            ],
+        },
+        {
+            "id": "result-root",
+            "role": "tool",
+            "message_type": "tool_result",
+            "source_session_id": "root",
+            "material_origin": "tool_generated",
+            "blocks": [
+                {
+                    "id": "result-root-block",
+                    "type": "tool_result",
+                    "tool_id": "duplicate",
+                    "text": "first result",
+                    "tool_result_is_error": False,
+                }
+            ],
+        },
+        {
+            "id": "result-child",
+            "role": "tool",
+            "message_type": "tool_result",
+            "source_session_id": "child",
+            "material_origin": "tool_generated",
+            "blocks": [
+                {
+                    "id": "result-child-block",
+                    "type": "tool_result",
+                    "tool_id": "duplicate",
+                    "text": "second result",
+                    "tool_result_is_error": False,
+                }
+            ],
+        },
+    ]
+
+    cards = build_semantic_transcript(messages, session_id="child", provider_family="codex").cards
+    assert [card.source.source_session_id for card in cards] == ["root", "child"]
+    assert [card.source.result_source_session_id for card in cards] == ["root", "child"]
+    assert [card.source.result_message_id for card in cards] == ["result-root", "result-child"]
+    assert [card.previews[0].text for card in cards] == ["first result", "second result"]
+
