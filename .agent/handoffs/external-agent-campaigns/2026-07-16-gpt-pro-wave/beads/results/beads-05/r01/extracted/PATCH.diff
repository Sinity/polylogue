+def test_placement_keeps_mixed_result_row_that_owns_visible_content() -> None:
+    """Production dependency: message-at-a-time semantic placement adapter.
+
+    Anti-vacuity mutation: suppressing every paired result message would hide
+    the context block that shares the physical result row.
+    """
+
+    messages: list[dict[str, object]] = [
+        {
+            "id": "use",
+            "role": "assistant",
+            "message_type": "tool_use",
+            "blocks": [
+                {
+                    "id": "use-block",
+                    "type": "tool_use",
+                    "tool_name": "exec_command",
+                    "tool_id": "tool",
+                    "tool_input": {"command": "verify"},
+                }
+            ],
+        },
+        {
+            "id": "mixed-result",
+            "role": "tool",
+            "message_type": "tool_result",
+            "blocks": [
+                {
+                    "id": "result-block",
+                    "type": "tool_result",
+                    "tool_id": "tool",
+                    "text": "done",
+                    "tool_result_is_error": False,
+                },
+                {
+                    "id": "context-block",
+                    "type": "text",
+                    "text": "Provider context carried beside the result.",
+                },
+            ],
+        },
+    ]
+
+    placement = semantic_card_placement_for_messages(
+        messages,
+        session_id="session",
+        provider_family="codex",
+    )
+
+    assert placement.is_suppressed("mixed-result") is False
+    entries = placement.entries_for("mixed-result")
+    assert len(entries) == 1
+    assert entries[0]["entry_type"] == "content"
+    assert entries[0]["content"]["text"] == "Provider context carried beside the result."  # type: ignore[index]
+    assert placement.cards_for("use")[0]["source"]["result_message_id"] == "mixed-result"  # type: ignore[index]
+
+
+def test_page_bounded_scope_is_machine_readable_and_visible_in_markdown() -> None:
+    """Production dependency: page-scope disclosure in model and Markdown leaf.
