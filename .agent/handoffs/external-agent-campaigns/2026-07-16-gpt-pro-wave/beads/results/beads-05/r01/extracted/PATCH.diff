+async def test_composed_message_reads_retain_ancestor_owned_attachments(tmp_path: Path) -> None:
+    """Composed reads fetch attachments from every physical owner session.
+
+    Production dependency: ``ArchiveRepository`` composes the canonical lineage
+    rows and batches attachment hydration by ``Message.source_session_id`` for
+    full, paginated, and bulk facade reads.
+
+    Anti-vacuity mutation: reverting attachment lookup to the requested child
+    session ID drops ``context.txt`` from the inherited parent message and makes
+    all three assertions below fail.
+    """
+
+    archive = _archive(tmp_path)
+    with ArchiveStore(tmp_path) as archive_db:
+        parent_id = archive_db.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="attachment-parent",
+                title="Attachment parent",
+                messages=[
+                    ParsedMessage(
+                        provider_message_id="p0",
+                        role=Role.USER,
+                        text="shared prompt",
+                    ),
+                    ParsedMessage(
+                        provider_message_id="p1",
+                        role=Role.ASSISTANT,
+                        text="shared reply",
+                    ),
+                ],
+                attachments=[
+                    ParsedAttachment(
+                        provider_attachment_id="att-parent",
+                        message_provider_id="p1",
+                        name="context.txt",
+                        mime_type="text/plain",
+                        size_bytes=7,
+                        path="context.txt",
+                    )
+                ],
+            )
+        )
+        child_id = archive_db.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="attachment-child",
+                title="Attachment child",
+                parent_session_provider_id="attachment-parent",
+                branch_type=BranchType.FORK,
+                messages=[
+                    ParsedMessage(
+                        provider_message_id="c0",
+                        role=Role.USER,
+                        text="shared prompt",
+                    ),
+                    ParsedMessage(
+                        provider_message_id="c1",
+                        role=Role.ASSISTANT,
+                        text="shared reply",
+                    ),
+                    ParsedMessage(
+                        provider_message_id="c2",
+                        role=Role.USER,
+                        text="child tail",
+                    ),
+                ],
+            )
+        )
+
+    def inherited_attachment_names(messages: Iterable[Any]) -> list[str]:
+        return [
+            attachment.name or ""
+            for message in messages
+            if message.source_session_id == parent_id
+            for attachment in message.attachments
+        ]
+
+    try:
+        session = await archive.get_session(child_id)
+        assert session is not None
+        paged, total = await archive.get_messages_paginated(child_id, limit=10)
+        bulk = await archive.bulk_get_messages((child_id,))
+    finally:
+        await archive.close()
+
+    assert total == 3
+    assert inherited_attachment_names(session.messages) == ["context.txt"]
+    assert inherited_attachment_names(paged) == ["context.txt"]
+    assert inherited_attachment_names(bulk[child_id]) == ["context.txt"]
+
+
