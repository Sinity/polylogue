+
+    transcript = build_semantic_transcript([], session_id="session", page_bounded=True)
+    document = transcript.to_document()
+
+    assert document["pairing_scope"] == "page"
+    assert document["absence_compaction_scope"] == "page"
+    assert "bounded to this page" in render_semantic_transcript_markdown(transcript)
