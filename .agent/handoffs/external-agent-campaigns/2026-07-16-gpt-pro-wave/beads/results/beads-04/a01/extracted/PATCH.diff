index 0000000000000000000000000000000000000000..fa5e6c99b8aebf6f4c5d3bac087e2954984cbece
--- /dev/null
+++ b/tests/unit/mcp/test_context_assertion_declarations.py
@@ -0,0 +1,253 @@
+"""Executable contracts for the context/assertion MCP declaration migration."""
+
+from __future__ import annotations
+
+import inspect
+import json
+from pathlib import Path
+from typing import cast
+from unittest.mock import patch
+
+import pytest
+
+from polylogue.api import Polylogue
+from polylogue.mcp.declarations.registry import (
+    MCP_CONTEXT_ASSERTION_DECLARATIONS,
+    MCP_CONTEXT_ASSERTION_TOOL_NAMES,
+    declaration_for,
+    declarations_for_role,
+    render_equivalence_json,
+)
+from polylogue.mcp.server import build_server
+from polylogue.mcp.server_support import MCPRole
+from tests.infra.mcp import EXPECTED_TOOL_NAMES, MCPServerUnderTest, invoke_surface
+from tests.infra.storage_records import SessionBuilder
+
+_EQUIVALENCE_ARTIFACT = Path("docs/generated/mcp-context-assertion-equivalence.json")
+
+
+def _tool_names(role: MCPRole) -> set[str]:
+    server = cast(MCPServerUnderTest, build_server(role=role))
+    return set(server._tool_manager._tools)
+
+
+@pytest.mark.parametrize("role", ("read", "write", "review", "admin"))
+def test_declarations_drive_role_scoped_registration(role: MCPRole) -> None:
+    """Production dependency: ``register_tools`` and ``MCPDeclarationRegistrar``.
+
+    Removing declaration-owned filtering, restoring a family-level role gate,
+    or changing a declaration's required role makes this exact discovery
+    equivalence fail.
+    """
+
+    actual = _tool_names(role) & MCP_CONTEXT_ASSERTION_TOOL_NAMES
+    expected = {declaration.name for declaration in declarations_for_role(role)}
+    assert actual == expected
+
+
+def test_declarations_bind_exact_production_handlers_and_input_contracts() -> None:
+    """Production dependency: every registered FastMCP handler and signature.
+
+    Replacing a handler with a wrapper in another module, deleting a handler,
+    dropping a minimal-invocation parameter, or removing a confirmation default
+    fails this test (and the production registrar's startup validation).
+    """
+
+    server = cast(MCPServerUnderTest, build_server(role="admin"))
+    for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS:
+        handler = server._tool_manager._tools[declaration.name].fn
+        assert handler.__module__ == declaration.module, declaration.name
+        assert inspect.iscoroutinefunction(handler), declaration.name
+        signature = inspect.signature(handler)
+        assert set(declaration.minimal_invocation()) <= set(signature.parameters), declaration.name
+        if declaration.confirmation_policy != "none":
+            assert signature.parameters["confirm"].default is False, declaration.name
+        if declaration.confirmation_policy == "dry_run_or_explicit_confirm":
+            assert signature.parameters["dry_run"].default is False, declaration.name
+
+
+def test_registry_preserves_trust_injection_and_annotation_provenance() -> None:
+    """Production dependency: candidate, judgment, and annotation declarations.
+
+    Promoting agent-authored candidates to injectable writes, weakening review
+    role, or omitting immutable schema/batch provenance makes these assertions
+    fail before an adapter can register.
+    """
+
+    capture = declaration_for("capture_assertion_candidate")
+    assert capture.required_role == "write"
+    assert capture.injection_policy == "candidate_only"
+    assert {"author_ref", "author_kind=agent"} <= set(capture.provenance_contract)
+
+    annotation_import = declaration_for("import_annotation_batch")
+    assert annotation_import.injection_policy == "candidate_only"
+    assert {
+        "batch_id",
+        "schema_id",
+        "schema_version",
+        "source_result_ref",
+        "actor_ref",
+        "model_ref",
+        "prompt_ref",
+    } <= set(annotation_import.provenance_contract)
+
+    for name in ("judge_assertion_candidate", "judge_assertion_candidates"):
+        judgment = declaration_for(name)
+        assert judgment.required_role == "review"
+        assert judgment.injection_policy == "operator_judgment"
+        assert "actor_ref" in judgment.provenance_contract
+
+
+def test_generated_equivalence_artifact_matches_executable_registry() -> None:
+    """Production dependency: ``render_equivalence_json`` and the registry.
+
+    Editing the committed artifact, changing a declaration without regenerating
+    it, or returning unstable declaration ordering makes byte equality fail.
+    """
+
+    assert _EQUIVALENCE_ARTIFACT.read_text() == render_equivalence_json()
+
+
+def test_declarations_do_not_claim_unimplemented_protocol_routes() -> None:
+    """Production dependency: current MCP resource/prompt registration.
+
+    Adding an invented URI or naming a prompt that is not actually registered
+    makes this fail. The migration may describe only real compatibility routes
+    until a production resource resolver is implemented.
+    """
+
+    assert all(declaration.resource_alternative is None for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS)
+    prompt_alternatives = {
+        declaration.name: declaration.prompt_alternative
+        for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS
+        if declaration.prompt_alternative is not None
+    }
+    assert prompt_alternatives == {"compose_context_preamble": "resume_context"}
+
+    server = cast(MCPServerUnderTest, build_server(role="admin"))
+    assert "resume_context" in server._prompt_manager._prompts
+
+
+def test_expected_tool_inventory_uses_declared_names() -> None:
+    """Production dependency: the shared discovery inventory in ``tests.infra``.
+
+    Removing the registry union or omitting one migrated declaration makes the
+    expected surface diverge from the executable declaration set.
+    """
+
+    assert MCP_CONTEXT_ASSERTION_TOOL_NAMES <= EXPECTED_TOOL_NAMES
+    assert len(MCP_CONTEXT_ASSERTION_TOOL_NAMES) == 41
+
+
+def test_declared_confirmation_contracts_fail_closed_before_backend_access() -> None:
+    """Production dependency: all individually implemented destructive handlers.
+
+    Removing any per-handler guard (or moving it after session resolution,
+    planner construction, or facade access) permits the patched backend seam to
+    be touched and fails this test. The test intentionally does not use a
+    generic mutation dispatcher.
+    """
+
+    guarded = tuple(
+        declaration for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS if declaration.confirmation_policy != "none"
+    )
+    assert {declaration.name for declaration in guarded} == {
+        "remove_tag",
+        "remove_mark",
+        "delete_annotation",
+        "delete_saved_view",
+        "delete_recall_pack",
+        "delete_workspace",
+        "delete_metadata",
+        "delete_session",
+        "maintenance_execute",
+        "rebuild_index",
+        "rebuild_session_insights",
+    }
+
+    with patch("polylogue.mcp.server._get_polylogue") as get_polylogue:
+        server = cast(MCPServerUnderTest, build_server(role="admin"))
+        for declaration in guarded:
+            kwargs = declaration.minimal_invocation()
+            kwargs.pop("confirm", None)
+            if declaration.confirmation_policy == "dry_run_or_explicit_confirm":
+                kwargs["dry_run"] = False
+            payload = json.loads(invoke_surface(server._tool_manager._tools[declaration.name].fn, **kwargs))
+            assert payload["code"] == "confirmation_required", declaration.name
+            assert payload["is_error"] is True, declaration.name
+
+    get_polylogue.assert_not_called()
+
+
+def test_real_mcp_candidate_write_review_and_readback_preserves_authority(
+    cli_workspace: dict[str, Path],
+) -> None:
+    """Production dependency: FastMCP adapters, facade, and real ``user.db``.
+
+    Replacing candidate capture with a mock-only path, making write-role tools
+    promote or inject content, bypassing reviewer actor/injection controls, or
+    disconnecting either MCP readback route makes this end-to-end test fail.
+    """
+
+    session = SessionBuilder(cli_workspace["db_path"], "mcp-declaration-roundtrip").provider("codex")
+    session.save()
+    session_ref = f"session:{session.native_session_id()}"
+    poly = Polylogue(archive_root=cli_workspace["archive_root"])
+
+    with patch("polylogue.mcp.server._get_polylogue", return_value=poly):
+        write_server = cast(MCPServerUnderTest, build_server(role="write"))
+        read_server = cast(MCPServerUnderTest, build_server(role="read"))
+        review_server = cast(MCPServerUnderTest, build_server(role="review"))
+
+        captured = json.loads(
+            invoke_surface(
+                write_server._tool_manager._tools["capture_assertion_candidate"].fn,
+                body_text="Agent candidate requiring operator judgment",
+                kind="lesson",
+                refs=[session_ref],
+                scope_refs=["repo:polylogue"],
+                author_ref="agent:codex-session:mcp-declaration-roundtrip",
+            )
+        )
+        assert captured["status"] == "candidate"
+        assert captured["author_kind"] == "agent"
+        assert captured["context_policy"] == {"inject": False, "promotion_required": True}
+
+        pending = json.loads(
+            invoke_surface(
+                read_server._tool_manager._tools["list_assertion_candidates"].fn,
+                target_ref=session_ref,
+                limit=10,
+            )
+        )
+        assert pending["total"] == 1
+        assert pending["items"][0]["assertion_id"] == captured["assertion_id"]
+        assert pending["items"][0]["status"] == "candidate"
+        assert pending["items"][0]["context_policy"]["inject"] is False
+
+        judgment = json.loads(
+            invoke_surface(
+                review_server._tool_manager._tools["judge_assertion_candidate"].fn,
+                candidate_ref=f"assertion:{captured['assertion_id']}",
+                decision="accept",
+                inject=True,
+                actor_ref="user:operator",
+                reason="verified against archived evidence",
+            )
+        )
+        assert judgment["applied_count"] == 1
+        assert judgment["failed_count"] == 0
+
+        active = json.loads(
+            invoke_surface(
+                read_server._tool_manager._tools["list_assertion_claims"].fn,
+                target_ref=session_ref,
+                statuses="active",
+                context_inject=True,
+                limit=10,
+            )
+        )
+        assert active["total"] == 1
+        assert active["items"][0]["status"] == "active"
+        assert active["items"][0]["body_text"] == "Agent candidate requiring operator judgment"
+        assert active["items"][0]["context_policy"] == {"inject": True}
