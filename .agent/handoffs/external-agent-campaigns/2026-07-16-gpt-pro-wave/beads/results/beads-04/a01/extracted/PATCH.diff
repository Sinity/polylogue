index 0000000000000000000000000000000000000000..7bbe70303eb4a43b6a7c41cfde2b9c3b40d87b1a
--- /dev/null
+++ b/polylogue/mcp/declarations/models.py
@@ -0,0 +1,121 @@
+"""Typed MCP declaration records for protocol-facing tool adapters.
+
+The declarations own discovery and compatibility metadata. They do not execute
+queries or mutations: production handlers remain thin adapters over the typed
+substrate/facade owners named by each declaration.
+"""
+
+from __future__ import annotations
+
+import json
+from dataclasses import dataclass
+from typing import Literal, cast
+
+from polylogue.mcp.server_support import MCPRole
+
+MCPDeclarationFamily = Literal[
+    "context",
+    "assertion",
+    "personal_state",
+    "correction",
+    "judgment",
+    "maintenance",
+]
+MCPVerb = Literal["context", "write", "judge", "maintenance"]
+MCPResultSemantics = Literal[
+    "bounded_context",
+    "receipt",
+    "exhaustive_page",
+    "mutation",
+    "maintenance_preview",
+    "maintenance_execute",
+    "maintenance_status",
+]
+MCPInjectionPolicy = Literal[
+    "not_applicable",
+    "candidate_only",
+    "operator_judgment",
+    "never_inject",
+]
+MCPConfirmationPolicy = Literal["none", "explicit_confirm", "dry_run_or_explicit_confirm"]
+MCPDeprecationState = Literal["retained_compatibility"]
+
+
+@dataclass(frozen=True, slots=True)
+class MCPToolDeclaration:
+    """One executable MCP compatibility declaration.
+
+    ``minimal_invocation_json`` is stored as canonical JSON rather than a
+    mutable mapping so declarations stay immutable and can be rendered without
+    aliasing caller-owned values.
+    """
+
+    name: str
+    module: str
+    family: MCPDeclarationFamily
+    verb: MCPVerb
+    object_kind: str
+    required_role: MCPRole
+    result_semantics: MCPResultSemantics
+    canonical_owner: str
+    canonical_plan: str
+    minimal_invocation_json: str
+    discovery: tuple[str, ...]
+    continuation: tuple[str, ...]
+    compatibility_route: str
+    workflow_coverage: tuple[str, ...]
+    telemetry_key: str
+    injection_policy: MCPInjectionPolicy = "not_applicable"
+    provenance_contract: tuple[str, ...] = ()
+    confirmation_policy: MCPConfirmationPolicy = "none"
+    lifecycle: tuple[str, ...] = ()
+    resource_alternative: str | None = None
+    prompt_alternative: str | None = None
+    deprecation_state: MCPDeprecationState = "retained_compatibility"
+
+    def minimal_invocation(self) -> dict[str, object]:
+        """Return a fresh validated mapping for generated contracts/tests."""
+
+        value = json.loads(self.minimal_invocation_json)
+        if not isinstance(value, dict):
+            raise ValueError(f"{self.name}: minimal invocation must decode to an object")
+        return cast(dict[str, object], value)
+
+    def to_equivalence_dict(self) -> dict[str, object]:
+        """Render stable, JSON-compatible equivalence metadata."""
+
+        return {
+            "name": self.name,
+            "module": self.module,
+            "family": self.family,
+            "verb": self.verb,
+            "object_kind": self.object_kind,
+            "required_role": self.required_role,
+            "result_semantics": self.result_semantics,
+            "canonical_owner": self.canonical_owner,
+            "canonical_plan": self.canonical_plan,
+            "minimal_invocation": self.minimal_invocation(),
+            "discovery": list(self.discovery),
+            "continuation": list(self.continuation),
+            "resource_alternative": self.resource_alternative,
+            "prompt_alternative": self.prompt_alternative,
+            "compatibility_route": self.compatibility_route,
+            "workflow_coverage": list(self.workflow_coverage),
+            "telemetry_key": self.telemetry_key,
+            "injection_policy": self.injection_policy,
+            "provenance_contract": list(self.provenance_contract),
+            "confirmation_policy": self.confirmation_policy,
+            "lifecycle": list(self.lifecycle),
+            "deprecation_state": self.deprecation_state,
+        }
+
+
+__all__ = [
+    "MCPConfirmationPolicy",
+    "MCPDeclarationFamily",
+    "MCPDeprecationState",
+    "MCPInjectionPolicy",
+    "MCPResultSemantics",
+    "MCPToolDeclaration",
+    "MCPVerb",
+]
