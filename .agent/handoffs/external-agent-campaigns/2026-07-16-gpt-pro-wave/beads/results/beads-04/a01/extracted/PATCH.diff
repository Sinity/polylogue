+def _build_registry(declarations: Iterable[MCPToolDeclaration]) -> dict[str, MCPToolDeclaration]:
+    registry: dict[str, MCPToolDeclaration] = {}
+    for declaration in declarations:
+        if declaration.name in registry:
+            raise ValueError(f"duplicate MCP declaration: {declaration.name}")
+        registry[declaration.name] = declaration
+    return registry
+
+
+MCP_CONTEXT_ASSERTION_REGISTRY = _build_registry(MCP_CONTEXT_ASSERTION_DECLARATIONS)
+MCP_CONTEXT_ASSERTION_TOOL_NAMES = frozenset(MCP_CONTEXT_ASSERTION_REGISTRY)
+
+
+def declaration_for(name: str) -> MCPToolDeclaration:
+    """Return one declaration, failing with an actionable adapter error."""
+
+    try:
+        return MCP_CONTEXT_ASSERTION_REGISTRY[name]
+    except KeyError as exc:
+        raise KeyError(f"MCP handler {name!r} has no context/assertion declaration") from exc
+
+
+def declarations_for_role(role: MCPRole) -> tuple[MCPToolDeclaration, ...]:
+    """Return declarations visible to one authenticated role."""
+
+    return tuple(
+        declaration
+        for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS
+        if role_allows(role, declaration.required_role)
+    )
+
+
+def equivalence_document() -> dict[str, object]:
+    """Return the generated migration/equivalence document."""
+
+    by_family: dict[str, int] = {}
+    by_role: dict[str, int] = {}
+    for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS:
+        by_family[declaration.family] = by_family.get(declaration.family, 0) + 1
+        by_role[declaration.required_role] = by_role.get(declaration.required_role, 0) + 1
+    return {
+        "schema_version": "polylogue.mcp.context-assertion-equivalence.v1",
+        "migration_owner": "polylogue-t46.8.3",
+        "dependency": "polylogue-t46.8.1",
+        "tool_count": len(MCP_CONTEXT_ASSERTION_DECLARATIONS),
+        "counts_by_family": dict(sorted(by_family.items())),
+        "counts_by_required_role": dict(sorted(by_role.items())),
+        "declarations": [declaration.to_equivalence_dict() for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS],
+    }
+
+
+def render_equivalence_json() -> str:
+    """Render the committed equivalence artifact deterministically."""
+
+    return json.dumps(equivalence_document(), indent=2, sort_keys=True, ensure_ascii=False) + "\n"
+
+
+def validate_registry() -> None:
+    """Fail closed on trust, role, provenance, and maintenance drift."""
+
+    if len(MCP_CONTEXT_ASSERTION_TOOL_NAMES) != len(MCP_CONTEXT_ASSERTION_DECLARATIONS):
+        raise ValueError("MCP declaration names must be unique")
+
+    for declaration in MCP_CONTEXT_ASSERTION_DECLARATIONS:
+        if declaration.compatibility_route != declaration.name:
+            raise ValueError(f"{declaration.name}: compatibility route must preserve the public tool name")
+        if declaration.canonical_plan != declaration.canonical_owner:
+            raise ValueError(f"{declaration.name}: canonical plan must name the existing production owner")
+        if declaration.telemetry_key != f"mcp.tool.{declaration.name}":
+            raise ValueError(f"{declaration.name}: telemetry key must preserve per-tool attribution")
+        if not declaration.module.startswith("polylogue.mcp."):
+            raise ValueError(f"{declaration.name}: declaration module must name the production MCP adapter")
+        if declaration.family == "context" and declaration.required_role != "read":
+            raise ValueError(f"{declaration.name}: context reads must remain read-role tools")
+        if declaration.family == "judgment" and declaration.required_role != "review":
+            raise ValueError(f"{declaration.name}: judgment tools require review capability")
+        if declaration.family == "maintenance" and declaration.required_role != "admin":
+            raise ValueError(f"{declaration.name}: maintenance tools require admin capability")
+        if declaration.injection_policy == "candidate_only" and declaration.required_role != "write":
+            raise ValueError(f"{declaration.name}: candidate writers must remain write-role tools")
+        if (
+            declaration.confirmation_policy not in {"none", "dry_run_or_explicit_confirm"}
+            and "confirm" not in declaration.minimal_invocation()
+        ):
+            raise ValueError(f"{declaration.name}: confirmation declaration needs confirm=true example")
+
+    capture = declaration_for("capture_assertion_candidate")
+    if capture.injection_policy != "candidate_only" or not {"author_ref", "author_kind=agent"} <= set(
+        capture.provenance_contract
+    ):
+        raise ValueError("capture_assertion_candidate must preserve agent candidate provenance")
+
+    annotation_import = declaration_for("import_annotation_batch")
+    required_batch_provenance = {
+        "batch_id",
+        "schema_id",
+        "schema_version",
+        "source_result_ref",
+        "actor_ref",
+        "model_ref",
+        "prompt_ref",
+    }
+    if not required_batch_provenance <= set(annotation_import.provenance_contract):
+        raise ValueError("import_annotation_batch must preserve immutable schema/batch provenance")
+
+    for name in ("judge_assertion_candidate", "judge_assertion_candidates"):
+        declaration = declaration_for(name)
+        if declaration.injection_policy != "operator_judgment":
+            raise ValueError(f"{name}: injection remains an operator judgment")
+
+    for name in (
+        "delete_annotation",
+        "delete_saved_view",
+        "delete_recall_pack",
+        "delete_workspace",
+        "delete_metadata",
+        "remove_tag",
+        "remove_mark",
+        "rebuild_index",
+        "rebuild_session_insights",
+    ):
+        if declaration_for(name).confirmation_policy != "explicit_confirm":
+            raise ValueError(f"{name}: interim confirmation contract missing")
+    if declaration_for("maintenance_execute").confirmation_policy != "dry_run_or_explicit_confirm":
+        raise ValueError("maintenance_execute must allow dry-run or require explicit confirmation")
+
+
+validate_registry()
+
+__all__ = [
+    "MCP_CONTEXT_ASSERTION_DECLARATIONS",
+    "MCP_CONTEXT_ASSERTION_REGISTRY",
+    "MCP_CONTEXT_ASSERTION_TOOL_NAMES",
+    "declaration_for",
+    "declarations_for_role",
+    "equivalence_document",
+    "render_equivalence_json",
+    "validate_registry",
+]
