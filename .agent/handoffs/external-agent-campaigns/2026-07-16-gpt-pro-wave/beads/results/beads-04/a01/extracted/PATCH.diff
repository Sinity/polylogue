index 0000000000000000000000000000000000000000..aa04aaadde56029e7201664906616431bb1995b1
--- /dev/null
+++ b/polylogue/mcp/declarations/registration.py
@@ -0,0 +1,114 @@
+"""Role-scoped registration adapter for declared MCP tools."""
+
+from __future__ import annotations
+
+import inspect
+from collections.abc import Awaitable, Callable
+from typing import Any, Protocol, TypeAlias
+
+from polylogue.mcp.declarations.models import MCPToolDeclaration
+from polylogue.mcp.declarations.registry import (
+    MCP_CONTEXT_ASSERTION_TOOL_NAMES,
+    declaration_for,
+)
+from polylogue.mcp.server_support import MCPRole, role_allows
+
+MCPToolHandler: TypeAlias = Callable[..., Awaitable[str]]
+
+
+class MCPToolHost(Protocol):
+    def tool(self) -> Callable[[MCPToolHandler], Any]:
+        raise NotImplementedError
+
+
+class MCPDeclarationRegistrationError(RuntimeError):
+    """Raised when a production handler and declaration drift apart."""
+
+
+class MCPDeclarationRegistrar:
+    """Register exact handlers from declarations without becoming an executor.
+
+    The registrar owns discovery/role filtering and static adapter-contract
+    checks only. It never invokes, wraps, or dispatches a handler, so distinct
+    maintenance/destructive implementations and their audit semantics remain
+    visible production code.
+    """
+
+    def __init__(self, mcp: MCPToolHost, *, role: MCPRole) -> None:
+        self._mcp = mcp
+        self._role = role
+        self._seen: dict[str, MCPToolDeclaration] = {}
+        self._registered: set[str] = set()
+
+    @property
+    def registered_names(self) -> frozenset[str]:
+        return frozenset(self._registered)
+
+    @property
+    def seen_names(self) -> frozenset[str]:
+        return frozenset(self._seen)
+
+    def tool(self) -> Callable[[MCPToolHandler], MCPToolHandler]:
+        """Validate and role-filter one exact production handler."""
+
+        def register(handler: MCPToolHandler) -> MCPToolHandler:
+            name = handler.__name__
+            try:
+                declaration = declaration_for(name)
+            except KeyError as exc:
+                raise MCPDeclarationRegistrationError(str(exc)) from exc
+            if name in self._seen:
+                raise MCPDeclarationRegistrationError(f"duplicate MCP handler registration: {name}")
+            self._validate_handler(declaration, handler)
+            self._seen[name] = declaration
+            if role_allows(self._role, declaration.required_role):
+                self._mcp.tool()(handler)
+                self._registered.add(name)
+            return handler
+
+        return register
+
+    def assert_complete(self) -> None:
+        """Require every migrated declaration to meet one concrete handler."""
+
+        missing = MCP_CONTEXT_ASSERTION_TOOL_NAMES - self.seen_names
+        unexpected = self.seen_names - MCP_CONTEXT_ASSERTION_TOOL_NAMES
+        if missing or unexpected:
+            raise MCPDeclarationRegistrationError(
+                "MCP declaration/adapter mismatch: "
+                f"missing_handlers={sorted(missing)}, unexpected_handlers={sorted(unexpected)}"
+            )
+
+    @staticmethod
+    def _validate_handler(declaration: MCPToolDeclaration, handler: MCPToolHandler) -> None:
+        if handler.__module__ != declaration.module:
+            raise MCPDeclarationRegistrationError(
+                f"{declaration.name}: declaration module {declaration.module!r} "
+                f"does not match handler module {handler.__module__!r}"
+            )
+        if not inspect.iscoroutinefunction(handler):
+            raise MCPDeclarationRegistrationError(f"{declaration.name}: MCP handler must be async")
+        signature = inspect.signature(handler)
+        missing_example_args = set(declaration.minimal_invocation()) - set(signature.parameters)
+        if missing_example_args:
+            raise MCPDeclarationRegistrationError(
+                f"{declaration.name}: minimal invocation names missing from handler: {sorted(missing_example_args)}"
+            )
+        if declaration.confirmation_policy != "none":
+            confirm = signature.parameters.get("confirm")
+            if confirm is None or confirm.default is not False:
+                raise MCPDeclarationRegistrationError(
+                    f"{declaration.name}: confirmation policy requires confirm: bool = False"
+                )
+        if declaration.confirmation_policy == "dry_run_or_explicit_confirm":
+            dry_run = signature.parameters.get("dry_run")
+            if dry_run is None or dry_run.default is not False:
+                raise MCPDeclarationRegistrationError(
+                    f"{declaration.name}: dry-run confirmation policy requires dry_run: bool = False"
+                )
+
+
+__all__ = [
+    "MCPDeclarationRegistrar",
+    "MCPDeclarationRegistrationError",
+]
