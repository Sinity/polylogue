new file mode 100644
index 0000000000000000000000000000000000000000..29a001131c922baebf9f289078955fad0d5ebbe2
--- /dev/null
+++ b/polylogue/mcp/declarations/registration.py
@@ -0,0 +1,60 @@
+"""FastMCP registration adapter for declared tools."""
+
+from __future__ import annotations
+
+from collections.abc import Callable, Mapping
+from typing import TYPE_CHECKING, Any, TypeVar
+
+from polylogue.mcp.declarations.registry import MCP_TOOL_REGISTRY
+from polylogue.mcp.server_support import role_allows
+
+if TYPE_CHECKING:
+    from mcp.server.fastmcp import FastMCP
+
+    from polylogue.mcp.server_support import ServerCallbacks
+
+ToolHandler = TypeVar("ToolHandler", bound=Callable[..., Any])
+MCP_DECLARATION_ATTRIBUTE = "__polylogue_mcp_declaration__"
+
+
+def register_declared_tool(
+    mcp: FastMCP,
+    hooks: ServerCallbacks,
+    name: str,
+    handler: ToolHandler,
+) -> ToolHandler:
+    """Register ``handler`` from the single declaration row for ``name``.
+
+    No wrapper is introduced: FastMCP inspects the original callable, so the
+    existing annotations, explicit ``__signature__`` overrides, asyncness, and
+    Pydantic constraints remain the wire-schema authority.
+    """
+
+    declaration = MCP_TOOL_REGISTRY[name]
+    if not declaration.registered_from_declaration:
+        raise ValueError(f"{name}: declaration is not enabled for algebra registration")
+    if not role_allows(hooks.role, declaration.required_role):
+        return handler
+    handler.__name__ = declaration.name
+    handler.__doc__ = declaration.description
+    setattr(handler, MCP_DECLARATION_ATTRIBUTE, declaration)
+    mcp.tool(name=declaration.name, description=declaration.description)(handler)
+    return handler
+
+
+def register_declared_tools(
+    mcp: FastMCP,
+    hooks: ServerCallbacks,
+    handlers: Mapping[str, Callable[..., Any]],
+) -> None:
+    """Register an ordered family of handlers through their declaration rows."""
+
+    for name, handler in handlers.items():
+        register_declared_tool(mcp, hooks, name, handler)
+
+
+__all__ = [
+    "MCP_DECLARATION_ATTRIBUTE",
+    "register_declared_tool",
+    "register_declared_tools",
+]
