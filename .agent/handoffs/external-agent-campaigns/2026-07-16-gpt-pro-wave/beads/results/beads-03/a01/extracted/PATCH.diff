diff --git a/tests/unit/mcp/test_read_tool_declarations.py b/tests/unit/mcp/test_read_tool_declarations.py
new file mode 100644
index 0000000000000000000000000000000000000000..edcfbeb785e482f132175a428108f5408637ccef
--- /dev/null
+++ b/tests/unit/mcp/test_read_tool_declarations.py
@@ -0,0 +1,202 @@
+"""Executable parity and real-route proofs for the MCP declaration migration."""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from types import SimpleNamespace
+from typing import cast
+from unittest.mock import patch
+
+import pytest
+
+from polylogue.api import Polylogue
+from polylogue.archive.message.roles import Role
+from polylogue.core.enums import BlockType, Provider
+from polylogue.mcp.declarations import (
+    MCP_MIGRATED_READ_TOOL_NAMES,
+    MCP_TOOL_REGISTRY,
+    tool_declaration_rows,
+)
+from polylogue.mcp.declarations.registration import MCP_DECLARATION_ATTRIBUTE
+from polylogue.mcp.server import build_server
+from polylogue.mcp.server_support import MCPRole, role_allows
+from polylogue.sources.parsers.base import ParsedContentBlock, ParsedMessage, ParsedSession
+from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore
+from tests.infra.mcp import EXPECTED_TOOL_NAMES, MCPServerUnderTest, invoke_surface_async
+
+ROOT = Path(__file__).resolve().parents[3]
+DECLARATION_FIXTURE = ROOT / "tests/data/witnesses/mcp-tool-declarations.json"
+SCHEMA_FIXTURE = ROOT / "tests/data/witnesses/mcp-tool-schemas.json"
+CONTRACT_FIXTURE = ROOT / "tests/data/witnesses/mcp-tool-contracts.json"
+
+
+def _load_rows(path: Path) -> list[dict[str, object]]:
+    value = json.loads(path.read_text(encoding="utf-8"))
+    assert isinstance(value, list)
+    return cast(list[dict[str, object]], value)
+
+
+async def _live_contract_rows_async() -> list[dict[str, object]]:
+    rows: list[dict[str, object]] = []
+    for tool in sorted(await build_server(role="admin").list_tools(), key=lambda item: item.name):
+        rows.append(
+            {
+                "name": tool.name,
+                "required_role": MCP_TOOL_REGISTRY[tool.name].required_role,
+                "description": tool.description,
+                "input_schema": tool.inputSchema,
+                "output_schema": tool.outputSchema,
+                "annotations": None if tool.annotations is None else tool.annotations.model_dump(mode="json"),
+            }
+        )
+    return rows
+
+
+def _seed_lineage_archive(archive_root: Path) -> tuple[str, str]:
+    """Plant independent search and topology facts for the real-route proof."""
+
+    with ArchiveStore(archive_root) as archive:
+        parent_id = archive.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="declaration-parent",
+                title="Declaration Parent",
+                messages=[
+                    ParsedMessage(
+                        provider_message_id="parent-message",
+                        role=Role.USER,
+                        text="declaration route needle",
+                        blocks=[
+                            ParsedContentBlock(
+                                type=BlockType.TEXT,
+                                text="declaration route needle",
+                            )
+                        ],
+                    )
+                ],
+            )
+        )
+        child_id = archive.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="declaration-child",
+                title="Declaration Child",
+                parent_session_provider_id="declaration-parent",
+                messages=[
+                    ParsedMessage(
+                        provider_message_id="child-message",
+                        role=Role.ASSISTANT,
+                        text="child continuation",
+                        blocks=[ParsedContentBlock(type=BlockType.TEXT, text="child continuation")],
+                    )
+                ],
+            )
+        )
+    return parent_id, child_id
+
+
+def test_declaration_fixture_pins_the_complete_inventory() -> None:
+    fixture_rows = _load_rows(DECLARATION_FIXTURE)
+
+    assert fixture_rows == list(tool_declaration_rows())
+    assert {str(row["name"]) for row in fixture_rows} == EXPECTED_TOOL_NAMES
+    assert len(fixture_rows) == len(EXPECTED_TOOL_NAMES) == 104
+    assert sum(bool(row["registered_from_declaration"]) for row in fixture_rows) == 56
+
+
+@pytest.mark.parametrize("role", ["read", "write", "review", "admin"])
+def test_role_discovery_is_projected_from_the_fixed_declaration_witness(role: MCPRole) -> None:
+    rows = _load_rows(DECLARATION_FIXTURE)
+    expected = {str(row["name"]) for row in rows if role_allows(role, cast(MCPRole, row["required_role"]))}
+    server = cast(MCPServerUnderTest, build_server(role=role))
+
+    assert set(server._tool_manager._tools) == expected
+
+
+@pytest.mark.asyncio
+async def test_live_fastmcp_contracts_match_the_committed_wire_witness() -> None:
+    contract_rows = await _live_contract_rows_async()
+    schema_rows = [{"name": row["name"], "parameters": row["input_schema"]} for row in contract_rows]
+
+    assert contract_rows == _load_rows(CONTRACT_FIXTURE)
+    assert schema_rows == _load_rows(SCHEMA_FIXTURE)
+
+
+def test_every_migrated_handler_was_registered_through_its_declaration() -> None:
+    server = cast(MCPServerUnderTest, build_server(role="read"))
+
+    assert len(MCP_MIGRATED_READ_TOOL_NAMES) == 56
+    for name in MCP_MIGRATED_READ_TOOL_NAMES:
+        handler = server._tool_manager._tools[name].fn
+        declaration = MCP_TOOL_REGISTRY[name]
+        assert getattr(handler, MCP_DECLARATION_ATTRIBUTE) is declaration
+        assert handler.__name__ == declaration.name
+        assert handler.__doc__ == declaration.description
+
+
+@pytest.mark.asyncio
+async def test_declared_query_topology_and_timeline_tools_execute_real_production_routes(tmp_path: Path) -> None:
+    """Exercise FastMCP registration plus ArchiveStore/Polylogue operations.
+
+    Production dependencies under test:
+    - ``search`` -> ``archive_search_payload`` -> ArchiveStore query/FTS;
+    - ``resolve_ref`` -> Polylogue facade -> canonical ObjectRef resolution;
+    - ``get_session_topology`` -> Polylogue facade -> topology archive reads;
+    - ``usage_timeline`` -> insight registry -> Polylogue usage-timeline operation.
+    """
+
+    archive_root = tmp_path / "archive"
+    parent_id, child_id = _seed_lineage_archive(archive_root)
+    config = SimpleNamespace(archive_root=archive_root, db_path=archive_root / "index.db")
+    polylogue = Polylogue(archive_root=archive_root, db_path=archive_root / "index.db")
+    server = cast(MCPServerUnderTest, build_server(role="read"))
+
+    try:
+        with (
+            patch("polylogue.mcp.server._get_config", return_value=config),
+            patch("polylogue.mcp.server._get_polylogue", return_value=polylogue),
+        ):
+            search_result = await invoke_surface_async(
+                server._tool_manager._tools["search"].fn,
+                query="declaration route needle",
+                limit=5,
+            )
+            resolved_ref_result = await invoke_surface_async(
+                server._tool_manager._tools["resolve_ref"].fn,
+                ref=f"session:{parent_id}",
+            )
+            missing_ref_result = await invoke_surface_async(
+                server._tool_manager._tools["resolve_ref"].fn,
+                ref="session:declaration-missing",
+            )
+            topology_result = await invoke_surface_async(
+                server._tool_manager._tools["get_session_topology"].fn,
+                session_id=child_id,
+            )
+            timeline_result = await invoke_surface_async(
+                server._tool_manager._tools["usage_timeline"].fn,
+                limit=1,
+            )
+    finally:
+        await polylogue.close()
+
+    search = json.loads(search_result)
+    resolved_ref = json.loads(resolved_ref_result)
+    missing_ref = json.loads(missing_ref_result)
+    topology = json.loads(topology_result)
+    timeline = json.loads(timeline_result)
+
+    assert search["total"] == 1
+    assert search["hits"][0]["session"]["id"] == parent_id
+    assert resolved_ref["normalized_ref"] == f"session:{parent_id}"
+    assert resolved_ref["resolved"] is True
+    assert resolved_ref["payload"]["id"] == parent_id
+    assert resolved_ref["object_refs"] == [f"session:{parent_id}"]
+    assert missing_ref["resolved"] is False
+    assert missing_ref["payload"] is None
+    assert missing_ref["caveats"] == ["session not found"]
+    assert topology["target_id"] == child_id
+    assert topology["root_id"] == parent_id
+    assert [node["session_id"] for node in topology["thread"]] == [parent_id, child_id]
+    assert timeline == {"total": 0, "items": []}
