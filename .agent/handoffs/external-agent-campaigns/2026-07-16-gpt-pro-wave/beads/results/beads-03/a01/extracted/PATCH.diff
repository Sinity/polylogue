diff --git a/devtools/render_mcp_contract_fixtures.py b/devtools/render_mcp_contract_fixtures.py
new file mode 100644
index 0000000000000000000000000000000000000000..140a86ded8f5ff1fdc2186268ed83fbc80e241b4
--- /dev/null
+++ b/devtools/render_mcp_contract_fixtures.py
@@ -0,0 +1,91 @@
+"""Render committed MCP declaration and wire-contract witnesses.
+
+The production declaration registry owns semantic inventory and role gates.
+FastMCP remains the wire-schema authority because it inspects the original
+handlers, including dynamic insight signatures.  This renderer snapshots both
+projections so a migration cannot silently change either side.
+"""
+
+from __future__ import annotations
+
+import argparse
+import asyncio
+import json
+import sys
+from pathlib import Path
+
+from devtools.command_catalog import control_plane_command
+from devtools.render_support import write_if_changed
+from polylogue.mcp.declarations import MCP_TOOL_REGISTRY, tool_declaration_rows
+from polylogue.mcp.server import build_server
+
+DEFAULT_DECLARATION_PATH = Path("tests/data/witnesses/mcp-tool-declarations.json")
+DEFAULT_SCHEMA_PATH = Path("tests/data/witnesses/mcp-tool-schemas.json")
+DEFAULT_CONTRACT_PATH = Path("tests/data/witnesses/mcp-tool-contracts.json")
+
+
+def _json_text(payload: object) -> str:
+    return json.dumps(payload, indent=2, sort_keys=True, ensure_ascii=False) + "\n"
+
+
+async def _wire_rows() -> tuple[list[dict[str, object]], list[dict[str, object]]]:
+    tools = await build_server(role="admin").list_tools()
+    schemas: list[dict[str, object]] = []
+    contracts: list[dict[str, object]] = []
+    for tool in sorted(tools, key=lambda item: item.name):
+        declaration = MCP_TOOL_REGISTRY[tool.name]
+        schemas.append({"name": tool.name, "parameters": tool.inputSchema})
+        contracts.append(
+            {
+                "name": tool.name,
+                "required_role": declaration.required_role,
+                "description": tool.description,
+                "input_schema": tool.inputSchema,
+                "output_schema": tool.outputSchema,
+                "annotations": (None if tool.annotations is None else tool.annotations.model_dump(mode="json")),
+            }
+        )
+    return schemas, contracts
+
+
+def build_outputs() -> dict[Path, str]:
+    """Build all declaration and live FastMCP witness payloads."""
+
+    schema_rows, contract_rows = asyncio.run(_wire_rows())
+    return {
+        DEFAULT_DECLARATION_PATH: _json_text(tool_declaration_rows()),
+        DEFAULT_SCHEMA_PATH: _json_text(schema_rows),
+        DEFAULT_CONTRACT_PATH: _json_text(contract_rows),
+    }
+
+
+def _check_outputs(outputs: dict[Path, str]) -> int:
+    stale = [path for path, rendered in outputs.items() if not path.exists() or path.read_text() != rendered]
+    if stale:
+        print("render mcp-contract-fixtures: out of sync:", file=sys.stderr)
+        for path in stale:
+            print(f"  - {path}", file=sys.stderr)
+        print(
+            f"render mcp-contract-fixtures: run: {control_plane_command('render mcp-contract-fixtures')}",
+            file=sys.stderr,
+        )
+        return 1
+    print("render mcp-contract-fixtures: sync OK")
+    return 0
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description="Render MCP declaration and wire-contract witnesses.")
+    parser.add_argument("--check", action="store_true", help="Exit non-zero when any witness is stale.")
+    args = parser.parse_args(argv)
+
+    outputs = build_outputs()
+    if args.check:
+        return _check_outputs(outputs)
+    for path, rendered in outputs.items():
+        write_if_changed(path, rendered)
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
