index 0000000000000000000000000000000000000000..b46af5875e7c2b78196fc2eba6daed557c58f4ae
--- /dev/null
+++ b/polylogue/mcp/declarations/models.py
@@ -0,0 +1,154 @@
+"""Typed declaration model for the public MCP tool surface.
+
+The declaration records protocol metadata only.  Handler implementations stay
+in the existing MCP leaf modules and continue to delegate to archive/query,
+operations, insight, and policy owners below the surface.
+"""
+
+from __future__ import annotations
+
+import re
+from collections.abc import Mapping
+from dataclasses import dataclass, field
+from enum import StrEnum
+from types import MappingProxyType
+
+from polylogue.mcp.server_support import MCPRole
+
+_TOOL_NAME_RE = re.compile(r"^[a-z][a-z0-9_]*$")
+
+
+class MCPToolFamily(StrEnum):
+    """Semantic family used for migration, discovery, and parity checks."""
+
+    QUERY = "query"
+    READ = "read"
+    INSIGHT = "insight"
+    TOPOLOGY = "topology"
+    TIMELINE = "timeline"
+    STATUS = "status"
+    CONTEXT = "context"
+    ASSERTION = "assertion"
+    COORDINATION = "coordination"
+    PERSONAL_STATE = "personal-state"
+    MUTATION = "mutation"
+    REVIEW = "review"
+    MAINTENANCE = "maintenance"
+
+
+class MCPToolVerb(StrEnum):
+    """Public protocol verb represented by a declaration."""
+
+    QUERY = "query"
+    SEARCH = "search"
+    LIST = "list"
+    GET = "get"
+    READ = "read"
+    RESOLVE = "resolve"
+    EXPLAIN = "explain"
+    STATUS = "status"
+    FIND = "find"
+    AGGREGATE = "aggregate"
+    COMPARE = "compare"
+    CORRELATE = "correlate"
+    COMPILE = "compile"
+    WRITE = "write"
+    JUDGE = "judge"
+    RUN = "run"
+
+
+class MCPResultSemantics(StrEnum):
+    """Logical result contract, independent of transport presentation."""
+
+    EXHAUSTIVE_PAGE = "exhaustive-page"
+    POINT_READ = "point-read"
+    TOP_K = "top-k"
+    AGGREGATE = "aggregate"
+    BOUNDED_CONTEXT = "bounded-context"
+    RECURSIVE_GRAPH = "recursive-graph"
+    STATUS = "status"
+    MUTATION = "mutation"
+    MAINTENANCE = "maintenance"
+
+
+class MCPContinuationKind(StrEnum):
+    """Continuation semantics exposed by the current compatibility route."""
+
+    NONE = "none"
+    OFFSET = "offset"
+    CURSOR = "cursor"
+    OFFSET_OR_CURSOR = "offset-or-cursor"
+    TOP_K = "top-k-bound"
+    GRAPH_UNPAGED = "recursive-graph-unpaged"
+    BOUNDED = "bounded-context"
+
+
+@dataclass(frozen=True, slots=True)
+class MCPToolDeclaration:
+    """One executable inventory row for a public MCP tool.
+
+    ``registered_from_declaration`` is true only after the handler's FastMCP
+    registration is driven through :mod:`polylogue.mcp.declarations.registration`.
+    Unmigrated rows remain in the same inventory so role/name drift is caught
+    while their implementation moves in the separately-owned migration.
+    """
+
+    name: str
+    description: str
+    family: MCPToolFamily
+    verb: MCPToolVerb
+    object_kind: str
+    required_role: MCPRole
+    result_semantics: MCPResultSemantics
+    continuation: MCPContinuationKind
+    implementation: str
+    operation_owner: str
+    output_contract: str
+    minimal_arguments: Mapping[str, object] = field(default_factory=dict)
+    object_ref_semantics: str = "none"
+    query_semantics: str = "none"
+    absence_contract: str = "typed empty/error envelope"
+    compatibility_route: str | None = None
+    migration_owner: str = "polylogue-t46.8.3"
+    registered_from_declaration: bool = False
+
+    def __post_init__(self) -> None:
+        if not _TOOL_NAME_RE.fullmatch(self.name):
+            raise ValueError(f"invalid MCP tool name: {self.name!r}")
+        for field_name in ("object_kind", "implementation", "operation_owner", "output_contract"):
+            if not getattr(self, field_name):
+                raise ValueError(f"{self.name}: {field_name} must be non-empty")
+        object.__setattr__(self, "minimal_arguments", MappingProxyType(dict(self.minimal_arguments)))
+
+    def to_contract_row(self) -> dict[str, object]:
+        """Return a stable JSON-compatible row for fixtures and generated views."""
+
+        return {
+            "name": self.name,
+            "description": self.description,
+            "family": self.family.value,
+            "verb": self.verb.value,
+            "object_kind": self.object_kind,
+            "required_role": self.required_role,
+            "result_semantics": self.result_semantics.value,
+            "continuation": self.continuation.value,
+            "implementation": self.implementation,
+            "operation_owner": self.operation_owner,
+            "output_contract": self.output_contract,
+            "minimal_arguments": dict(self.minimal_arguments),
+            "object_ref_semantics": self.object_ref_semantics,
+            "query_semantics": self.query_semantics,
+            "absence_contract": self.absence_contract,
+            "compatibility_route": self.compatibility_route,
+            "migration_owner": self.migration_owner,
+            "registered_from_declaration": self.registered_from_declaration,
+        }
+
+
+__all__ = [
+    "MCPContinuationKind",
+    "MCPResultSemantics",
+    "MCPToolDeclaration",
+    "MCPToolFamily",
+    "MCPToolVerb",
+]
