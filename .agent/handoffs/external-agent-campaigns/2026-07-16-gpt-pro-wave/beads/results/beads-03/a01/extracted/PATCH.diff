+class MCPToolRegistry(Mapping[str, MCPToolDeclaration]):
+    """Validated immutable lookup over the executable declaration inventory."""
+
+    def __init__(self, declarations: tuple[MCPToolDeclaration, ...]) -> None:
+        by_name: dict[str, MCPToolDeclaration] = {}
+        for declaration in declarations:
+            if declaration.name in by_name:
+                raise ValueError(f"duplicate MCP declaration: {declaration.name}")
+            by_name[declaration.name] = declaration
+        self._by_name = by_name
+
+    def __getitem__(self, name: str) -> MCPToolDeclaration:
+        return self._by_name[name]
+
+    def __iter__(self) -> Iterator[str]:
+        return iter(self._by_name)
+
+    def __len__(self) -> int:
+        return len(self._by_name)
+
+    def names_for_role(self, role: MCPRole) -> frozenset[str]:
+        return frozenset(
+            declaration.name for declaration in self._by_name.values() if role_allows(role, declaration.required_role)
+        )
+
+    def contract_rows(self) -> tuple[dict[str, object], ...]:
+        return tuple(self._by_name[name].to_contract_row() for name in sorted(self._by_name))
+
+
+MCP_TOOL_REGISTRY = MCPToolRegistry(_DECLARATIONS)
+MCP_MIGRATED_READ_TOOL_NAMES = frozenset(
+    declaration.name for declaration in _DECLARATIONS if declaration.registered_from_declaration
+)
+
+
+def expected_tool_names() -> frozenset[str]:
+    """Return the exact all-role discovery inventory."""
+
+    return frozenset(MCP_TOOL_REGISTRY)
+
+
+def tool_names_for_role(role: MCPRole) -> frozenset[str]:
+    """Project the exact role-scoped discovery inventory."""
+
+    return MCP_TOOL_REGISTRY.names_for_role(role)
+
+
+def tool_declaration_rows() -> tuple[dict[str, object], ...]:
+    """Return stable rows used by generated fixtures and parity checks."""
+
+    return MCP_TOOL_REGISTRY.contract_rows()
+
+
+__all__ = [
+    "MCP_MIGRATED_READ_TOOL_NAMES",
+    "MCP_TOOL_REGISTRY",
+    "MCPToolRegistry",
+    "expected_tool_names",
+    "tool_declaration_rows",
+    "tool_names_for_role",
+]
