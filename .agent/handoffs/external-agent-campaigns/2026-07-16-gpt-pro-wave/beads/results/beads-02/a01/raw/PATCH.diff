+def _validate_inventory_tables() -> None:
+    names = {row.name for row in _TOOL_ROWS}
+    tables: tuple[tuple[str, Mapping[str, object]], ...] = (
+        ("discovery", _DISCOVERY),
+        ("continuation", _CONTINUATION),
+        ("resource alternatives", _RESOURCE_ALTERNATIVES),
+        ("prompt alternatives", _PROMPT_ALTERNATIVES),
+        ("target routes", _TARGET_ROUTE),
+        ("workflow coverage", _WORKFLOW_COVERAGE),
+        ("observed use", _OBSERVED_USE),
+    )
+    for label, table in tables:
+        missing = sorted(names - set(table))
+        extra = sorted(set(table) - names)
+        if missing or extra:
+            raise RuntimeError(
+                f"MCP declaration {label} table drift: missing={missing}, extra={extra}; "
+                f"repair with `{_REPAIR_COMMAND}`"
+            )
+
+
+_validate_inventory_tables()
+
+
+def _compatibility(row: _ToolRow) -> CompatibilityKey:
+    return CompatibilityKey(
+        identity="mcp-tool:" + ",".join(row.object_kinds),
+        lifecycle="registered-handler-retained",
+        authority=f"mcp-role:{row.minimum_role}",
+        access_result_shape=f"{row.verb.value}:{row.result_semantics.value}:{row.output_kind}",
+        durability="transport-adapter; domain-owner-controls-durability",
+    )
+
+
+def _family_id(row: _ToolRow) -> str:
+    # Each live compatibility tool is its own family in this slice. Shared
+    # derivation families are introduced only when every compatibility
+    # dimension is intentionally identical; grouping by implementation shape
+    # alone would erase distinct ObjectRef and operation semantics.
+    return f"mcp.tool.{row.name}"
+
+
+def _python_parity(row: _ToolRow) -> PythonParityExpectation:
+    if row.python_binding is not None:
+        return PythonParityExpectation(binding=row.python_binding)
+    return PythonParityExpectation(
+        intentional_absence_authority="polylogue-s1kr",
+        reason=(
+            "The current MCP compatibility handler binds a lower-level owner or transport-only projection; "
+            "polylogue-s1kr owns any public Python facade addition and docs parity."
+        ),
+    )
+
+
+def _build_declaration(row: _ToolRow) -> MCPToolDeclaration:
+    grammar, fields, values = _DISCOVERY[row.name]
+    continuation_mode, continuation_ref, exhaustive_route, continuation_notes = _CONTINUATION[row.name]
+    retirement_owner = "polylogue-t46.8.2" if row.minimum_role == "read" else "polylogue-t46.8.3"
+    deprecation = (
+        MCPDeprecationState.COMPATIBILITY
+        if row.name in {"archive_list_sessions", "archive_search_sessions"}
+        else MCPDeprecationState.RETAINED
+    )
+    kernel = DeclarationSpec(
+        declaration_id=f"mcp.tool.{row.name}",
+        family_id=_family_id(row),
+        public_name=row.name,
+        owner_path="polylogue/mcp/declarations/registry.py",
+        compatibility=_compatibility(row),
+        producer=row.operation_owner,
+        role_gate=f"mcp.role:{row.minimum_role}",
+        schema_ref=row.schema_source,
+        discovery_text=row.description,
+        repair_command=_REPAIR_COMMAND,
+        handlers=(
+            HandlerBinding(
+                surface="mcp",
+                owner_path=row.module.replace(".", "/") + ".py",
+                symbol=row.name,
+                binding_key=f"{row.module}:{row.name}",
+            ),
+        ),
+        outputs=(
+            OutputSpec(
+                name="runtime-contract",
+                kind=row.output_kind,
+                schema_ref="tests/unit/mcp/test_envelope_contracts.py::TOOL_CONTRACT",
+                target_path=f"mcp://tool/{row.name}",
+            ),
+            OutputSpec(
+                name="equivalence-map",
+                kind="generated-json",
+                schema_ref="polylogue.mcp.declarations.models.MCPToolDeclaration",
+                target_path="docs/generated/mcp-equivalence.json",
+            ),
+        ),
+        examples=(
+            ExampleSpec(
+                name="minimal-valid-call",
+                summary=f"Minimal compatibility invocation for {row.name}.",
+                arguments=row.minimal_arguments,
+            ),
+        ),
+        completeness_edges=(
+            CompletenessEdge(
+                producer=f"mcp.tool.{row.name}",
+                consumer="tests.infra.mcp.EXPECTED_TOOL_NAMES",
+                kind="discovery-name-equivalence",
+                owner_path="tests/infra/mcp.py",
+            ),
+            CompletenessEdge(
+                producer=f"mcp.tool.{row.name}",
+                consumer="docs/generated/mcp-equivalence.json",
+                kind="generated-equivalence-row",
+                owner_path="devtools/render_mcp_equivalence.py",
+            ),
+        ),
+    )
+    return MCPToolDeclaration(
+        kernel=kernel,
+        name=row.name,
+        description=row.description,
+        verb=row.verb,
+        object_kinds=row.object_kinds,
+        minimum_role=row.minimum_role,
+        capability=f"{row.minimum_role}:{row.verb.value}",
+        result_semantics=row.result_semantics,
+        canonical_plan=row.operation_owner,
+        canonical_projection=f"{row.output_kind}:{','.join(row.envelope_fields) or 'root'}",
+        input_contract=MCPInputContract(
+            schema_source=row.schema_source,
+            schema_mode="FastMCP derives inputSchema from the unchanged handler object/signature",
+            required_arguments=row.required_arguments,
+        ),
+        output_contract=MCPOutputContract(kind=row.output_kind, envelope_fields=row.envelope_fields),
+        minimal_arguments=row.minimal_arguments,
+        grammar_discovery=grammar,
+        field_discovery=fields,
+        value_discovery=values,
+        continuation=MCPContinuationContract(
+            mode=continuation_mode,
+            continuation_ref=continuation_ref,
+            exhaustive_route=exhaustive_route,
+            notes=continuation_notes,
+        ),
+        resource_alternatives=_RESOURCE_ALTERNATIVES[row.name],
+        prompt_alternatives=_PROMPT_ALTERNATIVES[row.name],
+        compatibility_route=_TARGET_ROUTE[row.name],
+        workflow_coverage=_WORKFLOW_COVERAGE[row.name],
+        incident_coverage=(
+            "z9gh-workflow-incident"
+            if row.name
+            in {
+                "search",
+                "query_units",
+                "list_sessions",
+                "archive_list_sessions",
+                "archive_search_sessions",
+                "query_completions",
+                "explain_query_expression",
+            }
+            else "mcp-contract-census",
+        ),
+        observed_use=_OBSERVED_USE[row.name],
+        telemetry_key=row.name,
+        deprecation_state=deprecation,
+        retirement_owner=retirement_owner,
+        registration=MCPHandlerBinding(module=row.module, symbol=row.name, registrar=row.registrar),
+        operation_owner=row.operation_owner,
+        python_parity=_python_parity(row),
+    )
+
