+++ b/tests/infra/query_manifest_oracle.py
@@ -0,0 +1,244 @@
+"""Independent planted-fact oracle for real query composition laws.
+
+The oracle deliberately knows nothing about Polylogue's parser, query specs,
+SQL relations, or public payload models.  It computes expected membership and
+cardinality directly from the facts planted by the test fixture.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+
+
+@dataclass(frozen=True, slots=True)
+class QueryActionFact:
+    """One planted tool-use fact and its optional paired result."""
+
+    message_native_id: str
+    occurred_at_ms: int
+    tool_name: str
+    tool_id: str
+    command: str | None = None
+    path: str | None = None
+    output_text: str | None = None
+    is_error: bool | None = None
+    exit_code: int | None = None
+
+
+@dataclass(frozen=True, slots=True)
+class QuerySessionFact:
+    """One independently specified session planted into the archive."""
+
+    provider: str
+    origin: str
+    native_id: str
+    title: str
+    actions: tuple[QueryActionFact, ...] = ()
+
+    @property
+    def session_id(self) -> str:
+        return f"{self.origin}:{self.native_id}"
+
+
+@dataclass(frozen=True, slots=True)
+class ExpectedActionRow:
+    """Expected action row, including its hidden join key, from planted facts."""
+
+    session_id: str
+    message_id: str
+    tool_name: str
+    tool_id: str
+    output_text: str | None
+    is_error: bool | None
+    exit_code: int | None
+
+
+@dataclass(frozen=True, slots=True)
+class QueryManifest:
+    """Pure expected-result model for query membership and cardinality."""
+
+    sessions: tuple[QuerySessionFact, ...]
+
+    def session_ids(
+        self,
+        *,
+        origin: str | None = None,
+        title_contains: str | None = None,
+        exact_session_id: str | None = None,
+    ) -> tuple[str, ...]:
+        selected = []
+        for session in self.sessions:
+            if origin is not None and session.origin != origin:
+                continue
+            if title_contains is not None and title_contains.lower() not in session.title.lower():
+                continue
+            if exact_session_id is not None and session.session_id != exact_session_id:
+                continue
+            selected.append(session.session_id)
+        return tuple(sorted(selected))
+
+    def action_rows(
+        self,
+        *,
+        session_id: str,
+        tool_name: str | None = None,
+    ) -> tuple[ExpectedActionRow, ...]:
+        rows = []
+        for session in self.sessions:
+            if session.session_id != session_id:
+                continue
+            for action in session.actions:
+                if tool_name is not None and action.tool_name.casefold() != tool_name.casefold():
+                    continue
+                rows.append(
+                    ExpectedActionRow(
+                        session_id=session.session_id,
+                        message_id=f"{session.session_id}:{action.message_native_id}",
+                        tool_name=action.tool_name,
+                        tool_id=action.tool_id,
+                        output_text=action.output_text,
+                        is_error=action.is_error,
+                        exit_code=action.exit_code,
+                    )
+                )
+        return tuple(rows)
+
+    def action_partition(
+        self,
+        *,
+        session_id: str,
+        tool_name: str,
+        field: str,
+    ) -> tuple[tuple[str, int], ...]:
+        if field != "is_error":
+            raise ValueError(f"unsupported oracle partition field: {field}")
+        counts: dict[str, int] = {}
+        for row in self.action_rows(session_id=session_id, tool_name=tool_name):
+            key = "unknown" if row.is_error is None else str(int(row.is_error))
+            counts[key] = counts.get(key, 0) + 1
+        return tuple(sorted(counts.items()))
+
+    def page_actions(
+        self,
+        *,
+        session_id: str,
+        tool_name: str,
+        limit: int,
+        offset: int,
+    ) -> tuple[ExpectedActionRow, ...]:
+        rows = self.action_rows(session_id=session_id, tool_name=tool_name)
+        return rows[offset : offset + limit]
+
+
+QUERY_CARDINALITY_MANIFEST = QueryManifest(
+    sessions=(
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-action",
+            title="td01 action duplicate pairing",
+            actions=(
+                QueryActionFact(
+                    message_native_id="m-action-01",
+                    occurred_at_ms=1_767_225_601_000,
+                    tool_name="Bash",
+                    tool_id="td01-repeat",
+                    command="printf first",
+                    output_text="first ok",
+                    is_error=False,
+                    exit_code=0,
+                ),
+                QueryActionFact(
+                    message_native_id="m-action-02",
+                    occurred_at_ms=1_767_225_602_000,
+                    tool_name="Bash",
+                    tool_id="td01-repeat",
+                    command="printf second",
+                    output_text="second failed",
+                    is_error=True,
+                    exit_code=7,
+                ),
+                QueryActionFact(
+                    message_native_id="m-action-03",
+                    occurred_at_ms=1_767_225_603_000,
+                    tool_name="Bash",
+                    tool_id="td01-missing",
+                    command="printf missing",
+                ),
+                QueryActionFact(
+                    message_native_id="m-action-04",
+                    occurred_at_ms=1_767_225_604_000,
+                    tool_name="Read",
+                    tool_id="td01-read",
+                    path="polylogue/archive/query/expression.py",
+                    output_text="read ok",
+                    is_error=False,
+                    exit_code=0,
+                ),
+            ),
+        ),
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-action-decoy",
+            title="td01 action predicate decoy",
+            actions=(
+                QueryActionFact(
+                    message_native_id="m-decoy",
+                    occurred_at_ms=1_767_225_605_000,
+                    tool_name="Bash",
+                    tool_id="td01-repeat",
+                    command="printf decoy",
+                    output_text="decoy",
+                    is_error=False,
+                    exit_code=0,
+                ),
+            ),
+        ),
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-delete-a",
+            title="td01-delete-cohort alpha",
+        ),
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-delete-b",
+            title="td01-delete-cohort beta",
+        ),
+        QuerySessionFact(
+            provider="claude-code",
+            origin="claude-code-session",
+            native_id="td01-delete-shadow",
+            title="td01-delete-cohort provider shadow",
+        ),
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-shared",
+            title="td01 canonical identity codex",
+        ),
+        QuerySessionFact(
+            provider="claude-code",
+            origin="claude-code-session",
+            native_id="td01-shared",
+            title="td01 canonical identity claude",
+        ),
+        QuerySessionFact(
+            provider="codex",
+            origin="codex-session",
+            native_id="td01-keep",
+            title="td01 retained control",
+        ),
+    )
+)
+
+
+__all__ = [
+    "ExpectedActionRow",
+    "QUERY_CARDINALITY_MANIFEST",
+    "QueryActionFact",
+    "QueryManifest",
+    "QuerySessionFact",
+]
