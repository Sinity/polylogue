+def test_every_declared_embedding_recipe_field_denies_reuse_when_changed() -> None:
+    """Deleting any field from the complete recipe construction makes this fail."""
+
+    components = embedding_recipe_components(model="voyage-4", dimension=1024)
+    assert set(components) == {
+        "canonicalization",
+        "selector",
+        "chunking",
+        "provider",
+        "model_revision",
+        "dimensions",
+        "task_input_type",
+        "normalization",
+        "tool_implementation",
+        "input_schema",
+    }
+    baseline = canonical_identity("polylogue.archive-embedding.recipe", components)
+    for field in components:
+        changed = dict(components)
+        changed[field] = f"{changed[field]}:changed"
+        assert canonical_identity("polylogue.archive-embedding.recipe", changed) != baseline, field
+
+    # Eligibility is intentionally outside the computational key: changing
+    # an authorization decision has no parameter through which it could alter
+    # the recipe identity.
+    assert "authorization_policy" not in components
+    assert (
+        canonical_identity(
+            "polylogue.archive-embedding.recipe",
+            embedding_recipe_components(model="voyage-4", dimension=1024),
+        )
+        == baseline
+    )
+
