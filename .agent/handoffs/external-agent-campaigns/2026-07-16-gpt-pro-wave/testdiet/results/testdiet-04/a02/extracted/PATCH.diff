+def test_equal_count_fts_rowid_reuse_and_recipe_drift_are_detected_then_repaired() -> None:
+    """Count parity cannot hide reused rowids or a changed tokenizer/fold recipe."""
+
+    conn = _fts_connection()
+    try:
+        conn.execute(
+            "INSERT INTO blocks VALUES (?, ?, ?, ?, ?, ?)",
+            ("old-block", "old-message", "old-session", "text", "old needle", b"o" * 32),
+        )
+        rowid = int(conn.execute("SELECT rowid FROM blocks").fetchone()[0])
+
+        # Simulate the representative mutation: a writer omits the delete and
+        # insert trigger arms while SQLite reuses the same rowid for a new block.
+        conn.execute("DROP TRIGGER messages_fts_ad")
+        conn.execute("DROP TRIGGER messages_fts_ai")
+        conn.execute("DELETE FROM blocks WHERE rowid = ?", (rowid,))
+        conn.execute(
+            """
+            INSERT INTO blocks(rowid, block_id, message_id, session_id, block_type, search_text, content_hash)
+            VALUES (?, ?, ?, ?, ?, ?, ?)
+            """,
+            (rowid, "new-block", "new-message", "new-session", "text", "new needle", b"n" * 32),
+        )
+
+        reused = fts_invariant_snapshot_sync(conn).messages
+        assert reused.source_rows == reused.indexed_rows == 1
+        assert reused.missing_rows == reused.excess_rows == 0
+        assert reused.identity_mismatch_rows == 1
+        assert not reused.ready
+
+        restore_message_fts_triggers_sync(conn)
+        repair_message_fts_index_sync(conn, ["new-session"])
+        _assert_expected_fts_relation(conn)
+
+        conn.execute("UPDATE messages_fts_identity SET recipe_id = 'superseded-recipe'")
+        recipe_drift = fts_invariant_snapshot_sync(conn).messages
+        assert recipe_drift.recipe_mismatch_rows == 1
+        assert not recipe_drift.ready
+    finally:
+        conn.close()
+
