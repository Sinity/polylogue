+def test_superseded_embedding_success_and_terminal_error_cannot_clear_newer_debt() -> None:
+    """An old generation may retain a receipt but cannot become current/degraded."""
+
+    conn = _embedding_connection()
+    try:
+        old_key = archive_embedding_derivation_key(
+            session_id="session-1", source_identity="source-a", model="voyage-3", dimension=1024
+        )
+        old_attempt = begin_embedding_derivation_attempt(conn, old_key, occurred_at_ms=10)
+        new_key = archive_embedding_derivation_key(
+            session_id="session-1", source_identity="source-b", model="voyage-4", dimension=1024
+        )
+        new_attempt = begin_embedding_derivation_attempt(conn, new_key, occurred_at_ms=20)
+
+        assert not finish_embedding_derivation_success(conn, old_attempt, occurred_at_ms=30)
+        assert not finish_embedding_derivation_failure(
+            conn,
+            old_attempt,
+            retryable=False,
+            error_message="late terminal failure",
+            occurred_at_ms=40,
+        )
+        pending = read_embedding_derivation_state(conn, "session-1")
+        assert pending is not None
+        assert pending.key == new_key
+        assert pending.active_attempt_id == new_attempt.attempt_id
+        assert pending.state == "pending"
+
+        assert finish_embedding_derivation_success(conn, new_attempt, occurred_at_ms=50)
+        current = read_embedding_derivation_state(conn, "session-1")
+        assert current is not None and current.current
+        assert current.key == new_key
+        assert (
+            conn.execute(
+                "SELECT terminal_state FROM embedding_derivation_attempts WHERE attempt_id = ?",
+                (old_attempt.attempt_id,),
+            ).fetchone()[0]
+            == "superseded"
+        )
+    finally:
+        conn.close()
+
