+def test_provider_usage_source_trigger_and_catalog_recipe_never_present_stale_as_current() -> None:
+    """Ignoring source or pricing-catalog identity makes this witness fail."""
+
+    conn = _provider_usage_connection()
+    try:
+        conn.execute(
+            "INSERT INTO messages VALUES (?, ?, ?, ?, ?, ?, ?, ?)",
+            ("m1", "s1", 0, "gpt-5", 100, 20, 30, 10),
+        )
+        key = provider_usage_derivation_key(conn, session_id="s1", materializer_version=7)
+        conn.execute(
+            """
+            INSERT INTO insight_materialization (
+                insight_type, session_id, source_identity, recipe_identity,
+                output_contract, derivation_generation, derivation_state
+            ) VALUES ('provider_usage', ?, ?, ?, ?, 1, 'current')
+            """,
+            ("s1", key.source_identity, key.recipe_identity, key.output_contract),
+        )
+        assert key.output_contract == PROVIDER_USAGE_OUTPUT_CONTRACT
+        assert provider_usage_receipt_current(conn, session_id="s1", materializer_version=7)
+
+        # Same row count, different durable input: the trigger exposes pending
+        # before any reader can treat the old rollup as current.
+        conn.execute("UPDATE messages SET input_tokens = 101 WHERE message_id = 'm1'")
+        state = conn.execute("SELECT derivation_state, derivation_generation FROM insight_materialization").fetchone()
+        assert tuple(state) == ("pending", 2)
+        assert not provider_usage_receipt_current(conn, session_id="s1", materializer_version=7)
+        assert (
+            provider_usage_derivation_key(conn, session_id="s1", materializer_version=7).source_identity
+            != key.source_identity
+        )
+
+        # Position participates in the exact source key, so changing only that
+        # field must also invalidate a freshly restamped receipt.
+        refreshed = provider_usage_derivation_key(conn, session_id="s1", materializer_version=7)
+        conn.execute(
+            """
+            UPDATE insight_materialization
+            SET source_identity = ?, recipe_identity = ?, output_contract = ?,
+                derivation_state = 'current'
+            WHERE insight_type = 'provider_usage' AND session_id = 's1'
+            """,
+            (refreshed.source_identity, refreshed.recipe_identity, refreshed.output_contract),
+        )
+        conn.execute("UPDATE messages SET position = 1 WHERE message_id = 'm1'")
