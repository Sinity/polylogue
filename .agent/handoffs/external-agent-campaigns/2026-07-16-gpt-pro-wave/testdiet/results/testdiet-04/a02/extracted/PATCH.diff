+    "cache_read_tokens",
+    "cache_write_tokens",
+)
+
+
+def provider_usage_recipe_components(
+    *, materializer_version: int, catalog_hash: str | None = None
+) -> dict[str, object]:
+    """Return all computational fields that can change the provider rollup."""
+
+    if catalog_hash is None:
+        from polylogue.storage.sqlite.archive_tiers.pricing_seed import current_price_catalog_hash
+
+        catalog_hash = current_price_catalog_hash()
+    return {
+        "materializer_version": int(materializer_version),
+        "provider_event_fold": "latest-session-cumulative-else-per-model-last:v2",
+        "token_lane_mapping": "fresh-input-minus-cache-read:reasoning-inside-output:v1",
+        "message_fallback": "sum-per-message-known-model:v1",
+        "model_resolution": "event-model-else-single-source-model:v1",
+        "pricing_catalog_hash": catalog_hash,
+        "pricing_algorithm": "estimate-cost-catalog-normalization:v1",
+        "input_schema": "session_provider_usage_events+messages:v1",
+    }
+
+
+def provider_usage_recipe_identity(*, materializer_version: int) -> str:
+    return canonical_identity(
+        "polylogue.provider-usage.recipe",
+        provider_usage_recipe_components(materializer_version=materializer_version),
+    )
+
+
+def _normalized_rows(rows: Sequence[sqlite3.Row | tuple[object, ...]]) -> list[list[object]]:
+    return [list(row) for row in rows]
+
+
+def provider_usage_source_identity(conn: sqlite3.Connection, session_id: str) -> str:
+    """Hash the exact durable event/message facts read by the materializer."""
+
+    event_rows = conn.execute(
+        f"""
+        SELECT {", ".join(_PROVIDER_EVENT_COLUMNS)}
+        FROM session_provider_usage_events
+        WHERE session_id = ?
+        ORDER BY position
+        """,
+        (session_id,),
+    ).fetchall()
+    message_rows = conn.execute(
+        f"""
+        SELECT {", ".join(_MESSAGE_USAGE_COLUMNS)}
+        FROM messages
+        WHERE session_id = ?
+        ORDER BY position, message_id
+        """,
+        (session_id,),
+    ).fetchall()
+    return canonical_identity(
+        "polylogue.provider-usage.source",
+        {
+            "provider_events": _normalized_rows(event_rows),
+            "message_usage": _normalized_rows(message_rows),
+        },
+    )
+
+
+def provider_usage_derivation_key(
+    conn: sqlite3.Connection,
+    *,
+    session_id: str,
+    materializer_version: int,
+) -> DerivationKey:
+    return DerivationKey(
+        subject=f"provider-usage:{session_id}",
+        source_identity=provider_usage_source_identity(conn, session_id),
+        recipe_identity=provider_usage_recipe_identity(materializer_version=materializer_version),
+        output_contract=PROVIDER_USAGE_OUTPUT_CONTRACT,
+    )
+
+
+def provider_usage_receipt_current(
+    conn: sqlite3.Connection,
+    *,
+    session_id: str,
+    materializer_version: int,
+) -> bool:
+    """Compare the stored receipt with the live durable source and recipe."""
+
+    columns = {str(row[1]) for row in conn.execute("PRAGMA table_info(insight_materialization)").fetchall()}
+    required = {
+        "source_identity",
+        "recipe_identity",
+        "output_contract",
+        "derivation_state",
+    }
+    if not required <= columns:
+        return False
+    row = conn.execute(
+        """
+        SELECT source_identity, recipe_identity, output_contract, derivation_state
+        FROM insight_materialization
+        WHERE insight_type = 'provider_usage' AND session_id = ?
+        """,
+        (session_id,),
+    ).fetchone()
+    if row is None or str(row[3]) != "current":
+        return False
+    desired = provider_usage_derivation_key(
+        conn,
+        session_id=session_id,
+        materializer_version=materializer_version,
+    )
+    return (str(row[0]), str(row[1]), str(row[2])) == (
+        desired.source_identity,
+        desired.recipe_identity,
+        desired.output_contract,
+    )
+
+
+__all__ = [
+    "PROVIDER_USAGE_FRESHNESS_TRIGGER_DDL",
+    "PROVIDER_USAGE_OUTPUT_CONTRACT",
+    "provider_usage_derivation_key",
+    "provider_usage_receipt_current",
+    "provider_usage_recipe_components",
+    "provider_usage_recipe_identity",
+    "provider_usage_source_identity",
+]
