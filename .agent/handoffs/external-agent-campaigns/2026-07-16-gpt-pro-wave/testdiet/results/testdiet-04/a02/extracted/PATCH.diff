+def test_same_named_legacy_fts_triggers_cannot_authorize_a_recorded_ready_row() -> None:
+    """Trusting trigger names instead of programs makes stale identity look current."""
+
+    conn = _fts_connection()
+    try:
+        conn.execute(
+            "INSERT INTO blocks VALUES (?, ?, ?, ?, ?, ?)",
+            ("b-one", "m-one", "s", "text", "first searchable text", b"a" * 32),
+        )
+        record_fts_invariant_snapshot_sync(conn, fts_invariant_snapshot_sync(conn))
+
+        conn.executescript(
+            """
+            DROP TRIGGER messages_fts_ai;
+            DROP TRIGGER messages_fts_ad;
+            DROP TRIGGER messages_fts_au;
+            CREATE TRIGGER messages_fts_ai
+            AFTER INSERT ON blocks WHEN new.search_text != '' BEGIN
+                INSERT INTO messages_fts(rowid, block_id, message_id, session_id, block_type, text)
+                VALUES (new.rowid, new.block_id, new.message_id, new.session_id, new.block_type, new.search_text);
+            END;
+            CREATE TRIGGER messages_fts_ad
+            AFTER DELETE ON blocks WHEN old.search_text != '' BEGIN
+                DELETE FROM messages_fts WHERE rowid = old.rowid;
+            END;
+            CREATE TRIGGER messages_fts_au
+            AFTER UPDATE ON blocks BEGIN
+                DELETE FROM messages_fts WHERE rowid = old.rowid;
+                INSERT INTO messages_fts(rowid, block_id, message_id, session_id, block_type, text)
+                SELECT new.rowid, new.block_id, new.message_id, new.session_id, new.block_type, new.search_text
+                WHERE new.search_text != '';
+            END;
+            """
+        )
+        conn.execute(
+            "UPDATE blocks SET search_text = ?, content_hash = ? WHERE block_id = ?",
+            ("replacement searchable text", b"b" * 32, "b-one"),
+        )
+
+        assert not message_fts_triggers_current_sync(conn)
+        readiness = message_fts_search_readiness_sync(conn)
+        assert readiness["total_rows"] == readiness["indexed_rows"] == 1
+        assert not readiness["ready"]
+
+        ensure_fts_index_sync(conn)
+        assert message_fts_triggers_current_sync(conn)
+        repair_message_fts_index_sync(conn, ["s"])
+        _assert_expected_fts_relation(conn)
+    finally:
+        conn.close()
+
