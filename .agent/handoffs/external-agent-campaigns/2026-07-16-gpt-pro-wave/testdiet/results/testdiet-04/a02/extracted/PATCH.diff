diff --git a/polylogue/storage/derivation_identity.py b/polylogue/storage/derivation_identity.py
new file mode 100644
index 0000000000000000000000000000000000000000..38bad3bcc4c25dfbd63f1df95b11aca9ef99181e
--- /dev/null
+++ b/polylogue/storage/derivation_identity.py
@@ -0,0 +1,75 @@
+"""Storage-neutral identity values for rebuildable derived facts.
+
+A derivation key answers only *what* fact is desired: its subject/grain,
+exact source identity, complete computational recipe identity, and output
+contract.  Scheduling, retry policy, eligibility/privacy, producer/cost, and
+result integrity stay in their owning domain ledgers.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+from collections.abc import Mapping, Sequence
+from dataclasses import dataclass
+
+
+@dataclass(frozen=True, slots=True)
+class DerivationKey:
+    """Exact identity of one desired derived fact."""
+
+    subject: str
+    source_identity: str
+    recipe_identity: str
+    output_contract: str
+
+
+@dataclass(frozen=True, slots=True)
+class DerivationAttempt:
+    """A worker's captured key and monotonic domain generation."""
+
+    key: DerivationKey
+    generation: int
+    attempt_id: str
+
+    def __post_init__(self) -> None:
+        if self.generation < 1:
+            raise ValueError("derivation generation must be positive")
+        if not self.attempt_id:
+            raise ValueError("derivation attempt_id must be non-empty")
+
+
+def attempt_matches_current(
+    attempt: DerivationAttempt,
+    *,
+    key: DerivationKey,
+    generation: int,
+    attempt_id: str,
+) -> bool:
+    """Return whether a terminal write still owns the current pending key."""
+
+    return attempt.key == key and attempt.generation == generation and attempt.attempt_id == attempt_id
+
+
+def canonical_identity(namespace: str, fields: Mapping[str, object] | Sequence[tuple[str, object]]) -> str:
+    """Return a stable SHA-256 identity for explicitly named recipe/source fields."""
+
+    if isinstance(fields, Mapping):
+        items = sorted((str(name), value) for name, value in fields.items())
+    else:
+        items = [(str(name), value) for name, value in fields]
+    payload = json.dumps(
+        {"namespace": namespace, "fields": items},
+        ensure_ascii=True,
+        separators=(",", ":"),
+        sort_keys=True,
+    ).encode("utf-8")
+    return hashlib.sha256(payload).hexdigest()
+
+
+__all__ = [
+    "DerivationAttempt",
+    "DerivationKey",
+    "attempt_matches_current",
+    "canonical_identity",
+]
diff --git a/polylogue/storage/embeddings/freshness.py b/polylogue/storage/embeddings/freshness.py
new file mode 100644
index 0000000000000000000000000000000000000000..692498809533eedcf9a9d76309428b69b8fc22f8
--- /dev/null
+++ b/polylogue/storage/embeddings/freshness.py
@@ -0,0 +1,495 @@
+"""Monotonic content-and-recipe freshness for archive embeddings."""
+
+from __future__ import annotations
+
+import hashlib
+import sqlite3
+import time
+import uuid
+from collections.abc import Iterable, Mapping
+from dataclasses import dataclass
+
+from polylogue.storage.derivation_identity import (
+    DerivationAttempt,
+    DerivationKey,
+    attempt_matches_current,
+    canonical_identity,
+)
+from polylogue.storage.sqlite.archive_tiers.embeddings import EMBEDDING_DERIVATION_DDL
+
+EMBEDDING_PROVIDER = "voyage"
+EMBEDDING_INPUT_TYPE = "document"
+EMBEDDING_NORMALIZATION = "provider-native"
+EMBEDDING_OUTPUT_CONTRACT_VERSION = "message-vector-v1"
+
+
+@dataclass(frozen=True, slots=True)
+class EmbeddingDerivationState:
+    """Current desired/materialized identities for one archive session."""
+
+    session_id: str
+    key: DerivationKey
+    generation: int
+    active_attempt_id: str | None
+    state: str
+    materialized_source_identity: str | None
+    materialized_recipe_identity: str | None
+    materialized_output_contract: str | None
+    error_message: str | None
+
+    @property
+    def current(self) -> bool:
+        return (
+            self.state == "current"
+            and self.materialized_source_identity == self.key.source_identity
+            and self.materialized_recipe_identity == self.key.recipe_identity
+            and self.materialized_output_contract == self.key.output_contract
+        )
+
+
+def embedding_recipe_components(*, model: str, dimension: int) -> dict[str, object]:
+    """Return every declared computational field in the archive-vector recipe."""
+
+    from polylogue.storage.sqlite.archive_tiers.embeddings import EMBEDDINGS_SCHEMA_VERSION
+    from polylogue.storage.sqlite.archive_tiers.index import INDEX_SCHEMA_VERSION
+
+    return {
+        "canonicalization": "ordered-text-block-prose:trim-min-20:v1",
+        "selector": "message:user-assistant:authored-material:word-count-positive:v1",
+        "chunking": "one-vector-per-message:v1",
+        "provider": EMBEDDING_PROVIDER,
+        "model_revision": model,
+        "dimensions": int(dimension),
+        "task_input_type": EMBEDDING_INPUT_TYPE,
+        "normalization": EMBEDDING_NORMALIZATION,
+        "tool_implementation": "embed_archive_session_sync:v2",
+        "input_schema": f"index-v{INDEX_SCHEMA_VERSION}:embeddings-v{EMBEDDINGS_SCHEMA_VERSION}",
+    }
+
+
+def embedding_recipe_identity(*, model: str, dimension: int) -> str:
+    """Return the complete computational recipe identity for archive vectors."""
+
+    return canonical_identity(
+        "polylogue.archive-embedding.recipe",
+        embedding_recipe_components(model=model, dimension=dimension),
+    )
+
+
+def embedding_output_contract(*, dimension: int) -> str:
+    return f"sqlite-vec:float32:{int(dimension)}:{EMBEDDING_OUTPUT_CONTRACT_VERSION}"
+
+
+def archive_embedding_source_identity(
+    rows: Iterable[Mapping[str, object] | sqlite3.Row | tuple[object, ...]],
+) -> str:
+    """Hash the exact ordered embeddable message/content identities."""
+
+    payload: list[dict[str, str]] = []
+    for row in rows:
+        if isinstance(row, (sqlite3.Row, Mapping)):
+            message_id = row["message_id"]
+            content_hash = row["content_hash"]
+        else:
+            message_id, content_hash = row[0], row[1]
+        if content_hash is None:
+            raise ValueError("content_hash is required for embedding source identity")
+        if not isinstance(content_hash, (bytes, bytearray, memoryview)):
+            raise ValueError("embedding source content_hash must be bytes-like")
+        raw_hash = bytes(content_hash)
+        if len(raw_hash) != hashlib.sha256().digest_size:
+            raise ValueError("embedding source content_hash must be 32 bytes")
+        payload.append({"message_id": str(message_id), "content_hash": raw_hash.hex()})
+    payload.sort(key=lambda item: (item["message_id"], item["content_hash"]))
+    return canonical_identity("polylogue.archive-embedding.source", {"messages": payload})
+
+
+def archive_embedding_derivation_key(
+    *, session_id: str, source_identity: str, model: str, dimension: int
+) -> DerivationKey:
+    return DerivationKey(
+        subject=f"archive-session:{session_id}",
+        source_identity=source_identity,
+        recipe_identity=embedding_recipe_identity(model=model, dimension=dimension),
+        output_contract=embedding_output_contract(dimension=dimension),
+    )
+
+
+def ensure_embedding_derivation_tables(conn: sqlite3.Connection) -> None:
+    # ``executescript`` commits any active transaction.  These ledgers are also
+    # ensured from terminal write paths, so execute each complete DDL statement
+    # separately and preserve the caller's transaction boundary.
+    for statement in EMBEDDING_DERIVATION_DDL.split(";"):
+        sql = statement.strip()
+        if sql:
+            conn.execute(sql)
+
+
+def read_embedding_derivation_state(conn: sqlite3.Connection, session_id: str) -> EmbeddingDerivationState | None:
+    ensure_embedding_derivation_tables(conn)
+    row = conn.execute(
+        """
+        SELECT session_id, desired_source_identity, desired_recipe_identity,
+               desired_output_contract, generation, active_attempt_id, state,
+               materialized_source_identity, materialized_recipe_identity,
+               materialized_output_contract, error_message
+        FROM embedding_derivation_state
+        WHERE session_id = ?
+        """,
+        (session_id,),
+    ).fetchone()
+    if row is None:
+        return None
+    return EmbeddingDerivationState(
+        session_id=str(row[0]),
+        key=DerivationKey(
+            subject=f"archive-session:{row[0]}",
+            source_identity=str(row[1]),
+            recipe_identity=str(row[2]),
+            output_contract=str(row[3]),
+        ),
+        generation=int(row[4]),
+        active_attempt_id=None if row[5] is None else str(row[5]),
+        state=str(row[6]),
+        materialized_source_identity=None if row[7] is None else str(row[7]),
+        materialized_recipe_identity=None if row[8] is None else str(row[8]),
+        materialized_output_contract=None if row[9] is None else str(row[9]),
+        error_message=None if row[10] is None else str(row[10]),
+    )
+
+
+def _now_ms(value: int | None) -> int:
+    return int(time.time() * 1000) if value is None else int(value)
+
+
+def _begin_transaction_if_needed(conn: sqlite3.Connection) -> bool:
+    if conn.in_transaction:
+        return False
+    conn.execute("BEGIN IMMEDIATE")
+    return True
+
+
+def _finish_transaction(conn: sqlite3.Connection, started: bool, *, error: bool = False) -> None:
+    if not started:
+        return
+    conn.rollback() if error else conn.commit()
+
+
+def set_embedding_desired_key(
+    conn: sqlite3.Connection,
+    key: DerivationKey,
+    *,
+    occurred_at_ms: int | None = None,
+) -> int:
+    """Advance pending generation only when the desired key changed."""
+
+    ensure_embedding_derivation_tables(conn)
+    now_ms = _now_ms(occurred_at_ms)
+    started = _begin_transaction_if_needed(conn)
+    try:
+        row = conn.execute(
+            """
+            SELECT desired_source_identity, desired_recipe_identity, desired_output_contract,
+                   generation, active_attempt_id
+            FROM embedding_derivation_state WHERE session_id = ?
+            """,
+            (key.subject.removeprefix("archive-session:"),),
+        ).fetchone()
+        session_id = key.subject.removeprefix("archive-session:")
+        if row is not None and (str(row[0]), str(row[1]), str(row[2])) == (
+            key.source_identity,
+            key.recipe_identity,
+            key.output_contract,
+        ):
+            generation = int(row[3])
+        else:
+            generation = (int(row[3]) if row is not None else 0) + 1
+            if row is not None and row[4] is not None:
+                conn.execute(
+                    """
+                    UPDATE embedding_derivation_attempts
+                    SET terminal_state = 'superseded', finished_at_ms = ?
+                    WHERE attempt_id = ? AND terminal_state = 'running'
+                    """,
+                    (now_ms, str(row[4])),
+                )
+            conn.execute(
+                """
+                INSERT INTO embedding_derivation_state (
+                    session_id, desired_source_identity, desired_recipe_identity,
+                    desired_output_contract, generation, active_attempt_id, state,
+                    materialized_source_identity, materialized_recipe_identity,
+                    materialized_output_contract, updated_at_ms, error_message
+                ) VALUES (?, ?, ?, ?, ?, NULL, 'pending', NULL, NULL, NULL, ?, NULL)
+                ON CONFLICT(session_id) DO UPDATE SET
+                    desired_source_identity = excluded.desired_source_identity,
+                    desired_recipe_identity = excluded.desired_recipe_identity,
+                    desired_output_contract = excluded.desired_output_contract,
+                    generation = excluded.generation,
+                    active_attempt_id = NULL,
+                    state = 'pending',
+                    updated_at_ms = excluded.updated_at_ms,
+                    error_message = NULL
+                """,
+                (
+                    session_id,
+                    key.source_identity,
+                    key.recipe_identity,
+                    key.output_contract,
+                    generation,
+                    now_ms,
+                ),
+            )
+            if _table_exists(conn, "embedding_status"):
+                conn.execute(
+                    "UPDATE embedding_status SET needs_reindex = 1, error_message = NULL WHERE session_id = ?",
+                    (session_id,),
+                )
+        _finish_transaction(conn, started)
+        return generation
+    except Exception:
+        _finish_transaction(conn, started, error=True)
+        raise
+
+
+def begin_embedding_derivation_attempt(
+    conn: sqlite3.Connection,
+    key: DerivationKey,
+    *,
+    occurred_at_ms: int | None = None,
+) -> DerivationAttempt:
+    """Capture one desired key/generation before provider computation."""
+
+    ensure_embedding_derivation_tables(conn)
+    now_ms = _now_ms(occurred_at_ms)
+    session_id = key.subject.removeprefix("archive-session:")
+    attempt_id = f"embedding-attempt:{uuid.uuid4()}"
+    started = _begin_transaction_if_needed(conn)
+    try:
+        row = conn.execute(
+            "SELECT generation, active_attempt_id FROM embedding_derivation_state WHERE session_id = ?",
+            (session_id,),
+        ).fetchone()
+        generation = (int(row[0]) if row is not None else 0) + 1
+        if row is not None and row[1] is not None:
+            conn.execute(
+                """
+                UPDATE embedding_derivation_attempts
+                SET terminal_state = 'superseded', finished_at_ms = ?
+                WHERE attempt_id = ? AND terminal_state = 'running'
+                """,
+                (now_ms, str(row[1])),
+            )
+        conn.execute(
+            """
+            INSERT INTO embedding_derivation_state (
+                session_id, desired_source_identity, desired_recipe_identity,
+                desired_output_contract, generation, active_attempt_id, state,
+                materialized_source_identity, materialized_recipe_identity,
+                materialized_output_contract, updated_at_ms, error_message
+            ) VALUES (?, ?, ?, ?, ?, ?, 'pending', NULL, NULL, NULL, ?, NULL)
+            ON CONFLICT(session_id) DO UPDATE SET
+                desired_source_identity = excluded.desired_source_identity,
+                desired_recipe_identity = excluded.desired_recipe_identity,
+                desired_output_contract = excluded.desired_output_contract,
+                generation = excluded.generation,
+                active_attempt_id = excluded.active_attempt_id,
+                state = 'pending',
+                updated_at_ms = excluded.updated_at_ms,
+                error_message = NULL
+            """,
+            (
+                session_id,
+                key.source_identity,
+                key.recipe_identity,
+                key.output_contract,
+                generation,
+                attempt_id,
+                now_ms,
+            ),
+        )
+        conn.execute(
+            """
+            INSERT INTO embedding_derivation_attempts (
+                attempt_id, session_id, generation, source_identity, recipe_identity,
+                output_contract, started_at_ms, terminal_state
+            ) VALUES (?, ?, ?, ?, ?, ?, ?, 'running')
+            """,
+            (
+                attempt_id,
+                session_id,
+                generation,
+                key.source_identity,
+                key.recipe_identity,
+                key.output_contract,
+                now_ms,
+            ),
+        )
+        if _table_exists(conn, "embedding_status"):
+            conn.execute(
+                """
+                INSERT INTO embedding_status (
+                    session_id, origin, message_count_embedded, last_embedded_at_ms,
+                    needs_reindex, error_message
+                ) VALUES (?, '', 0, NULL, 1, NULL)
+                ON CONFLICT(session_id) DO UPDATE SET needs_reindex = 1, error_message = NULL
+                """,
+                (session_id,),
+            )
+        _finish_transaction(conn, started)
+    except Exception:
+        _finish_transaction(conn, started, error=True)
+        raise
+    return DerivationAttempt(key=key, generation=generation, attempt_id=attempt_id)
+
+
+def embedding_attempt_is_current(conn: sqlite3.Connection, attempt: DerivationAttempt) -> bool:
+    state = read_embedding_derivation_state(conn, attempt.key.subject.removeprefix("archive-session:"))
+    if state is None:
+        return False
+    return state.active_attempt_id is not None and attempt_matches_current(
+        attempt,
+        key=state.key,
+        generation=state.generation,
+        attempt_id=state.active_attempt_id,
+    )
+
+
+def finish_embedding_derivation_success(
+    conn: sqlite3.Connection,
+    attempt: DerivationAttempt,
+    *,
+    output_hash: str | None = None,
+    occurred_at_ms: int | None = None,
+) -> bool:
+    """Promote success only for the active exact key/generation."""
+
+    ensure_embedding_derivation_tables(conn)
+    now_ms = _now_ms(occurred_at_ms)
+    session_id = attempt.key.subject.removeprefix("archive-session:")
+    started = _begin_transaction_if_needed(conn)
+    try:
+        accepted = embedding_attempt_is_current(conn, attempt)
+        if accepted:
+            cursor = conn.execute(
+                """
+                UPDATE embedding_derivation_state
+                SET state = 'current', active_attempt_id = NULL,
+                    materialized_source_identity = desired_source_identity,
+                    materialized_recipe_identity = desired_recipe_identity,
+                    materialized_output_contract = desired_output_contract,
+                    updated_at_ms = ?, error_message = NULL
+                WHERE session_id = ? AND generation = ? AND active_attempt_id = ?
+                  AND desired_source_identity = ? AND desired_recipe_identity = ?
+                  AND desired_output_contract = ?
+                """,
+                (
+                    now_ms,
+                    session_id,
+                    attempt.generation,
+                    attempt.attempt_id,
+                    attempt.key.source_identity,
+                    attempt.key.recipe_identity,
+                    attempt.key.output_contract,
+                ),
+            )
+            accepted = cursor.rowcount == 1
+        conn.execute(
+            """
+            UPDATE embedding_derivation_attempts
+            SET terminal_state = ?, finished_at_ms = ?, output_hash = ?
+            WHERE attempt_id = ?
+            """,
+            ("succeeded" if accepted else "superseded", now_ms, output_hash, attempt.attempt_id),
+        )
+        _finish_transaction(conn, started)
+        return accepted
+    except Exception:
+        _finish_transaction(conn, started, error=True)
+        raise
+
+
+def finish_embedding_derivation_failure(
+    conn: sqlite3.Connection,
+    attempt: DerivationAttempt,
+    *,
+    retryable: bool,
+    error_message: str,
+    occurred_at_ms: int | None = None,
+) -> bool:
+    """Apply an error only to its active exact key/generation."""
+
+    ensure_embedding_derivation_tables(conn)
+    now_ms = _now_ms(occurred_at_ms)
+    session_id = attempt.key.subject.removeprefix("archive-session:")
+    started = _begin_transaction_if_needed(conn)
+    try:
+        accepted = embedding_attempt_is_current(conn, attempt)
+        if accepted:
+            cursor = conn.execute(
+                """
+                UPDATE embedding_derivation_state
+                SET state = ?, active_attempt_id = NULL, updated_at_ms = ?, error_message = ?
+                WHERE session_id = ? AND generation = ? AND active_attempt_id = ?
+                  AND desired_source_identity = ? AND desired_recipe_identity = ?
+                  AND desired_output_contract = ?
+                """,
+                (
+                    "pending" if retryable else "degraded",
+                    now_ms,
+                    error_message,
+                    session_id,
+                    attempt.generation,
+                    attempt.attempt_id,
+                    attempt.key.source_identity,
+                    attempt.key.recipe_identity,
+                    attempt.key.output_contract,
+                ),
+            )
+            accepted = cursor.rowcount == 1
+        conn.execute(
+            """
+            UPDATE embedding_derivation_attempts
+            SET terminal_state = ?, finished_at_ms = ?, error_message = ?
+            WHERE attempt_id = ?
+            """,
+            (
+                ("retryable_error" if retryable else "terminal_error") if accepted else "superseded",
+                now_ms,
+                error_message,
+                attempt.attempt_id,
+            ),
+        )
+        _finish_transaction(conn, started)
+        return accepted
+    except Exception:
+        _finish_transaction(conn, started, error=True)
+        raise
+
+
+def _table_exists(conn: sqlite3.Connection, table: str) -> bool:
+    row = conn.execute(
+        "SELECT 1 FROM sqlite_master WHERE type='table' AND name=? LIMIT 1",
+        (table,),
+    ).fetchone()
+    return row is not None
+
+
+__all__ = [
+    "EMBEDDING_INPUT_TYPE",
+    "EMBEDDING_NORMALIZATION",
+    "EMBEDDING_PROVIDER",
+    "EmbeddingDerivationState",
+    "archive_embedding_derivation_key",
+    "archive_embedding_source_identity",
+    "begin_embedding_derivation_attempt",
+    "embedding_attempt_is_current",
+    "embedding_output_contract",
+    "embedding_recipe_components",
+    "embedding_recipe_identity",
+    "ensure_embedding_derivation_tables",
+    "finish_embedding_derivation_failure",
+    "finish_embedding_derivation_success",
+    "read_embedding_derivation_state",
+    "set_embedding_desired_key",
