+"""Production-route witnesses for monotonic derived freshness.
+
+The expected relations in this module are computed independently of the
+production ledgers.  Each test names the mutation it is intended to kill:
+removing an FTS trigger/identity comparison, omitting one recipe field, or
+allowing a superseded embedding attempt to perform a terminal write.
+"""
+
+from __future__ import annotations
+
+import sqlite3
+
+from polylogue.config import load_polylogue_config
+from polylogue.storage.derivation_identity import canonical_identity
+from polylogue.storage.embeddings.freshness import (
+    archive_embedding_derivation_key,
+    begin_embedding_derivation_attempt,
+    embedding_recipe_components,
+    finish_embedding_derivation_failure,
+    finish_embedding_derivation_success,
+    read_embedding_derivation_state,
+)
+from polylogue.storage.embeddings.materialization import (
+    _record_archive_embedding_success,
+    select_pending_archive_session_window,
+)
+from polylogue.storage.fts.freshness import record_fts_invariant_snapshot_sync
+from polylogue.storage.fts.fts_lifecycle import (
+    ensure_fts_index_sync,
+    fts_invariant_snapshot_sync,
+    message_fts_search_readiness_sync,
+    message_fts_triggers_current_sync,
+    repair_message_fts_index_sync,
+    restore_message_fts_triggers_sync,
+)
+from polylogue.storage.fts.sql import FTS_OUTPUT_CONTRACT, FTS_RECIPE_ID
+from polylogue.storage.insights.session.provider_usage_freshness import (
+    PROVIDER_USAGE_FRESHNESS_TRIGGER_DDL,
+    PROVIDER_USAGE_OUTPUT_CONTRACT,
+    provider_usage_derivation_key,
+    provider_usage_receipt_current,
+    provider_usage_recipe_components,
+)
+from polylogue.storage.sqlite.archive_tiers.embedding_write import record_embedding_failure
+
+
+def _fts_connection() -> sqlite3.Connection:
+    conn = sqlite3.connect(":memory:")
+    conn.row_factory = sqlite3.Row
+    conn.create_function("pl_fold", 1, lambda value: value)
+    conn.executescript(
+        """
+        CREATE TABLE blocks (
+            block_id TEXT NOT NULL UNIQUE,
+            message_id TEXT NOT NULL,
+            session_id TEXT NOT NULL,
+            block_type TEXT NOT NULL,
+            search_text TEXT NOT NULL,
+            content_hash BLOB
+        );
+        """
+    )
+    ensure_fts_index_sync(conn)
+    return conn
+
+
+def _assert_expected_fts_relation(conn: sqlite3.Connection) -> None:
+    desired = {
+        int(row["rowid"]): (
+            str(row["block_id"]),
+            bytes(row["content_hash"]),
+            FTS_RECIPE_ID,
+            FTS_OUTPUT_CONTRACT,
+        )
+        for row in conn.execute("SELECT rowid, block_id, content_hash FROM blocks WHERE search_text != ''")
+    }
+    observed = {
+        int(row["rowid"]): (
+            str(row["block_id"]),
+            bytes(row["source_hash"]),
+            str(row["recipe_id"]),
+            str(row["output_contract"]),
+        )
+        for row in conn.execute(
+            """
+            SELECT rowid, block_id, source_hash, recipe_id, output_contract
+            FROM messages_fts_identity
+            """
+        )
+    }
+    docsize = {int(row[0]) for row in conn.execute("SELECT id FROM messages_fts_docsize")}
+    assert observed == desired
+    assert docsize == set(desired)
+    assert fts_invariant_snapshot_sync(conn).messages.ready
+
+
+def test_real_fts_triggers_follow_independent_relation_across_arrival_orders() -> None:
+    """Removing any INSERT/UPDATE/DELETE identity arm makes this fail."""
+
+    conn = _fts_connection()
+    try:
+        conn.execute(
+            "INSERT INTO blocks VALUES (?, ?, ?, ?, ?, ?)",
+            ("b-empty", "m-empty", "s", "text", "", b"e" * 32),
+        )
+        _assert_expected_fts_relation(conn)
+
+        conn.execute(
+            "INSERT INTO blocks VALUES (?, ?, ?, ?, ?, ?)",
+            ("b-one", "m-one", "s", "text", "first searchable text", b"a" * 32),
+        )
+        _assert_expected_fts_relation(conn)
+
+        conn.execute(
+            "UPDATE blocks SET search_text = ?, content_hash = ? WHERE block_id = ?",
+            ("now searchable", b"b" * 32, "b-empty"),
+        )
+        _assert_expected_fts_relation(conn)
+
+        conn.execute(
+            "UPDATE blocks SET search_text = '', content_hash = ? WHERE block_id = ?",
+            (b"c" * 32, "b-one"),
+        )
+        _assert_expected_fts_relation(conn)
+
+        conn.execute("DELETE FROM blocks WHERE block_id = ?", ("b-empty",))
+        _assert_expected_fts_relation(conn)
+    finally:
+        conn.close()
+
