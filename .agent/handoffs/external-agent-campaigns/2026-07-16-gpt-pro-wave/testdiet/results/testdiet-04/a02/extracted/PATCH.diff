+def _embedding_connection(*, production_write_tables: bool = False) -> sqlite3.Connection:
+    conn = sqlite3.connect(":memory:")
+    conn.executescript(
+        """
+        CREATE TABLE embedding_status (
+            session_id TEXT PRIMARY KEY,
+            origin TEXT NOT NULL DEFAULT '',
+            message_count_embedded INTEGER NOT NULL DEFAULT 0,
+            last_embedded_at_ms INTEGER,
+            needs_reindex INTEGER NOT NULL DEFAULT 0,
+            error_message TEXT
+        );
+        """
+    )
+    if production_write_tables:
+        conn.executescript(
+            """
+            CREATE TABLE message_embeddings (
+                message_id TEXT PRIMARY KEY, session_id TEXT, origin TEXT, embedding BLOB
+            );
+            CREATE TABLE message_embeddings_meta (
+                message_id TEXT PRIMARY KEY, model TEXT, dimension INTEGER,
+                content_hash BLOB, embedded_at_ms INTEGER, needs_reindex INTEGER
+            );
+            CREATE TABLE embedding_failures (
+                failure_id TEXT PRIMARY KEY, session_id TEXT, origin TEXT,
+                message_refs_json TEXT, provider TEXT, model TEXT, error_class TEXT,
+                error_message TEXT, retryable INTEGER, lifecycle_state TEXT,
+                created_at_ms INTEGER, updated_at_ms INTEGER, resolved_at_ms INTEGER,
+                resolution_action TEXT, resolution_note TEXT, superseded_by TEXT
+            );
+            """
+        )
+    return conn
