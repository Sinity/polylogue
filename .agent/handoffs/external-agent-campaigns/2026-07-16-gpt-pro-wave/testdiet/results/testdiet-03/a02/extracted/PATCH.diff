+)
+_PROFILE_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:session_profiles@materializer-v"
+    f"{SESSION_INSIGHT_MATERIALIZER_VERSION}(session_id,materializer_version,"
+    "input_high_water_mark_source,input_row_count,source_name,message_count,"
