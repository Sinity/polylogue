+)
+
+_SOURCE_PATHS = {
+    DEMO_GEMINI_SESSION_ID: Path("gemini/demo-00.json"),
+    DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID: Path("claude-ai/temporary-demo.json"),
+    DEMO_CODEX_LINEAGE_PARENT_SESSION_ID: Path("codex/lineage-parent.jsonl"),
+    DEMO_CODEX_LINEAGE_FORK_SESSION_ID: Path("codex/lineage-fork.jsonl"),
+    DEMO_CODEX_LINEAGE_SUBAGENT_SESSION_ID: Path("codex/lineage-subagent.jsonl"),
+    DEMO_CODEX_TERMINAL_ERROR_SESSION_ID: Path("codex/terminal-error.jsonl"),
+}
+
+_UPDATE_NATIVE_ID = "testdiet-equivalence-update-0001"
+_UPDATE_MESSAGE_ID = f"{DEMO_CODEX_TERMINAL_ERROR_SESSION_ID}:{_UPDATE_NATIVE_ID}"
+_UPDATE_BLOCK_ID = f"{_UPDATE_MESSAGE_ID}:0"
+_UPDATE_TEXT = "rebuild equivalence sentinel preserves terminal evidence"
