+def test_overlay_state_does_not_change_rebuild_identity(tmp_path: Path, monkeypatch: pytest.MonkeyPatch) -> None:
+    """User-tier state changes neither source/content nor workload identity."""
+    archive_root = tmp_path / "archive"
+    monkeypatch.setenv("POLYLOGUE_ARCHIVE_ROOT", str(archive_root))
+    monkeypatch.setenv("POLYLOGUE_RENDER_ROOT", str(archive_root / "render"))
+    monkeypatch.setenv("POLYLOGUE_INGEST_PARSE_WORKERS", "1")
+    monkeypatch.setenv("POLYLOGUE_SCHEMA_VALIDATION", "off")
+
+    asyncio.run(seed_demo_archive(archive_root, force=True, with_overlays=False))
+    repo_root = Path(__file__).resolve().parents[3]
+    recipe_identity = _recipe_identity(repo_root)
+    source_identity_before = source_revision_snapshot(archive_root)
+    content_identity_before = _content_identity(archive_root)
+    workload_before = _workload_spec(source_identity_before, recipe_identity)
+
+    _insert_overlay(archive_root)
+
+    source_identity_after = source_revision_snapshot(archive_root)
+    content_identity_after = _content_identity(archive_root)
+    workload_after = _workload_spec(source_identity_after, recipe_identity)
+    assert source_identity_after == source_identity_before
+    assert content_identity_after == content_identity_before
+    assert workload_after.spec_id == workload_before.spec_id
+    assert any(row[0] == _OVERLAY_ASSERTION_ID for row in _overlay_snapshot(archive_root))
