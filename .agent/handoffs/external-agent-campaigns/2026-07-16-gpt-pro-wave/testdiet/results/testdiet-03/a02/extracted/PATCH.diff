+    "message_id,session_id,native_id,parent_message_id,position,role,message_type,"
+    "material_origin,variant_index,is_active_path,is_active_leaf,content_hash)"
+)
+_BLOCK_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:blocks("
+    "block_id,message_id,session_id,position,block_type,text,tool_name,tool_id,"
+    "tool_result_is_error,tool_result_exit_code,search_text,content_hash)"
+)
+_ATTACHMENT_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:attachments+attachment_refs("
+    "attachment_id,display_name,media_type,byte_count,blob_hash,acquisition_status,"
