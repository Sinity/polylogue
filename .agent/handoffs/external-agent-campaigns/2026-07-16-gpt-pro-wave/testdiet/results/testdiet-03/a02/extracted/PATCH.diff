+def test_incremental_and_rebuild_public_facts_match(
+    tmp_path: Path,
+    monkeypatch: pytest.MonkeyPatch,
+    cli_runner: CliRunner,
+) -> None:
+    """One planted workload converges through incremental and fresh routes.
+
+    Production dependencies exercised: ``parse_sources_archive`` for update and
+    idempotent reprocess, scoped ``repair_message_fts_index_sync``, scoped
+    ``repair_session_insights`` after a connection restart, and the real
+    ``maintenance rebuild-index`` blue/green generation command.
+
+    Anti-vacuity mutations this test kills include removing the rebuild command's
+    ``repair_session_insights`` stage, skipping the scoped FTS repair, retaining
+    stale terminal materialization rows, or suffixing the one-document Gemini
+    replay identity as ``demo-00-0``.  Row counts can remain plausible under
+    those mutations; the exact derivation-key projections cannot.
+    """
+    archive_root = tmp_path / "archive"
+    monkeypatch.setenv("POLYLOGUE_ARCHIVE_ROOT", str(archive_root))
+    monkeypatch.setenv("POLYLOGUE_RENDER_ROOT", str(archive_root / "render"))
+    monkeypatch.setenv("POLYLOGUE_INGEST_PARSE_WORKERS", "1")
+    monkeypatch.setenv("POLYLOGUE_SCHEMA_VALIDATION", "off")
+
+    seed = asyncio.run(seed_demo_archive(archive_root, force=True, with_overlays=True))
+    update_path = seed.source_root / _SOURCE_PATHS[DEMO_CODEX_TERMINAL_ERROR_SESSION_ID]
+    _append_incremental_update(update_path)
+
+    with _pushd(seed.source_root):
+        update_source = Source(name="codex", path=_SOURCE_PATHS[DEMO_CODEX_TERMINAL_ERROR_SESSION_ID])
+        first_update = asyncio.run(parse_sources_archive(archive_root, [update_source]))
+        rows_after_update = _source_row_count(archive_root)
+        repeated_update = asyncio.run(parse_sources_archive(archive_root, [update_source]))
+        rows_after_repeat = _source_row_count(archive_root)
+
+    assert first_update.processed_ids == {DEMO_CODEX_TERMINAL_ERROR_SESSION_ID}
+    assert repeated_update.processed_ids == set()
+    assert rows_after_repeat == rows_after_update
+
+    identity_before_overlay = _content_identity(archive_root)
+    source_snapshot_before_overlay = source_revision_snapshot(archive_root)
+    _insert_overlay(archive_root)
+    identity_after_overlay = _content_identity(archive_root)
+    assert identity_after_overlay == identity_before_overlay
