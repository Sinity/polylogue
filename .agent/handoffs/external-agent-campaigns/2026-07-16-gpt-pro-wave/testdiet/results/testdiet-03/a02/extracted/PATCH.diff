+    f"{SESSION_INSIGHT_MATERIALIZER_VERSION}(insight_type,session_id,"
+    "materializer_version,input_high_water_mark_source,input_row_count)"
+)
+_THREAD_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:threads+thread_sessions@materializer-v"
+    f"{SESSION_INSIGHT_MATERIALIZER_VERSION}(thread_id,materializer_version,"
+    "input_high_water_mark_source,input_row_count,session_ids_json,session_count,"
+    "depth,branch_count,total_messages,work_event_breakdown_json)"
+)
+_ABSENCE_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:absence-unknown("
+    "attachment.display_name,attachment.source_url,attachment.caption,"
+    "session_profile.terminal_state,session_profile.terminal_state_method)"
+)
+
+_MATERIALIZATION_TYPES = (
+    "context_snapshots",
+    "latency",
+    "observed_events",
+    "phases",
+    "provider_usage",
+    "runs",
+    "session_profile",
+    "thread",
+    "work_events",
+)
+
+
+@dataclass(frozen=True, order=True, slots=True)
+class DerivationKey:
+    """Test-local exact identity for one compared derived fact."""
+
+    subject: str
+    source_identity: str
+    recipe_identity: str
+    output_contract: str
+
+
+@dataclass(frozen=True, slots=True)
+class SourceIdentity:
+    raw_id: str
+    origin: str
+    native_id: str | None
+    source_path: str
+    source_index: int
+    blob_sha256: str
+    blob_size: int
+
+    @property
+    def canonical(self) -> str:
+        return json.dumps(
+            {
+                "raw_id": self.raw_id,
+                "origin": self.origin,
+                "native_id": self.native_id,
+                "source_path": self.source_path,
+                "source_index": self.source_index,
+                "blob_sha256": self.blob_sha256,
+                "blob_size": self.blob_size,
+            },
+            sort_keys=True,
+            separators=(",", ":"),
+        )
+
+
+@dataclass(frozen=True, slots=True)
+class RouteSnapshot:
+    source_snapshot: str
+    generation_id: str
+    recipe_identity: str
+    source_identities: Mapping[str, SourceIdentity]
+    facts: Mapping[DerivationKey, tuple[tuple[Any, ...], ...]]
+
+
+@contextlib.contextmanager
+def _pushd(path: Path) -> Iterator[None]:
+    previous = Path.cwd()
+    os.chdir(path)
+    try:
+        yield
+    finally:
+        os.chdir(previous)
+
+
+def _normalized(value: Any) -> Any:
+    return value.hex() if isinstance(value, bytes) else value
+
+
+def _rows(
+    conn: sqlite3.Connection,
+    sql: str,
+    params: Sequence[object] = (),
+) -> tuple[tuple[Any, ...], ...]:
+    return tuple(tuple(_normalized(value) for value in row) for row in conn.execute(sql, params))
+
+
+def _recipe_identity(repo_root: Path) -> str:
+    """Hash the exact production recipe files and versioned output schemas."""
+    recipe_files = (
+        "polylogue/sources/dispatch.py",
+        "polylogue/pipeline/services/archive_ingest.py",
+        "polylogue/maintenance/replay.py",
+        "polylogue/storage/fts/fts_lifecycle.py",
+        "polylogue/storage/insights/session/rebuild.py",
+        "polylogue/cli/commands/maintenance/_rebuild_index.py",
+    )
+    digest = hashlib.sha256()
+    for relative in recipe_files:
+        digest.update(relative.encode())
+        digest.update(b"\0")
+        digest.update((repo_root / relative).read_bytes())
+        digest.update(b"\0")
+    digest.update(
+        (
+            f"source-v{SOURCE_SCHEMA_VERSION}|index-v{INDEX_SCHEMA_VERSION}|"
+            f"session-insight-v{SESSION_INSIGHT_MATERIALIZER_VERSION}"
+        ).encode()
+    )
+    return f"sha256:{digest.hexdigest()}"
+
+
+def _bundle_source_identity(source_identities: Mapping[str, SourceIdentity], session_ids: Sequence[str]) -> str:
+    return json.dumps(
+        [source_identities[session_id].canonical for session_id in session_ids],
+        separators=(",", ":"),
+    )
+
+
+def _project_route(archive_root: Path, *, generation_id: str, recipe_identity: str) -> RouteSnapshot:
+    placeholders = ",".join("?" for _ in _SELECTED_SESSION_IDS)
+    index_db = archive_root / "index.db"
+    source_db = archive_root / "source.db"
+
+    with sqlite3.connect(index_db) as conn:
+        session_raw_rows = _rows(
+            conn,
+            f"""
+            SELECT session_id, raw_id
+            FROM sessions
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        sessions = _rows(
+            conn,
+            f"""
+            SELECT session_id, native_id, origin, parent_session_id, root_session_id,
+                   branch_type, active_leaf_message_id, session_kind, message_count
+            FROM sessions
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        messages = _rows(
+            conn,
+            f"""
+            SELECT message_id, session_id, native_id, parent_message_id, position,
+                   role, message_type, material_origin, variant_index,
+                   is_active_path, is_active_leaf, content_hash
+            FROM messages
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id, position, message_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        blocks = _rows(
+            conn,
+            f"""
+            SELECT block_id, message_id, session_id, position, block_type, text,
+                   tool_name, tool_id, tool_result_is_error, tool_result_exit_code,
+                   search_text, content_hash
+            FROM blocks
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id, message_id, position, block_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        attachments = _rows(
+            conn,
+            """
+            SELECT a.attachment_id, a.display_name, a.media_type, a.byte_count,
+                   a.blob_hash, a.acquisition_status, r.session_id, r.message_id,
+                   r.position, r.upload_origin, r.source_url, r.caption
+            FROM attachments AS a
+            JOIN attachment_refs AS r USING (attachment_id)
+            WHERE r.session_id = ?
+            ORDER BY r.message_id, r.position
+            """,
+            (DEMO_GEMINI_SESSION_ID,),
+        )
+        links = _rows(
+            conn,
+            f"""
+            SELECT src_session_id, dst_origin, dst_native_id, link_type,
+                   resolved_dst_session_id, branch_point_message_id, inheritance,
+                   status, method, confidence
+            FROM session_links
+            WHERE src_session_id IN ({placeholders})
+            ORDER BY src_session_id, link_type
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        search = _rows(
+            conn,
+            """
+            SELECT b.block_id, b.message_id, b.session_id, b.position, b.block_type,
+                   b.search_text, b.content_hash
+            FROM messages_fts AS f
+            JOIN blocks AS b ON b.rowid = f.rowid
+            WHERE messages_fts MATCH 'rebuild equivalence sentinel'
+            ORDER BY b.block_id
+            """,
+        )
+        profiles = _rows(
+            conn,
+            f"""
+            SELECT session_id, materializer_version, input_high_water_mark_source,
+                   input_row_count, source_name, message_count, attachment_count,
+                   work_event_count, phase_count, tool_use_count, workflow_shape,
+                   terminal_state, terminal_state_method, terminal_state_confidence,
+                   total_input_tokens, total_output_tokens
+            FROM session_profiles
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        materialization = _rows(
+            conn,
+            f"""
+            SELECT insight_type, session_id, materializer_version,
+                   input_high_water_mark_source, input_row_count
+            FROM insight_materialization
+            WHERE session_id IN ({placeholders})
+            ORDER BY session_id, insight_type
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+        threads = _rows(
+            conn,
+            f"""
+            SELECT DISTINCT t.thread_id, t.materializer_version,
+                   t.input_high_water_mark_source, t.input_row_count,
+                   t.session_ids_json, t.session_count, t.depth, t.branch_count,
+                   t.total_messages, t.work_event_breakdown_json
+            FROM threads AS t
+            JOIN thread_sessions AS ts ON ts.thread_id = t.thread_id
+            WHERE ts.session_id IN ({placeholders})
+            ORDER BY t.thread_id
+            """,
+            _SELECTED_SESSION_IDS,
+        )
+
+    raw_ids = dict(session_raw_rows)
+    assert set(raw_ids) == set(_SELECTED_SESSION_IDS)
+    source_identities: dict[str, SourceIdentity] = {}
+    with sqlite3.connect(source_db) as conn:
+        for session_id, raw_id in raw_ids.items():
+            row = conn.execute(
+                """
+                SELECT raw_id, origin, native_id, source_path, source_index,
+                       blob_hash, blob_size
+                FROM raw_sessions
+                WHERE raw_id = ?
+                """,
+                (raw_id,),
+            ).fetchone()
+            assert row is not None
+            source_identities[session_id] = SourceIdentity(
+                raw_id=str(row[0]),
+                origin=str(row[1]),
+                native_id=None if row[2] is None else str(row[2]),
+                source_path=str(row[3]),
+                source_index=int(row[4]),
+                blob_sha256=bytes(row[5]).hex(),
+                blob_size=int(row[6]),
+            )
+
+    session_rows = {str(row[0]): (row,) for row in sessions}
+    message_rows = {
+        session_id: tuple(row for row in messages if row[1] == session_id) for session_id in _SELECTED_SESSION_IDS
+    }
+    block_rows = {
+        session_id: tuple(row for row in blocks if row[2] == session_id) for session_id in _SELECTED_SESSION_IDS
+    }
+    profile_rows = {str(row[0]): (row,) for row in profiles}
+    materialization_rows = {
+        session_id: tuple(row for row in materialization if row[1] == session_id)
+        for session_id in _SELECTED_SESSION_IDS
+    }
+
+    facts: dict[DerivationKey, tuple[tuple[Any, ...], ...]] = {}
+    for session_id in _SELECTED_SESSION_IDS:
+        source_identity = source_identities[session_id].canonical
+        for contract, value in (
+            (_SESSION_CONTRACT, session_rows[session_id]),
+            (_MESSAGE_CONTRACT, message_rows[session_id]),
+            (_BLOCK_CONTRACT, block_rows[session_id]),
+            (_PROFILE_CONTRACT, profile_rows[session_id]),
+            (_MATERIALIZATION_CONTRACT, materialization_rows[session_id]),
+        ):
+            facts[DerivationKey(session_id, source_identity, recipe_identity, contract)] = value
+
+    facts[
+        DerivationKey(
+            DEMO_GEMINI_SESSION_ID,
+            source_identities[DEMO_GEMINI_SESSION_ID].canonical,
+            recipe_identity,
+            _ATTACHMENT_CONTRACT,
+        )
+    ] = attachments
+
+    for session_id in (DEMO_CODEX_LINEAGE_FORK_SESSION_ID, DEMO_CODEX_LINEAGE_SUBAGENT_SESSION_ID):
+        facts[
+            DerivationKey(
+                session_id,
+                source_identities[session_id].canonical,
+                recipe_identity,
+                _LINEAGE_CONTRACT,
+            )
+        ] = tuple(row for row in links if row[0] == session_id)
+
+    facts[
+        DerivationKey(
+            DEMO_CODEX_TERMINAL_ERROR_SESSION_ID,
+            source_identities[DEMO_CODEX_TERMINAL_ERROR_SESSION_ID].canonical,
+            recipe_identity,
+            _SEARCH_CONTRACT,
+        )
+    ] = search
+
+    thread_members = {
+        DEMO_GEMINI_SESSION_ID: (DEMO_GEMINI_SESSION_ID,),
+        DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID: (DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID,),
+        DEMO_CODEX_LINEAGE_PARENT_SESSION_ID: (
+            DEMO_CODEX_LINEAGE_PARENT_SESSION_ID,
+            DEMO_CODEX_LINEAGE_SUBAGENT_SESSION_ID,
+            DEMO_CODEX_LINEAGE_FORK_SESSION_ID,
+        ),
+        DEMO_CODEX_TERMINAL_ERROR_SESSION_ID: (DEMO_CODEX_TERMINAL_ERROR_SESSION_ID,),
+    }
+    for thread in threads:
+        thread_id = str(thread[0])
+        facts[
+            DerivationKey(
+                thread_id,
+                _bundle_source_identity(source_identities, thread_members[thread_id]),
+                recipe_identity,
+                _THREAD_CONTRACT,
+            )
+        ] = (thread,)
+
+    gemini_profile = profile_rows[DEMO_GEMINI_SESSION_ID][0]
+    temporary_profile = profile_rows[DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID][0]
+    attachment = attachments[0] if attachments else (None,) * 12
+    facts[
+        DerivationKey(
+            DEMO_GEMINI_SESSION_ID,
+            source_identities[DEMO_GEMINI_SESSION_ID].canonical,
+            recipe_identity,
+            _ABSENCE_CONTRACT,
+        )
+    ] = ((attachment[1], attachment[10], attachment[11], gemini_profile[11], gemini_profile[12]),)
+    facts[
+        DerivationKey(
+            DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID,
+            source_identities[DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID].canonical,
+            recipe_identity,
+            _ABSENCE_CONTRACT,
+        )
+    ] = ((None, None, None, temporary_profile[11], temporary_profile[12]),)
+
+    return RouteSnapshot(
+        source_snapshot=source_revision_snapshot(archive_root),
+        generation_id=generation_id,
+        recipe_identity=recipe_identity,
+        source_identities=source_identities,
+        facts=facts,
+    )
+
+
+def _fact(snapshot: RouteSnapshot, subject: str, contract: str) -> tuple[tuple[Any, ...], ...]:
+    matches = [
+        value for key, value in snapshot.facts.items() if key.subject == subject and key.output_contract == contract
+    ]
+    assert len(matches) == 1
+    return matches[0]
+
+
+def _assert_planted_invariants(snapshot: RouteSnapshot, source_root: Path) -> None:
+    """Assert source-authored facts, never facts copied from the other route."""
+    expected_sessions = {
+        DEMO_GEMINI_SESSION_ID: (
+            DEMO_GEMINI_SESSION_ID,
+            "demo-00",
+            "aistudio-drive",
+            None,
+            DEMO_GEMINI_SESSION_ID,
+            None,
+            f"{DEMO_GEMINI_SESSION_ID}:chunk-4",
+            "standard",
+            4,
+        ),
+        DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID: (
+            DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID,
+            "demo-temporary-claude-ai",
+            "claude-ai-export",
+            None,
+            DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID,
+            None,
+            f"{DEMO_CLAUDE_AI_TEMPORARY_SESSION_ID}:temporary-a1",
+            "temporary",
+            2,
+        ),
+        DEMO_CODEX_LINEAGE_PARENT_SESSION_ID: (
+            DEMO_CODEX_LINEAGE_PARENT_SESSION_ID,
+            "demo-lineage-parent",
