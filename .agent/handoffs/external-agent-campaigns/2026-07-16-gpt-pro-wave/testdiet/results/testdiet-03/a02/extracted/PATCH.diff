+
+_SESSION_CONTRACT = (
+    f"index-v{INDEX_SCHEMA_VERSION}:sessions("
+    "session_id,native_id,origin,parent_session_id,root_session_id,branch_type,"
+    "active_leaf_message_id,session_kind,message_count)"
+)
+_MESSAGE_CONTRACT = (
