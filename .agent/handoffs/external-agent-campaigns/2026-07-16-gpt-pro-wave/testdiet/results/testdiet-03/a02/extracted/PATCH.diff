+def _append_incremental_update(path: Path) -> None:
+    records = [json.loads(line) for line in path.read_text(encoding="utf-8").splitlines()]
+    records.append(
+        {
+            "type": "response_item",
+            "payload": {
+                "type": "message",
+                "id": _UPDATE_NATIVE_ID,
+                "role": "assistant",
+                "timestamp": "2026-07-04T10:05:05Z",
+                "content": [{"type": "output_text", "text": _UPDATE_TEXT}],
+            },
+        }
+    )
+    path.write_text(
+        "\n".join(json.dumps(record, sort_keys=True) for record in records) + "\n",
+        encoding="utf-8",
+    )
+
+
+def _source_row_count(archive_root: Path) -> int:
+    with sqlite3.connect(archive_root / "source.db") as conn:
+        row = conn.execute("SELECT COUNT(*) FROM raw_sessions").fetchone()
+    assert row is not None
+    return int(row[0])
+
+
+def _overlay_snapshot(archive_root: Path) -> tuple[tuple[Any, ...], ...]:
+    with sqlite3.connect(archive_root / "user.db") as conn:
+        return _rows(conn, "SELECT * FROM assertions ORDER BY assertion_id")
+
+
+def _content_identity(archive_root: Path) -> tuple[tuple[Any, ...], ...]:
+    placeholders = ",".join("?" for _ in _SELECTED_SESSION_IDS)
+    with sqlite3.connect(archive_root / "source.db") as conn:
+        source_rows = _rows(
+            conn,
+            """
+            SELECT raw_id, origin, native_id, source_path, source_index, blob_hash, blob_size
+            FROM raw_sessions
+            ORDER BY raw_id
+            """,
+        )
+    with sqlite3.connect(archive_root / "index.db") as conn:
+        index_rows = _rows(
+            conn,
+            f"""
+            SELECT 'session', session_id, raw_id, NULL
+            FROM sessions
+            WHERE session_id IN ({placeholders})
+            UNION ALL
+            SELECT 'message', message_id, session_id, content_hash
+            FROM messages
+            WHERE session_id IN ({placeholders})
+            UNION ALL
+            SELECT 'block', block_id, session_id, content_hash
+            FROM blocks
+            WHERE session_id IN ({placeholders})
+            ORDER BY 1, 2
+            """,
+            (*_SELECTED_SESSION_IDS, *_SELECTED_SESSION_IDS, *_SELECTED_SESSION_IDS),
+        )
+    return source_rows + index_rows
+
+
+def _insert_overlay(archive_root: Path) -> None:
+    with sqlite3.connect(archive_root / "user.db") as conn:
+        upsert_assertion(
+            conn,
