@@ -0,0 +1,165 @@
+"""Terminal continuity composition and mutation curriculum."""
+
+from __future__ import annotations
+
+import json
+import shutil
+from collections.abc import Callable
+from pathlib import Path
+
+import pytest
+
+from devtools.continuity_terminal import (
+    TerminalContinuityError,
+    verify_selective_action_sql,
+    verify_terminal_continuity_gate,
+)
+from polylogue.core.json import JSONDocument, json_document_list, require_json_document
+from polylogue.product.continuity_scenarios import continuity_scenario
+from tests.infra.continuity import ContinuityFixtureSeed, load_continuity_catalog, seed_continuity_archive
+
+EvidenceMutation = Callable[[Path], None]
+
+
+@pytest.fixture(scope="module")
+def terminal_corpus(tmp_path_factory: pytest.TempPathFactory) -> tuple[Path, JSONDocument, ContinuityFixtureSeed]:
+    archive_root = tmp_path_factory.mktemp("terminal-continuity") / "archive"
+    catalog = load_continuity_catalog()
+    seed = seed_continuity_archive(archive_root, catalog=catalog)
+    return archive_root, catalog, seed
+
+
+def _incident_route_result() -> JSONDocument:
+    scenario = continuity_scenario("parallel-claude-incident")
+    return require_json_document(
+        {
+            "scenario": scenario.scenario_id,
+            "question": scenario.operator_question,
+            "accepted_plan_signatures": [list(signature) for signature in scenario.equivalent_plan_signatures],
+            "observed_facts": {"non_workflow_children": 38},
+        },
+        context="terminal incident route result",
+    )
+
+
+def _copy_evidence(seed: ContinuityFixtureSeed, target: Path) -> Path:
+    copied = target / "continuity-evidence"
+    shutil.copytree(seed.evidence_root, copied)
+    return copied
+
+
+def _remove_agent_metadata(evidence_root: Path) -> None:
+    next((evidence_root / "claude" / "subagents").glob("agent-*.meta.json")).unlink()
+
+
+def _drop_attempt_representation(evidence_root: Path) -> None:
+    journal = next((evidence_root / "claude" / "subagents" / "workflows").glob("*/journal.jsonl"))
+    records = [json.loads(line) for line in journal.read_text(encoding="utf-8").splitlines() if line.strip()]
+    attempt = next(record for record in records if record.get("type") == "attempt")
+    attempt.pop("metaPath")
+    journal.write_text("".join(json.dumps(record, sort_keys=True) + "\n" for record in records), encoding="utf-8")
+
+
+def _collapse_material_origin(evidence_root: Path) -> None:
+    transcript = next((evidence_root / "claude" / "subagents").glob("agent-*.jsonl"))
+    records = [json.loads(line) for line in transcript.read_text(encoding="utf-8").splitlines() if line.strip()]
+    records[0]["origin"] = {"kind": "human"}
+    transcript.write_text("".join(json.dumps(record, sort_keys=True) + "\n" for record in records), encoding="utf-8")
+
+
+def _collapse_claim_effect_identity(evidence_root: Path) -> None:
+    journal = next((evidence_root / "claude" / "subagents" / "workflows").glob("*/journal.jsonl"))
+    records = [json.loads(line) for line in journal.read_text(encoding="utf-8").splitlines() if line.strip()]
+    final = next(
+        record
+        for record in records
+        if isinstance(record.get("structuredResult"), dict) and record["structuredResult"].get("final") is True
+    )
+    claims = final["structuredResult"]["claims"]
+    pr_claim = next(claim for claim in claims if claim.get("claimId") == "pr-effect")
+    pr_claim["effectRef"] = "commit:terminal-sanitized-commit"
+    journal.write_text("".join(json.dumps(record, sort_keys=True) + "\n" for record in records), encoding="utf-8")
+
+    github_receipt = evidence_root / "effects" / "github-pr.json"
+    payload = json.loads(github_receipt.read_text(encoding="utf-8"))
+    payload["ref"] = "commit:terminal-sanitized-commit"
+    github_receipt.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+
+
+def _break_effect_reference(evidence_root: Path) -> None:
+    journal = next((evidence_root / "claude" / "subagents" / "workflows").glob("*/journal.jsonl"))
+    records = [json.loads(line) for line in journal.read_text(encoding="utf-8").splitlines() if line.strip()]
+    final = next(
+        record
+        for record in records
+        if isinstance(record.get("structuredResult"), dict) and record["structuredResult"].get("final") is True
+    )
+    claims = final["structuredResult"]["claims"]
+    git_claim = next(claim for claim in claims if claim.get("claimId") == "git-effect")
+    git_claim["effectRef"] = "commit:uncited-mutant"
+    journal.write_text("".join(json.dumps(record, sort_keys=True) + "\n" for record in records), encoding="utf-8")
+
+
+@pytest.mark.asyncio
+@pytest.mark.parametrize(
+    ("mutation", "expected_kind", "expected_class"),
+    (
+        (_remove_agent_metadata, "terminal_source_coverage_mismatch", "source_coverage"),
+        (_drop_attempt_representation, "terminal_orchestration_representation_mismatch", "source_coverage"),
+        (_collapse_material_origin, "material_origin_collapse", "provenance"),
+        (_break_effect_reference, "terminal_effect_ref_mismatch", "effect_mapping"),
+        (_collapse_claim_effect_identity, "claim_effect_collapse", "effect_mapping"),
+    ),
+    ids=(
+        "source-coverage",
+        "orchestration-representation",
+        "material-origin",
+        "direct-effect-reference",
+        "claim-effect-identity",
+    ),
+)
+async def test_terminal_mutations_fail_at_their_production_boundary(
+    terminal_corpus: tuple[Path, JSONDocument, ContinuityFixtureSeed],
+    tmp_path: Path,
+    mutation: EvidenceMutation,
+    expected_kind: str,
+    expected_class: str,
+) -> None:
+    """Each mutation removes or corrupts evidence consumed by the named production seam."""
+
+    archive_root, catalog, seed = terminal_corpus
+    evidence_root = _copy_evidence(seed, tmp_path)
+    mutation(evidence_root)
+
+    report = await verify_terminal_continuity_gate(
+        archive_root,
+        catalog,
+        incident_result=_incident_route_result(),
+        evidence_root=evidence_root,
+    )
+
+    assert report["status"] == "fail"
+    diagnostics = json_document_list(report["diagnostics"])
+    assert diagnostics == [
+        {
+            "kind": expected_kind,
+            "failure_class": expected_class,
+            "message": diagnostics[0]["message"],
+        }
+    ]
+
+
+def test_global_first_action_relation_is_killed_by_terminal_sql_canary(
+    tmp_path: Path,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """Production dependency: ArchiveStore's selective action relation planner."""
+
+    monkeypatch.setattr(
+        "polylogue.storage.sqlite.archive_tiers.archive._action_relation_for_query",
+        lambda **_kwargs: ("", "actions", []),
+    )
+    with pytest.raises(TerminalContinuityError) as raised:
+        verify_selective_action_sql(tmp_path)
+    assert raised.value.kind == "selective_sql_plan_amplification"
+    assert raised.value.failure_class == "plan"
