+            "ref": "commit:terminal-sanitized-commit",
+            "present": True,
+            "treeMatches": True,
+            "evidence": "sanitized-git-show-receipt",
+        },
+    )
+    write_json(
+        "effects/github-pr.json",
+        {
+            "ref": "github-pr:3060",
+            "state": "open",
+            "headCommit": "terminal-sanitized-commit",
+            "checks": "unavailable",
+            "evidence": "sanitized-github-api-receipt",
