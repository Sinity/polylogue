+"""Terminal continuity composition over admitted Claude/effect/query primitives.
+
+This module is called by :mod:`devtools.continuity_replay`; it is not a second
+transport or scenario harness.  It composes the current source-admission,
+provider-neutral work-evidence, repository-effect reconciliation, SQLite
+persistence, and selective-query-plan seams into one auditable terminal
+receipt.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import shutil
+import tempfile
+from collections import Counter
+from collections.abc import Mapping
+from pathlib import Path
+from typing import TypeGuard, cast
+
+from polylogue.core.json import JSONDocument, JSONValue, require_json_document
+
+
+class TerminalContinuityError(RuntimeError):
+    """Fact-addressed terminal gate failure."""
+
+    def __init__(self, message: str, *, kind: str, failure_class: str) -> None:
+        super().__init__(message)
+        self.kind = kind
+        self.failure_class = failure_class
+
+
+async def verify_terminal_continuity_gate(
+    archive_root: Path,
+    fixture: Mapping[str, JSONValue],
+    *,
+    incident_result: Mapping[str, JSONValue],
+    evidence_root: Path | None = None,
+    cold_model_receipt: Path | None = None,
+) -> JSONDocument:
+    """Verify the terminal incident claim through production-owned seams."""
+
+    root = (evidence_root or archive_root / "continuity-evidence").resolve()
+    diagnostics: list[JSONDocument] = []
+    try:
+        report = await _verify_terminal(
+            archive_root.resolve(),
+            fixture,
+            incident_result=incident_result,
+            evidence_root=root,
+            cold_model_receipt=cold_model_receipt,
+        )
+        return report
+    except TerminalContinuityError as exc:
+        diagnostics.append(
+            require_json_document(
+                {
+                    "kind": exc.kind,
+                    "failure_class": exc.failure_class,
+                    "message": str(exc),
+                },
+                context="terminal continuity diagnostic",
+            )
+        )
+    except Exception as exc:  # pragma: no cover - defensive receipt boundary
+        diagnostics.append(
+            require_json_document(
+                {
+                    "kind": "terminal_gate_unexpected_error",
+                    "failure_class": "execution",
+                    "message": f"{type(exc).__name__}: {exc}",
+                },
+                context="terminal continuity unexpected diagnostic",
+            )
+        )
+    return require_json_document(
+        {
+            "schema_version": 1,
+            "status": "fail",
+            "classification": diagnostics[0]["failure_class"],
+            "diagnostics": diagnostics,
+            "evidence_root_available": root.is_dir(),
+        },
+        context="failed terminal continuity receipt",
+    )
+
+
+async def _verify_terminal(
+    archive_root: Path,
+    fixture: Mapping[str, JSONValue],
+    *,
+    incident_result: Mapping[str, JSONValue],
+    evidence_root: Path,
+    cold_model_receipt: Path | None,
+) -> JSONDocument:
+    from polylogue.archive.message.roles import Role
+    from polylogue.core.enums import MaterialOrigin, Provider
+    from polylogue.core.refs import EvidenceRef, ObjectRef
+    from polylogue.insights.claude_workflow_evidence import project_claude_workflow_evidence
+    from polylogue.insights.work_reconciliation import (
+        EffectAuthority,
+        Evaluation,
+        ObservedRepositoryEffect,
+        ReconciliationJudgment,
+        reconcile_work_effects,
