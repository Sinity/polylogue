+def _seed_parallel_claude_evidence(
+    archive_root: Path,
+    *,
+    timestamp: str,
+    data: Mapping[str, JSONValue],
+) -> tuple[Path, tuple[str, ...]]:
+    """Write a sanitized native Claude Workflow/effect corpus for the terminal gate."""
+
+    evidence_root = archive_root / "continuity-evidence"
+    claude_root = evidence_root / "claude"
+    run_ref = _string(data, "run_ref")
+    resumed_run_ref = f"{run_ref}-resume"
+    logical_paths: list[str] = []
+
+    def write_json(relative: str, payload: object) -> str:
+        path = evidence_root / relative
+        path.parent.mkdir(parents=True, exist_ok=True)
+        path.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+        logical = f"continuity-evidence/{relative}"
+        logical_paths.append(logical)
+        return logical
+
+    coordinator_records: list[object] = [
+        {
+            "type": "user",
+            "uuid": "terminal-operator-prompt",
+            "sessionId": "terminal-coordinator",
+            "timestamp": timestamp,
+            "origin": {"kind": "human"},
+            "message": {
+                "role": "user",
+                "content": (
+                    f"Investigate repo:{_string(data, 'repo_marker')} "
+                    f"date:{_string(data, 'date_marker')} {_string(data, 'discovery_marker')} work."
+                ),
+            },
+        }
+    ]
+    for index in range(1, _integer(data, "workflow_invocations") + 1):
+        invocation_run = resumed_run_ref if index == _integer(data, "workflow_invocations") else run_ref
+        workflow_input: dict[str, object] = {
+            "runId": invocation_run,
+            "taskId": f"task-{index:02d}",
+            "workflowName": "terminal-continuity",
+            "scriptHash": "sha256:sanitized-workflow-v1",
+        }
+        if invocation_run == resumed_run_ref:
+            workflow_input["resumeFromRunId"] = run_ref
+        coordinator_records.append(
+            {
+                "type": "assistant",
+                "uuid": f"workflow-tool-use-{index:02d}",
+                "sessionId": "terminal-coordinator",
+                "timestamp": timestamp,
+                "message": {
+                    "role": "assistant",
+                    "content": [
+                        {
+                            "type": "tool_use",
+                            "id": f"workflow-{index:02d}",
+                            "name": "Workflow",
+                            "input": workflow_input,
+                        }
+                    ],
+                },
+            }
+        )
+    coordinator_records.append(
+        {
+            "type": "assistant",
+            "uuid": "terminal-final-result",
+            "sessionId": "terminal-coordinator",
+            "timestamp": timestamp,
+            "message": {"role": "assistant", "content": "Sanitized structured result emitted."},
+        }
+    )
+    coordinator_path = claude_root / "coordinator.jsonl"
+    coordinator_path.parent.mkdir(parents=True, exist_ok=True)
+    coordinator_path.write_text(
+        "".join(json.dumps(record, sort_keys=True) + "\n" for record in coordinator_records),
+        encoding="utf-8",
+    )
+    logical_paths.append("continuity-evidence/claude/coordinator.jsonl")
+
+    write_json(
+        f"claude/workflows/{run_ref}.json",
+        {
+            "runId": run_ref,
+            "workflowName": "terminal-continuity",
+            "scriptHash": "sha256:sanitized-workflow-v1",
+            "status": "complete-with-unresolved-call",
+        },
+    )
+
+    journal_records: list[dict[str, object]] = []
+    call_key_count = _integer(data, "call_keys")
+    completed_count = _integer(data, "completed_call_keys")
+    attempt_count = _integer(data, "member_children")
+    result_count = _integer(data, "result_records")
+    for call_number in range(1, call_key_count + 1):
+        journal_records.append(
+            {
+                "type": "call",
+                "runId": run_ref,
+                "contentKey": f"call-{call_number:02d}",
+                "status": "unresolved" if call_number > completed_count else "scheduled",
+                "unresolved": call_number > completed_count,
+            }
+        )
+    for attempt_number in range(1, attempt_count + 1):
+        call_number = ((attempt_number - 1) % call_key_count) + 1
+        agent_id = f"agent-attempt-{attempt_number:03d}"
+        transcript_logical = f"continuity-evidence/claude/subagents/{agent_id}.jsonl"
+        meta_logical = f"continuity-evidence/claude/subagents/{agent_id}.meta.json"
+        transcript = [
+            {
+                "type": "user",
+                "uuid": f"{agent_id}-prompt",
+                "sessionId": agent_id,
+                "timestamp": timestamp,
+                "message": {
+                    "role": "user",
+                    "content": f"Generated task pack for call-{call_number:02d}; sanitized.",
+                },
+            },
+            {
+                "type": "assistant",
+                "uuid": f"{agent_id}-answer",
+                "sessionId": agent_id,
+                "timestamp": timestamp,
+                "message": {"role": "assistant", "content": "Sanitized attempt evidence."},
+            },
+        ]
+        transcript_path = evidence_root / transcript_logical.removeprefix("continuity-evidence/")
+        transcript_path.parent.mkdir(parents=True, exist_ok=True)
+        transcript_path.write_text(
+            "".join(json.dumps(record, sort_keys=True) + "\n" for record in transcript),
+            encoding="utf-8",
+        )
+        logical_paths.append(transcript_logical)
+        write_json(
+            meta_logical.removeprefix("continuity-evidence/"),
+            {
+                "runId": run_ref,
+                "agentId": agent_id,
+                "model": "claude-sanitized",
+                "status": "complete" if call_number <= completed_count else "unresolved",
+            },
+        )
+        journal_records.append(
+            {
+                "type": "attempt",
+                "runId": run_ref,
+                "contentKey": f"call-{call_number:02d}",
+                "attemptId": agent_id,
+                "agentId": agent_id,
+                "status": "complete" if call_number <= completed_count else "unresolved",
+                "transcriptPath": transcript_logical,
+                "metaPath": meta_logical,
+            }
+        )
+    for result_number in range(1, result_count + 1):
