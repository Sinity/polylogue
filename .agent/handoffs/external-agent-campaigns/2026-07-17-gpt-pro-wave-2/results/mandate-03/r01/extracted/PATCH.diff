+                    "case": case_id,
+                    "expected": expected[case_id],
+                    "source_refs": list(source_refs),
+                }
+            )
+        elif observed[case_id] != expected[case_id]:
+            diagnostics.append(
+                {
+                    "kind": "attempt_grade_mismatch",
+                    "failure_class": "reasoning",
+                    "case": case_id,
+                    "expected": expected[case_id],
+                    "observed": observed[case_id],
+                    "source_refs": list(source_refs),
+                }
+            )
+    return diagnostics
