@@ -0,0 +1,189 @@
+from __future__ import annotations
+
+import hashlib
+import json
+from copy import deepcopy
+from pathlib import Path
+
+import pytest
+
+from devtools.continuity_replay import _validate_lane_contract, redact_live_continuity_report
+from devtools.continuity_terminal import TerminalContinuityError, _verify_cold_model_receipt
+from polylogue.core.json import json_document_list, require_json_document
+from polylogue.product.continuity_scenarios import continuity_scenario
+from tests.infra.continuity import load_continuity_catalog
+
+_AUTHORIZATION = "I_AUTHORIZE_POLYLOGUE_REDACTED_LIVE_SCALE"
+_SALT = "terminal-continuity-redaction-salt-0001"
+
+
+def test_ci_lane_rejects_catalogs_that_are_not_explicitly_sanitized() -> None:
+    catalog = load_continuity_catalog()
+    assert (
+        _validate_lane_contract(
+            catalog,
+            lane="ci",
+            live_authorized=False,
+            live_environment_authorization=None,
+            redaction_salt=None,
+        )
+        == "sanitized"
+    )
+
+    unsafe = deepcopy(catalog)
+    privacy = require_json_document(unsafe["privacy"], context="unsafe continuity privacy")
+    privacy["contains_live_identifiers"] = True
+    unsafe["privacy"] = privacy
+    with pytest.raises(ValueError, match="contains_live_identifiers=false"):
+        _validate_lane_contract(
+            unsafe,
+            lane="ci",
+            live_authorized=False,
+            live_environment_authorization=None,
+            redaction_salt=None,
+        )
+
+
+def test_live_lane_requires_two_party_authorization_and_redaction_key() -> None:
+    catalog = load_continuity_catalog()
+    with pytest.raises(ValueError, match="exact authorization environment value"):
+        _validate_lane_contract(
+            catalog,
+            lane="live",
+            live_authorized=True,
+            live_environment_authorization="wrong",
+            redaction_salt=_SALT,
+        )
+    with pytest.raises(ValueError, match="at least 32 bytes"):
+        _validate_lane_contract(
+            catalog,
+            lane="live",
+            live_authorized=True,
+            live_environment_authorization=_AUTHORIZATION,
+            redaction_salt="too-short",
+        )
+    assert (
+        _validate_lane_contract(
+            catalog,
+            lane="live",
+            live_authorized=True,
+            live_environment_authorization=_AUTHORIZATION,
+            redaction_salt=_SALT,
+        )
+        == "sanitized"
+    )
+
+
+def test_live_receipt_hmac_redacts_paths_identifiers_text_and_arguments() -> None:
+    raw = require_json_document(
+        {
+            "schema_version": 2,
+            "lane": "live",
+            "status": "pass",
+            "archive_root": "/operator/private/archive",
+            "fixture_id": "live-customer-001",
+            "scenario_count": 1,
+            "results": [
+                {
+                    "scenario": "parallel-claude-incident",
+                    "status": "pass",
+                    "route_receipts": [
+                        {
+                            "step_id": "incident-members",
+                            "arguments": {
+                                "expression": 'messages where text:"workflow_run:wf_live_secret"',
+                                "continuation": "raw-continuation-token",
+                            },
+                            "query_ref": "query:live-secret",
+                            "result_ref": "result-set:live-secret",
+                            "page_count": 6,
+                        }
+                    ],
+                    "observed_evidence_refs": ["message:private-session:message-1"],
+                }
+            ],
+        },
+        context="raw live continuity report",
+    )
+
+    first = redact_live_continuity_report(raw, _SALT)
+    second = redact_live_continuity_report(raw, _SALT)
+    other_salt = redact_live_continuity_report(raw, "terminal-continuity-redaction-salt-0002")
+
+    assert first == second
+    assert first != other_salt
+    rendered = json.dumps(first, sort_keys=True)
+    for secret in (
+        "/operator/private/archive",
+        "live-customer-001",
+        "wf_live_secret",
+        "raw-continuation-token",
+        "query:live-secret",
+        "result-set:live-secret",
+        "message:private-session:message-1",
+    ):
+        assert secret not in rendered
+    assert first["lane"] == "live"
+    assert first["status"] == "pass"
+    assert first["scenario_count"] == 1
+    [result] = json_document_list(first["results"])
+    [route] = json_document_list(result["route_receipts"])
+    assert route["step_id"] == "incident-members"
+    assert route["page_count"] == 6
+    arguments = require_json_document(route["arguments"], context="redacted route arguments")
+    hmac_sha256 = arguments["hmac_sha256"]
+    assert isinstance(hmac_sha256, str)
+    assert arguments == {
+        "redacted": True,
+        "hmac_sha256": hmac_sha256,
+    }
+    assert len(hmac_sha256) == 64
+    redaction = require_json_document(first["redaction"], context="live receipt redaction")
+    assert redaction == {
+        "algorithm": "HMAC-SHA256",
+        "raw_archive_paths": False,
+        "raw_query_arguments": False,
+        "raw_identifiers": False,
+        "raw_text": False,
+        "raw_evidence_refs": False,
+    }
+
+
+def test_cold_model_receipt_is_prompt_bound_and_rejects_hidden_inputs(tmp_path: Path) -> None:
+    scenario = continuity_scenario("parallel-claude-incident")
+    receipt_path = tmp_path / "cold-model.json"
+    payload = require_json_document(
+        {
+            "schema_version": 1,
+            "prompt_sha256": hashlib.sha256(scenario.operator_question.encode("utf-8")).hexdigest(),
+            "input_classes": ["mcp_tool_schema", "mcp_error", "continuity_catalog"],
+            "plan_signature": list(scenario.equivalent_plan_signatures[0]),
+            "evidence_refs": ["message:sanitized-discovery"],
+            "facts": {"attempt_transcripts": 91, "unresolved_call_keys": 1},
+        },
+        context="cold-model test receipt",
+    )
+    receipt_path.write_text(json.dumps(payload), encoding="utf-8")
+
+    verified = _verify_cold_model_receipt(
+        receipt_path,
+        question=scenario.operator_question,
+        accepted_signatures=[list(signature) for signature in scenario.equivalent_plan_signatures],
+    )
+    assert verified["status"] == "verified"
+    assert verified["evidence_ref_count"] == 1
+    assert verified["fact_count"] == 2
+    assert verified["model_competence_claimed"] is True
+
+    input_classes = payload["input_classes"]
+    assert isinstance(input_classes, list)
+    input_classes.append("fixture_internal_ids")
+    receipt_path.write_text(json.dumps(payload), encoding="utf-8")
+    with pytest.raises(TerminalContinuityError) as raised:
+        _verify_cold_model_receipt(
+            receipt_path,
+            question=scenario.operator_question,
+            accepted_signatures=[list(signature) for signature in scenario.equivalent_plan_signatures],
+        )
+    assert raised.value.kind == "cold_model_input_scope_violation"
+    assert raised.value.failure_class == "reasoning"
