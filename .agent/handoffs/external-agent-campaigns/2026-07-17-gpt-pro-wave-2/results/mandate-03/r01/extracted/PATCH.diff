+def verify_selective_action_sql(archive_root: Path) -> JSONDocument:
+    """Prove exact-session action aggregation stays relation-selective."""
+
+    from hashlib import sha256
+
+    from polylogue.archive.message.roles import Role
+    from polylogue.archive.query import execution_control as execution_control
+    from polylogue.archive.query.execution_control import (
+        QueryAdmissionController,
+        QueryExecutionContext,
+        execute_archive_read_sync,
+    )
+    from polylogue.archive.query.expression import parse_unit_source_expression
+    from polylogue.archive.query.unit_results import query_unit_rows
+    from polylogue.core.enums import BlockType, Origin
+    from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore, _action_relation_for_query
+    from polylogue.surfaces.payloads import QueryUnitAggregateEnvelope
+
+    probe_parent = archive_root / ".continuity-terminal"
+    probe_parent.mkdir(parents=True, exist_ok=True)
+    probe_root = Path(tempfile.mkdtemp(prefix="selective-sql-", dir=probe_parent))
+    try:
+        target_session_id = "codex-session:target"
+        session_rows: list[tuple[str, str, bytes]] = []
+        message_rows: list[tuple[str, str, int, str, str, bytes]] = []
+        block_rows: list[tuple[str, str, int, str, str | None, str, str | None, str | None]] = []
+        for index in range(512):
+            native_id = "target" if index == 0 else f"irrelevant-{index:04d}"
+            session_id = f"codex-session:{native_id}"
+            message_id = f"{session_id}:m1"
+            tool_id = f"tool-{index:04d}"
+            session_rows.append((native_id, Origin.CODEX_SESSION.value, sha256(session_id.encode()).digest()))
+            message_rows.append(
+                (session_id, "m1", 0, Role.ASSISTANT.value, "message", sha256(message_id.encode()).digest())
+            )
+            block_rows.extend(
+                (
+                    (message_id, session_id, 0, BlockType.TOOL_USE.value, "Bash", tool_id, "{}", "shell"),
+                    (message_id, session_id, 1, BlockType.TOOL_RESULT.value, None, tool_id, None, None),
+                )
+            )
+        with ArchiveStore(probe_root) as facade:
+            facade._conn.executemany(
+                "INSERT INTO sessions (native_id, origin, content_hash) VALUES (?, ?, ?)",
+                session_rows,
+            )
+            facade._conn.executemany(
+                """
+                INSERT INTO messages (session_id, native_id, position, role, message_type, content_hash)
+                VALUES (?, ?, ?, ?, ?, ?)
+                """,
+                message_rows,
+            )
+            facade._conn.executemany(
+                """
+                INSERT INTO blocks (
+                    message_id, session_id, position, block_type, tool_name, tool_id, tool_input, semantic_type
+                ) VALUES (?, ?, ?, ?, ?, ?, ?, ?)
+                """,
+                block_rows,
+            )
+            facade._conn.commit()
+        source = parse_unit_source_expression(
+            f"actions where session.id:{target_session_id} | group by tool, session.origin | count"
+        )
+        if source is None:
+            raise TerminalContinuityError(
+                "selective SQL probe expression did not parse",
+                kind="selective_sql_expression_unavailable",
+                failure_class="plan",
+            )
+        prefix_sql, relation_name, relation_params = _action_relation_for_query(
+            predicate=source.predicate,
+            include_followup=False,
+        )
+        expected_relation_params: list[object] = [target_session_id, target_session_id, target_session_id]
+        if (
+            relation_name != "bounded_actions"
+            or "bounded_actions AS" not in prefix_sql
+            or relation_params != expected_relation_params
+        ):
+            raise TerminalContinuityError(
+                "exact-session action query did not select the bounded production relation",
+                kind="selective_sql_plan_amplification",
+                failure_class="plan",
+            )
+        original_guard = execution_control.PROGRESS_GUARD_OPCODES
+        execution_control.PROGRESS_GUARD_OPCODES = 100
+        try:
+            context = QueryExecutionContext.create(
+                query_text="terminal-selective-action-sql",
+                workload_class="scan",
+                timeout_s=10.0,
+            )
+            result = execute_archive_read_sync(
+                probe_root,
+                lambda archive: query_unit_rows(
+                    archive,
+                    source,
+                    query="terminal-selective-action-sql",
+                    limit=10,
+                    execution_context=context,
+                ),
+                ctx=context,
+                controller=QueryAdmissionController(),
+            )
+        finally:
+            execution_control.PROGRESS_GUARD_OPCODES = original_guard
+        if not isinstance(result, QueryUnitAggregateEnvelope):
+            raise TerminalContinuityError(
+                f"selective SQL probe returned {type(result).__name__}",
+                kind="selective_sql_result_shape_mismatch",
+                failure_class="execution",
+            )
+        receipt = context.receipt
+        if receipt.selected_rows_exact != 1 or receipt.rows_emitted != 1:
+            raise TerminalContinuityError(
+                f"selective SQL semantic census is selected={receipt.selected_rows_exact}, emitted={receipt.rows_emitted}",
+                kind="selective_sql_semantic_mismatch",
+                failure_class="execution",
+            )
+        if receipt.sqlite_vm_steps_lower_bound >= 50_000:
+            raise TerminalContinuityError(
+                f"exact-session action query used at least {receipt.sqlite_vm_steps_lower_bound} SQLite VM steps",
+                kind="selective_sql_plan_amplification",
+                failure_class="plan",
+            )
+        return require_json_document(
+            {
+                "status": "pass",
+                "seeded_sessions": 512,
+                "target_sessions": 1,
+                "selected_rows_exact": receipt.selected_rows_exact,
+                "rows_emitted": receipt.rows_emitted,
+                "result_pages_emitted": receipt.result_pages_emitted,
+                "relation_name": relation_name,
+                "bounded_relation": True,
+                "relation_parameter_count": len(relation_params),
+                "sqlite_vm_steps_lower_bound": receipt.sqlite_vm_steps_lower_bound,
+                "plan_canary_max_vm_steps": 49_999,
+                "cleanup_complete": receipt.cleanup_complete,
+            },
+            context="selective SQL terminal receipt",
+        )
+    finally:
+        shutil.rmtree(probe_root, ignore_errors=True)
+
+
+def _verify_cold_model_receipt(
+    path: Path | None,
+    *,
+    question: str,
+    accepted_signatures: object,
+) -> JSONDocument:
+    if path is None:
+        return {
+            "status": "unavailable",
+            "reason": "no external cold-model receipt was supplied",
+            "deterministic_sparse_route_verified": True,
+            "model_competence_claimed": False,
+        }
+    payload = _load_document(path)
+    expected_prompt_hash = hashlib.sha256(question.encode("utf-8")).hexdigest()
+    if payload.get("schema_version") != 1 or payload.get("prompt_sha256") != expected_prompt_hash:
+        raise TerminalContinuityError(
+            "cold-model receipt does not bind to the sparse operator question",
+            kind="cold_model_prompt_binding_mismatch",
+            failure_class="reasoning",
+        )
+    input_classes = payload.get("input_classes")
+    allowed_inputs = {"mcp_tool_schema", "mcp_error", "continuity_catalog"}
+    if not isinstance(input_classes, list) or not set(input_classes).issubset(allowed_inputs):
+        raise TerminalContinuityError(
+            "cold-model receipt includes an unauthorized input class",
+            kind="cold_model_input_scope_violation",
+            failure_class="reasoning",
+        )
+    plan_signature = payload.get("plan_signature")
+    accepted = accepted_signatures if isinstance(accepted_signatures, list) else []
+    if not isinstance(plan_signature, list) or plan_signature not in accepted:
+        raise TerminalContinuityError(
+            "cold-model receipt plan is outside the declared equivalent plan family",
+            kind="cold_model_plan_signature_mismatch",
+            failure_class="reasoning",
+        )
+    evidence_refs = payload.get("evidence_refs")
+    facts = payload.get("facts")
+    if not isinstance(evidence_refs, list) or not evidence_refs or not isinstance(facts, Mapping):
+        raise TerminalContinuityError(
+            "cold-model receipt omits evidence or facts",
+            kind="cold_model_evidence_contract_missing",
+            failure_class="reasoning",
+        )
+    return require_json_document(
+        {
+            "status": "verified",
+            "prompt_sha256": expected_prompt_hash,
+            "input_classes": input_classes,
+            "plan_signature": plan_signature,
+            "evidence_ref_count": len(evidence_refs),
+            "fact_count": len(facts),
+            "model_competence_claimed": True,
+        },
+        context="cold-model continuity receipt",
+    )
+
+
+def _claim_effect_refs(payload: Mapping[str, object]) -> dict[str, str]:
+    structured = payload.get("structuredResult", payload.get("result"))
+    if not isinstance(structured, Mapping):
+        raise TerminalContinuityError(
+            "final Workflow result has no structured payload",
+            kind="missing_final_structured_result",
+            failure_class="source_coverage",
+        )
+    raw_claims = structured.get("claims")
+    if not isinstance(raw_claims, list):
+        raise TerminalContinuityError(
+            "final Workflow result has no claim inventory",
+            kind="missing_final_claim_inventory",
+            failure_class="effect_mapping",
+        )
+    result: dict[str, str] = {}
+    for raw in raw_claims:
+        if not isinstance(raw, Mapping):
+            continue
+        claim_id = raw.get("claimId", raw.get("claim_id"))
+        effect_ref = raw.get("effectRef", raw.get("effect_ref"))
+        if isinstance(claim_id, str) and isinstance(effect_ref, str):
+            result[claim_id] = effect_ref
+    if len(result) != 3:
+        raise TerminalContinuityError(
+            f"final Workflow result has {len(result)} direct effect refs, expected 3",
+            kind="incomplete_final_claim_inventory",
+            failure_class="effect_mapping",
+        )
+    return result
+
+
+def _evaluate_git(payload: Mapping[str, JSONValue]) -> str:
+    if payload.get("present") is True and payload.get("treeMatches") is True:
+        return "supported"
+    if payload.get("present") is False:
+        return "contradicted"
+    return "unresolved"
+
+
+def _evaluate_pr(payload: Mapping[str, JSONValue]) -> str:
+    if (
+        payload.get("state") in {"open", "merged"}
+        and payload.get("headCommit")
+        and payload.get("checks") == "unavailable"
+    ):
+        return "partial"
+    if payload.get("state") == "missing":
+        return "contradicted"
+    return "unresolved"
+
+
+def _evaluate_beads(payload: Mapping[str, JSONValue]) -> str:
+    if payload.get("status") == "closed" and payload.get("closureEvidence") not in {None, "unavailable"}:
+        return "supported"
+    if payload.get("status") == "open" or payload.get("closureEvidence") == "unavailable":
+        return "unresolved"
+    return "partial"
+
+
+def _jsonl_records(path: Path) -> list[object]:
+    records: list[object] = []
+    for line_number, line in enumerate(path.read_text(encoding="utf-8").splitlines(), start=1):
+        if not line.strip():
+            continue
+        try:
+            records.append(json.loads(line))
+        except json.JSONDecodeError as exc:
+            raise TerminalContinuityError(
+                f"invalid JSONL at {path.name}:{line_number}: {exc}",
+                kind="invalid_terminal_jsonl",
+                failure_class="source_coverage",
+            ) from exc
+    return records
+
+
+def _load_document(path: Path) -> JSONDocument:
+    if not path.is_file():
+        raise TerminalContinuityError(
+            f"terminal evidence file is missing: {path.name}",
+            kind="missing_terminal_evidence_file",
+            failure_class="source_coverage",
+        )
+    try:
+        decoded = json.loads(path.read_text(encoding="utf-8"))
+    except json.JSONDecodeError as exc:
+        raise TerminalContinuityError(
+            f"terminal evidence file is invalid JSON: {path.name}: {exc}",
+            kind="invalid_terminal_evidence_json",
+            failure_class="source_coverage",
+        ) from exc
+    return require_json_document(decoded, context=f"terminal evidence {path}")
+
+
+def _incident_fixture(fixture: Mapping[str, JSONValue]) -> Mapping[str, JSONValue]:
+    corpus = fixture.get("corpus")
+    if not isinstance(corpus, Mapping):
+        raise TerminalContinuityError(
+            "continuity fixture has no corpus",
+            kind="missing_terminal_fixture_corpus",
+            failure_class="source_coverage",
+        )
+    incident = corpus.get("parallel_incident")
+    if not isinstance(incident, Mapping):
+        raise TerminalContinuityError(
+            "continuity fixture has no parallel incident",
+            kind="missing_terminal_incident_fixture",
+            failure_class="source_coverage",
+        )
+    return cast(Mapping[str, JSONValue], incident)
+
+
+def _integer(source: Mapping[str, JSONValue], key: str) -> int:
+    value = source.get(key)
+    if not _is_int(value):
+        raise TerminalContinuityError(
+            f"terminal fixture field {key!r} must be an integer",
+            kind="invalid_terminal_fixture_field",
+            failure_class="source_coverage",
+        )
+    return value
+
+
+def _is_int(value: object) -> TypeGuard[int]:
+    return isinstance(value, int) and not isinstance(value, bool)
+
+
+__all__ = [
+    "TerminalContinuityError",
+    "verify_selective_action_sql",
+    "verify_terminal_continuity_gate",
+]
