+            structured_result["claims"] = [
+                {
+                    "claimId": "git-effect",
+                    "text": "The terminal implementation is present in the cited commit.",
+                    "effectRef": "commit:terminal-sanitized-commit",
+                },
+                {
+                    "claimId": "pr-effect",
+                    "text": "The cited pull request carries the continuity replay branch.",
+                    "effectRef": "github-pr:3060",
+                },
+                {
+                    "claimId": "beads-effect",
+                    "text": "The terminal Bead is complete.",
+                    "effectRef": "artifact:bead-polylogue-z9gh.7",
+                },
+            ]
+        journal_records.append(
+            {
+                "type": "result",
+                "runId": run_ref,
+                "contentKey": f"call-{call_number:02d}",
+                "status": "complete",
+                "structuredResult": structured_result,
+            }
+        )
+    journal_relative = f"claude/subagents/workflows/{run_ref}/journal.jsonl"
+    journal_path = evidence_root / journal_relative
+    journal_path.parent.mkdir(parents=True, exist_ok=True)
+    journal_path.write_text(
+        "".join(json.dumps(record, sort_keys=True) + "\n" for record in journal_records),
+        encoding="utf-8",
+    )
+    logical_paths.append(f"continuity-evidence/{journal_relative}")
+
+    write_json(
+        "claude/jobs/recovery-001/adopt.json",
+        {
+            "runId": resumed_run_ref,
+            "resumeFromRunId": run_ref,
+            "status": "adopted",
+        },
+    )
+    write_json(
