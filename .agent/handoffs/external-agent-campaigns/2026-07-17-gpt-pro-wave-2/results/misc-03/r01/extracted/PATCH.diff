diff --git a/tests/property/test_fts_identity_state_machine.py b/tests/property/test_fts_identity_state_machine.py
new file mode 100644
index 0000000000000000000000000000000000000000..935144df2c00c234b182ab77e2807d606b53c575
--- /dev/null
+++ b/tests/property/test_fts_identity_state_machine.py
@@ -0,0 +1,294 @@
+"""Metamorphic coherence laws for the production message-FTS trigger DDL."""
+
+from __future__ import annotations
+
+import hashlib
+import sqlite3
+
+from hypothesis import HealthCheck, settings
+from hypothesis import strategies as st
+from hypothesis.stateful import RuleBasedStateMachine, initialize, invariant, rule
+
+from polylogue.storage.fts.freshness import record_fts_surface_state_sync
+from polylogue.storage.fts.fts_lifecycle import audit_message_fts_index_sync, fts_invariant_snapshot_sync
+from polylogue.storage.fts.sql import (
+    BLOCKS_FTS_TRIGGER_DDL,
+    FTS_IDENTITY_TABLE_SQL,
+    FTS_MESSAGE_RECIPE_ID,
+    FTS_MESSAGES_TABLE_SQL,
+)
+from polylogue.storage.sqlite.archive_tiers.index import FTS_FRESHNESS_STATE_DDL
+
+_TEXT = st.text(
+    alphabet=st.characters(whitelist_categories=("Ll", "Lu", "Nd"), whitelist_characters=" -_łŁ"),
+    min_size=0,
+    max_size=40,
+)
+_NONEMPTY_TEXT = _TEXT.filter(bool)
+
+
+def _hash(text: str) -> bytes:
+    return hashlib.sha256(text.encode()).digest()
+
+
+class MessageFtsIdentityStateMachine(RuleBasedStateMachine):
+    """Assert blocks ∥ docsize ∥ identity coherence after every mutation.
+
+    The machine executes ``BLOCKS_FTS_TRIGGER_DDL`` directly. Representative
+    anti-vacuity mutations are removal of any trigger arm, omission of the
+    ledger write, or deletion of rowid/block/source/recipe checks from the
+    exact audit: each makes a reachable rule violate ``exact_coherence``.
+    """
+
+    def __init__(self) -> None:
+        super().__init__()
+        self.conn = sqlite3.connect(":memory:")
+        self.conn.row_factory = sqlite3.Row
+        self.conn.execute(
+            """
+            CREATE TABLE blocks (
+                block_id TEXT NOT NULL UNIQUE,
+                message_id TEXT NOT NULL,
+                session_id TEXT NOT NULL,
+                block_type TEXT NOT NULL,
+                search_text TEXT NOT NULL,
+                content_hash BLOB CHECK(content_hash IS NULL OR length(content_hash) = 32)
+            ) STRICT
+            """
+        )
+        self.conn.execute(FTS_MESSAGES_TABLE_SQL)
+        self.conn.execute(FTS_IDENTITY_TABLE_SQL)
+        self.conn.execute(FTS_FRESHNESS_STATE_DDL)
+        record_fts_surface_state_sync(
+            self.conn,
+            surface="messages_fts",
+            state="ready",
+            exact=True,
+            source_rows=0,
+            indexed_rows=0,
+            ledger_rows=0,
+        )
+        for ddl in BLOCKS_FTS_TRIGGER_DDL:
+            self.conn.execute(ddl)
+        self.model: dict[int, tuple[str, str, str, bytes]] = {}
+        self.current_markers: dict[int, str] = {}
+        self.retired_markers: set[str] = set()
+        self.next_block = 0
+        self.next_marker = 0
+
+    def teardown(self) -> None:
+        self.conn.close()
+
+    def _new_block_id(self) -> str:
+        self.next_block += 1
+        return f"block-{self.next_block}"
+
+    def _project_text(self, text: str) -> tuple[str, str | None]:
+        if text == "":
+            return "", None
+        self.next_marker += 1
+        marker = f"ftsmarker{self.next_marker}"
+        return f"{text} {marker}", marker
+
+    def _retire_marker(self, rowid: int) -> None:
+        marker = self.current_markers.pop(rowid, None)
+        if marker is not None:
+            self.retired_markers.add(marker)
+
+    def _insert(self, *, rowid: int | None, session_id: str, text: str) -> int:
+        block_id = self._new_block_id()
+        projected_text, marker = self._project_text(text)
+        params = (block_id, f"message-{block_id}", session_id, projected_text, _hash(projected_text))
+        if rowid is None:
+            cursor = self.conn.execute(
+                """
+                INSERT INTO blocks(block_id, message_id, session_id, block_type, search_text, content_hash)
+                VALUES (?, ?, ?, 'text', ?, ?)
+                """,
+                params,
+            )
+            assert cursor.lastrowid is not None
+            resolved_rowid = cursor.lastrowid
+        else:
+            self.conn.execute(
+                """
+                INSERT INTO blocks(rowid, block_id, message_id, session_id, block_type, search_text, content_hash)
+                VALUES (?, ?, ?, ?, 'text', ?, ?)
+                """,
+                (rowid, *params),
+            )
+            resolved_rowid = rowid
+        self.model[resolved_rowid] = (block_id, session_id, projected_text, _hash(projected_text))
+        if marker is not None:
+            self.current_markers[resolved_rowid] = marker
+        return resolved_rowid
+
+    @initialize()
+    def seed(self) -> None:
+        self._insert(rowid=1, session_id="session-0", text="seed")
+
+    @rule(rowid=st.integers(min_value=1, max_value=16), session=st.integers(0, 2), text=_TEXT)
+    def insert(self, rowid: int, session: int, text: str) -> None:
+        if rowid in self.model:
+            return
+        self._insert(rowid=rowid, session_id=f"session-{session}", text=text)
+
+    @rule(rowid=st.integers(min_value=1, max_value=16), text=_TEXT)
+    def update_text_and_source(self, rowid: int, text: str) -> None:
+        current = self.model.get(rowid)
+        if current is None:
+            return
+        block_id, session_id, _old_text, _old_hash = current
+        projected_text, marker = self._project_text(text)
+        self.conn.execute(
+            "UPDATE blocks SET search_text = ?, content_hash = ? WHERE rowid = ?",
+            (projected_text, _hash(projected_text), rowid),
+        )
+        self._retire_marker(rowid)
+        if marker is not None:
+            self.current_markers[rowid] = marker
+        self.model[rowid] = (block_id, session_id, projected_text, _hash(projected_text))
+
+    @rule(rowid=st.integers(min_value=1, max_value=16))
+    def delete(self, rowid: int) -> None:
+        if rowid not in self.model:
+            return
+        self.conn.execute("DELETE FROM blocks WHERE rowid = ?", (rowid,))
+        self._retire_marker(rowid)
+        del self.model[rowid]
+
+    @rule(text=_NONEMPTY_TEXT)
+    def rowid_reuse_delete_then_insert(self, text: str) -> None:
+        """Named ROWID-reuse sequence that defeats count-only currentness."""
+        if not self.model:
+            self._insert(rowid=1, session_id="session-reuse", text="predecessor")
+        rowid = min(self.model)
+        self.conn.execute("DELETE FROM blocks WHERE rowid = ?", (rowid,))
+        self._retire_marker(rowid)
+        del self.model[rowid]
+        self._insert(rowid=rowid, session_id="session-reuse", text=text)
+
+    @rule(
+        session=st.integers(min_value=0, max_value=2),
+        replacements=st.lists(_TEXT, min_size=0, max_size=4),
+    )
+    def full_session_replace(self, session: int, replacements: list[str]) -> None:
+        session_id = f"session-{session}"
+        removed = [rowid for rowid, (_bid, sid, _text, _hash_value) in self.model.items() if sid == session_id]
+        self.conn.execute("DELETE FROM blocks WHERE session_id = ?", (session_id,))
+        for rowid in removed:
+            self._retire_marker(rowid)
+            del self.model[rowid]
+        for text in replacements:
+            self._insert(rowid=None, session_id=session_id, text=text)
+
+    @rule(text=_TEXT)
+    def rollback_mutation(self, text: str) -> None:
+        before = dict(self.model)
+        markers_before = dict(self.current_markers)
+        retired_before = set(self.retired_markers)
+        self.conn.execute("SAVEPOINT fts_property_rollback")
+        try:
+            if self.model:
+                rowid = min(self.model)
+                projected_text, _marker = self._project_text(text)
+                self.conn.execute(
+                    "UPDATE blocks SET search_text = ?, content_hash = ? WHERE rowid = ?",
+                    (projected_text, _hash(projected_text), rowid),
+                )
+            else:
+                self._insert(rowid=1, session_id="session-rollback", text=text)
+        finally:
+            self.conn.execute("ROLLBACK TO fts_property_rollback")
+            self.conn.execute("RELEASE fts_property_rollback")
+            self.model = before
+            self.current_markers = markers_before
+            self.retired_markers = retired_before
+
+    @rule()
+    def source_identity_drift_then_repair(self) -> None:
+        indexed = [rowid for rowid, (_bid, _sid, text, _hash_value) in self.model.items() if text]
+        if not indexed:
+            return
+        rowid = min(indexed)
+        self.conn.execute("UPDATE messages_fts_identity SET source_hash = X'77726F6E67' WHERE rowid = ?", (rowid,))
+        drift = fts_invariant_snapshot_sync(self.conn).messages
+        assert drift.source_mismatch_rows == 1
+        audit_message_fts_index_sync(self.conn, max_repair_rows=32)
+
+    @rule()
+    def recipe_identity_drift_then_repair(self) -> None:
+        indexed = [rowid for rowid, (_bid, _sid, text, _hash_value) in self.model.items() if text]
+        if not indexed:
+            return
+        rowid = max(indexed)
+        self.conn.execute(
+            "UPDATE messages_fts_identity SET recipe_id = 'obsolete-recipe' WHERE rowid = ?",
+            (rowid,),
+        )
+        drift = fts_invariant_snapshot_sync(self.conn).messages
+        assert drift.recipe_mismatch_rows == 1
+        audit_message_fts_index_sync(self.conn, max_repair_rows=32)
+
+    @invariant()
+    def exact_coherence(self) -> None:
+        """Every completed rule leaves all three rowid sets exactly coherent."""
+        surface = fts_invariant_snapshot_sync(self.conn).messages
+        assert surface.ready
+
+        desired = {int(row["rowid"]) for row in self.conn.execute("SELECT rowid FROM blocks WHERE search_text != ''")}
+        docsize = {int(row[0]) for row in self.conn.execute("SELECT id FROM messages_fts_docsize")}
+        ledger = {int(row[0]) for row in self.conn.execute("SELECT rowid FROM messages_fts_identity")}
+        assert desired == docsize == ledger
+
+        for row in self.conn.execute(
+            """
+            SELECT b.rowid, b.block_id, b.content_hash, i.block_id, i.source_hash, i.recipe_id
+            FROM blocks AS b
+            JOIN messages_fts_identity AS i ON i.rowid = b.rowid
+            WHERE b.search_text != ''
+            """
+        ):
+            assert row[1] == row[3]
+            assert bytes(row[4]) == b"\x00" + bytes(row[2])
+            assert row[5] == FTS_MESSAGE_RECIPE_ID
+
+        # Rowid-set equality alone cannot prove that the FTS postings contain
+        # the current text. Every non-empty model value carries a never-reused
+        # token, so removing any insert/update/delete trigger arm leaves either
+        # a missing current marker or a searchable retired marker.
+        for rowid, marker in self.current_markers.items():
+            rows = self.conn.execute(
+                "SELECT rowid FROM messages_fts WHERE messages_fts MATCH ? ORDER BY rowid",
+                (marker,),
+            ).fetchall()
+            assert [int(row[0]) for row in rows] == [rowid]
+        for marker in self.retired_markers:
+            assert (
+                self.conn.execute(
+                    "SELECT rowid FROM messages_fts WHERE messages_fts MATCH ? LIMIT 1",
+                    (marker,),
+                ).fetchone()
+                is None
+            )
+
+        state = self.conn.execute(
+            """
+            SELECT state, exact, source_rows, indexed_rows, ledger_rows,
+                   missing_rows, excess_rows, identity_mismatch_rows,
+                   source_mismatch_rows, recipe_mismatch_rows, duplicate_rows
+            FROM fts_freshness_state WHERE surface = 'messages_fts'
+            """
+        ).fetchone()
+        assert state is not None
+        assert tuple(state[:5]) == ("ready", 1, len(desired), len(desired), len(desired))
+        assert tuple(state[5:]) == (0, 0, 0, 0, 0, 0)
+
+
+TestMessageFtsIdentityStateMachine = MessageFtsIdentityStateMachine.TestCase
+TestMessageFtsIdentityStateMachine.settings = settings(
+    max_examples=30,
+    stateful_step_count=45,
+    deadline=None,
+    suppress_health_check=[HealthCheck.too_slow],
+)
