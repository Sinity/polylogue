index 0000000000000000000000000000000000000000..a5b33bd8c1a0d4b6266d4a8458dd40194f81e457
--- /dev/null
+++ b/tests/unit/daemon/test_fts_identity_observability.py
@@ -0,0 +1,176 @@
+"""O(1) observability contracts for the exact message FTS identity state."""
+
+from __future__ import annotations
+
+import sqlite3
+
+from polylogue.daemon.fts_status import _archive_blocks_surface
+from polylogue.daemon.metrics import _emit_fts_freshness_metrics, _fts_freshness_samples
+from polylogue.storage.fts.freshness import record_fts_surface_state_sync
+from polylogue.storage.fts.sql import BLOCKS_FTS_TRIGGER_DDL, FTS_IDENTITY_TABLE_SQL, FTS_MESSAGES_TABLE_SQL
+from polylogue.storage.sqlite.archive_tiers.index import FTS_FRESHNESS_STATE_DDL
+
+_BLOCKS_DDL = """
+CREATE TABLE blocks (
+    block_id TEXT NOT NULL UNIQUE,
+    message_id TEXT NOT NULL,
+    session_id TEXT NOT NULL,
+    block_type TEXT NOT NULL,
+    search_text TEXT NOT NULL,
+    content_hash BLOB CHECK(content_hash IS NULL OR length(content_hash) = 32)
+) STRICT
+"""
+
+
+def _open_surface() -> sqlite3.Connection:
+    conn = sqlite3.connect(":memory:")
+    conn.execute(_BLOCKS_DDL)
+    conn.execute(FTS_MESSAGES_TABLE_SQL)
+    conn.execute(FTS_IDENTITY_TABLE_SQL)
+    conn.execute(FTS_FRESHNESS_STATE_DDL)
+    for ddl in BLOCKS_FTS_TRIGGER_DDL:
+        conn.execute(ddl)
+    return conn
+
+
+def _assert_no_data_scan(statements: list[str]) -> None:
+    normalized = "\n".join(statements).lower()
+    forbidden = (
+        "from blocks",
+        "join blocks",
+        "from messages_fts_docsize",
+        "join messages_fts_docsize",
+        "from messages_fts_identity",
+        "join messages_fts_identity",
+    )
+    assert all(fragment not in normalized for fragment in forbidden), normalized
+
+
+def test_metrics_read_only_constant_size_freshness_rows() -> None:
+    """Metric collection must not scan canonical, docsize, or ledger rows.
+
+    Production dependency: ``_fts_freshness_samples`` is the Prometheus state
+    seam. Replacing its durable-row read with an exact JOIN makes this trace
+    assertion fail even when the numeric gauges remain superficially correct.
+    """
+    conn = _open_surface()
+    try:
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="stale",
+            exact=True,
+            source_rows=10,
+            indexed_rows=9,
+            ledger_rows=8,
+            missing_rows=1,
+            excess_rows=2,
+            identity_mismatch_rows=3,
+            source_mismatch_rows=4,
+            recipe_mismatch_rows=5,
+            duplicate_rows=6,
+            repair_generation=7,
+            detail="fixture drift",
+        )
+        traced: list[str] = []
+        conn.set_trace_callback(traced.append)
+        samples = _fts_freshness_samples(conn)
+        conn.set_trace_callback(None)
+
+        lines: list[str] = []
+        _emit_fts_freshness_metrics(lines, samples)
+        rendered = "\n".join(lines)
+
+        _assert_no_data_scan(traced)
+        assert len(samples) == 1
+        assert float(samples[0]["checked_at_timestamp_seconds"]) > 0
+        assert {key: value for key, value in samples[0].items() if key != "checked_at_timestamp_seconds"} == {
+            "surface": "messages_fts",
+            "ready": 0,
+            "exact": 1,
+            "source_rows": 10,
+            "indexed_rows": 9,
+            "ledger_rows": 8,
+            "missing_rows": 1,
+            "excess_rows": 2,
+            "identity_mismatch_rows": 3,
+            "source_mismatch_rows": 4,
+            "recipe_mismatch_rows": 5,
+            "duplicate_rows": 6,
+            "repair_generation": 7,
+            "drift_rows": 21,
+        }
+        for kind, value in (
+            ("missing", 1),
+            ("excess", 2),
+            ("identity_mismatch", 3),
+            ("source_mismatch", 4),
+            ("recipe_mismatch", 5),
+            ("duplicate", 6),
+            ("total", 21),
+        ):
+            assert f'polylogue_fts_drift_rows{{kind="{kind}",surface="messages_fts"}} {value}' in rendered
+        assert 'polylogue_fts_source_rows{surface="messages_fts"} 10' in rendered
+        assert 'polylogue_fts_indexed_rows{surface="messages_fts"} 9' in rendered
+        assert 'polylogue_fts_identity_rows{surface="messages_fts"} 8' in rendered
+        assert 'polylogue_fts_drift_exact{surface="messages_fts"} 1' in rendered
+        assert 'polylogue_fts_repair_generation{surface="messages_fts"} 7' in rendered
+        assert 'polylogue_fts_last_exact_check_timestamp_seconds{surface="messages_fts"} ' in rendered
+    finally:
+        conn.close()
+
+
+def test_status_projection_reads_state_and_schema_only() -> None:
+    """Ordinary readiness remains O(1); exact audit is an explicit mode.
+
+    Production dependency: ``_archive_blocks_surface`` backs daemon status and
+    health. Adding a count fallback or identity JOIN fails the trace assertion.
+    """
+    conn = _open_surface()
+    try:
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="ready",
+            exact=True,
+            source_rows=0,
+            indexed_rows=0,
+            ledger_rows=0,
+        )
+        traced: list[str] = []
+        conn.set_trace_callback(traced.append)
+        surface = _archive_blocks_surface(conn)
+        conn.set_trace_callback(None)
+
+        _assert_no_data_scan(traced)
+        assert surface["ready"] is True
+        assert surface["exact"] is True
+        assert surface["source_rows"] == 0
+        assert surface["indexed_rows"] == 0
+        assert surface["ledger_rows"] == 0
+        assert surface["freshness_trusted"] is True
+    finally:
+        conn.close()
+
+
+def test_metrics_ready_gauge_requires_identity_and_all_triggers() -> None:
+    """Durable counters cannot mask structural loss in the metric surface."""
+    conn = _open_surface()
+    try:
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="ready",
+            exact=True,
+            source_rows=0,
+            indexed_rows=0,
+            ledger_rows=0,
+        )
+        conn.execute("DROP TRIGGER messages_fts_ad")
+        samples = _fts_freshness_samples(conn)
+
+        assert len(samples) == 1
+        assert samples[0]["ready"] == 0
+        assert samples[0]["exact"] == 1
+    finally:
+        conn.close()
