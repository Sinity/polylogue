+"""Exact identity-ledger contracts for the production message FTS triggers."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import sqlite3
+
+import aiosqlite
+import pytest
+
+from polylogue.storage.fts.freshness import (
+    apply_message_fts_replacement_delta_sync,
+    ensure_fts_freshness_table_sync,
+    mark_all_fts_stale_sync,
+    record_fts_surface_state_sync,
+)
+from polylogue.storage.fts.fts_lifecycle import (
+    audit_message_fts_index_sync,
+    ensure_fts_index_async,
+    ensure_fts_triggers_sync,
+    fts_invariant_snapshot_sync,
+    message_fts_search_readiness_sync,
+    repair_fts_index_async,
+    repair_message_fts_index_sync,
+)
+from polylogue.storage.fts.pl_fold import pl_fold_sql_expr
+from polylogue.storage.fts.sql import (
+    BLOCKS_FTS_TRIGGER_DDL,
+    FTS_IDENTITY_TABLE_SQL,
+    FTS_MESSAGE_RECIPE_DESCRIPTOR,
+    FTS_MESSAGE_RECIPE_ID,
+    FTS_MESSAGE_TOKENIZER,
+    FTS_MESSAGES_TABLE_SQL,
+)
+from polylogue.storage.sqlite.archive_tiers.index import (
+    FTS_FRESHNESS_STATE_DDL,
+    FTS_NEVER_EXACT_CHECKED_AT,
+)
+
+_BLOCKS_DDL = """
+CREATE TABLE blocks (
+    block_id TEXT NOT NULL UNIQUE,
+    message_id TEXT NOT NULL,
+    session_id TEXT NOT NULL,
+    block_type TEXT NOT NULL,
+    search_text TEXT NOT NULL,
+    content_hash BLOB CHECK(content_hash IS NULL OR length(content_hash) = 32)
+) STRICT
+"""
+
+
+def _content_hash(text: str) -> bytes:
+    return hashlib.sha256(text.encode()).digest()
+
+
+def _open_db(*, production_triggers: bool = True) -> sqlite3.Connection:
+    conn = sqlite3.connect(":memory:")
+    conn.row_factory = sqlite3.Row
+    conn.execute(_BLOCKS_DDL)
+    conn.execute(FTS_MESSAGES_TABLE_SQL)
+    conn.execute(FTS_FRESHNESS_STATE_DDL)
+    if production_triggers:
+        conn.execute(FTS_IDENTITY_TABLE_SQL)
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="ready",
+            exact=True,
+            source_rows=0,
+            indexed_rows=0,
+            ledger_rows=0,
+        )
+        for ddl in BLOCKS_FTS_TRIGGER_DDL:
+            conn.execute(ddl)
+    return conn
+
+
+def _insert(
+    conn: sqlite3.Connection,
+    *,
+    rowid: int,
+    block_id: str,
+    text: str,
+    session_id: str = "s",
+) -> None:
+    conn.execute(
+        """
+        INSERT INTO blocks(
+            rowid, block_id, message_id, session_id, block_type, search_text, content_hash
+        ) VALUES (?, ?, ?, ?, 'text', ?, ?)
+        """,
+        (rowid, block_id, f"m-{block_id}", session_id, text, _content_hash(text)),
+    )
+
+
+def _matches(conn: sqlite3.Connection, term: str) -> tuple[str, ...]:
+    rows = conn.execute(
+        """
+        SELECT b.block_id
+        FROM messages_fts AS f
+        JOIN blocks AS b ON b.rowid = f.rowid
+        WHERE messages_fts MATCH ?
+        ORDER BY b.block_id
+        """,
+        (term,),
+    ).fetchall()
+    return tuple(str(row[0]) for row in rows)
+
+
+def _state(conn: sqlite3.Connection) -> dict[str, object]:
+    row = conn.execute(
+        """
+        SELECT state, checked_at, exact, source_rows, indexed_rows, ledger_rows,
+               missing_rows, excess_rows, identity_mismatch_rows,
+               source_mismatch_rows, recipe_mismatch_rows, duplicate_rows,
+               repair_generation
+        FROM fts_freshness_state
+        WHERE surface = 'messages_fts'
+        """
+    ).fetchone()
+    assert row is not None
+    return dict(row)
+
+
+def _assert_exact_ready(conn: sqlite3.Connection, expected_rows: int) -> None:
+    surface = fts_invariant_snapshot_sync(conn).messages
+    assert surface.ready
+    assert surface.source_rows == expected_rows
+    assert surface.indexed_rows == expected_rows
+    assert surface.ledger_rows == expected_rows
+    state = _state(conn)
+    assert state["state"] == "ready"
+    assert state["exact"] == 1
+    assert state["source_rows"] == expected_rows
+    assert state["indexed_rows"] == expected_rows
+    assert state["ledger_rows"] == expected_rows
+    assert all(
+        state[name] == 0
+        for name in (
+            "missing_rows",
+            "excess_rows",
+            "identity_mismatch_rows",
+            "source_mismatch_rows",
+            "recipe_mismatch_rows",
+            "duplicate_rows",
+        )
+    )
+
+
+def test_recipe_identity_serializes_the_actual_derivation_contract() -> None:
+    """Fold/tokenizer/selector changes must deterministically change recipe ID.
+
+    Replacing ``fold_sql`` with a fixed label would make a real ``PL_FOLD_TABLE``
+    implementation change invisible to exact recipe reconciliation.
+    """
+    descriptor = json.loads(FTS_MESSAGE_RECIPE_DESCRIPTOR)
+
+    assert descriptor["subject"] == "block/search_text"
+    assert descriptor["selector"] == "search_text != ''"
+    assert descriptor["fold_sql"] == pl_fold_sql_expr("__source__")
+    assert descriptor["tokenizer"] == FTS_MESSAGE_TOKENIZER == "unicode61 remove_diacritics 2"
+    assert descriptor["content_mode"] == {"content": "", "contentless_delete": 1}
+    assert descriptor["output_contract"].endswith("messages_fts_identity/rowid-block-source-recipe-v1")
+
+    canonical = json.dumps(
+        descriptor,
+        ensure_ascii=False,
+        separators=(",", ":"),
+        sort_keys=True,
+    )
+    assert canonical == FTS_MESSAGE_RECIPE_DESCRIPTOR
+    assert "sha256:" + hashlib.sha256(canonical.encode()).hexdigest() == FTS_MESSAGE_RECIPE_ID
+
+    mutated = dict(descriptor)
+    mutated["fold_sql"] = f"REPLACE({descriptor['fold_sql']}, 'x', 'y')"
+    mutated_canonical = json.dumps(
+        mutated,
+        ensure_ascii=False,
+        separators=(",", ":"),
+        sort_keys=True,
+    )
+    assert hashlib.sha256(mutated_canonical.encode()).digest() != hashlib.sha256(canonical.encode()).digest()
+
+
+def test_non_exact_state_does_not_claim_an_exact_check_time() -> None:
+    """Unknown/stale writes expose epoch until an exact reconciliation occurs.
+
+    Using the current wall clock for an unknown seed would make the daemon's
+    ``last_exact_check`` gauge report an audit that never happened.
+    """
+    conn = sqlite3.connect(":memory:")
+    conn.row_factory = sqlite3.Row
+    try:
+        ensure_fts_freshness_table_sync(conn)
+        initial = _state(conn)
+        assert initial["state"] == "unknown"
+        assert initial["exact"] == 0
+        assert initial["checked_at"] == FTS_NEVER_EXACT_CHECKED_AT
+
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="stale",
+            exact=False,
+            source_rows=2,
+            indexed_rows=1,
+            ledger_rows=1,
+            missing_rows=1,
+        )
+        assert _state(conn)["checked_at"] == FTS_NEVER_EXACT_CHECKED_AT
+
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="ready",
+            exact=True,
+            source_rows=1,
+            indexed_rows=1,
+            ledger_rows=1,
+        )
+        exact_checked_at = str(_state(conn)["checked_at"])
+        assert exact_checked_at != FTS_NEVER_EXACT_CHECKED_AT
+
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="stale",
+            exact=False,
+            source_rows=1,
+            indexed_rows=0,
+            ledger_rows=0,
+            missing_rows=1,
+        )
+        assert _state(conn)["checked_at"] == exact_checked_at
+    finally:
+        conn.close()
+
+
+def test_count_only_rowid_reuse_can_cite_replacement_block() -> None:
+    """Legacy FTS-only triggers let equal counts conceal a ghost→replacement bind.
+
+    Production dependency proved vulnerable: contentless ``messages_fts`` keyed
+    only by ``blocks.rowid``. Removing the delete arm is representative of a
+    stale/missing trigger; this test would stop demonstrating the hole if the
+    count-only design somehow gained logical identity.
+    """
+    conn = _open_db(production_triggers=False)
+    try:
+        conn.execute(
+            """
+            CREATE TRIGGER legacy_messages_fts_ai
+            AFTER INSERT ON blocks WHEN new.search_text != '' BEGIN
+                INSERT INTO messages_fts(rowid, block_id, message_id, session_id, block_type, text)
+                VALUES (new.rowid, new.block_id, new.message_id, new.session_id, new.block_type, new.search_text);
+            END
+            """
+        )
+        conn.execute(
+            """
+            CREATE TRIGGER legacy_messages_fts_ad
+            AFTER DELETE ON blocks WHEN old.search_text != '' BEGIN
+                DELETE FROM messages_fts WHERE rowid = old.rowid;
+            END
+            """
+        )
+        _insert(conn, rowid=1, block_id="block-a", text="alpha retired")
+        conn.execute("DROP TRIGGER legacy_messages_fts_ad")
+        conn.execute("DELETE FROM blocks WHERE rowid = 1")
+        _insert(conn, rowid=1, block_id="block-b", text="beta current")
+
+        source_count = conn.execute("SELECT COUNT(*) FROM blocks WHERE search_text != ''").fetchone()[0]
+        docsize_count = conn.execute("SELECT COUNT(*) FROM messages_fts_docsize").fetchone()[0]
+
+        assert source_count == docsize_count == 1
+        assert _matches(conn, "alpha") == ("block-b",)
+        assert _matches(conn, "beta") == ("block-b",)
+    finally:
+        conn.close()
+
+
+def test_identity_ledger_prevents_silent_rowid_rebinding() -> None:
+    """The production INSERT trigger must fail atomically on a retained identity.
+
+    Removing ``messages_fts_ad`` simulates the same missing trigger arm. The
+    ledger primary key is the anti-vacuity dependency: deleting the ledger
+    INSERT or its rowid key makes the replacement silently bind again.
+    """
+    conn = _open_db()
+    try:
+        _insert(conn, rowid=1, block_id="block-a", text="alpha retired")
+        conn.execute("DROP TRIGGER messages_fts_ad")
+        conn.execute("DELETE FROM blocks WHERE rowid = 1")
+
+        with pytest.raises(sqlite3.IntegrityError, match="messages_fts_identity.rowid"):
+            _insert(conn, rowid=1, block_id="block-b", text="beta current")
+
+        assert conn.execute("SELECT COUNT(*) FROM blocks").fetchone()[0] == 0
+        assert conn.execute("SELECT block_id FROM messages_fts_identity WHERE rowid = 1").fetchone()[0] == "block-a"
+        assert conn.execute("SELECT COUNT(*) FROM messages_fts_docsize").fetchone()[0] == 1
+    finally:
+        conn.close()
+
+
+def test_exact_audit_detects_equal_count_rowid_reuse_and_repairs() -> None:
+    """Exact reconciliation catches logical rebinding even when all counts agree.
+
+    Dropping all three production trigger arms represents out-of-band or stale
+    DDL. Removing the audit's ``block_id`` comparison makes this named
+    regression pass as ready and leaves ``alpha`` citing ``block-b``.
+    """
+    conn = _open_db()
+    try:
+        _insert(conn, rowid=1, block_id="block-a", text="alpha retired")
+        for name in ("messages_fts_ai", "messages_fts_ad", "messages_fts_au"):
+            conn.execute(f"DROP TRIGGER {name}")
+        conn.execute("DELETE FROM blocks WHERE rowid = 1")
+        _insert(conn, rowid=1, block_id="block-b", text="beta current")
+
+        counts = (
+            conn.execute("SELECT COUNT(*) FROM blocks WHERE search_text != ''").fetchone()[0],
+            conn.execute("SELECT COUNT(*) FROM messages_fts_docsize").fetchone()[0],
+            conn.execute("SELECT COUNT(*) FROM messages_fts_identity").fetchone()[0],
+        )
+        before = fts_invariant_snapshot_sync(conn).messages
+
+        assert counts == (1, 1, 1)
+        assert not before.ready
+        assert before.identity_mismatch_rows == 1
+        assert _matches(conn, "alpha") == ("block-b",)
+
+        result = audit_message_fts_index_sync(conn, max_repair_rows=10)
+
+        assert result.repaired
+        assert result.repair_rows == 1
+        assert result.repair_generation_after == result.repair_generation_before + 1
+        assert _matches(conn, "alpha") == ()
+        assert _matches(conn, "beta") == ("block-b",)
+        _assert_exact_ready(conn, 1)
+    finally:
+        conn.close()
+
+
+def test_production_triggers_keep_fts_ledger_and_state_atomic() -> None:
+    """Exercise every empty/text transition and statement rollback via real DDL.
+
+    Removing any FTS or ledger statement from ``BLOCKS_FTS_TRIGGER_DDL`` makes
+    one transition fail the exact three-way invariant.
+    """
+    conn = _open_db()
+    try:
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        _assert_exact_ready(conn, 1)
+
+        conn.execute(
+            "UPDATE blocks SET search_text = '', content_hash = ? WHERE rowid = 1",
+            (_content_hash(""),),
+        )
+        _assert_exact_ready(conn, 0)
+
+        conn.execute(
+            "UPDATE blocks SET search_text = 'beta', content_hash = ? WHERE rowid = 1",
+            (_content_hash("beta"),),
+        )
+        _assert_exact_ready(conn, 1)
+        assert _matches(conn, "beta") == ("block-a",)
+
+        conn.execute("SAVEPOINT rollback_probe")
+        conn.execute(
+            "UPDATE blocks SET search_text = 'gamma', content_hash = ? WHERE rowid = 1",
+            (_content_hash("gamma"),),
+        )
+        conn.execute("ROLLBACK TO rollback_probe")
+        conn.execute("RELEASE rollback_probe")
+        _assert_exact_ready(conn, 1)
+        assert _matches(conn, "beta") == ("block-a",)
+        assert _matches(conn, "gamma") == ()
+
+        conn.execute("DELETE FROM blocks WHERE rowid = 1")
+        _assert_exact_ready(conn, 0)
+    finally:
+        conn.close()
+
+
+def test_exact_audit_classifies_source_and_recipe_drift() -> None:
+    """Source and recipe identity are independent exact-currentness dimensions.
+
+    Removing either comparison from the production audit makes the respective
+    mutation vacuously ready.
+    """
+    conn = _open_db()
+    try:
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        conn.execute(
+            "UPDATE messages_fts_identity SET source_hash = ?, recipe_id = ? WHERE rowid = 1",
+            (b"wrong", "obsolete-recipe"),
+        )
+
+        before = fts_invariant_snapshot_sync(conn).messages
+        assert not before.ready
+        assert before.source_mismatch_rows == 1
+        assert before.recipe_mismatch_rows == 1
+
+        result = audit_message_fts_index_sync(conn, max_repair_rows=10)
+        row = conn.execute("SELECT source_hash, recipe_id FROM messages_fts_identity WHERE rowid = 1").fetchone()
+
+        assert result.repaired
+        assert row is not None
+        assert bytes(row["source_hash"]) == b"\x00" + _content_hash("alpha")
+        assert row["recipe_id"] == FTS_MESSAGE_RECIPE_ID
+        _assert_exact_ready(conn, 1)
+    finally:
+        conn.close()
+
+
+def test_stale_freshness_state_is_not_counter_delta_guessed() -> None:
+    """Hot triggers preserve stale measured magnitudes until an exact audit.
+
+    The representative mutation is replacing the trusted-state predicate with
+    an unconditional counter update; that would manufacture apparently exact
+    counts on top of an already-corrupt baseline.
+    """
+    conn = _open_db()
+    try:
+        record_fts_surface_state_sync(
+            conn,
+            surface="messages_fts",
+            state="stale",
+            exact=False,
+            source_rows=7,
+            indexed_rows=6,
+            ledger_rows=5,
+            missing_rows=2,
+            detail="known drift",
+        )
+        before = _state(conn)
+
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        after_mutation = _state(conn)
+
+        assert after_mutation["state"] == "stale"
+        assert after_mutation["exact"] == 0
+        for name in (
+            "source_rows",
+            "indexed_rows",
+            "ledger_rows",
+            "missing_rows",
+            "excess_rows",
+            "identity_mismatch_rows",
+            "source_mismatch_rows",
+            "recipe_mismatch_rows",
+            "duplicate_rows",
+            "repair_generation",
+        ):
+            assert after_mutation[name] == before[name]
+
+        result = audit_message_fts_index_sync(conn, max_repair_rows=10)
+        assert not result.repaired
+        _assert_exact_ready(conn, 1)
+    finally:
+        conn.close()
+
+
+def test_last_exact_check_time_changes_only_on_exact_reconciliation() -> None:
+    """Hot trigger/delta/invalidation writes must not masquerade as audits.
+
+    ``polylogue_fts_last_exact_check_timestamp_seconds`` is sourced from this
+    field. Updating it from a trigger or scoped counter delta would conceal how
+    long it has been since the ledger itself was independently reconciled.
+    """
+    conn = _open_db()
+    try:
+        sentinel = "2000-01-01T00:00:00+00:00"
+        conn.execute(
+            "UPDATE fts_freshness_state SET checked_at = ? WHERE surface = 'messages_fts'",
+            (sentinel,),
+        )
+
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        conn.execute(
+            "UPDATE blocks SET search_text = 'beta', content_hash = ? WHERE rowid = 1",
+            (_content_hash("beta"),),
+        )
+        apply_message_fts_replacement_delta_sync(conn, removed_rows=1, inserted_rows=1)
+        assert _state(conn)["checked_at"] == sentinel
+
+        mark_all_fts_stale_sync(conn, detail="audit requested")
+        stale = _state(conn)
+        assert stale["exact"] == 0
+        assert stale["checked_at"] == sentinel
+
+        result = audit_message_fts_index_sync(conn, max_repair_rows=10)
+        assert result.ready
+        assert not result.repaired
+        assert _state(conn)["checked_at"] != sentinel
+    finally:
+        conn.close()
+
+
+def test_restoring_missing_triggers_cannot_reauthenticate_stale_zero_counters() -> None:
+    """Trigger restoration invalidates durable state before names look healthy.
+
+    Without this invalidation, inserting a block while all message triggers are
+    absent leaves an exact-ready 0/0/0 row. Merely recreating trigger names and
+    repairing the selected session would then make bounded search readiness
+    trust those stale zero counters.
+    """
+    conn = _open_db()
+    try:
+        for name in ("messages_fts_ai", "messages_fts_ad", "messages_fts_au"):
+            conn.execute(f"DROP TRIGGER {name}")
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        assert _state(conn)["state"] == "ready"
+        assert _state(conn)["source_rows"] == 0
+
+        ensure_fts_triggers_sync(conn)
+        repaired_trigger_state = _state(conn)
+        assert repaired_trigger_state["state"] == "stale"
+        assert repaired_trigger_state["exact"] == 0
+
+        repair_message_fts_index_sync(conn, ["s"], record_exact_snapshot=False)
+        assert _matches(conn, "alpha") == ("block-a",)
+        assert not bool(message_fts_search_readiness_sync(conn)["ready"])
+        assert _state(conn)["state"] == "stale"
+
+        result = audit_message_fts_index_sync(conn, max_repair_rows=10)
+        assert result.ready
+        assert not result.repaired
+        _assert_exact_ready(conn, 1)
+    finally:
+        conn.close()
+
+
+def test_missing_delete_trigger_is_visible_to_exact_invariant() -> None:
+    """An absent production trigger arm plus delete must never look ready."""
+    conn = _open_db()
+    try:
+        _insert(conn, rowid=1, block_id="block-a", text="alpha")
+        conn.execute("DROP TRIGGER messages_fts_ad")
+        conn.execute("DELETE FROM blocks WHERE rowid = 1")
+
+        surface = fts_invariant_snapshot_sync(conn).messages
+
+        assert not surface.ready
+        assert not surface.triggers_present
+        assert surface.excess_rows == 1
+    finally:
+        conn.close()
+
+
+@pytest.mark.asyncio
+async def test_async_targeted_repair_falls_back_to_atomic_global_rebuild() -> None:
+    """Unowned orphan drift is repaired rather than merely reported async."""
+    async with aiosqlite.connect(":memory:") as conn:
+        await conn.execute(_BLOCKS_DDL)
+        await ensure_fts_index_async(conn)
+        await conn.execute(
+            """
+            INSERT INTO blocks(
+                rowid, block_id, message_id, session_id, block_type, search_text, content_hash
+            ) VALUES (1, 'block-a', 'm-a', 'session-a', 'text', 'alpha', ?)
+            """,
+            (_content_hash("alpha"),),
+        )
+        await conn.execute(
+            """
+            INSERT INTO blocks(
+                rowid, block_id, message_id, session_id, block_type, search_text, content_hash
+            ) VALUES (2, 'block-b', 'm-b', 'session-b', 'text', 'beta', ?)
+            """,
+            (_content_hash("beta"),),
+        )
+        await conn.execute("DROP TRIGGER messages_fts_ad")
+        await conn.execute("DELETE FROM blocks WHERE rowid = 1")
+
+        await repair_fts_index_async(conn, ["session-b"])
+
+        docsize_row = await (await conn.execute("SELECT COUNT(*) FROM messages_fts_docsize")).fetchone()
+        identity_row = await (await conn.execute("SELECT COUNT(*) FROM messages_fts_identity")).fetchone()
+        assert docsize_row is not None
+        assert identity_row is not None
+        assert docsize_row[0] == 1
+        assert identity_row[0] == 1
+        row = await (
+            await conn.execute(
+                """
+                SELECT state, exact, source_rows, indexed_rows, ledger_rows,
+                       excess_rows, repair_generation
+                FROM fts_freshness_state
+                WHERE surface = 'messages_fts'
+                """
+            )
+        ).fetchone()
+        assert row == ("ready", 1, 1, 1, 1, 0, 1)
