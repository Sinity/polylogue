+            ledger_rows=10 - index,
+            missing_rows=index,
+            excess_rows=0,
+            identity_mismatch_rows=0,
+            source_mismatch_rows=0,
+            recipe_mismatch_rows=0,
+            duplicate_rows=0,
+            repair_generation=index,
+            sampled_at_ms=1_700_100_000 + index,
+            retention_rows=2,
+        )
+
+    rows = list_fts_drift_samples(conn, surface="messages_fts")
+    assert rows == (
+        ArchiveFtsDriftSample(
+            sample_id="sample-3",
+            surface="messages_fts",
+            phase="audit_ready",
+            exact=True,
+            source_rows=10,
+            indexed_rows=7,
+            ledger_rows=7,
+            missing_rows=3,
+            excess_rows=0,
+            identity_mismatch_rows=0,
+            source_mismatch_rows=0,
+            recipe_mismatch_rows=0,
+            duplicate_rows=0,
+            repair_generation=3,
+            sampled_at_ms=1_700_100_003,
+        ),
+        ArchiveFtsDriftSample(
+            sample_id="sample-2",
+            surface="messages_fts",
+            phase="repair_after",
+            exact=True,
+            source_rows=10,
+            indexed_rows=8,
+            ledger_rows=8,
+            missing_rows=2,
+            excess_rows=0,
+            identity_mismatch_rows=0,
+            source_mismatch_rows=0,
+            recipe_mismatch_rows=0,
