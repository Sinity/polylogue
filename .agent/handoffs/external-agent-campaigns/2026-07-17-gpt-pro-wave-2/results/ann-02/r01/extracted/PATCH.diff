+def test_krippendorff_alpha_matches_hand_computed_nominal_fixture() -> None:
+    # Ratings by unit: A/A, A/B, B/B. Do = 1/3, De = 3/5, so
+    # alpha = 1 - (1/3)/(3/5) = 4/9.
+    alpha = krippendorff_alpha(
+        {
+            "unit-1": ("A", "A"),
+            "unit-2": ("A", "B"),
+            "unit-3": ("B", "B"),
+        }
+    )
+    assert alpha == pytest.approx(4 / 9)
+    assert krippendorff_alpha({"unit-1": ("A",), "unit-2": ("B",)}) is None
+    assert krippendorff_alpha({"unit-1": (1.0, 1.0), "unit-2": (2.0, 2.0)}, level="interval") == 1.0
+
