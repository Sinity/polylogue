+def _safe_loader(target_ref: str, evidence_refs: tuple[str, ...]) -> CalibrationSourceItem:
+    return CalibrationSourceItem(
+        target_ref=target_ref,
+        evidence_refs=evidence_refs,
+        presentation={"text": f"evidence for {target_ref}"},
+    )
+
+
+def _compose(
+    conn: sqlite3.Connection,
+    *,
+    schema: AnnotationSchema,
+    judge: AnnotationJudgeRefs,
+    batch_id: str,
+    gold_count: int = 3,
+    gold_strata: tuple[GoldStratumQuota, ...] = (),
+    created_at_ms: int = 200,
+) -> JudgeBatchView:
+    composed = compose_calibration_batch(
+        conn,
+        request=CalibrationCompositionRequest(
+            batch_id=batch_id,
+            schema_id=schema.schema_id,
+            schema_version=schema.version,
+            source_result_ref="result-set:calibration-source",
+            judge=judge,
+            prompt_ref="block:prompt:0",
+            rubric_ref="insight:rubric-v1",
+            ordinary_items=(),
+            gold_set_ref="analysis:test-gold-v1",
+            gold_count=gold_count,
+            gold_strata=gold_strata,
+            seed=f"seed-{batch_id}",
+            created_at_ms=created_at_ms,
+        ),
+        item_loader=_safe_loader,
+    )
+    return composed.judge_view
+
+
+def _record(
+    conn: sqlite3.Connection,
+    *,
+    schema: AnnotationSchema,
+    registry: AnnotationSchemaRegistry,
+    batch_id: str,
+    view: JudgeBatchView,
+    labels_by_target: Mapping[str, str],
+    confidence: float = 0.9,
+):
+    return record_calibration_batch(
+        conn,
+        schema=schema,
+        registry=registry,
+        batch_id=batch_id,
+        labels=tuple(
+            CalibrationLabelInput(
+                item_id=item.item_id,
+                value={"label": labels_by_target[item.target_ref]},
+                confidence=confidence,
+            )
+            for item in view.items
+        ),
+        now_ms=300,
+    )
+
+
+def _assert_no_masked_key(value: object) -> None:
+    if isinstance(value, dict):
+        assert not (set(value) & _EXPECTED_CALIBRATION_MASK)
+        for item in value.values():
+            _assert_no_masked_key(item)
+    elif isinstance(value, list):
+        for item in value:
+            _assert_no_masked_key(item)
+
