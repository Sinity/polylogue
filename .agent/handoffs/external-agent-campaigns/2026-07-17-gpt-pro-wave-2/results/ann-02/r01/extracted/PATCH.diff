new file mode 100644
index 000000000..32451b89e
--- /dev/null
+++ b/polylogue/annotations/calibration.py
@@ -0,0 +1,2442 @@
+"""Blinded gold injection and durable calibration products for annotations.
+
+The annotation substrate deliberately keeps labels in the unified
+``assertions`` table and provenance in ``annotation_batches``. This module adds
+no parallel label, judge, or report store. It introduces three assertion
+vocabularies over that substrate:
+
+``annotation_gold``
+    Operator-authored, immutable gold answers bound to an existing versioned
+    :class:`~polylogue.annotations.schema.AnnotationSchema`.
+``annotation_assignment``
+    A private assignment receipt that records deterministic gold selection,
+    randomized order, and exact judge/context refs. The judge receives a
+    separately shaped :class:`JudgeBatchView`; the receipt is never part of
+    that view.
+``annotation_measure``
+    Deterministic per-construct agreement, gold accuracy, confidence
+    calibration, and drift products scoped to one ``annotation-batch:<id>``.
+
+Every preserve/read/write boundary in this module owns a ``BEGIN IMMEDIATE``
+transaction. This is intentional: the generic assertion upsert currently has a
+known read-before-write TOCTOU hazard (polylogue-41ow), so calibration writes do
+not rely on a caller's timing or on judge goodwill for correctness.
+"""
+
+from __future__ import annotations
+
+import json
+import re
+import sqlite3
+from collections import Counter, defaultdict
+from collections.abc import Callable, Iterator, Mapping, Sequence
+from contextlib import contextmanager
+from dataclasses import dataclass
+from math import isfinite
+from typing import Literal, cast
+
+from polylogue.annotations.batch import ANNOTATION_BATCH_ITEM_TARGET_REFS_KEY, AnnotationBatch
+from polylogue.annotations.schema import (
+    AnnotationField,
+    AnnotationSchema,
+    AnnotationSchemaRegistry,
+    validate_annotation_row,
+)
+from polylogue.annotations.write import assertion_id_for_schema_annotation, upsert_annotation_assertion
+from polylogue.core.enums import AssertionKind, AssertionStatus, AssertionVisibility
+from polylogue.core.hashing import hash_payload
+from polylogue.core.json import JSONDocument, require_json_document
+from polylogue.core.refs import ObjectRef, normalize_object_ref_text, normalize_public_ref_text
+from polylogue.storage.sqlite.archive_tiers.user_annotations import (
+    persist_annotation_batch,
+    persist_annotation_schema,
+    read_annotation_batch,
+    read_durable_annotation_schema,
+)
+from polylogue.storage.sqlite.archive_tiers.user_write import (
+    ArchiveAssertionEnvelope,
+    read_assertion_envelope,
+    upsert_assertion,
+)
+
+ANNOTATION_GOLD_FORMAT = "polylogue.annotation-gold/v1"
+ANNOTATION_ASSIGNMENT_FORMAT = "polylogue.annotation-calibration-assignment/v1"
+ANNOTATION_MEASURE_FORMAT = "polylogue.annotation-calibration-measure/v1"
+ANNOTATION_CALIBRATION_BATCH_FORMAT = "polylogue.annotation-calibration-batch/v1"
+ANNOTATION_MEASURE_ALGORITHM = "polylogue.annotation-calibration-algorithm/v1"
+ANNOTATION_CALIBRATION_AUTHOR_REF = "insight:annotation-calibration@v1"
+ANNOTATION_CALIBRATION_EXECUTION_CONTEXT_KEY = "execution_context_ref"
+ANNOTATION_CALIBRATION_ASSIGNMENT_REF_KEY = "assignment_ref"
+ANNOTATION_CALIBRATION_RUBRIC_REF_KEY = "rubric_ref"
+ANNOTATION_CALIBRATION_GOLD_COUNT_KEY = "gold_count"
+ANNOTATION_CALIBRATION_ORDER_HASH_KEY = "item_order_hash"
+
+MeasurementLevel = Literal["nominal", "interval"]
+TrustState = Literal["eligible", "below_threshold", "drifting", "unknown"]
+
+# Hardcoded independently of the existing blinding constant. A mutation that
+# shrinks either list must fail a frozen-checklist test instead of shrinking the
+# test's own expectations alongside production.
+BASE_BLINDING_MASKED_FIELDS: frozenset[str] = frozenset(
+    {
+        "actor_ref",
+        "arm",
+        "author_kind",
+        "author_ref",
+        "detector_ref",
+        "execution_context_id",
+        "judge_ref",
+        "model",
+        "prior_rank",
+        "prior_score",
+        "provider",
+    }
+)
+CALIBRATION_MASKED_FIELDS: frozenset[str] = frozenset(
+    {
+        *BASE_BLINDING_MASKED_FIELDS,
+        "assignment_ref",
+        "gold_assertion_ref",
+        "gold_label",
+        "gold_set_ref",
+        "is_gold",
+        "prior_judgments",
+        "prior_labels",
+        "seed",
+    }
+)
+
+_CONTEXT_REF_KIND = "context-snapshot"
+_ACTOR_REF_KINDS = frozenset({"agent", "user"})
+_BATCH_ID_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._:-]*$")
+
+
+class AnnotationCalibrationError(ValueError):
+    """Raised when calibration provenance or values fail closed."""
+
+
+@dataclass(frozen=True, slots=True)
+class AnnotationJudgeRefs:
+    """Exact judge partition projected onto existing durable refs.
+
+    This is not a universal judge registry. ``actor_ref`` identifies the
+    durable human/agent actor, ``model_ref`` records the versioned model or the
+    human actor ref for human judgments, and ``execution_context_ref`` is a
+    content-addressed ``context-snapshot`` ref for prompt/tools/runtime/config.
+    Calibration never pools across any of these three refs.
+    """
+
+    actor_ref: str
+    model_ref: str
+    execution_context_ref: str
+
+    def __post_init__(self) -> None:
+        actor_ref = _normalized_ref(self.actor_ref, label="judge actor_ref")
+        model_ref = _normalized_ref(self.model_ref, label="judge model_ref")
+        context_ref = _normalized_ref(
+            self.execution_context_ref,
+            label="judge execution_context_ref",
+            expected_kind=_CONTEXT_REF_KIND,
+        )
+        actor_kind = ObjectRef.parse(actor_ref).kind
+        if actor_kind not in _ACTOR_REF_KINDS:
+            raise AnnotationCalibrationError("judge actor_ref must use the 'agent' or 'user' ObjectRef kind")
+        object.__setattr__(self, "actor_ref", actor_ref)
+        object.__setattr__(self, "model_ref", model_ref)
+        object.__setattr__(self, "execution_context_ref", context_ref)
+
+    @property
+    def key(self) -> tuple[str, str, str]:
+        return (self.actor_ref, self.model_ref, self.execution_context_ref)
+
+    def as_document(self) -> JSONDocument:
+        return {
+            "actor_ref": self.actor_ref,
+            "execution_context_ref": self.execution_context_ref,
+            "model_ref": self.model_ref,
+        }
+
+
+@dataclass(frozen=True, slots=True)
+class GoldAnnotationInput:
+    """One operator-authored gold item under an existing construct schema."""
+
+    gold_key: str
+    target_ref: str
+    label: Mapping[str, object]
+    evidence_refs: tuple[str, ...]
+    strata: Mapping[str, str]
+    rationale: str | None = None
+
+    def __post_init__(self) -> None:
+        if not isinstance(self.gold_key, str) or not self.gold_key.strip():
+            raise AnnotationCalibrationError("gold_key cannot be empty")
+        object.__setattr__(self, "gold_key", self.gold_key.strip())
+        if self.rationale is not None and not isinstance(self.rationale, str):
+            raise AnnotationCalibrationError("gold rationale must be a string or null")
+        object.__setattr__(self, "target_ref", _normalized_ref(self.target_ref, label="gold target_ref"))
+        object.__setattr__(
+            self,
+            "evidence_refs",
+            tuple(normalize_public_ref_text(ref) for ref in self.evidence_refs),
+        )
+        if not self.strata:
+            raise AnnotationCalibrationError("gold item must declare at least one stratum")
+        normalized_strata: dict[str, str] = {}
+        for raw_key, raw_value in self.strata.items():
+            key = str(raw_key).strip()
+            value = str(raw_value).strip()
+            if not key or not value:
+                raise AnnotationCalibrationError("gold strata keys and values must be non-empty strings")
+            if key in normalized_strata:
+                raise AnnotationCalibrationError(f"duplicate gold stratum key {key!r}")
+            normalized_strata[key] = value
+        object.__setattr__(self, "strata", normalized_strata)
+        object.__setattr__(self, "label", _detached_document(self.label, context="gold label"))
+
+
+@dataclass(frozen=True, slots=True)
+class GoldStratumQuota:
+    """Deterministic quota over exact gold-item stratum key/value filters."""
+
+    filters: Mapping[str, str]
+    count: int
+
+    def __post_init__(self) -> None:
+        if isinstance(self.count, bool) or not isinstance(self.count, int) or self.count < 1:
+            raise AnnotationCalibrationError("gold stratum quota count must be >= 1")
+        if not self.filters:
+            raise AnnotationCalibrationError("gold stratum quota must declare at least one filter")
+        normalized: dict[str, str] = {}
+        for raw_key, raw_value in self.filters.items():
+            key = str(raw_key).strip()
+            value = str(raw_value).strip()
+            if not key or not value:
+                raise AnnotationCalibrationError("gold stratum filters must be non-empty strings")
+            normalized[key] = value
+        object.__setattr__(self, "filters", normalized)
+
+
+@dataclass(frozen=True, slots=True)
+class CalibrationSourceItem:
+    """Archive material admitted to the exact judge-facing projection."""
+
+    target_ref: str
+    evidence_refs: tuple[str, ...]
+    presentation: Mapping[str, object]
+
+    def __post_init__(self) -> None:
+        object.__setattr__(self, "target_ref", _normalized_ref(self.target_ref, label="item target_ref"))
+        object.__setattr__(
+            self,
+            "evidence_refs",
+            tuple(normalize_public_ref_text(ref) for ref in self.evidence_refs),
+        )
+        presentation = _detached_document(self.presentation, context="calibration item presentation")
+        leaked_keys = _recursive_key_intersection(presentation, CALIBRATION_MASKED_FIELDS)
+        if leaked_keys:
+            raise AnnotationCalibrationError(
+                f"calibration item presentation contains forbidden provenance keys: {sorted(leaked_keys)}"
+            )
+        object.__setattr__(self, "presentation", presentation)
+
+
+@dataclass(frozen=True, slots=True)
+class CalibrationCompositionRequest:
+    """Complete deterministic request for one blinded multi-item assignment."""
+
+    batch_id: str
+    schema_id: str
+    schema_version: int
+    source_result_ref: str
+    judge: AnnotationJudgeRefs
+    prompt_ref: str
+    rubric_ref: str
+    ordinary_items: tuple[CalibrationSourceItem, ...]
+    gold_set_ref: str
+    gold_count: int = 0
+    gold_strata: tuple[GoldStratumQuota, ...] = ()
+    seed: str = ""
+    created_at_ms: int = 0
+
+    def __post_init__(self) -> None:
+        if not isinstance(self.batch_id, str) or not _BATCH_ID_RE.fullmatch(self.batch_id):
+            raise AnnotationCalibrationError("batch_id must form a stable annotation-batch ObjectRef")
+        if (
+            not isinstance(self.schema_id, str)
+            or not self.schema_id.strip()
+            or isinstance(self.schema_version, bool)
+            or not isinstance(self.schema_version, int)
+            or self.schema_version < 1
+        ):
+            raise AnnotationCalibrationError("schema identity must be schema_id plus version >= 1")
+        if isinstance(self.gold_count, bool) or not isinstance(self.gold_count, int) or self.gold_count < 0:
+            raise AnnotationCalibrationError("gold_count cannot be negative")
+        if (
+            isinstance(self.created_at_ms, bool)
+            or not isinstance(self.created_at_ms, int)
+            or self.created_at_ms < 0
+        ):
+            raise AnnotationCalibrationError("created_at_ms cannot be negative")
+        if not isinstance(self.seed, str) or not self.seed:
+            raise AnnotationCalibrationError("composition seed must be explicit")
+        object.__setattr__(
+            self,
+            "source_result_ref",
+            _normalized_ref(self.source_result_ref, label="source_result_ref", expected_kind="result-set"),
+        )
+        object.__setattr__(self, "prompt_ref", _normalized_ref(self.prompt_ref, label="prompt_ref"))
+        object.__setattr__(self, "rubric_ref", _normalized_ref(self.rubric_ref, label="rubric_ref"))
+        object.__setattr__(self, "gold_set_ref", _normalized_ref(self.gold_set_ref, label="gold_set_ref"))
+        ordinary_targets = [item.target_ref for item in self.ordinary_items]
+        if len(ordinary_targets) != len(set(ordinary_targets)):
+            raise AnnotationCalibrationError("ordinary calibration item target_refs must be unique")
+        quota_total = sum(quota.count for quota in self.gold_strata)
+        if self.gold_strata and self.gold_count not in (0, quota_total):
+            raise AnnotationCalibrationError("gold_count must be zero or equal the sum of gold_strata quotas")
+        if not self.ordinary_items and max(self.gold_count, quota_total) == 0:
+            raise AnnotationCalibrationError("calibration assignment cannot be empty")
+
+    @property
+    def requested_gold_count(self) -> int:
+        return sum(quota.count for quota in self.gold_strata) if self.gold_strata else self.gold_count
+
+    @property
+    def batch_ref(self) -> str:
+        return f"annotation-batch:{self.batch_id}"
+
+
+@dataclass(frozen=True, slots=True)
+class JudgeItemView:
+    """Only item fields exposed to a judge before a verdict is recorded."""
+
+    item_id: str
+    target_ref: str
+    evidence_refs: tuple[str, ...]
+    presentation: JSONDocument
+
+    def as_document(self) -> JSONDocument:
+        return {
+            "evidence_refs": list(self.evidence_refs),
+            "item_id": self.item_id,
+            "presentation": self.presentation,
+            "target_ref": self.target_ref,
+        }
+
+
+@dataclass(frozen=True, slots=True)
+class JudgeBatchView:
+    """The exact pre-verdict surface: no labels, authors, gold marks, or scores."""
+
+    batch_ref: str
+    qualified_schema_id: str
+    rubric_ref: str
+    items: tuple[JudgeItemView, ...]
+    item_order_hash: str
+
+    def as_document(self) -> JSONDocument:
+        return {
+            "batch_ref": self.batch_ref,
+            "item_order_hash": self.item_order_hash,
+            "items": [item.as_document() for item in self.items],
+            "qualified_schema_id": self.qualified_schema_id,
+            "rubric_ref": self.rubric_ref,
+        }
+
+
+@dataclass(frozen=True, slots=True)
+class ComposedCalibrationBatch:
+    """Private assignment ref plus the separately shaped judge-facing view."""
+
+    assignment_ref: str
+    judge_view: JudgeBatchView
+
+
+@dataclass(frozen=True, slots=True)
+class CalibrationLabelInput:
+    """One judge response keyed only by opaque assignment item id."""
+
+    item_id: str
+    value: Mapping[str, object]
+    confidence: float | None = None
+    body_text: str | None = None
+
+    def __post_init__(self) -> None:
+        if not self.item_id.strip():
+            raise AnnotationCalibrationError("calibration label item_id cannot be empty")
+        if self.confidence is not None:
+            if (
+                isinstance(self.confidence, bool)
+                or not isinstance(self.confidence, (int, float))
+                or not isfinite(float(self.confidence))
+                or not 0.0 <= float(self.confidence) <= 1.0
+            ):
+                raise AnnotationCalibrationError("calibration label confidence must be finite and in [0, 1]")
+            object.__setattr__(self, "confidence", float(self.confidence))
+        object.__setattr__(self, "value", _detached_document(self.value, context="calibration label value"))
+
