+        peer_batch_ids=(third.batch_id, second.batch_id),
+        constructs=("label",),
+        now_ms=500,
+    )[0]
+    reverse_order = materialize_calibration_measures(
+        user_conn,
+        batch_id=current.batch_id,
+        peer_batch_ids=(second.batch_id, third.batch_id),
+        constructs=("label",),
+        now_ms=501,
+    )[0]
+    assert reverse_order.assertion_id == first_order.assertion_id
+    assert cast(dict[str, object], reverse_order.value)["measured_at_ms"] == 500
+    agreement = cast(dict[str, object], cast(dict[str, object], first_order.value)["agreement"])
+    assert agreement["peer_batch_refs"] == sorted((second.batch_ref, third.batch_ref))
+
+    future_view = _compose(
+        user_conn,
+        schema=schema,
+        judge=current_judge,
+        batch_id="canonical-future",
+        created_at_ms=400,
+    )
+    future = _record(
+        user_conn,
+        schema=schema,
+        registry=registry,
+        batch_id="canonical-future",
+        view=future_view,
+        labels_by_target=labels,
+    )
+    with pytest.raises(AnnotationCalibrationError, match="baseline cannot be newer"):
+        materialize_calibration_measures(
+            user_conn,
+            batch_id=current.batch_id,
+            baseline_batch_id=future.batch_id,
+            constructs=("label",),
+            now_ms=600,
+        )
