+def test_recording_is_immediate_and_cannot_overwrite_operator_judgment(user_conn: sqlite3.Connection) -> None:
+    schema = _schema()
+    registry = _registry(schema)
+    _author_gold(user_conn, schema=schema, registry=registry)
+    judge = AnnotationJudgeRefs("agent:judge-authority", "agent:model-v1", "context-snapshot:ctx-authority")
+    view = _compose(user_conn, schema=schema, judge=judge, batch_id="authority")
+    labels_by_target = {"session:s1": "A", "session:s2": "A", "session:s3": "B"}
+
+    trace: list[str] = []
+    user_conn.set_trace_callback(trace.append)
+    batch = _record(
+        user_conn,
+        schema=schema,
+        registry=registry,
+        batch_id="authority",
+        view=view,
+        labels_by_target=labels_by_target,
+    )
+    user_conn.set_trace_callback(None)
+    first_statement = next(statement for statement in trace if statement.strip())
+    assert first_statement.upper().startswith("BEGIN IMMEDIATE")
+    assert batch.item_target_refs == tuple(item.target_ref for item in view.items)
+
+    candidate_ref = batch.assertion_refs[0]
+    candidate = read_assertion_envelope(user_conn, candidate_ref.removeprefix("assertion:"))
+    assert candidate is not None
+    assert candidate.status is AssertionStatus.CANDIDATE
+    accepted_value = candidate.value
+    accepted_item_id = candidate.key
+    database_path = Path(str(user_conn.execute("PRAGMA database_list").fetchone()[2]))
+    operator_ready = threading.Event()
+    operator_judged = threading.Event()
+    release_operator = threading.Event()
+    replay_ready = threading.Event()
+    replay_begin_seen = threading.Event()
+    replay_done = threading.Event()
+    operator_result: Queue[BaseException | None] = Queue()
+    replay_result: Queue[BaseException | None] = Queue()
+
+    def operator_write() -> None:
+        operator_conn: sqlite3.Connection | None = None
+        try:
+            operator_conn = open_connection(database_path)
+            operator_ready.set()
+            operator_conn.execute("BEGIN IMMEDIATE")
+            judge_assertion_candidate(
+                operator_conn,
+                candidate_ref=candidate_ref,
+                decision="accept",
+                actor_ref="user:operator",
+                now_ms=500,
+            )
+            operator_judged.set()
+            if not release_operator.wait(5):
+                raise AssertionError("test did not release the operator transaction")
+            operator_conn.commit()
+            operator_result.put(None)
+        except BaseException as exc:
+            if operator_conn is not None:
+                operator_conn.rollback()
+            operator_result.put(exc)
+            operator_judged.set()
+        finally:
+            operator_ready.set()
+            if operator_conn is not None:
+                operator_conn.close()
+
+    def replay_agent_batch() -> None:
+        replay_conn: sqlite3.Connection | None = None
+        try:
+            replay_conn = open_connection(database_path)
+            replay_conn.set_trace_callback(
+                lambda statement: replay_begin_seen.set()
+                if statement.strip().upper().startswith("BEGIN IMMEDIATE")
+                else None
+            )
+            replay_ready.set()
+            _record(
+                replay_conn,
+                schema=schema,
+                registry=registry,
+                batch_id="authority",
+                view=view,
+                labels_by_target=labels_by_target,
+            )
+            replay_result.put(None)
+        except BaseException as exc:
+            replay_result.put(exc)
+        finally:
+            replay_ready.set()
+            replay_done.set()
+            if replay_conn is not None:
+                replay_conn.close()
+
+    operator_thread = threading.Thread(target=operator_write, name="calibration-operator-write")
+    replay_thread = threading.Thread(target=replay_agent_batch, name="calibration-agent-replay")
+    operator_thread.start()
+    assert operator_ready.wait(5)
+    assert operator_judged.wait(5)
+    replay_thread.start()
+    assert replay_ready.wait(5)
+    assert replay_begin_seen.wait(5)
+    assert not replay_done.wait(0.1), "agent replay did not wait behind BEGIN IMMEDIATE"
+    release_operator.set()
+    operator_thread.join(5)
+    replay_thread.join(5)
+    assert not operator_thread.is_alive()
+    assert not replay_thread.is_alive()
+    operator_error = operator_result.get(timeout=1)
+    replay_error = replay_result.get(timeout=1)
+    if operator_error is not None:
+        raise operator_error
+    if replay_error is not None:
+        raise replay_error
+
+    # The blocked, byte-identical retry starts after the operator commit and
+    # therefore observes and preserves the terminal operator outcome.
+    preserved = read_assertion_envelope(user_conn, candidate_ref.removeprefix("assertion:"))
+    assert preserved is not None
+    assert preserved.status is AssertionStatus.ACCEPTED
+    assert preserved.value == accepted_value
+
+    # A changed replay for the accepted item fails the batched immutable-input
+    # check and rolls back the whole immediate transaction.
+    changed_labels = dict(labels_by_target)
+    accepted_view_item = next(item for item in view.items if item.item_id == accepted_item_id)
+    changed_labels[accepted_view_item.target_ref] = (
+        "B" if labels_by_target[accepted_view_item.target_ref] == "A" else "A"
+    )
+    with pytest.raises(AnnotationValidationError, match="immutable input drift"):
+        _record(
+            user_conn,
+            schema=schema,
+            registry=registry,
+            batch_id="authority",
+            view=view,
+            labels_by_target=changed_labels,
+        )
+    after_attack = read_assertion_envelope(user_conn, candidate_ref.removeprefix("assertion:"))
+    assert after_attack is not None
+    assert after_attack.status is AssertionStatus.ACCEPTED
+    assert after_attack.value == accepted_value
