+def test_measures_are_batch_scoped_queryable_and_context_exact(user_conn: sqlite3.Connection) -> None:
+    schema = _schema()
+    registry = _registry(schema)
+    _author_gold(user_conn, schema=schema, registry=registry)
+
+    judge_one = AnnotationJudgeRefs("agent:judge-1", "agent:model-v1", "context-snapshot:ctx-1")
+    judge_two = AnnotationJudgeRefs("agent:judge-2", "agent:model-v1", "context-snapshot:ctx-2")
+    first_view = _compose(user_conn, schema=schema, judge=judge_one, batch_id="judge-one-baseline")
+    second_view = _compose(user_conn, schema=schema, judge=judge_two, batch_id="judge-two-peer")
+    first = _record(
+        user_conn,
+        schema=schema,
+        registry=registry,
+        batch_id="judge-one-baseline",
+        view=first_view,
+        labels_by_target={"session:s1": "A", "session:s2": "A", "session:s3": "B"},
+    )
+    second = _record(
+        user_conn,
+        schema=schema,
+        registry=registry,
+        batch_id="judge-two-peer",
+        view=second_view,
+        labels_by_target={"session:s1": "A", "session:s2": "B", "session:s3": "B"},
+    )
+
+    measures = materialize_calibration_measures(
+        user_conn,
+        batch_id=first.batch_id,
+        peer_batch_ids=(second.batch_id,),
+        constructs=("label",),
+        bucket_count=10,
+        now_ms=500,
+    )
+    assert len(measures) == 1
+    measure = measures[0]
+    assert measure.kind is AssertionKind.ANNOTATION_MEASURE
+    assert measure.scope_ref == measure.target_ref == first.batch_ref
+    assert measure.visibility is AssertionVisibility.PRIVATE
+    assert measure.context_policy.get("inject") is False
+    value = cast(dict[str, object], measure.value)
+    assert value["format"] == ANNOTATION_MEASURE_FORMAT
+    assert value["measured_at_ms"] == 500
+    agreement = cast(dict[str, object], value["agreement"])
+    gold = cast(dict[str, object], value["gold"])
+    calibration = cast(dict[str, object], value["calibration"])
+    assert agreement["alpha"] == pytest.approx(4 / 9)
+    assert agreement["n_pairable_units"] == 3
+    assert gold["accuracy"] == 1.0
+    assert gold["n_assigned"] == gold["n_overlap"] == 3
+    assert gold["label_distribution"] == {'"A"': pytest.approx(2 / 3), '"B"': pytest.approx(1 / 3)}
+    assert calibration["brier_score"] == pytest.approx(0.01)
+    assert calibration["expected_calibration_error"] == pytest.approx(0.1)
+    assert len(cast(list[object], calibration["buckets"])) == 10
+
+    recomputed = materialize_calibration_measures(
+        user_conn,
+        batch_id=first.batch_id,
+        peer_batch_ids=(second.batch_id,),
+        constructs=("label",),
+        bucket_count=10,
+        now_ms=501,
+    )[0]
+    assert recomputed.assertion_id == measure.assertion_id
+    assert cast(dict[str, object], recomputed.value)["measured_at_ms"] == 500
+
+    eligible = query_judge_trust(
+        user_conn,
+        schema_id=schema.schema_id,
+        schema_version=schema.version,
+        construct="label",
+        judge=judge_one,
+        minimum_gold=3,
+        minimum_confident_gold=3,
+        maximum_expected_calibration_error=0.11,
+    )
+    assert len(eligible) == 1
+    assert eligible[0].state == "eligible"
+    assert eligible[0].batch_ref == first.batch_ref
+    assert eligible[0].measured_at_ms == 500
+
+    unseen_context = query_judge_trust(
+        user_conn,
+        schema_id=schema.schema_id,
+        schema_version=schema.version,
+        construct="label",
+        judge=AnnotationJudgeRefs("agent:judge-1", "agent:model-v1", "context-snapshot:ctx-unseen"),
+        minimum_gold=3,
+        minimum_confident_gold=3,
+    )
+    assert unseen_context[0].state == "unknown"
+    assert unseen_context[0].reasons == ("no_measure",)
+    assert unseen_context[0].batch_ref is None
+
+    # A later batch for the exact same judge/context is compared to the
+    # baseline and becomes the latest trust product for that exact partition.
+    drift_view = _compose(
+        user_conn,
+        schema=schema,
+        judge=judge_one,
+        batch_id="judge-one-drift",
+        created_at_ms=250,
+    )
+    drift_batch = _record(
+        user_conn,
+        schema=schema,
+        registry=registry,
+        batch_id="judge-one-drift",
+        view=drift_view,
+        labels_by_target={"session:s1": "B", "session:s2": "B", "session:s3": "A"},
+    )
+    drift_measure = materialize_calibration_measures(
+        user_conn,
+        batch_id=drift_batch.batch_id,
+        baseline_batch_id=first.batch_id,
+        constructs=("label",),
+        now_ms=600,
+    )[0]
+    drift_value = cast(dict[str, object], drift_measure.value)
+    drift = cast(dict[str, object], drift_value["drift"])
+    assert drift["alert"] is True
+    assert "accuracy_drop" in cast(list[str], drift["reasons"])
+    assert "brier_increase" in cast(list[str], drift["reasons"])
+
+    # A later analysis run over the older batch (with changed bucket
+    # parameters, hence a distinct product) must not make old calibration
+    # provenance look newer than the later judged batch.
+    historical_reanalysis = materialize_calibration_measures(
+        user_conn,
+        batch_id=first.batch_id,
+        peer_batch_ids=(second.batch_id,),
+        constructs=("label",),
+        bucket_count=5,
+        now_ms=700,
+    )[0]
+    assert historical_reanalysis.assertion_id != measure.assertion_id
+
+    latest = query_judge_trust(
+        user_conn,
+        schema_id=schema.schema_id,
+        schema_version=schema.version,
+        construct="label",
+        judge=judge_one,
+        minimum_gold=3,
+        minimum_confident_gold=3,
+        maximum_expected_calibration_error=1.0,
+    )
+    assert latest[0].state == "drifting"
+    assert latest[0].batch_ref == drift_batch.batch_ref
+
+    # The query surface fails closed if a durable calibration product is
+    # subsequently made public or otherwise policy-mutated out of band.
+    user_conn.execute(
+        "UPDATE assertions SET visibility = 'public' WHERE assertion_id = ?",
+        (drift_measure.assertion_id,),
+    )
+    user_conn.commit()
+    with pytest.raises(AnnotationCalibrationError, match="private and non-injectable"):
+        query_judge_trust(
+            user_conn,
+            schema_id=schema.schema_id,
+            schema_version=schema.version,
+            construct="label",
+            judge=judge_one,
+            minimum_gold=3,
+            minimum_confident_gold=3,
+        )
