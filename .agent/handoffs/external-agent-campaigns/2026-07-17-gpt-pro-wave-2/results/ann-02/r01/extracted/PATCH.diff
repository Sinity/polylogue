+def _normalized_ref(value: str, *, label: str, expected_kind: str | None = None) -> str:
+    try:
+        normalized = normalize_object_ref_text(value)
+        parsed = ObjectRef.parse(normalized)
+    except ValueError as exc:
+        raise AnnotationCalibrationError(f"{label} must be a valid ObjectRef") from exc
+    if expected_kind is not None and parsed.kind != expected_kind:
+        raise AnnotationCalibrationError(f"{label} must use the {expected_kind!r} ObjectRef kind")
+    return normalized
+
+
+def _detached_document(value: Mapping[str, object], *, context: str) -> JSONDocument:
+    try:
+        encoded = json.dumps(value, allow_nan=False, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+        return require_json_document(json.loads(encoded), context=context)
+    except (TypeError, ValueError, UnicodeEncodeError) as exc:
+        raise AnnotationCalibrationError(f"{context} must be a finite JSON object") from exc
+
+
+def _canonical_json(value: object) -> str:
+    return json.dumps(value, allow_nan=False, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+
+
+def _normalized_provenance_key(value: object) -> str:
+    # Compare a separator-free, case-folded fingerprint so common JSON naming
+    # variants (``prior_labels``, ``Prior-Labels``, ``priorLabels``) cannot
+    # bypass the composition boundary. Matching only exact snake_case keys
+    # would make the recursive defense materially weaker than its contract.
+    return re.sub(r"[^a-z0-9]+", "", str(value).casefold())
+
+
+def _recursive_key_intersection(value: object, forbidden: frozenset[str]) -> frozenset[str]:
+    found: set[str] = set()
+    forbidden_fingerprints = {_normalized_provenance_key(item) for item in forbidden}
+    if isinstance(value, Mapping):
+        for raw_key, item in value.items():
+            key = str(raw_key)
+            if _normalized_provenance_key(key) in forbidden_fingerprints:
+                found.add(key)
+            found.update(_recursive_key_intersection(item, forbidden))
+    elif isinstance(value, Sequence) and not isinstance(value, (str, bytes)):
+        for item in value:
+            found.update(_recursive_key_intersection(item, forbidden))
+    return frozenset(found)
+
+
+@contextmanager
+def _immediate_transaction(conn: sqlite3.Connection) -> Iterator[None]:
+    """Own one preserve/write transaction; nested/deferred callers fail closed."""
+
+    if conn.in_transaction:
+        raise AnnotationCalibrationError("calibration writes must start outside an existing transaction")
+    conn.execute("BEGIN IMMEDIATE")
+    try:
+        yield
+    except BaseException:
+        conn.rollback()
+        raise
+    else:
+        conn.commit()
+
+
+def _gold_assertion_id(*, gold_set_ref: str, schema_qualified_id: str, gold_key: str, target_ref: str) -> str:
+    digest = hash_payload(
+        {
+            "gold_key": gold_key,
+            "gold_set_ref": gold_set_ref,
+            "schema": schema_qualified_id,
+            "target_ref": target_ref,
+        }
+    )
+    return f"assertion-annotation-gold:{digest}"
+
+
+def _assignment_assertion_id(batch_ref: str) -> str:
+    return f"assertion-annotation-assignment:{hash_payload({'batch_ref': batch_ref})}"
+
+
+def _measure_assertion_id(*, batch_ref: str, construct: str, input_digest: str) -> str:
+    digest = hash_payload(
+        {
+            "batch_ref": batch_ref,
+            "construct": construct,
+            "input": input_digest,
+        }
+    )
+    return f"assertion-annotation-measure:{digest}"
+
+
+def _assert_immutable_replay(
+    existing: ArchiveAssertionEnvelope,
+    *,
+    candidate: Mapping[str, object],
+    allowed_statuses: frozenset[AssertionStatus] = frozenset({AssertionStatus.ACTIVE}),
+) -> None:
+    stored = {
+        "author_kind": existing.author_kind,
+        "author_ref": existing.author_ref,
+        "body_text": existing.body_text,
+        "confidence": existing.confidence,
+        "evidence_refs": existing.evidence_refs,
+        "key": existing.key,
+        "kind": existing.kind.value,
+        "scope_ref": existing.scope_ref,
+        "target_ref": existing.target_ref,
+        "value": existing.value,
+    }
+    if _canonical_json(stored) != _canonical_json(candidate):
+        raise AnnotationCalibrationError(
+            f"assertion {existing.assertion_id!r} already exists with incompatible provenance"
+        )
+    if existing.status not in allowed_statuses:
+        raise AnnotationCalibrationError(
+            f"assertion {existing.assertion_id!r} has unsupported status {existing.status.value!r}"
+        )
+    if existing.visibility is not AssertionVisibility.PRIVATE:
+        raise AnnotationCalibrationError(f"assertion {existing.assertion_id!r} must remain private")
+    if existing.context_policy.get("inject") is not False:
+        raise AnnotationCalibrationError(f"assertion {existing.assertion_id!r} must remain non-injectable")
+    if existing.context_policy.get("promotion_required") is not False:
+        raise AnnotationCalibrationError(
+            f"assertion {existing.assertion_id!r} must not enter the promotion queue"
+        )
+
+
+def _gold_content_digest(envelope: ArchiveAssertionEnvelope) -> str:
+    return hash_payload(
+        {
+            "assertion_ref": f"assertion:{envelope.assertion_id}",
+            "author_kind": envelope.author_kind,
+            "author_ref": envelope.author_ref,
+            "body_text": envelope.body_text,
+            "evidence_refs": list(envelope.evidence_refs),
+            "key": envelope.key,
+            "scope_ref": envelope.scope_ref,
+            "target_ref": envelope.target_ref,
+            "value": envelope.value,
+        }
+    )
+
+
+def _validated_gold_record(
+    envelope: ArchiveAssertionEnvelope,
+    *,
+    schema: AnnotationSchema,
+    gold_set_ref: str,
+) -> _GoldRecord:
+    if envelope.kind is not AssertionKind.ANNOTATION_GOLD:
+        raise AnnotationCalibrationError(f"assertion {envelope.assertion_id!r} is not annotation gold")
+    if envelope.scope_ref != gold_set_ref:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has the wrong gold-set scope")
+    if envelope.status not in {AssertionStatus.ACTIVE, AssertionStatus.ACCEPTED}:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} is not active")
+    if envelope.visibility is not AssertionVisibility.PRIVATE or envelope.context_policy.get("inject") is not False:
+        raise AnnotationCalibrationError(
+            f"gold assertion {envelope.assertion_id!r} must remain private and non-injectable"
+        )
+    if envelope.context_policy.get("promotion_required") is not False:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} must not require promotion")
+    if envelope.author_kind != "user" or envelope.author_ref is None:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} must be user-authored")
+    try:
+        if ObjectRef.parse(envelope.author_ref).kind != "user":
+            raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has a non-user author ref")
+    except ValueError as exc:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has an invalid author ref") from exc
+    if not isinstance(envelope.value, dict):
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has a malformed payload")
+    if envelope.value.get("format") != ANNOTATION_GOLD_FORMAT:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has an unsupported format")
+    if envelope.value.get("_schema") != schema.qualified_id:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} uses a different schema version")
+    if envelope.value.get("gold_set_ref") != gold_set_ref:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} payload has the wrong gold set")
+    gold_key = envelope.value.get("gold_key")
+    if not isinstance(gold_key, str) or not gold_key or envelope.key != gold_key:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has an invalid gold key")
+    expected_id = _gold_assertion_id(
+        gold_set_ref=gold_set_ref,
+        schema_qualified_id=schema.qualified_id,
+        gold_key=gold_key,
+        target_ref=envelope.target_ref,
+    )
+    if envelope.assertion_id != expected_id:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has a non-canonical identity")
+    label = envelope.value.get("label")
+    strata = envelope.value.get("strata")
+    if not isinstance(label, dict) or not isinstance(strata, dict) or not strata:
+        raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has malformed label/strata")
+    errors = validate_annotation_row(
+        schema,
+        target_ref=envelope.target_ref,
+        value=label,
+        evidence_refs=envelope.evidence_refs,
+    )
+    if errors:
+        raise AnnotationCalibrationError(
+            f"gold assertion {envelope.assertion_id!r} violates {schema.qualified_id}: {errors}"
+        )
+    return _GoldRecord(
+        assertion_ref=f"assertion:{envelope.assertion_id}",
+        gold_key=gold_key,
+        target_ref=envelope.target_ref,
+        evidence_refs=tuple(envelope.evidence_refs),
+        label=require_json_document(label, context="stored gold label"),
+        strata=require_json_document(strata, context="stored gold strata"),
+        content_digest=_gold_content_digest(envelope),
+    )
+
+
+def author_gold_annotations(
+    conn: sqlite3.Connection,
+    *,
+    schema: AnnotationSchema,
+    registry: AnnotationSchemaRegistry,
+    gold_set_ref: str,
+    items: Sequence[GoldAnnotationInput],
+    author_ref: str = "user:local",
+    now_ms: int,
+) -> tuple[ArchiveAssertionEnvelope, ...]:
+    """Persist immutable operator gold rows under one immediate transaction."""
+
+    if isinstance(now_ms, bool) or not isinstance(now_ms, int) or now_ms < 0:
+        raise AnnotationCalibrationError("now_ms must be a non-negative integer")
+    registered = registry.require_active(schema)
+    normalized_gold_set_ref = _normalized_ref(gold_set_ref, label="gold_set_ref")
+    normalized_author_ref = _normalized_ref(author_ref, label="gold author_ref", expected_kind="user")
+    if not items:
+        raise AnnotationCalibrationError("gold authoring requires at least one item")
+    if len({item.gold_key for item in items}) != len(items):
+        raise AnnotationCalibrationError("gold keys must be unique within one authoring call")
+    if len({item.target_ref for item in items}) != len(items):
+        raise AnnotationCalibrationError("gold target_refs must be unique within one authoring call")
+
+    envelopes: list[ArchiveAssertionEnvelope] = []
+    with _immediate_transaction(conn):
+        persist_annotation_schema(conn, registered, registered_at_ms=now_ms)
+        existing_records = _gold_records(
+            conn,
+            schema=registered,
+            gold_set_ref=normalized_gold_set_ref,
+        )
+        existing_by_key = {record.gold_key: record for record in existing_records}
+        existing_by_target = {record.target_ref: record for record in existing_records}
+        for item in items:
+            expected_assertion_id = _gold_assertion_id(
+                gold_set_ref=normalized_gold_set_ref,
+                schema_qualified_id=registered.qualified_id,
+                gold_key=item.gold_key,
+                target_ref=item.target_ref,
+            )
+            expected_ref = f"assertion:{expected_assertion_id}"
+            key_collision = existing_by_key.get(item.gold_key)
+            if key_collision is not None and key_collision.assertion_ref != expected_ref:
+                raise AnnotationCalibrationError(
+                    f"gold key {item.gold_key!r} already identifies {key_collision.target_ref!r}"
+                )
+            target_collision = existing_by_target.get(item.target_ref)
+            if target_collision is not None and target_collision.assertion_ref != expected_ref:
+                raise AnnotationCalibrationError(
+                    f"gold target {item.target_ref!r} already uses key {target_collision.gold_key!r}"
+                )
+            errors = validate_annotation_row(
+                registered,
+                target_ref=item.target_ref,
+                value=item.label,
+                evidence_refs=item.evidence_refs,
+            )
+            if errors:
+                raise AnnotationCalibrationError(
+                    f"gold item {item.gold_key!r} violates {registered.qualified_id}: {errors}"
+                )
+            value: JSONDocument = {
+                "_schema": registered.qualified_id,
+                "format": ANNOTATION_GOLD_FORMAT,
+                "gold_key": item.gold_key,
+                "gold_set_ref": normalized_gold_set_ref,
+                "label": cast(JSONDocument, item.label),
+                "strata": cast(JSONDocument, item.strata),
+            }
+            if item.rationale is not None:
+                value["rationale"] = item.rationale
+            assertion_id = _gold_assertion_id(
+                gold_set_ref=normalized_gold_set_ref,
+                schema_qualified_id=registered.qualified_id,
+                gold_key=item.gold_key,
+                target_ref=item.target_ref,
+            )
+            candidate = {
+                "author_kind": "user",
+                "author_ref": normalized_author_ref,
+                "body_text": item.rationale,
+                "confidence": None,
+                "evidence_refs": list(item.evidence_refs),
+                "key": item.gold_key,
+                "kind": AssertionKind.ANNOTATION_GOLD.value,
+                "scope_ref": normalized_gold_set_ref,
+                "target_ref": item.target_ref,
+                "value": value,
+            }
+            existing = read_assertion_envelope(conn, assertion_id)
+            if existing is not None:
+                _assert_immutable_replay(
+                    existing,
+                    candidate=candidate,
+                    allowed_statuses=frozenset({AssertionStatus.ACTIVE, AssertionStatus.ACCEPTED}),
+                )
+                envelopes.append(existing)
+                continue
+            envelopes.append(
+                upsert_assertion(
+                    conn,
+                    assertion_id=assertion_id,
+                    scope_ref=normalized_gold_set_ref,
+                    target_ref=item.target_ref,
+                    key=item.gold_key,
+                    kind=AssertionKind.ANNOTATION_GOLD,
+                    value=value,
+                    body_text=item.rationale,
+                    author_ref=normalized_author_ref,
+                    author_kind="user",
+                    evidence_refs=item.evidence_refs,
+                    status=AssertionStatus.ACTIVE,
+                    visibility=AssertionVisibility.PRIVATE,
+                    context_policy={"inject": False, "promotion_required": False},
+                    now_ms=now_ms,
+                )
+            )
+    return tuple(envelopes)
+
+
+def _gold_records(
+    conn: sqlite3.Connection,
+    *,
+    schema: AnnotationSchema,
+    gold_set_ref: str,
+) -> tuple[_GoldRecord, ...]:
+    records: list[_GoldRecord] = []
+    rows = conn.execute(
+        """
+        SELECT assertion_id
+        FROM assertions
+        WHERE kind = ?
+          AND scope_ref = ?
+          AND status IN (?, ?)
+        ORDER BY assertion_id
+        """,
+        (
+            AssertionKind.ANNOTATION_GOLD.value,
+            gold_set_ref,
+            AssertionStatus.ACTIVE.value,
+            AssertionStatus.ACCEPTED.value,
+        ),
+    ).fetchall()
+    by_key: dict[str, _GoldRecord] = {}
+    by_target: dict[str, _GoldRecord] = {}
+    for row in rows:
+        envelope = read_assertion_envelope(conn, str(row[0]))
+        if envelope is None:
+            raise AnnotationCalibrationError(f"gold set {gold_set_ref!r} references a missing assertion")
+        if not isinstance(envelope.value, dict):
+            raise AnnotationCalibrationError(f"gold assertion {envelope.assertion_id!r} has a malformed payload")
+        if envelope.value.get("_schema") != schema.qualified_id:
+            continue
+        record = _validated_gold_record(envelope, schema=schema, gold_set_ref=gold_set_ref)
+        previous_key = by_key.get(record.gold_key)
+        if previous_key is not None and previous_key.assertion_ref != record.assertion_ref:
+            raise AnnotationCalibrationError(
+                f"gold set {gold_set_ref!r} has duplicate key {record.gold_key!r} for {schema.qualified_id}"
+            )
+        previous_target = by_target.get(record.target_ref)
+        if previous_target is not None and previous_target.assertion_ref != record.assertion_ref:
+            raise AnnotationCalibrationError(
+                f"gold set {gold_set_ref!r} has duplicate target {record.target_ref!r} for {schema.qualified_id}"
+            )
+        by_key[record.gold_key] = record
+        by_target[record.target_ref] = record
+        records.append(record)
+    return tuple(records)
+
+
+def _selection_rank(
+    request: CalibrationCompositionRequest,
+    *,
+    phase: str,
+    identity: str,
+) -> str:
+    return hash_payload(
+        {
+            "batch_ref": request.batch_ref,
+            "identity": identity,
+            "phase": phase,
+            "seed": request.seed,
+        }
+    )
+
+
+def _select_gold(
+    records: Sequence[_GoldRecord],
+    *,
+    request: CalibrationCompositionRequest,
+) -> tuple[_GoldRecord, ...]:
+    ordinary_targets = {item.target_ref for item in request.ordinary_items}
+    available = [record for record in records if record.target_ref not in ordinary_targets]
+    selected: list[_GoldRecord] = []
+    selected_refs: set[str] = set()
+
+    if request.gold_strata:
+        for quota_index, quota in enumerate(request.gold_strata):
+            matches = [
+                record
+                for record in available
+                if record.assertion_ref not in selected_refs
+                and all(record.strata.get(key) == value for key, value in quota.filters.items())
+            ]
+            phase = f"gold-stratum:{quota_index}:{_canonical_json(dict(quota.filters))}"
+            matches.sort(
+                key=lambda record, selection_phase=phase: (
+                    _selection_rank(request, phase=selection_phase, identity=record.assertion_ref),
+                    record.assertion_ref,
+                )
+            )
+            if len(matches) < quota.count:
+                raise AnnotationCalibrationError(
+                    f"gold stratum {dict(quota.filters)!r} requested {quota.count}, only {len(matches)} available"
+                )
+            for record in matches[: quota.count]:
+                selected.append(record)
+                selected_refs.add(record.assertion_ref)
+    else:
+        available.sort(
+            key=lambda record: (
+                _selection_rank(request, phase="gold-unstratified", identity=record.assertion_ref),
+                record.assertion_ref,
+            )
+        )
+        if len(available) < request.gold_count:
+            raise AnnotationCalibrationError(
+                f"gold_count requested {request.gold_count}, only {len(available)} non-overlapping gold items available"
+            )
+        selected.extend(available[: request.gold_count])
+
+    if len({record.target_ref for record in selected}) != len(selected):
+        raise AnnotationCalibrationError("selected gold items must have unique target_refs")
+    return tuple(selected)
+
+
+def _item_id(*, batch_ref: str, target_ref: str) -> str:
+    return f"item-{hash_payload({'batch_ref': batch_ref, 'target_ref': target_ref})[:24]}"
+
+
+def compose_calibration_batch(
+    conn: sqlite3.Connection,
+    *,
+    request: CalibrationCompositionRequest,
+    item_loader: ItemLoader,
+) -> ComposedCalibrationBatch:
+    """Select/inject gold and persist a private receipt, returning only a blind view.
+
+    The only assertion vocabulary read for selection is ``annotation_gold``.
+    Existing ``annotation`` labels and ``judgment`` rows are never joined into
+    the source records. The judge-facing DTO is constructed from explicit
+    fields after :func:`blind_items` and a recursive forbidden-key check. Gold
+    selection, item loading, receipt construction, and preserve/write execute
+    under one ``BEGIN IMMEDIATE`` transaction so the assignment cannot bind a
+    gold snapshot different from the one it selected.
+    """
+
+    from polylogue.insights.judgment.blinding import (
+        DEFAULT_MASKED_PROVENANCE_FIELDS,
+        assert_no_leak,
+        blind_items,
+    )
+
+    with _immediate_transaction(conn):
+        durable_schema = read_durable_annotation_schema(conn, request.schema_id, request.schema_version)
+        if durable_schema is None:
+            raise AnnotationCalibrationError(
+                f"unknown durable annotation schema {request.schema_id}@v{request.schema_version}"
+            )
+        schema = durable_schema.schema
+        gold_records = _gold_records(
+            conn,
+            schema=schema,
+            gold_set_ref=request.gold_set_ref,
+        )
+        selected_gold = _select_gold(gold_records, request=request)
+
+        source_items: list[tuple[CalibrationSourceItem, _GoldRecord | None]] = [
+            (item, None) for item in request.ordinary_items
+        ]
+        for gold in selected_gold:
+            loaded = item_loader(gold.target_ref, gold.evidence_refs)
+            if loaded.target_ref != gold.target_ref:
+                raise AnnotationCalibrationError("gold item loader changed target_ref")
+            if tuple(loaded.evidence_refs) != tuple(gold.evidence_refs):
+                raise AnnotationCalibrationError("gold item loader changed evidence_refs")
+            source_items.append((loaded, gold))
+        # A batch is set-valued before its deliberately randomized judge order.
+        # Canonicalizing the source set makes byte-identical replays independent
+        # of a caller's incidental ordinary-item sequence order.
+        source_items.sort(key=lambda pair: pair[0].target_ref)
+
+        incompatible_targets = [
+            item.target_ref for item, _ in source_items if not schema.accepts_target_kind(item.target_ref)
+        ]
+        if incompatible_targets:
+            raise AnnotationCalibrationError(
+                f"calibration item targets {incompatible_targets!r} are incompatible with {schema.qualified_id}"
+            )
+
+        target_refs = [item.target_ref for item, _ in source_items]
+        if len(target_refs) != len(set(target_refs)):
+            raise AnnotationCalibrationError("ordinary and selected gold target_refs must be disjoint")
+
+        raw_records: list[JSONDocument] = []
+        internal_items: list[_AssignmentItem] = []
+        for item, gold in source_items:
+            item_id = _item_id(batch_ref=request.batch_ref, target_ref=item.target_ref)
+            record: JSONDocument = {
+                "actor_ref": request.judge.actor_ref,
+                "assignment_ref": f"assertion:{_assignment_assertion_id(request.batch_ref)}",
+                "evidence_refs": list(item.evidence_refs),
+                "execution_context_id": request.judge.execution_context_ref,
+                "gold_assertion_ref": gold.assertion_ref if gold is not None else None,
+                "gold_label": gold.label if gold is not None else None,
+                "gold_set_ref": request.gold_set_ref,
+                "is_gold": gold is not None,
+                "item_id": item_id,
+                "model": request.judge.model_ref,
+                "presentation": cast(JSONDocument, item.presentation),
+                "target_ref": item.target_ref,
+            }
+            raw_records.append(record)
+            internal_items.append(
+                _AssignmentItem(
+                    item_id=item_id,
+                    target_ref=item.target_ref,
+                    evidence_refs=item.evidence_refs,
+                    presentation_digest=hash_payload(item.presentation),
+                    is_gold=gold is not None,
+                    gold_assertion_ref=gold.assertion_ref if gold is not None else None,
+                    gold_assertion_digest=gold.content_digest if gold is not None else None,
+                )
+            )
+
+        source_item_ids = [item.item_id for item in internal_items]
+        order = sorted(
+            range(len(raw_records)),
+            key=lambda index: (
+                _selection_rank(
+                    request,
+                    phase="judge-order",
+                    identity=internal_items[index].item_id,
+                ),
+                internal_items[index].item_id,
+            ),
+        )
+        blinded, receipt = blind_items(
+            raw_records,
+            order=order,
+            rubric_ref=request.rubric_ref,
+            sealed_at_ms=request.created_at_ms,
+            extra_masked_fields=tuple(CALIBRATION_MASKED_FIELDS - DEFAULT_MASKED_PROVENANCE_FIELDS),
+        )
+        assert_no_leak(blinded, masked_fields=CALIBRATION_MASKED_FIELDS)
+
+        ordered_internal = tuple(internal_items[index] for index in order)
+        view_items: list[JudgeItemView] = []
+        for item in blinded:
+            leaked_keys = _recursive_key_intersection(item.visible_fields, CALIBRATION_MASKED_FIELDS)
+            if leaked_keys:
+                raise AnnotationCalibrationError(f"blinded judge projection leaked keys: {sorted(leaked_keys)}")
+            visible = item.visible_fields
+            item_id = visible.get("item_id")
+            target_ref = visible.get("target_ref")
+            presentation = visible.get("presentation")
+            if not isinstance(item_id, str) or not isinstance(target_ref, str) or not isinstance(presentation, dict):
+                raise AnnotationCalibrationError("blinded judge projection lost a required field")
+            view_items.append(
+                JudgeItemView(
+                    item_id=item_id,
+                    target_ref=target_ref,
+                    evidence_refs=item.evidence_refs,
+                    presentation=require_json_document(presentation, context="judge item presentation"),
+                )
+            )
+
+        assignment_value: JSONDocument = {
+            "batch_ref": request.batch_ref,
+            "format": ANNOTATION_ASSIGNMENT_FORMAT,
+            "gold_count": len(selected_gold),
+            "gold_set_ref": request.gold_set_ref,
+            "item_order_hash": receipt.item_order_hash,
+            "items": [
+                {
+                    "evidence_refs": list(item.evidence_refs),
+                    "gold_assertion_digest": item.gold_assertion_digest,
+                    "gold_assertion_ref": item.gold_assertion_ref,
+                    "is_gold": item.is_gold,
+                    "item_id": item.item_id,
+                    "presentation_digest": item.presentation_digest,
+                    "target_ref": item.target_ref,
+                }
+                for item in ordered_internal
+            ],
+            "judge": request.judge.as_document(),
+            "masked_fields": list(receipt.masked_fields),
+            "prompt_ref": request.prompt_ref,
+            "qualified_schema_id": schema.qualified_id,
+            "rubric_ref": request.rubric_ref,
+            "seed": request.seed,
+            "selection": {
+                "gold_count": request.requested_gold_count,
+                "gold_strata": [
+                    {
+                        "count": quota.count,
+                        "filters": dict(quota.filters),
+                    }
+                    for quota in request.gold_strata
+                ],
+            },
+            "sealed_at_ms": receipt.sealed_at_ms,
+            "source_result_ref": request.source_result_ref,
+            "source_item_ids": source_item_ids,
+        }
+        assertion_id = _assignment_assertion_id(request.batch_ref)
+        candidate = {
+            "author_kind": "system",
+            "author_ref": ANNOTATION_CALIBRATION_AUTHOR_REF,
+            "body_text": None,
+            "confidence": None,
+            "evidence_refs": [request.source_result_ref, request.gold_set_ref],
+            "key": "composition",
+            "kind": AssertionKind.ANNOTATION_ASSIGNMENT.value,
+            "scope_ref": request.batch_ref,
+            "target_ref": request.batch_ref,
+            "value": assignment_value,
+        }
+        existing = read_assertion_envelope(conn, assertion_id)
+        if existing is not None:
+            _assert_immutable_replay(existing, candidate=candidate)
+        else:
+            upsert_assertion(
+                conn,
+                assertion_id=assertion_id,
+                scope_ref=request.batch_ref,
+                target_ref=request.batch_ref,
+                key="composition",
+                kind=AssertionKind.ANNOTATION_ASSIGNMENT,
+                value=assignment_value,
+                author_ref=ANNOTATION_CALIBRATION_AUTHOR_REF,
+                author_kind="system",
+                evidence_refs=(request.source_result_ref, request.gold_set_ref),
+                status=AssertionStatus.ACTIVE,
+                visibility=AssertionVisibility.PRIVATE,
+                context_policy={"inject": False, "promotion_required": False},
+                now_ms=request.created_at_ms,
+                require_promotion=False,
+            )
+
+        judge_view = JudgeBatchView(
+            batch_ref=request.batch_ref,
+            qualified_schema_id=schema.qualified_id,
+            rubric_ref=request.rubric_ref,
+            items=tuple(view_items),
+            item_order_hash=receipt.item_order_hash,
+        )
+        leaked_keys = _recursive_key_intersection(judge_view.as_document(), CALIBRATION_MASKED_FIELDS)
+        if leaked_keys:
+            raise AnnotationCalibrationError(f"final judge view leaked keys: {sorted(leaked_keys)}")
+
+    return ComposedCalibrationBatch(
+        assignment_ref=f"assertion:{assertion_id}",
+        judge_view=judge_view,
+    )
+
+
+def _required_mapping(value: object, *, context: str) -> Mapping[str, object]:
+    if not isinstance(value, Mapping):
+        raise AnnotationCalibrationError(f"{context} must be an object")
+    return cast(Mapping[str, object], value)
+
+
+def _required_string(value: object, *, context: str) -> str:
+    if not isinstance(value, str) or not value:
+        raise AnnotationCalibrationError(f"{context} must be a non-empty string")
+    return value
+
+
+def _read_assignment(conn: sqlite3.Connection, batch_ref: str) -> _Assignment:
+    normalized_batch_ref = _normalized_ref(batch_ref, label="batch_ref", expected_kind="annotation-batch")
+    assertion_id = _assignment_assertion_id(normalized_batch_ref)
+    envelope = read_assertion_envelope(conn, assertion_id)
+    if envelope is None or envelope.kind != AssertionKind.ANNOTATION_ASSIGNMENT:
+        raise AnnotationCalibrationError(f"missing calibration assignment for {normalized_batch_ref!r}")
+    if envelope.scope_ref != normalized_batch_ref or envelope.target_ref != normalized_batch_ref:
+        raise AnnotationCalibrationError("assignment assertion scope/target does not match batch_ref")
+    if envelope.author_ref != ANNOTATION_CALIBRATION_AUTHOR_REF or envelope.author_kind != "system":
+        raise AnnotationCalibrationError("assignment assertion has an unsupported author identity")
+    if envelope.status is not AssertionStatus.ACTIVE:
+        raise AnnotationCalibrationError("assignment assertion must remain active")
+    if envelope.key != "composition":
+        raise AnnotationCalibrationError("assignment assertion key must be 'composition'")
+    if envelope.visibility != AssertionVisibility.PRIVATE or envelope.context_policy.get("inject") is not False:
+        raise AnnotationCalibrationError("assignment assertion must remain private and non-injectable")
+    if envelope.context_policy.get("promotion_required") is not False:
+        raise AnnotationCalibrationError("assignment assertion must not require promotion")
+    value = _required_mapping(envelope.value, context="assignment value")
+    if value.get("format") != ANNOTATION_ASSIGNMENT_FORMAT:
+        raise AnnotationCalibrationError("assignment format is unsupported")
+    if value.get("batch_ref") != normalized_batch_ref:
+        raise AnnotationCalibrationError("assignment batch_ref does not match its assertion scope")
+    judge_doc = _required_mapping(value.get("judge"), context="assignment judge")
+    judge = AnnotationJudgeRefs(
+        actor_ref=_required_string(judge_doc.get("actor_ref"), context="assignment judge.actor_ref"),
+        model_ref=_required_string(judge_doc.get("model_ref"), context="assignment judge.model_ref"),
+        execution_context_ref=_required_string(
+            judge_doc.get("execution_context_ref"),
+            context="assignment judge.execution_context_ref",
+        ),
+    )
+    raw_items = value.get("items")
+    if not isinstance(raw_items, list):
+        raise AnnotationCalibrationError("assignment items must be an array")
+    raw_gold_count = value.get("gold_count")
+    if isinstance(raw_gold_count, bool) or not isinstance(raw_gold_count, int) or raw_gold_count < 0:
+        raise AnnotationCalibrationError("assignment gold_count must be a non-negative integer")
+    items: list[_AssignmentItem] = []
+    for raw in raw_items:
+        document = _required_mapping(raw, context="assignment item")
+        evidence = document.get("evidence_refs")
+        if not isinstance(evidence, list) or not all(isinstance(ref, str) for ref in evidence):
+            raise AnnotationCalibrationError("assignment item evidence_refs must be an array of strings")
+        is_gold = document.get("is_gold")
+        if not isinstance(is_gold, bool):
+            raise AnnotationCalibrationError("assignment item is_gold must be boolean")
+        raw_gold_ref = document.get("gold_assertion_ref")
+        if raw_gold_ref is not None and not isinstance(raw_gold_ref, str):
+            raise AnnotationCalibrationError("assignment item gold_assertion_ref must be a string or null")
+        raw_gold_digest = document.get("gold_assertion_digest")
+        if raw_gold_digest is not None and not isinstance(raw_gold_digest, str):
+            raise AnnotationCalibrationError("assignment item gold_assertion_digest must be a string or null")
+        if is_gold != (raw_gold_ref is not None and raw_gold_digest is not None):
+            raise AnnotationCalibrationError("assignment item gold marker and gold receipt disagree")
+        if raw_gold_ref is not None:
+            raw_gold_ref = _normalized_ref(
+                raw_gold_ref,
+                label="assignment item gold_assertion_ref",
+                expected_kind="assertion",
+            )
+        item_id = _required_string(document.get("item_id"), context="assignment item.item_id")
+        target_ref = _normalized_ref(
+            _required_string(document.get("target_ref"), context="assignment item.target_ref"),
+            label="assignment item target_ref",
+        )
+        if item_id != _item_id(batch_ref=normalized_batch_ref, target_ref=target_ref):
+            raise AnnotationCalibrationError("assignment item has a non-canonical item_id")
+        items.append(
+            _AssignmentItem(
+                item_id=item_id,
+                target_ref=target_ref,
+                evidence_refs=tuple(normalize_public_ref_text(ref) for ref in evidence),
+                presentation_digest=_required_string(
+                    document.get("presentation_digest"),
+                    context="assignment item.presentation_digest",
+                ),
+                is_gold=is_gold,
+                gold_assertion_ref=raw_gold_ref,
+                gold_assertion_digest=raw_gold_digest,
+            )
+        )
+    if not items:
+        raise AnnotationCalibrationError("assignment items cannot be empty")
+    if len({item.item_id for item in items}) != len(items):
+        raise AnnotationCalibrationError("assignment item_ids must be unique")
+    if len({item.target_ref for item in items}) != len(items):
+        raise AnnotationCalibrationError("assignment target_refs must be unique")
+    if sum(item.is_gold for item in items) != raw_gold_count:
+        raise AnnotationCalibrationError("assignment gold_count does not match its item receipts")
+    masked = value.get("masked_fields")
+    if not isinstance(masked, list) or not all(isinstance(item, str) for item in masked):
+        raise AnnotationCalibrationError("assignment masked_fields must be an array of strings")
+    if masked != sorted(set(masked)):
+        raise AnnotationCalibrationError("assignment masked_fields must be unique and sorted")
+    if not CALIBRATION_MASKED_FIELDS.issubset(masked):
+        missing = sorted(CALIBRATION_MASKED_FIELDS - set(masked))
+        raise AnnotationCalibrationError(f"assignment masked_fields omit required fields: {missing}")
+    sealed_at_ms = value.get("sealed_at_ms")
+    if isinstance(sealed_at_ms, bool) or not isinstance(sealed_at_ms, int) or sealed_at_ms < 0:
+        raise AnnotationCalibrationError("assignment sealed_at_ms must be a non-negative integer")
+    receipt = _BlindingReceipt(
+        item_order_hash=_required_string(value.get("item_order_hash"), context="assignment item_order_hash"),
+        masked_fields=tuple(masked),
+        rubric_ref=_normalized_ref(
+            _required_string(value.get("rubric_ref"), context="assignment rubric_ref"),
+            label="assignment rubric_ref",
+        ),
+        sealed_at_ms=sealed_at_ms,
+    )
+    source_item_ids = value.get("source_item_ids")
+    if not isinstance(source_item_ids, list) or not all(isinstance(item, str) for item in source_item_ids):
+        raise AnnotationCalibrationError("assignment source_item_ids must be an array of strings")
+    if len(source_item_ids) != len(set(source_item_ids)) or set(source_item_ids) != {item.item_id for item in items}:
+        raise AnnotationCalibrationError("assignment source_item_ids must be a permutation of assigned item ids")
+    source_positions = {item_id: index for index, item_id in enumerate(source_item_ids)}
+    order = [source_positions[item.item_id] for item in items]
+    if hash_payload(order) != receipt.item_order_hash:
+        raise AnnotationCalibrationError("assignment item order does not match its blinding receipt")
+    seed = _required_string(value.get("seed"), context="assignment seed")
+    selection = _required_mapping(value.get("selection"), context="assignment selection")
+    selected_gold_count = selection.get("gold_count")
+    if (
+        isinstance(selected_gold_count, bool)
+        or not isinstance(selected_gold_count, int)
+        or selected_gold_count != raw_gold_count
+    ):
+        raise AnnotationCalibrationError("assignment selection gold_count differs from the selected items")
+    raw_gold_strata = selection.get("gold_strata")
+    if not isinstance(raw_gold_strata, list):
+        raise AnnotationCalibrationError("assignment selection gold_strata must be an array")
+    quota_total = 0
+    for raw_quota in raw_gold_strata:
+        quota = _required_mapping(raw_quota, context="assignment gold stratum quota")
+        count = quota.get("count")
+        filters = quota.get("filters")
+        if isinstance(count, bool) or not isinstance(count, int) or count < 1:
+            raise AnnotationCalibrationError("assignment gold stratum quota count must be >= 1")
+        if not isinstance(filters, dict) or not filters or not all(
+            isinstance(key, str) and isinstance(item, str) and key and item for key, item in filters.items()
+        ):
+            raise AnnotationCalibrationError("assignment gold stratum quota filters must be string pairs")
+        quota_total += count
+    if raw_gold_strata and quota_total != raw_gold_count:
+        raise AnnotationCalibrationError("assignment gold stratum quotas do not sum to gold_count")
+
+    source_result_ref = _normalized_ref(
+        _required_string(value.get("source_result_ref"), context="assignment source_result_ref"),
+        label="assignment source_result_ref",
+        expected_kind="result-set",
+    )
+    gold_set_ref = _normalized_ref(
+        _required_string(value.get("gold_set_ref"), context="assignment gold_set_ref"),
+        label="assignment gold_set_ref",
+    )
+    if tuple(envelope.evidence_refs) != (source_result_ref, gold_set_ref):
+        raise AnnotationCalibrationError("assignment assertion evidence differs from its payload refs")
+    return _Assignment(
+        assertion=envelope,
+        batch_ref=normalized_batch_ref,
+        qualified_schema_id=_required_string(
+            value.get("qualified_schema_id"), context="assignment qualified_schema_id"
+        ),
+        source_result_ref=source_result_ref,
+        judge=judge,
+        prompt_ref=_normalized_ref(
+            _required_string(value.get("prompt_ref"), context="assignment prompt_ref"),
+            label="assignment prompt_ref",
+        ),
+        rubric_ref=receipt.rubric_ref,
+        gold_set_ref=gold_set_ref,
+        seed=seed,
+        items=tuple(items),
+        receipt=receipt,
+    )
+
+
+def _resolved_calibration_confidence(
+    schema: AnnotationSchema,
+    label: CalibrationLabelInput,
+) -> float | None:
+    """Resolve the assertion confidence without allowing two divergent values.
+
+    Annotation imports already treat a declared ``value.confidence`` field as
+    the analytical source of truth. Calibration recording follows the same
+    contract: a separately supplied envelope confidence may repeat that value,
+    but it may not disagree with it. This keeps Brier/reliability products tied
+    to the schema-validated judgment payload rather than an unchecked side
+    channel.
+    """
+
+    if not any(field_def.name == "confidence" for field_def in schema.fields):
+        return label.confidence
+    value_confidence = label.value.get("confidence")
+    if value_confidence is None:
+        return label.confidence
+    if (
+        isinstance(value_confidence, bool)
+        or not isinstance(value_confidence, (int, float))
+        or not isfinite(float(value_confidence))
+        or not 0.0 <= float(value_confidence) <= 1.0
+    ):
+        raise AnnotationCalibrationError("value.confidence must be finite and in [0, 1]")
+    resolved = float(value_confidence)
+    if label.confidence is not None and label.confidence != resolved:
+        raise AnnotationCalibrationError("top-level confidence must equal value.confidence")
+    return resolved
+
+
+def record_calibration_batch(
+    conn: sqlite3.Connection,
+    *,
+    schema: AnnotationSchema,
+    registry: AnnotationSchemaRegistry,
+    batch_id: str,
+    labels: Sequence[CalibrationLabelInput],
+    now_ms: int,
+) -> AnnotationBatch:
+    """Persist one complete judged packet through the existing annotation writer.
+
+    Target/evidence refs come exclusively from the private assignment receipt;
+    a judge can submit only ``item_id`` plus a schema-valid value. The batch and
+    all labels commit atomically under ``BEGIN IMMEDIATE``. Agent rows remain
+    candidates, and their ids include actor + batch, so they cannot collide
+    with operator-authored gold rows or unrelated operator judgments.
+    """
+
+    if not isinstance(batch_id, str) or not _BATCH_ID_RE.fullmatch(batch_id):
+        raise AnnotationCalibrationError("batch_id must form a stable annotation-batch ObjectRef")
+    if isinstance(now_ms, bool) or not isinstance(now_ms, int) or now_ms < 0:
+        raise AnnotationCalibrationError("now_ms must be a non-negative integer")
+    batch_ref = f"annotation-batch:{batch_id}"
+    registered = registry.require_active(schema)
+    if len({label.item_id for label in labels}) != len(labels):
+        raise AnnotationCalibrationError("calibration label item_ids must be unique")
+
+    with _immediate_transaction(conn):
+        assignment = _read_assignment(conn, batch_ref)
+        if assignment.qualified_schema_id != registered.qualified_id:
+            raise AnnotationCalibrationError(
+                f"assignment uses {assignment.qualified_schema_id!r}, not {registered.qualified_id!r}"
+            )
+        by_item_id = {label.item_id: label for label in labels}
+        expected_ids = {item.item_id for item in assignment.items}
+        if set(by_item_id) != expected_ids:
+            missing = sorted(expected_ids - set(by_item_id))
+            extra = sorted(set(by_item_id) - expected_ids)
+            raise AnnotationCalibrationError(f"calibration response item set differs: missing={missing}, extra={extra}")
+
+        assertion_ids: list[str] = []
+        confidence_by_item_id: dict[str, float | None] = {}
+        abstained_count = 0
+        for item in assignment.items:
+            label = by_item_id[item.item_id]
+            errors = validate_annotation_row(
+                registered,
+                target_ref=item.target_ref,
+                value=label.value,
+                evidence_refs=item.evidence_refs,
+            )
+            if errors:
+                raise AnnotationCalibrationError(
+                    f"calibration label {item.item_id!r} violates {registered.qualified_id}: {errors}"
+                )
+            confidence_by_item_id[item.item_id] = _resolved_calibration_confidence(registered, label)
+            if registered.abstain_field is not None and label.value.get(registered.abstain_field) is True:
+                abstained_count += 1
+            assertion_ids.append(
+                assertion_id_for_schema_annotation(
+                    schema_qualified_id=registered.qualified_id,
+                    target_ref=item.target_ref,
+                    author_ref=assignment.judge.actor_ref,
+                    row_key=item.item_id,
+                    batch_ref=batch_ref,
+                )
+            )
+
+        metadata: JSONDocument = {
+            ANNOTATION_BATCH_ITEM_TARGET_REFS_KEY: [item.target_ref for item in assignment.items],
+            ANNOTATION_CALIBRATION_ASSIGNMENT_REF_KEY: f"assertion:{assignment.assertion.assertion_id}",
+            ANNOTATION_CALIBRATION_EXECUTION_CONTEXT_KEY: assignment.judge.execution_context_ref,
+            ANNOTATION_CALIBRATION_GOLD_COUNT_KEY: sum(item.is_gold for item in assignment.items),
+            ANNOTATION_CALIBRATION_ORDER_HASH_KEY: assignment.receipt.item_order_hash,
+            ANNOTATION_CALIBRATION_RUBRIC_REF_KEY: assignment.rubric_ref,
+            "format": ANNOTATION_CALIBRATION_BATCH_FORMAT,
+            "item_ids": [item.item_id for item in assignment.items],
+        }
+        batch = AnnotationBatch(
+            batch_id=batch_id,
+            schema_id=registered.schema_id,
+            schema_version=registered.version,
+            # Heterogeneous packets use the source result-set as their
+            # collection target; item targets are immutable metadata.
+            target_ref=assignment.source_result_ref,
+            source_result_ref=assignment.source_result_ref,
+            actor_ref=assignment.judge.actor_ref,
+            model_ref=assignment.judge.model_ref,
+            prompt_ref=assignment.prompt_ref,
+            total_count=len(assignment.items),
+            valid_count=len(assignment.items),
+            invalid_count=0,
+            abstained_count=abstained_count,
+            assertion_refs=tuple(f"assertion:{assertion_id}" for assertion_id in assertion_ids),
+            metadata=metadata,
+            # The batch identity is sealed at composition time. Using the
+            # receipt timestamp keeps a later retry byte-for-byte idempotent
+            # instead of turning wall-clock retry time into provenance drift.
+            created_at_ms=assignment.receipt.sealed_at_ms,
+        )
+        persist_annotation_schema(conn, registered, registered_at_ms=now_ms)
+        persist_annotation_batch(conn, batch)
+
+        author_kind = "user" if ObjectRef.parse(assignment.judge.actor_ref).kind == "user" else "agent"
+        for item, assertion_id in zip(assignment.items, assertion_ids, strict=True):
+            label = by_item_id[item.item_id]
+            envelope = upsert_annotation_assertion(
+                conn,
+                schema=registered,
+                registry=registry,
+                target_ref=item.target_ref,
+                value=label.value,
+                row_key=item.item_id,
+                evidence_refs=item.evidence_refs,
+                author_ref=assignment.judge.actor_ref,
+                author_kind=author_kind,
+                confidence=confidence_by_item_id[item.item_id],
+                body_text=label.body_text,
+                batch_ref=batch_ref,
+                now_ms=now_ms,
+            )
+            if envelope.assertion_id != assertion_id:
+                raise AnnotationCalibrationError("annotation assertion identity drifted after batch admission")
+    return batch
+
+
+def krippendorff_alpha(
+    units: Mapping[str, Sequence[object]],
+    *,
+    level: MeasurementLevel = "nominal",
+) -> float | None:
+    """Compute Krippendorff's alpha over incomplete unit/rater observations.
+
+    ``nominal`` uses exact category identity. ``interval`` uses squared numeric
+    distance. Units with fewer than two observed ratings are excluded from both
+    observed and expected coincidence distributions. ``None`` means fewer than
+    two pairable ratings or malformed interval values; a degenerate all-equal
+    set returns ``1.0``. Invalid interval values raise
+    :class:`AnnotationCalibrationError`.
+    """
+
+    if level not in ("nominal", "interval"):
+        raise AnnotationCalibrationError(f"unsupported measurement level {level!r}")
+    pairable: list[tuple[object, ...]] = [tuple(values) for values in units.values() if len(values) >= 2]
+    all_values = [value for values in pairable for value in values]
+    if len(all_values) < 2:
+        return None
+
+    def distance(left: object, right: object) -> float:
+        if level == "nominal":
+            return 0.0 if _canonical_json(left) == _canonical_json(right) else 1.0
+        if (
+            isinstance(left, bool)
+            or isinstance(right, bool)
+            or not isinstance(left, (int, float))
+            or not isinstance(right, (int, float))
+            or not isfinite(float(left))
+            or not isfinite(float(right))
+        ):
+            raise AnnotationCalibrationError("interval alpha requires finite numeric values")
+        return (float(left) - float(right)) ** 2
+
+    observed = 0.0
+    for values in pairable:
+        denominator = len(values) - 1
+        observed += sum(
+            distance(left, right)
+            for left_index, left in enumerate(values)
+            for right_index, right in enumerate(values)
+            if left_index != right_index
+        ) / denominator
+
+    expected = sum(
+        distance(left, right)
+        for left_index, left in enumerate(all_values)
+        for right_index, right in enumerate(all_values)
+        if left_index != right_index
+    ) / (len(all_values) - 1)
+    if expected == 0.0:
+        return 1.0 if observed == 0.0 else None
+    return 1.0 - observed / expected
+
+
+def _schema_field(schema: AnnotationSchema, name: str) -> AnnotationField:
+    for field_def in schema.fields:
+        if field_def.name == name:
+            return field_def
+    raise AnnotationCalibrationError(f"construct field {name!r} is not declared by {schema.qualified_id}")
+
+
+def _batch_observation(conn: sqlite3.Connection, batch_id: str) -> _BatchObservation:
+    batch = read_annotation_batch(conn, batch_id)
+    if batch is None:
+        raise AnnotationCalibrationError(f"unknown annotation batch {batch_id!r}")
+    assignment_ref = batch.metadata.get(ANNOTATION_CALIBRATION_ASSIGNMENT_REF_KEY)
+    if not isinstance(assignment_ref, str) or not assignment_ref.startswith("assertion:"):
+        raise AnnotationCalibrationError(f"annotation batch {batch.batch_ref!r} is not a calibration batch")
+    assignment = _read_assignment(conn, batch.batch_ref)
+    expected_assignment_ref = f"assertion:{assignment.assertion.assertion_id}"
+    if assignment_ref != expected_assignment_ref:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} points at a different assignment receipt")
+    if batch.metadata.get("format") != ANNOTATION_CALIBRATION_BATCH_FORMAT:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} has an unsupported calibration format")
+    if batch.source_result_ref != assignment.source_result_ref or batch.target_ref != assignment.source_result_ref:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} source scope differs from its assignment")
+    if batch.qualified_schema_id != assignment.qualified_schema_id:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} schema differs from its assignment")
+    if (batch.actor_ref, batch.model_ref, batch.prompt_ref) != (
+        assignment.judge.actor_ref,
+        assignment.judge.model_ref,
+        assignment.prompt_ref,
+    ):
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} judge provenance differs from its assignment")
+    if batch.metadata.get(ANNOTATION_CALIBRATION_EXECUTION_CONTEXT_KEY) != assignment.judge.execution_context_ref:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} context differs from its assignment")
+    if batch.metadata.get(ANNOTATION_CALIBRATION_RUBRIC_REF_KEY) != assignment.rubric_ref:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} rubric differs from its assignment")
+    if batch.metadata.get(ANNOTATION_CALIBRATION_ORDER_HASH_KEY) != assignment.receipt.item_order_hash:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} order receipt differs from its assignment")
+    expected_targets = tuple(item.target_ref for item in assignment.items)
+    if batch.item_target_refs != expected_targets:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} item targets differ from its assignment")
+    raw_item_ids = batch.metadata.get("item_ids")
+    expected_item_ids = [item.item_id for item in assignment.items]
+    if raw_item_ids != expected_item_ids:
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} item ids differ from its assignment")
+    if batch.metadata.get(ANNOTATION_CALIBRATION_GOLD_COUNT_KEY) != sum(item.is_gold for item in assignment.items):
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} gold count differs from its assignment")
+
+    assignment_by_target = {item.target_ref: item for item in assignment.items}
+    labels_by_target: dict[str, ArchiveAssertionEnvelope] = {}
+    for assertion_ref in batch.assertion_refs:
+        assertion_id = assertion_ref.removeprefix("assertion:")
+        envelope = read_assertion_envelope(conn, assertion_id)
+        if envelope is None:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} references missing {assertion_ref!r}")
+        if envelope.kind != AssertionKind.ANNOTATION or envelope.scope_ref != batch.batch_ref:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} contains a non-annotation assertion")
+        assignment_item = assignment_by_target.get(envelope.target_ref)
+        if assignment_item is None:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} contains an unassigned target label")
+        if envelope.key != assignment_item.item_id:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} label key differs from its assigned item id")
+        if envelope.author_ref != assignment.judge.actor_ref:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} label author differs from its judge")
+        if tuple(envelope.evidence_refs) != assignment_item.evidence_refs:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} label evidence differs from its assignment")
+        if not isinstance(envelope.value, dict):
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} contains a malformed annotation value")
+        if envelope.value.get("_schema") != assignment.qualified_schema_id:
+            raise AnnotationCalibrationError(
+                f"batch {batch.batch_ref!r} label schema stamp differs from its assignment"
+            )
+        if envelope.value.get("_batch") != batch.batch_ref:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} label batch stamp is missing")
+        if envelope.target_ref in labels_by_target:
+            raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} contains duplicate target labels")
+        labels_by_target[envelope.target_ref] = envelope
+    if set(labels_by_target) != set(expected_targets):
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} does not contain its complete assigned target set")
+    return _BatchObservation(batch=batch, assignment=assignment, labels_by_target=labels_by_target)
+
+
+def _gold_by_target(
+    conn: sqlite3.Connection,
+    assignment: _Assignment,
+    *,
+    schema: AnnotationSchema,
+) -> Mapping[str, _GoldRecord]:
+    records: dict[str, _GoldRecord] = {}
+    for item in assignment.items:
+        if not item.is_gold:
+            continue
+        if item.gold_assertion_ref is None:
+            raise AnnotationCalibrationError("gold assignment item lacks gold_assertion_ref")
+        assertion_id = item.gold_assertion_ref.removeprefix("assertion:")
+        envelope = read_assertion_envelope(conn, assertion_id)
+        if envelope is None:
+            raise AnnotationCalibrationError(f"assignment references missing gold {item.gold_assertion_ref!r}")
+        record = _validated_gold_record(
+            envelope,
+            schema=schema,
+            gold_set_ref=assignment.gold_set_ref,
+        )
+        if record.target_ref != item.target_ref:
+            raise AnnotationCalibrationError(f"gold {item.gold_assertion_ref!r} does not match its assignment receipt")
+        if item.gold_assertion_digest is None or record.content_digest != item.gold_assertion_digest:
+            raise AnnotationCalibrationError(f"gold {item.gold_assertion_ref!r} changed after assignment sealing")
+        records[item.target_ref] = record
+        if records[item.target_ref].evidence_refs != item.evidence_refs:
+            raise AnnotationCalibrationError(f"gold {item.gold_assertion_ref!r} evidence differs from its receipt")
+    return records
+
+
+def _label_value(envelope: ArchiveAssertionEnvelope, construct: str) -> object | None:
+    if not isinstance(envelope.value, dict):
+        return None
+    return envelope.value.get(construct)
+
+
+def _is_abstained(envelope: ArchiveAssertionEnvelope, schema: AnnotationSchema) -> bool:
+    return bool(
+        schema.abstain_field
+        and isinstance(envelope.value, dict)
+        and envelope.value.get(schema.abstain_field) is True
+    )
+
+
+def _construct_gold_metrics(
+    observation: _BatchObservation,
+    *,
+    gold_by_target: Mapping[str, _GoldRecord],
+    schema: AnnotationSchema,
+    construct: str,
+) -> _ConstructGoldMetrics:
+    correct_count = 0
+    n_assigned = 0
+    n_scored = 0
+    n_abstained = 0
+    n_missing = 0
+    outcomes: list[tuple[float, int]] = []
+    observed_values: list[object] = []
+    for target_ref, label in observation.labels_by_target.items():
+        gold_record = gold_by_target.get(target_ref)
+        is_scored_gold = gold_record is not None and construct in gold_record.label
+        if is_scored_gold:
+            n_assigned += 1
+        if _is_abstained(label, schema):
+            if is_scored_gold:
+                n_abstained += 1
+            continue
+        value = _label_value(label, construct)
+        if value is None:
+            if is_scored_gold:
+                n_missing += 1
+            continue
+        if not is_scored_gold or gold_record is None:
+            continue
+        observed_values.append(value)
+        outcome = int(_canonical_json(value) == _canonical_json(gold_record.label[construct]))
+        n_scored += 1
+        correct_count += outcome
+        if label.confidence is not None:
+            outcomes.append((label.confidence, outcome))
+    return _ConstructGoldMetrics(
+        correct_count=correct_count,
+        n_assigned=n_assigned,
+        n_scored=n_scored,
+        n_abstained=n_abstained,
+        n_missing=n_missing,
+        outcomes=tuple(outcomes),
+        observed_values=tuple(observed_values),
+    )
+
+
+def _reliability(
+    outcomes: Sequence[tuple[float, int]],
+    *,
+    bucket_count: int,
+) -> tuple[float | None, float | None, tuple[ReliabilityBucket, ...]]:
+    if isinstance(bucket_count, bool) or not isinstance(bucket_count, int) or bucket_count < 1:
+        raise AnnotationCalibrationError("bucket_count must be >= 1")
+    if not outcomes:
+        return None, None, tuple(
+            ReliabilityBucket(
+                lower=index / bucket_count,
+                upper=(index + 1) / bucket_count,
+                count=0,
+                mean_confidence=None,
+                empirical_accuracy=None,
+                gap=None,
+            )
+            for index in range(bucket_count)
+        )
+    brier = sum((confidence - outcome) ** 2 for confidence, outcome in outcomes) / len(outcomes)
+    buckets: list[list[tuple[float, int]]] = [[] for _ in range(bucket_count)]
+    for confidence, outcome in outcomes:
+        index = min(int(confidence * bucket_count), bucket_count - 1)
+        buckets[index].append((confidence, outcome))
+    documents: list[ReliabilityBucket] = []
+    weighted_gap = 0.0
+    for index, entries in enumerate(buckets):
+        if entries:
+            mean_confidence = sum(confidence for confidence, _ in entries) / len(entries)
+            empirical_accuracy = sum(outcome for _, outcome in entries) / len(entries)
+            gap = abs(mean_confidence - empirical_accuracy)
+            weighted_gap += len(entries) / len(outcomes) * gap
+        else:
+            mean_confidence = None
+            empirical_accuracy = None
+            gap = None
+        documents.append(
+            ReliabilityBucket(
+                lower=index / bucket_count,
+                upper=(index + 1) / bucket_count,
+                count=len(entries),
+                mean_confidence=mean_confidence,
+                empirical_accuracy=empirical_accuracy,
+                gap=gap,
+            )
+        )
+    return brier, weighted_gap, tuple(documents)
+
+
+def _distribution(values: Sequence[object]) -> Mapping[str, float]:
+    if not values:
+        return {}
+    counts = Counter(_canonical_json(value) for value in values)
+    total = sum(counts.values())
+    return {key: count / total for key, count in sorted(counts.items())}
+
+
+def _total_variation(left: Mapping[str, float], right: Mapping[str, float]) -> float | None:
+    if not left or not right:
+        return None
+    keys = set(left) | set(right)
+    return 0.5 * sum(abs(left.get(key, 0.0) - right.get(key, 0.0)) for key in keys)
+
+
+def _judge_from_batch(batch: AnnotationBatch) -> AnnotationJudgeRefs:
+    context_ref = batch.metadata.get(ANNOTATION_CALIBRATION_EXECUTION_CONTEXT_KEY)
+    if not isinstance(context_ref, str):
+        raise AnnotationCalibrationError(f"batch {batch.batch_ref!r} lacks execution_context_ref")
+    return AnnotationJudgeRefs(
+        actor_ref=batch.actor_ref,
+        model_ref=batch.model_ref,
+        execution_context_ref=context_ref,
+    )
+
+
+def materialize_calibration_measures(
+    conn: sqlite3.Connection,
+    *,
+    batch_id: str,
+    peer_batch_ids: Sequence[str] = (),
+    baseline_batch_id: str | None = None,
+    constructs: Sequence[str] | None = None,
+    measurement_levels: Mapping[str, MeasurementLevel] | None = None,
+    bucket_count: int = 10,
+    accuracy_drop_alert: float = 0.10,
+    brier_increase_alert: float = 0.05,
+    distribution_tv_alert: float = 0.15,
+    now_ms: int,
+) -> tuple[ArchiveAssertionEnvelope, ...]:
+    """Compute and persist typed measures for one batch and exact peers/baseline.
+
+    The complete read/compute/preserve/write operation runs under one immediate
+    transaction. Each output row is scoped to the current annotation batch and
+    one schema construct; its deterministic identity includes every algorithm
+    parameter and immutable input ref that can change the result.
+    """
+
+    if isinstance(now_ms, bool) or not isinstance(now_ms, int) or now_ms < 0:
+        raise AnnotationCalibrationError("now_ms must be a non-negative integer")
+    if isinstance(bucket_count, bool) or not isinstance(bucket_count, int) or bucket_count < 1:
+        raise AnnotationCalibrationError("bucket_count must be >= 1")
+    for name, threshold in (
+        ("accuracy_drop_alert", accuracy_drop_alert),
+        ("brier_increase_alert", brier_increase_alert),
+        ("distribution_tv_alert", distribution_tv_alert),
+    ):
+        if isinstance(threshold, bool) or not isinstance(threshold, (int, float)) or not isfinite(float(threshold)):
+            raise AnnotationCalibrationError(f"{name} must be a finite number")
+        if not 0.0 <= float(threshold) <= 1.0:
+            raise AnnotationCalibrationError(f"{name} must be in [0, 1]")
+
+    requested_peer_ids = tuple(peer_batch_ids)
+    if len(requested_peer_ids) != len(set(requested_peer_ids)):
+        raise AnnotationCalibrationError("peer_batch_ids must be unique")
+    # Agreement is a set-valued computation. Canonicalize caller order so the
+    # same peer set produces one immutable measure identity and evidence order.
+    peer_ids = tuple(sorted(requested_peer_ids))
+    if batch_id in peer_ids:
+        raise AnnotationCalibrationError("the current batch cannot also be an agreement peer")
+    if baseline_batch_id == batch_id:
+        raise AnnotationCalibrationError("the current batch cannot be its own drift baseline")
+    if baseline_batch_id is not None and baseline_batch_id in peer_ids:
+        raise AnnotationCalibrationError("a drift baseline cannot also be an agreement peer")
+
+    with _immediate_transaction(conn):
+        current = _batch_observation(conn, batch_id)
+        durable_schema = read_durable_annotation_schema(
+            conn,
+            current.batch.schema_id,
+            current.batch.schema_version,
+        )
+        if durable_schema is None:
+            raise AnnotationCalibrationError(f"batch {current.batch.batch_ref!r} has no durable schema")
+        schema = durable_schema.schema
+        selected_constructs = tuple(constructs) if constructs is not None else tuple(
+            field_def.name
+            for field_def in schema.fields
+            if field_def.name not in {schema.abstain_field, "confidence", "rationale"}
+        )
+        if not selected_constructs:
+            raise AnnotationCalibrationError("at least one construct field is required")
+        if len(selected_constructs) != len(set(selected_constructs)):
+            raise AnnotationCalibrationError("constructs must be unique")
+        for construct in selected_constructs:
+            _schema_field(schema, construct)
+
+        resolved_levels = dict(measurement_levels or {})
+        extra_level_keys = set(resolved_levels) - set(selected_constructs)
+        if extra_level_keys:
+            raise AnnotationCalibrationError(
+                f"measurement_levels names unselected constructs: {sorted(extra_level_keys)}"
+            )
+
+        peers = tuple(_batch_observation(conn, peer_id) for peer_id in peer_ids)
+        current_judge = _judge_from_batch(current.batch)
+        seen_peer_judges: set[tuple[str, str, str]] = set()
+        for peer in peers:
+            if peer.batch.qualified_schema_id != current.batch.qualified_schema_id:
+                raise AnnotationCalibrationError("agreement peers must use the same annotation schema version")
+            peer_judge = _judge_from_batch(peer.batch)
+            if peer_judge.key == current_judge.key:
+                raise AnnotationCalibrationError(
+                    "inter-judge agreement peers must use a different exact judge identity"
+                )
+            if peer_judge.key in seen_peer_judges:
+                raise AnnotationCalibrationError("agreement peers must have distinct exact judge identities")
+            seen_peer_judges.add(peer_judge.key)
+
+        baseline = _batch_observation(conn, baseline_batch_id) if baseline_batch_id is not None else None
+        if baseline is not None:
+            if baseline.batch.qualified_schema_id != current.batch.qualified_schema_id:
+                raise AnnotationCalibrationError("drift baseline must use the same annotation schema version")
+            if _judge_from_batch(baseline.batch) != current_judge:
+                raise AnnotationCalibrationError("drift baseline must match exact actor/model/execution-context refs")
+            if baseline.assignment.gold_set_ref != current.assignment.gold_set_ref:
+                raise AnnotationCalibrationError("drift baseline must use the same gold_set_ref")
+            if baseline.batch.created_at_ms > current.batch.created_at_ms:
+                raise AnnotationCalibrationError("drift baseline cannot be newer than the current batch")
+
+        current_gold = _gold_by_target(conn, current.assignment, schema=schema)
+        baseline_gold = (
+            _gold_by_target(conn, baseline.assignment, schema=schema) if baseline is not None else {}
+        )
+        if baseline is not None:
+            current_gold_refs = {record.assertion_ref for record in current_gold.values()}
+            baseline_gold_refs = {record.assertion_ref for record in baseline_gold.values()}
+            if baseline_gold_refs != current_gold_refs:
+                raise AnnotationCalibrationError(
+                    "drift baseline must use the exact same sealed gold anchors as the current batch"
+                )
+        gold_assertion_refs = sorted(record.assertion_ref for record in current_gold.values())
+        evidence_refs = [
+            current.batch.batch_ref,
+            *(peer.batch.batch_ref for peer in peers),
+            *((baseline.batch.batch_ref,) if baseline is not None else ()),
+            *gold_assertion_refs,
+        ]
+        envelopes: list[ArchiveAssertionEnvelope] = []
+
+        for construct in selected_constructs:
+            level = resolved_levels.get(construct, "nominal")
+            if level not in ("nominal", "interval"):
+                raise AnnotationCalibrationError(f"unsupported measurement level {level!r}")
+
+            current_metrics = _construct_gold_metrics(
+                current,
+                gold_by_target=current_gold,
+                schema=schema,
+                construct=construct,
+            )
+            brier, expected_calibration_error, buckets = _reliability(
+                current_metrics.outcomes,
+                bucket_count=bucket_count,
+            )
+
+            units: dict[str, list[object]] = defaultdict(list)
+            for observation in (current, *peers):
+                for target_ref, label in observation.labels_by_target.items():
+                    if _is_abstained(label, schema):
+                        continue
+                    value = _label_value(label, construct)
+                    if value is not None:
+                        units[target_ref].append(value)
+            alpha = krippendorff_alpha(units, level=level)
+            n_pairable_units = sum(len(values) >= 2 for values in units.values())
+            n_ratings = sum(len(values) for values in units.values() if len(values) >= 2)
+
+            drift_doc: JSONDocument = {
+                "accuracy_delta": None,
+                "alert": False,
+                "baseline_batch_ref": None,
+                "brier_delta": None,
+                "distribution_tv": None,
+                "reasons": [],
+                "thresholds": {
+                    "accuracy_drop": float(accuracy_drop_alert),
+                    "brier_increase": float(brier_increase_alert),
+                    "distribution_tv": float(distribution_tv_alert),
+                },
+            }
+            if baseline is not None:
+                baseline_metrics = _construct_gold_metrics(
+                    baseline,
+                    gold_by_target=baseline_gold,
+                    schema=schema,
+                    construct=construct,
+                )
+                baseline_brier, _, _ = _reliability(baseline_metrics.outcomes, bucket_count=bucket_count)
+                accuracy_delta = (
+                    current_metrics.accuracy - baseline_metrics.accuracy
+                    if current_metrics.accuracy is not None and baseline_metrics.accuracy is not None
+                    else None
+                )
+                brier_delta = brier - baseline_brier if brier is not None and baseline_brier is not None else None
+                tv = _total_variation(
+                    _distribution(current_metrics.observed_values),
+                    _distribution(baseline_metrics.observed_values),
+                )
+                reasons: list[str] = []
+                if accuracy_delta is not None and accuracy_delta <= -float(accuracy_drop_alert):
+                    reasons.append("accuracy_drop")
+                if brier_delta is not None and brier_delta >= float(brier_increase_alert):
+                    reasons.append("brier_increase")
+                if tv is not None and tv >= float(distribution_tv_alert):
+                    reasons.append("label_distribution_shift")
+                drift_doc = {
+                    "accuracy_delta": accuracy_delta,
+                    "alert": bool(reasons),
+                    "baseline_batch_ref": baseline.batch.batch_ref,
+                    "brier_delta": brier_delta,
+                    "distribution_tv": tv,
+                    "reasons": reasons,
+                    "thresholds": {
+                        "accuracy_drop": float(accuracy_drop_alert),
+                        "brier_increase": float(brier_increase_alert),
+                        "distribution_tv": float(distribution_tv_alert),
+                    },
+                }
+
+            input_document: JSONDocument = {
+                "algorithm": ANNOTATION_MEASURE_ALGORITHM,
+                "baseline_assertion_refs": list(baseline.batch.assertion_refs) if baseline is not None else [],
+                "baseline_batch_ref": baseline.batch.batch_ref if baseline is not None else None,
+                "batch_assertion_refs": list(current.batch.assertion_refs),
+                "batch_ref": current.batch.batch_ref,
+                "bucket_count": bucket_count,
+                "construct": construct,
+                "drift_thresholds": {
+                    "accuracy_drop": float(accuracy_drop_alert),
+                    "brier_increase": float(brier_increase_alert),
+                    "distribution_tv": float(distribution_tv_alert),
+                },
+                "gold_assertion_refs": gold_assertion_refs,
+                "measurement_level": level,
+                "peer_assertion_refs": {
+                    peer.batch.batch_ref: list(peer.batch.assertion_refs) for peer in peers
+                },
+                "peer_batch_refs": [peer.batch.batch_ref for peer in peers],
+                "qualified_schema_id": current.batch.qualified_schema_id,
+            }
+            input_digest = hash_payload(input_document)
+            value: JSONDocument = {
+                "agreement": {
+                    "alpha": alpha,
+                    "measurement_level": level,
+                    "method": "krippendorff_alpha",
+                    "n_judges": 1 + len(peers),
+                    "n_pairable_units": n_pairable_units,
+                    "n_ratings": n_ratings,
+                    "peer_batch_refs": [peer.batch.batch_ref for peer in peers],
+                },
+                "algorithm": ANNOTATION_MEASURE_ALGORITHM,
+                "batch_ref": current.batch.batch_ref,
+                "calibration": {
+                    "brier_score": brier,
+                    "bucket_count": bucket_count,
+                    "buckets": [bucket.as_document() for bucket in buckets],
+                    "expected_calibration_error": expected_calibration_error,
+                    "n_confident_gold": len(current_metrics.outcomes),
+                },
+                "construct": construct,
+                "drift": drift_doc,
+                "format": ANNOTATION_MEASURE_FORMAT,
+                "gold": {
+                    "abstention_rate": current_metrics.abstention_rate,
+                    "accuracy": current_metrics.accuracy,
+                    "correct": current_metrics.correct_count,
+                    "label_distribution": _distribution(current_metrics.observed_values),
+                    "n_abstained": current_metrics.n_abstained,
+                    "n_assigned": current_metrics.n_assigned,
+                    "n_missing": current_metrics.n_missing,
+                    "n_overlap": current_metrics.n_scored,
+                    "unscored_rate": current_metrics.unscored_rate,
+                },
+                "input_digest": input_digest,
+                "judge": current_judge.as_document(),
+                "measured_at_ms": now_ms,
+                "qualified_schema_id": current.batch.qualified_schema_id,
+            }
+            assertion_id = _measure_assertion_id(
+                batch_ref=current.batch.batch_ref,
+                construct=construct,
+                input_digest=input_digest,
+            )
+            candidate = {
+                "author_kind": "system",
+                "author_ref": ANNOTATION_CALIBRATION_AUTHOR_REF,
+                "body_text": None,
+                "confidence": None,
+                "evidence_refs": evidence_refs,
+                "key": construct,
+                "kind": AssertionKind.ANNOTATION_MEASURE.value,
+                "scope_ref": current.batch.batch_ref,
+                "target_ref": current.batch.batch_ref,
+                "value": value,
+            }
+            existing = read_assertion_envelope(conn, assertion_id)
+            if existing is not None:
+                if not isinstance(existing.value, dict):
+                    raise AnnotationCalibrationError(
+                        f"measure assertion {existing.assertion_id!r} has a malformed payload"
+                    )
+                existing_measured_at_ms = existing.value.get("measured_at_ms")
+                if (
+                    isinstance(existing_measured_at_ms, bool)
+                    or not isinstance(existing_measured_at_ms, int)
+                    or existing_measured_at_ms < 0
+                ):
+                    raise AnnotationCalibrationError(
+                        f"measure assertion {existing.assertion_id!r} has an invalid timestamp"
+                    )
+                value["measured_at_ms"] = existing_measured_at_ms
+                _assert_immutable_replay(existing, candidate=candidate)
+                envelopes.append(existing)
+                continue
+            envelopes.append(
+                upsert_assertion(
+                    conn,
+                    assertion_id=assertion_id,
+                    scope_ref=current.batch.batch_ref,
+                    target_ref=current.batch.batch_ref,
+                    key=construct,
+                    kind=AssertionKind.ANNOTATION_MEASURE,
+                    value=value,
+                    author_ref=ANNOTATION_CALIBRATION_AUTHOR_REF,
+                    author_kind="system",
+                    evidence_refs=evidence_refs,
+                    status=AssertionStatus.ACTIVE,
+                    visibility=AssertionVisibility.PRIVATE,
+                    context_policy={"inject": False, "promotion_required": False},
+                    now_ms=now_ms,
+                    require_promotion=False,
+                )
+            )
+    return tuple(envelopes)
+
+
+def query_judge_trust(
+    conn: sqlite3.Connection,
+    *,
+    schema_id: str,
+    schema_version: int,
+    construct: str,
+    judge: AnnotationJudgeRefs | None = None,
+    minimum_gold: int = 20,
+    minimum_confident_gold: int = 20,
+    minimum_accuracy: float = 0.80,
+    maximum_brier: float = 0.25,
+    maximum_expected_calibration_error: float = 0.10,
+    maximum_gold_unscored_rate: float = 0.25,
+) -> tuple[JudgeTrustSummary, ...]:
+    """Return latest exact-context trust status for each measured judge.
+
+    No cross-context pooling occurs. When ``judge`` is supplied and no measure
+    exists for that exact actor/model/context triple, one explicit ``unknown``
+    result is returned rather than inheriting confidence from a sibling
+    execution context.
+    """
+
+    for name, value in (("minimum_gold", minimum_gold), ("minimum_confident_gold", minimum_confident_gold)):
+        if isinstance(value, bool) or not isinstance(value, int) or value < 0:
+            raise AnnotationCalibrationError(f"{name} must be a non-negative integer")
+    for name, value in (
+        ("minimum_accuracy", minimum_accuracy),
+        ("maximum_brier", maximum_brier),
+        ("maximum_expected_calibration_error", maximum_expected_calibration_error),
+        ("maximum_gold_unscored_rate", maximum_gold_unscored_rate),
+    ):
+        if isinstance(value, bool) or not isinstance(value, (int, float)) or not isfinite(float(value)):
+            raise AnnotationCalibrationError(f"{name} must be a finite number")
+        if not 0.0 <= float(value) <= 1.0:
+            raise AnnotationCalibrationError(f"{name} must be in [0, 1]")
+
+    if (
+        not isinstance(schema_id, str)
+        or not schema_id.strip()
+        or isinstance(schema_version, bool)
+        or not isinstance(schema_version, int)
+        or schema_version < 1
+    ):
+        raise AnnotationCalibrationError("schema identity must be schema_id plus version >= 1")
+    durable_schema = read_durable_annotation_schema(conn, schema_id, schema_version)
+    if durable_schema is None:
+        raise AnnotationCalibrationError(f"unknown durable annotation schema {schema_id}@v{schema_version}")
+    _schema_field(durable_schema.schema, construct)
+    qualified_schema_id = durable_schema.schema.qualified_id
+    rows = conn.execute(
+        """
+        SELECT assertion_id
+        FROM assertions
+        WHERE kind = ?
+          AND key = ?
+          AND status = ?
+        ORDER BY assertion_id
+        """,
+        (
+            AssertionKind.ANNOTATION_MEASURE.value,
+            construct,
+            AssertionStatus.ACTIVE.value,
+        ),
+    ).fetchall()
+    latest: dict[tuple[str, str, str], tuple[tuple[int, int, str, str], JudgeTrustSummary]] = {}
+    observations: dict[str, _BatchObservation] = {}
+    for row in rows:
+        envelope = read_assertion_envelope(conn, str(row[0]))
+        if envelope is None:
+            raise AnnotationCalibrationError("calibration-measure query returned a missing assertion")
+        if not isinstance(envelope.value, dict):
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has a malformed payload")
+        value = envelope.value
+        if value.get("format") != ANNOTATION_MEASURE_FORMAT:
+            continue
+        if value.get("algorithm") != ANNOTATION_MEASURE_ALGORITHM:
+            continue
+        if value.get("qualified_schema_id") != qualified_schema_id or value.get("construct") != construct:
+            continue
+        if envelope.author_ref != ANNOTATION_CALIBRATION_AUTHOR_REF or envelope.author_kind != "system":
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has a forged author")
+        if envelope.visibility is not AssertionVisibility.PRIVATE or envelope.context_policy.get("inject") is not False:
+            raise AnnotationCalibrationError(
+                f"measure assertion {envelope.assertion_id!r} must remain private and non-injectable"
+            )
+        if envelope.context_policy.get("promotion_required") is not False:
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} must not require promotion")
+
+        batch_ref = _normalized_ref(
+            _required_string(value.get("batch_ref"), context="measure batch_ref"),
+            label="measure batch_ref",
+            expected_kind="annotation-batch",
+        )
+        input_digest = _required_string(value.get("input_digest"), context="measure input_digest")
+        expected_assertion_id = _measure_assertion_id(
+            batch_ref=batch_ref,
+            construct=construct,
+            input_digest=input_digest,
+        )
+        if envelope.assertion_id != expected_assertion_id:
+            raise AnnotationCalibrationError(
+                f"measure assertion {envelope.assertion_id!r} has a non-canonical identity"
+            )
+        if envelope.scope_ref != batch_ref or envelope.target_ref != batch_ref:
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has the wrong batch scope")
+        if batch_ref not in envelope.evidence_refs:
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} omits its batch evidence")
+        measured_at_ms = value.get("measured_at_ms")
+        if isinstance(measured_at_ms, bool) or not isinstance(measured_at_ms, int) or measured_at_ms < 0:
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has an invalid timestamp")
+
+        judge_doc = value.get("judge")
+        gold_doc = value.get("gold")
+        calibration_doc = value.get("calibration")
+        drift_doc = value.get("drift")
+        if not all(isinstance(document, dict) for document in (judge_doc, gold_doc, calibration_doc, drift_doc)):
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has malformed products")
+        judge_mapping = cast(dict[str, object], judge_doc)
+        measured_judge = AnnotationJudgeRefs(
+            actor_ref=_required_string(judge_mapping.get("actor_ref"), context="measure judge.actor_ref"),
+            model_ref=_required_string(judge_mapping.get("model_ref"), context="measure judge.model_ref"),
+            execution_context_ref=_required_string(
+                judge_mapping.get("execution_context_ref"),
+                context="measure judge.execution_context_ref",
+            ),
+        )
+        if judge is not None and measured_judge != judge:
+            continue
+
+        observation = observations.get(batch_ref)
+        if observation is None:
+            observation = _batch_observation(conn, ObjectRef.parse(batch_ref).object_id)
+            observations[batch_ref] = observation
+        if observation.batch.qualified_schema_id != qualified_schema_id:
+            raise AnnotationCalibrationError(
+                f"measure assertion {envelope.assertion_id!r} disagrees with its batch schema"
+            )
+        if _judge_from_batch(observation.batch) != measured_judge:
+            raise AnnotationCalibrationError(
+                f"measure assertion {envelope.assertion_id!r} disagrees with its batch judge"
+            )
+
+        gold_mapping = cast(dict[str, object], gold_doc)
+        calibration_mapping = cast(dict[str, object], calibration_doc)
+        drift_mapping = cast(dict[str, object], drift_doc)
+        n_gold = _required_nonnegative_int(gold_mapping.get("n_overlap"), context="measure gold.n_overlap")
+        n_gold_assigned = _required_nonnegative_int(
+            gold_mapping.get("n_assigned"),
+            context="measure gold.n_assigned",
+        )
+        n_confident_gold = _required_nonnegative_int(
+            calibration_mapping.get("n_confident_gold"),
+            context="measure calibration.n_confident_gold",
+        )
+        accuracy = _optional_unit_float(gold_mapping.get("accuracy"), context="measure gold.accuracy")
+        brier = _optional_unit_float(
+            calibration_mapping.get("brier_score"),
+            context="measure calibration.brier_score",
+        )
+        ece = _optional_unit_float(
+            calibration_mapping.get("expected_calibration_error"),
+            context="measure calibration.expected_calibration_error",
+        )
+        abstention_rate = _optional_unit_float(
+            gold_mapping.get("abstention_rate"),
+            context="measure gold.abstention_rate",
+        )
+        unscored_rate = _optional_unit_float(
+            gold_mapping.get("unscored_rate"),
+            context="measure gold.unscored_rate",
+        )
+        if not isinstance(drift_mapping.get("alert"), bool):
+            raise AnnotationCalibrationError(f"measure assertion {envelope.assertion_id!r} has an invalid drift alert")
+        drift_alert = drift_mapping.get("alert") is True
+        reasons: list[str] = []
+        if n_gold < minimum_gold:
+            reasons.append("insufficient_gold")
+        if n_confident_gold < minimum_confident_gold:
+            reasons.append("insufficient_confident_gold")
+        if reasons:
+            state: TrustState = "unknown"
+        elif drift_alert:
+            state = "drifting"
+            reasons.append("drift_alert")
+        else:
+            if accuracy is None or accuracy < float(minimum_accuracy):
+                reasons.append("accuracy_below_threshold")
+            if brier is None or brier > float(maximum_brier):
+                reasons.append("brier_above_threshold")
+            if ece is None or ece > float(maximum_expected_calibration_error):
+                reasons.append("calibration_error_above_threshold")
+            if unscored_rate is None or unscored_rate > float(maximum_gold_unscored_rate):
+                reasons.append("gold_unscored_above_threshold")
+            state = "eligible" if not reasons else "below_threshold"
+        summary = JudgeTrustSummary(
+            judge=measured_judge,
+            batch_ref=batch_ref,
+            qualified_schema_id=qualified_schema_id,
+            construct=construct,
+            state=state,
+            reasons=tuple(reasons),
+            n_gold=n_gold,
+            n_gold_assigned=n_gold_assigned,
+            n_confident_gold=n_confident_gold,
+            gold_abstention_rate=abstention_rate,
+            gold_unscored_rate=unscored_rate,
+            accuracy=accuracy,
+            brier_score=brier,
+            expected_calibration_error=ece,
+            drift_alert=drift_alert,
+            measured_at_ms=measured_at_ms,
+        )
+        # Batch provenance, not analysis execution time, defines recency. A
+        # historical batch can be re-materialized under changed thresholds or
+        # bucket parameters without becoming the judge's latest calibration.
+        sort_key = (
+            observation.batch.created_at_ms,
+            measured_at_ms,
+            batch_ref,
+            envelope.assertion_id,
+        )
+        existing = latest.get(measured_judge.key)
+        if existing is None or sort_key > existing[0]:
+            latest[measured_judge.key] = (sort_key, summary)
+
+    if judge is not None and judge.key not in latest:
+        return (
+            JudgeTrustSummary(
+                judge=judge,
+                batch_ref=None,
+                qualified_schema_id=qualified_schema_id,
+                construct=construct,
+                state="unknown",
+                reasons=("no_measure",),
+                n_gold=0,
+                n_gold_assigned=0,
+                n_confident_gold=0,
+                gold_abstention_rate=None,
+                gold_unscored_rate=None,
+                accuracy=None,
+                brier_score=None,
+                expected_calibration_error=None,
+                drift_alert=False,
+                measured_at_ms=None,
+            ),
+        )
+    return tuple(sorted((item[1] for item in latest.values()), key=lambda item: item.judge.key))
+
+
+def _required_nonnegative_int(value: object, *, context: str) -> int:
+    if isinstance(value, bool) or not isinstance(value, int) or value < 0:
+        raise AnnotationCalibrationError(f"{context} must be a non-negative integer")
+    return value
+
+
+def _optional_unit_float(value: object, *, context: str) -> float | None:
+    if value is None:
+        return None
+    if isinstance(value, bool) or not isinstance(value, (int, float)):
+        raise AnnotationCalibrationError(f"{context} must be null or a finite number in [0, 1]")
+    normalized = float(value)
+    if not isfinite(normalized) or not 0.0 <= normalized <= 1.0:
+        raise AnnotationCalibrationError(f"{context} must be null or a finite number in [0, 1]")
+    return normalized
+
+
+__all__ = [
+    "ANNOTATION_ASSIGNMENT_FORMAT",
+    "ANNOTATION_CALIBRATION_BATCH_FORMAT",
+    "ANNOTATION_GOLD_FORMAT",
+    "ANNOTATION_MEASURE_ALGORITHM",
+    "ANNOTATION_MEASURE_FORMAT",
+    "BASE_BLINDING_MASKED_FIELDS",
+    "CALIBRATION_MASKED_FIELDS",
+    "AnnotationCalibrationError",
+    "AnnotationJudgeRefs",
+    "CalibrationCompositionRequest",
+    "CalibrationLabelInput",
+    "CalibrationSourceItem",
+    "ComposedCalibrationBatch",
+    "GoldAnnotationInput",
+    "GoldStratumQuota",
+    "JudgeBatchView",
+    "JudgeItemView",
+    "JudgeTrustSummary",
+    "ReliabilityBucket",
+    "author_gold_annotations",
+    "compose_calibration_batch",
+    "krippendorff_alpha",
+    "materialize_calibration_measures",
+    "query_judge_trust",
+    "record_calibration_batch",
+]
