+        history_source_refs=(ObjectRef(kind="commit", object_id="beads-history-fixture"),),
+    )
+    changes = {
+        str(effect.attributes["event_id"]): effect
+        for effect in projection.effects
+        if effect.effect_kind == "beads-change"
+    }
+
+    segments: list[WorkEvidenceNode] = []
+    associations: list[EffectAssociation] = []
+    for event_id in ("evt-create", "evt-edit", "evt-claim", "evt-close"):
+        event = _event_for_change(
+            event_id=event_id,
+            effect_ref=changes[event_id].ref,
+            evidence=evidence_by_event[event_id],
+        )
+        if event_id == "evt-claim":
+            # The source node deliberately retains only the admitted event ref;
+            # the association edge carries the archive EvidenceRef. The query
+            # must recover sessions from the complete persisted relation.
+            segment = WorkEvidenceNode(
+                ref=ObjectRef(kind="work-session-segment", object_id=f"work-effects-route:{event_id}"),
+                kind="session-segment",
+                label=f"Archived session segment for {event_id}",
+                source_refs=(event.event_ref,),
+                corpus_snapshot_ref=CORPUS,
+                authority="provider",
+                confidence=1.0,
+            )
+        else:
+            segment = session_segment_from_observed_events(
+                ref=ObjectRef(kind="work-session-segment", object_id=f"work-effects-route:{event_id}"),
+                label=f"Archived session segment for {event_id}",
+                corpus_snapshot_ref=CORPUS,
+                events=(event,),
+            )
+        segments.append(segment)
+        associations.extend(
+            associations_from_observed_events(
+                work_ref=segment.ref,
+                events=(event,),
+                effects=projection.effects,
+            )
+        )
+
+    candidate_evidence = EvidenceRef(
+        session_id="codex-session:time-overlap-only",
+        message_id="message:candidate",
+        block_index=0,
