+        interaction_records=interactions,
+        interaction_evidence={event_id: (evidence,) for event_id, evidence in evidence_by_event.items()},
+        baseline_source_refs=(ObjectRef(kind="file", object_id=".beads/issues.jsonl"),),
+        interaction_source_refs={
+            event_id: (ObjectRef(kind="file", object_id=".beads/interactions.jsonl"),)
+            for event_id in evidence_by_event
