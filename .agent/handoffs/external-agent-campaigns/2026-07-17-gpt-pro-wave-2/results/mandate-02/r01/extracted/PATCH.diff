+            basis = "file_overlap"
+        else:
+            basis = "time_overlap"
+        commit_ref = ObjectRef(kind="commit", object_id=commit.commit_sha)
+        associations.append(
+            EffectAssociation(
+                work_ref=work_ref,
+                effect_ref=commit_ref,
+                basis=basis,
+                evidence_refs=evidence_refs,
+                source_refs=(ObjectRef(kind="session", object_id=result.session_id), commit_ref),
+                confidence=commit.confidence,
+                attributes={
+                    "legacy_projection": "SessionCorrelationResult",
+                    "file_overlap_count": commit.file_overlap_count,
+                },
+            )
+        )
+    return tuple(associations)
+
+
+def relations_for_pr_effects(
+    *,
+    pr_effect: ObservedRepositoryEffect,
+    merge_commit_ref: ObjectRef | None = None,
+    bead_issue_refs: tuple[ObjectRef, ...] = (),
+) -> tuple[ObservedEffectRelation, ...]:
+    """Represent a squash/merge commit and one-PR-to-many-Beads links."""
+
+    if pr_effect.effect_kind != "github-pr":
+        raise ValueError("relations_for_pr_effects requires a GitHub PR effect")
+    if merge_commit_ref is not None and merge_commit_ref.kind != "commit":
+        raise ValueError("PR merge_commit_ref must be a commit ref")
+    if any(ref.kind != "beads-issue" for ref in bead_issue_refs):
+        raise ValueError("PR Beads targets must be Beads issue refs")
+    relations: list[ObservedEffectRelation] = []
+    targets = _dedupe_object_refs((*((merge_commit_ref,) if merge_commit_ref is not None else ()), *bead_issue_refs))
+    for target in targets:
+        relations.append(
+            ObservedEffectRelation(
+                source_effect_ref=pr_effect.ref,
+                target_effect_ref=target,
+                repository_ref=pr_effect.repository_ref,
+                repository_snapshot_ref=pr_effect.repository_snapshot_ref,
+                evidence_refs=pr_effect.evidence_refs,
+                source_refs=pr_effect.source_refs,
+                occurred_at_ms=pr_effect.occurred_at_ms,
+                attributes={"relation": "pr-effect"},
+            )
+        )
+    return tuple(relations)
+
+
+def _beads_issue_ref(
+    repository_ref: ObjectRef,
+    snapshot_ref: ObjectRef,
+    branch_ref: ObjectRef,
+    issue_id: str,
+) -> ObjectRef:
+    scope = _stable_id(repository_ref.format(), snapshot_ref.format(), branch_ref.format(), issue_id)
+    return ObjectRef(kind="beads-issue", object_id=f"{issue_id}@{scope}")
+
+
+def _beads_change_ref(
+    repository_ref: ObjectRef,
+    snapshot_ref: ObjectRef,
+    branch_ref: ObjectRef,
+    issue_id: str,
+    event_id: str,
+) -> ObjectRef:
+    scope = _stable_id(repository_ref.format(), snapshot_ref.format(), branch_ref.format(), issue_id, event_id)
+    return ObjectRef(kind="beads-change", object_id=f"{issue_id}:{event_id}@{scope}")
+
+
+def _edge_ref(kind: str, *refs_or_text: ObjectRef | str) -> ObjectRef:
+    parts = [value.format() if isinstance(value, ObjectRef) else value for value in refs_or_text]
+    return ObjectRef(kind="work-edge", object_id=f"{kind}:{_stable_id(kind, *parts)}")
+
+
+def _stable_id(*parts: str) -> str:
+    return sha256("\0".join(parts).encode("utf-8")).hexdigest()[:24]
+
+
+def _dedupe_object_refs(refs: Iterable[ObjectRef]) -> tuple[ObjectRef, ...]:
+    return tuple({ref.format(): ref for ref in refs}.values())
+
+
+def _evaluation_association_state(evaluation: WorkEvidenceEvaluation) -> WorkEvidenceAssociationState:
+    return {
+        "supported": "resolved",
+        "partial": "ambiguous",
+        "contradicted": "contradicted",
+        "unresolved": "unresolved",
+        "superseded": "superseded",
+    }[evaluation]
+
+
+def _required_record_string(record: Mapping[str, JSONValue], key: str) -> str:
+    value = record.get(key)
+    if not isinstance(value, str) or not value:
+        raise ValueError(f"Beads record requires non-empty {key}")
+    return value
+
+
+def _beads_action(record: Mapping[str, JSONValue]) -> WorkEvidenceEffectAction:
+    kind_value = record.get("kind")
+    kind = kind_value.lower() if isinstance(kind_value, str) else ""
+    if kind in {"create", "created", "issue_created"}:
+        return "created"
+    if kind in {"claim", "claimed"}:
+        return "claimed"
+    if kind in {"close", "closed"}:
+        return "closed"
+    extra = record.get("extra")
+    if is_json_document(extra):
+        field = extra.get("field")
+        new_value = extra.get("new_value")
+        old_value = extra.get("old_value")
+        if field == "status" and new_value == "closed":
+            return "closed"
+        if field == "status" and old_value == "closed" and new_value != "closed":
+            return "reopened"
+        if field in {"assignee", "owner"} and new_value not in {None, ""} and old_value in {None, ""}:
+            return "claimed"
+        if extra.get("corrects") is not None or extra.get("supersedes") is not None:
+            return "corrected"
+    return "edited"
+
+
+def _superseded_event_id(record: Mapping[str, JSONValue]) -> str | None:
+    extra = record.get("extra")
+    if not is_json_document(extra):
+        return None
+    for key in ("supersedes", "corrects", "supersedes_event_id"):
+        value = extra.get(key)
+        if isinstance(value, str) and value:
+            return value
+    return None
+
+
+def _record_time_ms(record: Mapping[str, JSONValue]) -> int | None:
+    for key in ("created_at", "updated_at", "closed_at"):
+        value = record.get(key)
+        if not isinstance(value, str) or not value:
+            continue
+        try:
+            normalized = value[:-1] + "+00:00" if value.endswith("Z") else value
+            return int(datetime.fromisoformat(normalized).timestamp() * 1000)
+        except ValueError:
+            continue
+    return None
+
+
+__all__ = [
+    "AssociationBasis",
+    "BeadsEffectProjection",
+    "EffectAssociation",
+    "ObservedEffectRelation",
+    "ObservedRepositoryEffect",
+    "ReconciliationJudgment",
+    "artifact_effect",
+    "associations_from_observed_events",
+    "associations_from_session_correlation",
+    "effects_from_beads_records",
+    "git_branch_effect",
+    "git_commit_effect",
+    "github_issue_effect",
+    "github_pr_effect",
+    "reconcile_work_effects",
+    "relations_for_pr_effects",
+    "unresolved_coverage_gap",
+    "verification_receipt_effect",
+]
