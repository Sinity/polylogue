+        wrong_repository = await repository.find_bead_work_sessions(
+            graph_id=graph.graph_id,
+            repository_ref=ObjectRef(kind="repo", object_id="other/repository").format(),
+            bead_id=BEAD_ID,
+        )
+        wrong_snapshot = await repository.find_bead_work_sessions(
+            graph_id=graph.graph_id,
+            repository_ref=REPOSITORY.format(),
+            repository_snapshot_ref=ObjectRef(
+                kind="repository-snapshot",
