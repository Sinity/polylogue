+async def test_seeded_bead_history_query_round_trips_direct_refs_and_candidate_overlap(tmp_path: Path) -> None:
+    """Exercise effects_from_beads_records -> reconciliation -> SQLite -> repository query.
+
+    Anti-vacuity: deleting ``subject_key`` persistence, session source-ref recovery,
+    repository scoping, or the observed/candidate edge distinction makes this test
+    fail at the production route rather than only at DTO construction.
