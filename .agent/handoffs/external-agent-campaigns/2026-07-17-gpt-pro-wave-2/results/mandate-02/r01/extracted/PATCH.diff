+    candidate_event = ObservedEvent(
+        event_ref=ObjectRef(kind="observed-event", object_id="archive-beads:time-overlap-only"),
+        kind="tool_finished",
+        run_ref=ObjectRef(kind="run", object_id=candidate_evidence.session_id),
