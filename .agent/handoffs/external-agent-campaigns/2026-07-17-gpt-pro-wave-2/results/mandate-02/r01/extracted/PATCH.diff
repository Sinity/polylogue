+        ],
+    )
+    projected = associations_from_session_correlation(correlation, work_ref=segment.ref, evidence_refs=(EVIDENCE,))
+    assert [association.basis for association in projected] == [
+        "direct_identifier",
+        "file_overlap",
+        "time_overlap",
+    ]
+    reconciled = reconcile_work_effects(graph, effects=(direct,), associations=(projected[0],))
+    assert reconciled.edges[-1].kind == "observed_effect"
