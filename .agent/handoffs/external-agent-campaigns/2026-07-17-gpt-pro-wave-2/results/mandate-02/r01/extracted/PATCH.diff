+    )
+    associations = associations_from_observed_events(work_ref=segment.ref, events=(event,), effects=(direct,))
+    assert [(association.effect_ref, association.basis) for association in associations] == [
+        (direct.ref, "direct_evidence")
+    ]
+
+    pr = github_pr_effect(
+        repository_ref=REPOSITORY,
+        repository_snapshot_ref=REPOSITORY_SNAPSHOT,
+        pr_ref=ObjectRef(kind="github-pr", object_id="openai/polylogue#direct"),
