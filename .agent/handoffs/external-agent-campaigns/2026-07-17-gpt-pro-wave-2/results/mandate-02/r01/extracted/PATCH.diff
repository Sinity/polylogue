+def _event_for_change(*, event_id: str, effect_ref: ObjectRef, evidence: EvidenceRef) -> ObservedEvent:
+    return ObservedEvent(
+        event_ref=ObjectRef(kind="observed-event", object_id=f"archive-beads:{event_id}"),
+        kind="tool_finished",
+        run_ref=ObjectRef(kind="run", object_id=evidence.session_id),
+        summary=f"Archived structural Beads command named {effect_ref.format()}",
+        object_refs=(effect_ref,),
+        evidence_refs=(evidence,),
+        tool_name="Bash",
+        command=f"bd history {BEAD_ID}",
+        status="completed",
+    )
+
+
+def _claim_subgraph(
+    evidence: EvidenceRef,
+) -> tuple[tuple[WorkEvidenceNode, ...], tuple[WorkEvidenceEdge, ...], ObjectRef]:
+    result = WorkEvidenceNode(
+        ref=ObjectRef(kind="work-result", object_id="work-effects-route:result"),
+        kind="structured-result",
+        label="Agent completion report",
+        evidence_refs=(evidence,),
+        corpus_snapshot_ref=CORPUS,
+        authority="provider",
+        confidence=1.0,
+    )
+    claim = WorkEvidenceNode(
+        ref=ObjectRef(kind="work-claim", object_id="work-effects-route:claim"),
+        kind="claim",
+        label="Agent claimed the Bead work was complete",
+        claim_text="The requested Bead was updated and the repository change was verified.",
+        evidence_refs=(evidence,),
+        corpus_snapshot_ref=CORPUS,
+        authority="provider",
+        confidence=1.0,
+    )
+    edge = WorkEvidenceEdge(
+        ref=ObjectRef(kind="work-edge", object_id="work-effects-route:claimed"),
+        kind="claimed",
+        source_ref=result.ref,
+        target_ref=claim.ref,
+        evidence_refs=(evidence,),
+        corpus_snapshot_ref=CORPUS,
+        authority="provider",
+        confidence=1.0,
+    )
+    return (result, claim), (edge,), claim.ref
