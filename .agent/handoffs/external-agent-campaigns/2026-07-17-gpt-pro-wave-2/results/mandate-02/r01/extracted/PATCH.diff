+async def get_bead_work_history(
+    conn: aiosqlite.Connection,
+    query: BeadWorkHistoryQuery,
+) -> BeadWorkHistory | None:
+    """Answer which archived sessions directly/candidately touched one Bead."""
+
+    repository_ref = ObjectRef.parse(query.repository_ref)
+    if repository_ref.kind != "repo":
+        raise ValueError("Bead work history requires a repo ref")
+    if not query.bead_id.strip():
+        raise ValueError("Bead work history requires a non-empty bead id")
+    allowed_actions = {"created", "edited", "claimed", "closed"}
+    invalid_actions = sorted(set(query.actions) - allowed_actions)
+    if invalid_actions:
+        raise ValueError(f"unsupported Bead work actions: {', '.join(invalid_actions)}")
+    snapshot_ref: ObjectRef | None = None
+    if query.repository_snapshot_ref is not None:
+        snapshot_ref = ObjectRef.parse(query.repository_snapshot_ref)
+        if snapshot_ref.kind != "repository-snapshot":
+            raise ValueError("Bead work history snapshot filter requires a repository-snapshot ref")
+
+    graph_cursor = await conn.execute(
+        "SELECT 1 FROM work_evidence_graphs WHERE graph_id = ?",
+        (query.graph_id,),
+    )
+    if await graph_cursor.fetchone() is None:
+        return None
+
+    predicates = [
+        "graph_id = ?",
+        "node_kind = 'effect'",
+        "effect_kind = 'beads-change'",
+        "repository_ref = ?",
+        "subject_key = ?",
+    ]
+    params: list[object] = [query.graph_id, repository_ref.format(), query.bead_id]
+    if query.actions:
+        placeholders = ", ".join("?" for _ in query.actions)
+        predicates.append(f"effect_action IN ({placeholders})")
+        params.extend(query.actions)
+    if snapshot_ref is not None:
+        predicates.append("repository_snapshot_ref = ?")
+        params.append(snapshot_ref.format())
+    effect_cursor = await conn.execute(
+        "SELECT * FROM work_evidence_nodes WHERE " + " AND ".join(predicates) + " ORDER BY occurred_at_ms, node_ref",
+        tuple(params),
+    )
+    effect_nodes = tuple(_node_from_row(row) for row in await effect_cursor.fetchall())
+    if not effect_nodes:
+        return BeadWorkHistory(
+            graph_id=query.graph_id,
+            repository_ref=repository_ref,
+            bead_id=query.bead_id,
+            issue_refs=(),
+            direct_matches=(),
+            candidate_matches=(),
+        )
+
+    effect_by_ref = {node.ref.format(): node for node in effect_nodes}
+    effect_placeholders = ", ".join("?" for _ in effect_by_ref)
+    edge_kinds = ("observed_effect", "candidate_effect") if query.include_candidates else ("observed_effect",)
+    kind_placeholders = ", ".join("?" for _ in edge_kinds)
+    edge_cursor = await conn.execute(
+        "SELECT * FROM work_evidence_edges "
+        f"WHERE graph_id = ? AND target_ref IN ({effect_placeholders}) AND edge_kind IN ({kind_placeholders}) "
+        "ORDER BY occurred_at_ms, edge_ref",
+        (query.graph_id, *sorted(effect_by_ref), *edge_kinds),
+    )
+    edges = tuple(_edge_from_row(row) for row in await edge_cursor.fetchall())
+    source_refs = sorted({edge.source_ref.format() for edge in edges})
+    source_nodes: dict[str, WorkEvidenceNode] = {}
+    if source_refs:
+        source_placeholders = ", ".join("?" for _ in source_refs)
+        source_cursor = await conn.execute(
+            f"SELECT * FROM work_evidence_nodes WHERE graph_id = ? AND node_ref IN ({source_placeholders})",
+            (query.graph_id, *source_refs),
+        )
+        source_nodes = {node.ref.format(): node for node in map(_node_from_row, await source_cursor.fetchall())}
+
+    direct: dict[tuple[str, str, str], BeadWorkSessionMatch] = {}
+    candidates: dict[tuple[str, str, str], BeadWorkSessionMatch] = {}
+    for edge in edges:
+        source = source_nodes.get(edge.source_ref.format())
+        effect = effect_by_ref[edge.target_ref.format()]
+        if source is None or effect.effect_action not in {"created", "edited", "claimed", "closed"}:
+            continue
+        association_evidence_refs = tuple(dict.fromkeys((*source.evidence_refs, *edge.evidence_refs)))
+        association_source_refs = tuple(
+            {ref.format(): ref for ref in (*source.source_refs, *edge.source_refs)}.values()
+        )
+        evidence_refs = tuple(dict.fromkeys((*association_evidence_refs, *effect.evidence_refs)))
+        direct_source_refs = tuple(
+            {ref.format(): ref for ref in (*association_source_refs, *effect.source_refs)}.values()
+        )
+        session_refs = {
+            ObjectRef(kind="session", object_id=evidence.session_id).format(): ObjectRef(
+                kind="session", object_id=evidence.session_id
+            )
+            for evidence in association_evidence_refs
+        }
+        session_refs.update({ref.format(): ref for ref in association_source_refs if ref.kind == "session"})
+        if effect.repository_snapshot_ref is None:
+            raise ValueError("persisted Beads effect lost repository snapshot")
+        for session_ref in session_refs.values():
+            match = BeadWorkSessionMatch(
+                session_ref=session_ref,
+                action=cast(BeadWorkAction, effect.effect_action),
+                effect_ref=effect.ref,
+                edge_ref=edge.ref,
+                evidence_refs=evidence_refs,
+                source_refs=direct_source_refs,
+                repository_snapshot_ref=effect.repository_snapshot_ref,
+                confidence=edge.confidence,
+                association_state=edge.association_state,
+            )
+            key = (session_ref.format(), match.action, effect.ref.format())
+            if edge.kind == "observed_effect":
+                direct[key] = match
+            else:
+                candidates[key] = match
+
+    issue_refs = tuple(
+        {node.subject_ref.format(): node.subject_ref for node in effect_nodes if node.subject_ref is not None}.values()
+    )
+    return BeadWorkHistory(
+        graph_id=query.graph_id,
+        repository_ref=repository_ref,
+        bead_id=query.bead_id,
+        issue_refs=tuple(sorted(issue_refs, key=lambda ref: ref.format())),
+        direct_matches=tuple(direct[key] for key in sorted(direct)),
+        candidate_matches=tuple(candidates[key] for key in sorted(candidates)),
+    )
