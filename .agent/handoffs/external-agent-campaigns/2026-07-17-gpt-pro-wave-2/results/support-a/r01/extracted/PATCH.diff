+def _analysis_world_from_payload(payload: Mapping[str, JsonValue]) -> AnalysisEvaluationWorld:
+    model_refs = payload.get("model_refs", [])
+    if not isinstance(model_refs, list) or not all(isinstance(item, str) for item in model_refs):
+        raise ValueError("analysis evaluation world model_refs must be an array of strings")
+    parameters = payload.get("parameters", {})
+    if not isinstance(parameters, dict):
+        raise ValueError("analysis evaluation world parameters must be an object")
+    return AnalysisEvaluationWorld(
+        frame_ref=normalize_object_ref_text(_non_empty(payload.get("frame_ref"), label="analysis frame_ref")),
+        runtime_build_ref=_non_empty(payload.get("runtime_build_ref"), label="analysis runtime_build_ref"),
+        model_refs=tuple(_non_empty(ref, label="analysis model_ref") for ref in model_refs),
+        parameters=_canonical_json_mapping(parameters, label="analysis world parameters"),
+    )
