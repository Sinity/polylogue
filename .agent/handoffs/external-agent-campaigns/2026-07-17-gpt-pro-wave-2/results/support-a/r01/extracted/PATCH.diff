+def _stored_evaluation_receipt_from_row(row: sqlite3.Row | tuple[object, ...]) -> StoredEvaluationReceipt:
+    model_refs = _json_sequence(row[7], label="evaluation receipt model refs")
+    if not all(isinstance(item, str) for item in model_refs):
+        raise ValueError("evaluation receipt model refs must be strings")
+    return StoredEvaluationReceipt(
+        receipt_id=str(row[0]),
+        query_hash=str(row[1]),
+        result_set_id=str(row[2]) if row[2] is not None else None,
+        source_generation=str(row[3]),
+        user_generation=str(row[4]),
+        index_generation=str(row[5]),
+        runtime_build_ref=str(row[6]),
+        model_refs=tuple(cast(str, item) for item in model_refs),
+        resolved_bounds=_json_mapping(row[8], label="evaluation receipt resolved bounds"),
+        degradation=_json_mapping(row[9], label="evaluation receipt degradation"),
+        created_at_ms=_stored_int(row[10], label="evaluation receipt created_at_ms"),
+    )
+
+
+def _require_protocol_version(value: str, *, expected: str, label: str) -> str:
+    normalized = _non_empty(value, label=f"{label} protocol version")
+    if normalized != expected:
+        raise ValueError(f"unsupported {label} protocol version: {normalized!r}")
+    return normalized
+
+
+def _non_empty(value: object, *, label: str) -> str:
+    if not isinstance(value, str):
+        raise TypeError(f"{label} must be a string")
+    normalized = unicodedata.normalize("NFC", value).strip()
+    if not normalized:
+        raise ValueError(f"{label} must be non-empty")
+    return normalized
+
+
+def _require_non_negative_int(value: object, *, label: str) -> int:
+    if isinstance(value, bool) or not isinstance(value, int):
+        raise TypeError(f"{label} must be an integer")
+    if value < 0:
+        raise ValueError(f"{label} must be non-negative")
+    return value
+
+
+def _stored_int(value: object, *, label: str) -> int:
+    if isinstance(value, bool) or not isinstance(value, int):
+        raise ValueError(f"{label} must be an integer")
+    return value
+
+
+def _canonical_analysis_value(value: JsonValue) -> JsonValue:
+    if isinstance(value, str):
+        return unicodedata.normalize("NFC", value)
+    if value is None or isinstance(value, (bool, int)):
+        return value
+    if isinstance(value, float):
+        if not math.isfinite(value):
+            raise ValueError("analysis payload floats must be finite")
+        return value
+    if isinstance(value, Mapping):
+        canonical: dict[str, JsonValue] = {}
+        for key, item in value.items():
+            if not isinstance(key, str):
+                raise TypeError("analysis payload object keys must be strings")
+            canonical_key = unicodedata.normalize("NFC", key)
+            if canonical_key in canonical:
+                raise ValueError(f"analysis payload has duplicate normalized key: {canonical_key!r}")
+            canonical[canonical_key] = _canonical_analysis_value(item)
+        return canonical
+    if isinstance(value, Sequence):
+        return [_canonical_analysis_value(item) for item in value]
+    raise TypeError(f"analysis payload contains unsupported JSON value: {type(value).__name__}")
+
+
+def _canonical_json_mapping(value: Mapping[str, JsonValue], *, label: str) -> dict[str, JsonValue]:
+    canonical = _canonical_analysis_value(value)
+    if not isinstance(canonical, dict):
+        raise TypeError(f"{label} must be a JSON object")
+    return canonical
+
+
+def _json_mapping(value: object, *, label: str) -> dict[str, JsonValue]:
+    parsed = json.loads(str(value))
+    if not isinstance(parsed, dict):
+        raise ValueError(f"{label} must be a JSON object")
+    return parsed
+
+
+def _json_sequence(value: object, *, label: str) -> list[JsonValue]:
+    parsed = json.loads(str(value))
+    if not isinstance(parsed, list):
+        raise ValueError(f"{label} must be a JSON array")
+    return parsed
+
