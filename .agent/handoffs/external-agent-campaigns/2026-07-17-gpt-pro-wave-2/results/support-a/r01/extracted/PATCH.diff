+++ b/polylogue/storage/sqlite/migrations/user/010_analysis_evidence_kernel.sql
@@ -0,0 +1,112 @@
+-- DB-native analysis evidence objects. Definitions and run receipts are
+-- procedure/execution records, not assertion claims; findings continue to
+-- live in assertions and cite analysis-run refs through evidence_refs_json.
+CREATE TABLE analysis_definitions (
+    analysis_hash                TEXT PRIMARY KEY NOT NULL CHECK(
+        length(analysis_hash) = 64
+        AND analysis_hash NOT GLOB '*[^0-9a-f]*'
+    ),
+    canonical_definition_json    TEXT NOT NULL CHECK(
+        json_valid(canonical_definition_json)
+        AND json_type(canonical_definition_json) = 'object'
+    ),
+    definition_protocol_version  TEXT NOT NULL CHECK(length(trim(definition_protocol_version)) > 0),
+    created_at_ms                INTEGER NOT NULL CHECK(created_at_ms >= 0)
+) STRICT;
+
+CREATE TABLE analysis_runs (
+    receipt_id               TEXT PRIMARY KEY NOT NULL CHECK(
+        receipt_id GLOB 'ar_*'
+        AND length(receipt_id) = 67
+        AND substr(receipt_id, 4) NOT GLOB '*[^0-9a-f]*'
+    ),
+    analysis_hash            TEXT NOT NULL REFERENCES analysis_definitions(analysis_hash)
+        ON UPDATE RESTRICT ON DELETE RESTRICT,
+    source_generation        TEXT NOT NULL CHECK(length(trim(source_generation)) > 0),
+    user_generation          TEXT NOT NULL CHECK(length(trim(user_generation)) > 0),
+    index_generation         TEXT NOT NULL CHECK(length(trim(index_generation)) > 0),
+    evaluator_ref            TEXT NOT NULL CHECK(length(trim(evaluator_ref)) > 0),
+    evaluation_world_json    TEXT NOT NULL CHECK(
+        json_valid(evaluation_world_json)
+        AND json_type(evaluation_world_json) = 'object'
+    ),
+    privacy_stamp_json       TEXT NOT NULL CHECK(
+        json_valid(privacy_stamp_json)
+        AND json_type(privacy_stamp_json) = 'object'
+    ),
+    retention_stamp_json     TEXT NOT NULL CHECK(
+        json_valid(retention_stamp_json)
+        AND json_type(retention_stamp_json) = 'object'
+    ),
+    receipt_protocol_version TEXT NOT NULL CHECK(length(trim(receipt_protocol_version)) > 0),
+    created_at_ms            INTEGER NOT NULL CHECK(created_at_ms >= 0)
+) STRICT;
+
+CREATE INDEX idx_analysis_runs_definition_time
+ON analysis_runs(analysis_hash, created_at_ms DESC, receipt_id);
+
+CREATE TABLE analysis_run_inputs (
+    receipt_id            TEXT NOT NULL REFERENCES analysis_runs(receipt_id)
+        ON UPDATE RESTRICT ON DELETE RESTRICT,
+    input_key             TEXT NOT NULL CHECK(length(trim(input_key)) > 0),
+    ordinal               INTEGER NOT NULL CHECK(ordinal >= 0),
+    query_hash            TEXT NOT NULL REFERENCES queries(query_hash)
+        ON UPDATE RESTRICT ON DELETE RESTRICT,
+    result_set_id         TEXT NOT NULL REFERENCES result_sets(result_set_id)
+        ON UPDATE RESTRICT ON DELETE RESTRICT,
+    evaluation_receipt_id TEXT NOT NULL REFERENCES query_evaluation_receipts(receipt_id)
+        ON UPDATE RESTRICT ON DELETE RESTRICT,
+    PRIMARY KEY (receipt_id, input_key),
+    UNIQUE (receipt_id, ordinal)
+) STRICT;
+
+CREATE INDEX idx_analysis_run_inputs_evidence
+ON analysis_run_inputs(result_set_id, evaluation_receipt_id, receipt_id);
+
+CREATE TRIGGER analysis_run_inputs_evidence_match_insert
+BEFORE INSERT ON analysis_run_inputs
+WHEN NOT EXISTS (
+    SELECT 1
+    FROM query_evaluation_receipts AS receipt
+    JOIN result_sets AS result_set ON result_set.result_set_id = receipt.result_set_id
+    WHERE receipt.receipt_id = NEW.evaluation_receipt_id
+      AND receipt.query_hash = NEW.query_hash
+      AND receipt.result_set_id = NEW.result_set_id
+      AND result_set.query_hash = NEW.query_hash
+)
+BEGIN
+    SELECT RAISE(ABORT, 'analysis input must bind one matching query result set and evaluation receipt');
+END;
+
+CREATE TRIGGER analysis_run_inputs_evidence_match_update
+BEFORE UPDATE OF query_hash, result_set_id, evaluation_receipt_id ON analysis_run_inputs
+WHEN NOT EXISTS (
+    SELECT 1
+    FROM query_evaluation_receipts AS receipt
+    JOIN result_sets AS result_set ON result_set.result_set_id = receipt.result_set_id
+    WHERE receipt.receipt_id = NEW.evaluation_receipt_id
+      AND receipt.query_hash = NEW.query_hash
+      AND receipt.result_set_id = NEW.result_set_id
+      AND result_set.query_hash = NEW.query_hash
+)
+BEGIN
+    SELECT RAISE(ABORT, 'analysis input must bind one matching query result set and evaluation receipt');
+END;
+
+CREATE TRIGGER analysis_definitions_immutable_update
+BEFORE UPDATE ON analysis_definitions
+BEGIN
+    SELECT RAISE(ABORT, 'analysis definitions are immutable');
+END;
+
+CREATE TRIGGER analysis_runs_immutable_update
+BEFORE UPDATE ON analysis_runs
+BEGIN
+    SELECT RAISE(ABORT, 'analysis run receipts are immutable');
+END;
+
+CREATE TRIGGER analysis_run_inputs_immutable_update
+BEFORE UPDATE ON analysis_run_inputs
+BEGIN
+    SELECT RAISE(ABORT, 'analysis run inputs are immutable');
+END;
