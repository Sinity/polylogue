+               receipt_protocol_version, created_at_ms
+        FROM analysis_runs
+        WHERE receipt_id = ?
+        """,
+        (receipt_id,),
+    ).fetchone()
+    if row is None:
+        return None
+    input_rows = conn.execute(
+        """
+        SELECT input_key, query_hash, result_set_id, evaluation_receipt_id
+        FROM analysis_run_inputs
+        WHERE receipt_id = ?
+        ORDER BY ordinal
+        """,
+        (receipt_id,),
+    ).fetchall()
+    world = _analysis_world_from_payload(_json_mapping(row[6], label="analysis evaluation world"))
+    privacy = _analysis_privacy_from_payload(_json_mapping(row[7], label="analysis privacy stamp"))
+    retention = _analysis_retention_from_payload(_json_mapping(row[8], label="analysis retention stamp"))
+    version = _require_protocol_version(
+        str(row[9]),
+        expected=ANALYSIS_RUN_RECEIPT_PROTOCOL_VERSION,
+        label="analysis run receipt",
+    )
+    inputs = _validated_analysis_inputs(
+        conn,
+        tuple(
+            AnalysisRunInput(
+                input_key=str(input_row[0]),
+                query_hash=str(input_row[1]),
+                result_set_id=str(input_row[2]),
+                evaluation_receipt_id=str(input_row[3]),
+            )
+            for input_row in input_rows
+        ),
+    )
+    analysis_hash = str(row[1])
+    if get_analysis_definition(conn, analysis_hash) is None:
+        raise ValueError(f"analysis run {receipt_id} cites a missing analysis definition")
+    candidate = AnalysisRunReceipt(
+        receipt_id=str(row[0]),
+        analysis_hash=analysis_hash,
+        inputs=inputs,
+        archive_generations=AnalysisArchiveGenerations(
+            source_generation=_non_empty(row[2], label="source_generation"),
+            user_generation=_non_empty(row[3], label="user_generation"),
+            index_generation=_non_empty(row[4], label="index_generation"),
+        ),
+        evaluator_ref=normalize_object_ref_text(str(row[5])),
+        evaluation_world=world,
+        privacy_stamp=privacy,
+        retention_stamp=retention,
+        receipt_protocol_version=version,
+        created_at_ms=_stored_int(row[10], label="analysis run created_at_ms"),
+    )
+    canonical_receipt = _analysis_receipt_payload(
+        analysis_hash=candidate.analysis_hash,
+        inputs=candidate.inputs,
+        archive_generations=candidate.archive_generations,
+        evaluator_ref=candidate.evaluator_ref,
+        evaluation_world=candidate.evaluation_world,
+        privacy_stamp=candidate.privacy_stamp,
+        retention_stamp=candidate.retention_stamp,
+        receipt_protocol_version=candidate.receipt_protocol_version,
+        created_at_ms=candidate.created_at_ms,
+    )
+    expected_id = f"{ANALYSIS_RUN_ID_PREFIX}{hash_payload(canonical_receipt)}"
+    if candidate.receipt_id != expected_id:
+        raise ValueError(f"analysis run {candidate.receipt_id} failed receipt verification")
+    return candidate
+
