+def analysis_run_binds_evidence(
+    conn: sqlite3.Connection,
+    *,
+    receipt_id: str,
+    query_hash: str,
+    result_set_id: str,
+) -> bool:
+    """Return whether a run cites the exact query/result-set pair."""
+
+    return (
+        conn.execute(
+            """
+            SELECT 1
+            FROM analysis_run_inputs
+            WHERE receipt_id = ? AND query_hash = ? AND result_set_id = ?
+            LIMIT 1
+            """,
+            (receipt_id, query_hash, result_set_id),
+        ).fetchone()
+        is not None
+    )
+
