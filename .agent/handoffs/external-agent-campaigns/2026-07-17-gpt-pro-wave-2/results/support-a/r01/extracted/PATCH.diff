@@ -0,0 +1,347 @@
+"""Real-route proof for the first-party analysis evidence kernel.
+
+This fixture is deliberately synthetic: it uses only generic provider/session
+labels and generated text.  The route is not a toy repository.  It writes
+sessions through ``ArchiveStore.write_parsed``, materializes watched-query
+result sets and evaluation receipts through the default daemon convergence
+stage and ``ArchiveCanonicalPlanEvaluator``, persists analysis definitions/runs
+through ``query_objects``, writes findings through the assertion lifecycle, and
+reads all three public objects through ``Polylogue.resolve_ref``.
+"""
+
+from __future__ import annotations
+
+import sqlite3
+from pathlib import Path
+
+import pytest
+
+from polylogue import Polylogue
+from polylogue.archive.message.roles import Role
+from polylogue.core.enums import BlockType, Provider
+from polylogue.daemon.convergence import DaemonConverger
+from polylogue.daemon.convergence_stages import make_default_convergence_stages
+from polylogue.sources.parsers.base import ParsedContentBlock, ParsedMessage, ParsedSession
+from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore
+from polylogue.storage.sqlite.archive_tiers.bootstrap import initialize_archive_database
+from polylogue.storage.sqlite.archive_tiers.types import ArchiveTier
+from polylogue.storage.sqlite.archive_tiers.user_write import FindingAssertion, upsert_findings_as_assertions
+from polylogue.storage.sqlite.query_objects import (
+    AnalysisArchiveGenerations,
+    AnalysisEvaluationWorld,
+    AnalysisPrivacyStamp,
+    AnalysisRetentionStamp,
+    AnalysisRunInput,
+    AnalysisRunReceipt,
+    StoredEvaluationReceipt,
+    get_analysis_run,
+    get_latest_evaluation_receipt_for_result_set,
+    get_watched_query_baseline,
+    put_analysis_definition,
+    put_analysis_run,
+    put_query,
+    put_query_name,
+)
+
+
+def _write_synthetic_session(archive_root: Path, *, ordinal: int) -> str:
+    with ArchiveStore(archive_root) as archive:
+        return archive.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id=f"analysis-fixture-{ordinal}",
+                title=f"Synthetic analysis fixture {ordinal}",
+                created_at=f"2026-01-{ordinal:02d}T00:00:00+00:00",
+                updated_at=f"2026-01-{ordinal:02d}T00:01:00+00:00",
+                messages=[
+                    ParsedMessage(
+                        provider_message_id=f"analysis-fixture-{ordinal}-m1",
+                        role=Role.USER,
+                        text=f"synthetic archive item {ordinal}",
+                        timestamp=f"2026-01-{ordinal:02d}T00:00:00+00:00",
+                        blocks=[
+                            ParsedContentBlock(
+                                type=BlockType.TEXT,
+                                text=f"synthetic archive item {ordinal}",
+                            )
+                        ],
+                    )
+                ],
+            )
+        )
+
+
+def _converge_watched_query(archive_root: Path, session_id: str) -> None:
+    stages = make_default_convergence_stages(archive_root / "index.db")
+    standing_stage = next(stage for stage in stages if stage.name == "standing-queries")
+    converger = DaemonConverger(stages=(standing_stage,), max_workers=1)
+    states, _timings = converger.converge_sessions((session_id,))
+    assert states[session_id].stages["standing-queries"].value == "done"
+
+
+def _latest_watch_evidence(
+    conn: sqlite3.Connection,
+    query_hash: str,
+) -> tuple[str, StoredEvaluationReceipt]:
+    result_set = get_watched_query_baseline(conn, query_hash)
+    assert result_set is not None
+    receipt = get_latest_evaluation_receipt_for_result_set(conn, result_set.result_set_id)
+    assert receipt is not None
+    return result_set.result_set_id, receipt
+
+
+def _put_run(
+    conn: sqlite3.Connection,
+    *,
+    analysis_hash: str,
+    query_hash: str,
+    result_set_id: str,
+    evaluation_receipt: StoredEvaluationReceipt,
+    evaluator_version: int,
+    created_at_ms: int,
+) -> AnalysisRunReceipt:
+    return put_analysis_run(
+        conn,
+        analysis_hash=analysis_hash,
+        inputs=(
+            AnalysisRunInput(
+                input_key="matched-sessions",
+                query_hash=query_hash,
+                result_set_id=result_set_id,
+                evaluation_receipt_id=evaluation_receipt.receipt_id,
+            ),
+        ),
+        archive_generations=AnalysisArchiveGenerations(
+            source_generation=evaluation_receipt.source_generation,
+            user_generation=evaluation_receipt.user_generation,
+            index_generation=evaluation_receipt.index_generation,
+        ),
+        evaluator_ref=f"agent:synthetic-analysis-evaluator.v{evaluator_version}",
+        evaluation_world=AnalysisEvaluationWorld(
+            frame_ref=f"artifact:synthetic-analysis-frame.v{evaluator_version}",
+            runtime_build_ref=f"polylogue:synthetic-analysis.v{evaluator_version}",
+            parameters={"aggregation": "count", "include_raw_content": False},
+        ),
+        privacy_stamp=AnalysisPrivacyStamp(
+            classification="synthetic",
+            policy_ref="artifact:synthetic-privacy-policy.v1",
+            contains_raw_content=False,
+            details={"fixture": True},
+        ),
+        retention_stamp=AnalysisRetentionStamp(
+            retention_class="fixture",
+            policy_ref="artifact:synthetic-retention-policy.v1",
+            excision_policy_ref="artifact:synthetic-excision-policy.v1",
+            details={"history": "append-only"},
+        ),
+        created_at_ms=created_at_ms,
+    )
+
+
+async def test_analysis_definition_run_and_finding_survive_real_route_rerun(tmp_path: Path) -> None:
+    """Prove stable identity, exact evidence, and append-only rerun history.
+
+    Production dependencies exercised:
+
+    * ``ArchiveStore.write_parsed`` for source/index storage;
+    * ``make_default_convergence_stages`` ->
+      ``ArchiveCanonicalPlanEvaluator`` for exact result-set/evaluation receipt
+      materialization;
+    * ``put_analysis_definition``/``put_analysis_run`` for user-tier objects;
+    * ``upsert_findings_as_assertions`` for the real claim lifecycle; and
+    * ``Polylogue.resolve_ref`` for typed product reads.
+
+    Anti-vacuity mutations: deleting canonical definition hashing breaks the
+    equal-definition assertions; dropping an exact input, evaluator, or world
+    field from the receipt digest breaks the second-run distinction (the
+    component-isolation storage test covers generations and both policy stamps);
+    bypassing analysis-run binding in the finding writer breaks both rejection
+    assertions; returning the old pending stub or prose-only finding payload
+    breaks the public-resolution assertions; replacing INSERT-only receipts
+    with an upsert-overwrite breaks the two-row and old-receipt checks.
+    """
+
+    archive_root = tmp_path / "archive"
+    first_session_id = _write_synthetic_session(archive_root, ordinal=1)
+    initialize_archive_database(archive_root / "user.db", ArchiveTier.USER)
+    initialize_archive_database(archive_root / "ops.db", ArchiveTier.OPS)
+
+    with sqlite3.connect(archive_root / "user.db") as conn:
+        query = put_query(
+            conn,
+            {"kind": "field", "field": "origin", "op": "=", "values": ["codex-session"]},
+            grain="session",
+            lane="dialogue",
+            rank_policy="mixed",
+            created_at_ms=1,
+        )
+        put_query_name(
+            conn,
+            name="synthetic-analysis-watch",
+            query_hash=query.query_hash,
+            watch=True,
+            updated_at_ms=2,
+        )
+        conn.commit()
+
+    _converge_watched_query(archive_root, first_session_id)
+
+    with sqlite3.connect(archive_root / "user.db") as conn:
+        first_result_set_id, first_evaluation_receipt = _latest_watch_evidence(conn, query.query_hash)
+        definition = put_analysis_definition(
+            conn,
+            {
+                "name": "Synthetic café match count",
+                "inputs": {"matched-sessions": {"type": "query-result"}},
+                "steps": [{"op": "count", "input": "matched-sessions"}],
+                "output": {"measure": "member_count", "unit": "sessions"},
+            },
+            created_at_ms=10,
+        )
+        equivalent_definition = put_analysis_definition(
+            conn,
+            {
+                "output": {"unit": "sessions", "measure": "member_count"},
+                "steps": [{"input": "matched-sessions", "op": "count"}],
+                "inputs": {"matched-sessions": {"type": "query-result"}},
+                "name": "Synthetic cafe\u0301 match count",
+            },
+            created_at_ms=11,
+        )
+        assert equivalent_definition == definition
+        assert conn.execute("SELECT COUNT(*) FROM analysis_definitions").fetchone()[0] == 1
+
+        first_run = _put_run(
+            conn,
+            analysis_hash=definition.analysis_hash,
+            query_hash=query.query_hash,
+            result_set_id=first_result_set_id,
+            evaluation_receipt=first_evaluation_receipt,
+            evaluator_version=1,
+            created_at_ms=12,
+        )
+
+        uncited_finding = FindingAssertion(
+            claim_key="synthetic-session-count",
+            target_ref=definition.ref,
+            body_text="One synthetic session matched the archived query.",
+            finding_kind="analysis",
+            statistic={"op": "count", "value": 1, "unit": "sessions"},
+            n=1,
+            query_ref=query.ref,
+            result_set_ref=f"result-set:{first_result_set_id}",
+            detector_ref=first_run.evaluator_ref,
+        )
+        with pytest.raises(ValueError, match="require analysis_run_ref"):
+            upsert_findings_as_assertions(conn, [uncited_finding], now_ms=13)
+
+        [finding] = upsert_findings_as_assertions(
+            conn,
+            [
+                FindingAssertion(
+                    claim_key=uncited_finding.claim_key,
+                    target_ref=uncited_finding.target_ref,
+                    body_text=uncited_finding.body_text,
+                    finding_kind=uncited_finding.finding_kind,
+                    statistic=uncited_finding.statistic,
+                    n=uncited_finding.n,
+                    query_ref=uncited_finding.query_ref,
+                    result_set_ref=uncited_finding.result_set_ref,
+                    detector_ref=uncited_finding.detector_ref,
+                    analysis_run_ref=first_run.ref,
+                    scope_ref=definition.ref,
+                )
+            ],
+            now_ms=14,
+        )
+        conn.commit()
+
+    second_session_id = _write_synthetic_session(archive_root, ordinal=2)
+    _converge_watched_query(archive_root, second_session_id)
+
+    with sqlite3.connect(archive_root / "user.db") as conn:
+        second_result_set_id, second_evaluation_receipt = _latest_watch_evidence(conn, query.query_hash)
+        assert second_result_set_id != first_result_set_id
+        assert second_evaluation_receipt.receipt_id != first_evaluation_receipt.receipt_id
+
+        with pytest.raises(ValueError, match="cited analysis run inputs"):
+            upsert_findings_as_assertions(
+                conn,
+                [
+                    FindingAssertion(
+                        claim_key="mismatched-run-evidence",
+                        target_ref=definition.ref,
+                        body_text="This must not bind an uncited result set.",
+                        finding_kind="analysis",
+                        statistic={"op": "count", "value": 2, "unit": "sessions"},
+                        n=2,
+                        query_ref=query.ref,
+                        result_set_ref=f"result-set:{second_result_set_id}",
+                        detector_ref=first_run.evaluator_ref,
+                        analysis_run_ref=first_run.ref,
+                    )
+                ],
+                now_ms=15,
+            )
+
+        second_run = _put_run(
+            conn,
+            analysis_hash=definition.analysis_hash,
+            query_hash=query.query_hash,
+            result_set_id=second_result_set_id,
+            evaluation_receipt=second_evaluation_receipt,
+            evaluator_version=2,
+            created_at_ms=16,
+        )
+        assert second_run.receipt_id != first_run.receipt_id
+        assert get_analysis_run(conn, first_run.receipt_id) == first_run
+        assert get_analysis_run(conn, second_run.receipt_id) == second_run
+        assert conn.execute("SELECT COUNT(*) FROM analysis_runs").fetchone()[0] == 2
+        conn.commit()
+
+    archive = Polylogue(archive_root=archive_root, db_path=archive_root / "index.db")
+    try:
+        definition_resolution = await archive.resolve_ref(definition.ref)
+        first_run_resolution = await archive.resolve_ref(first_run.ref)
+        second_run_resolution = await archive.resolve_ref(second_run.ref)
+        finding_resolution = await archive.resolve_ref(f"finding:{finding.assertion_id}")
+
+        assert definition_resolution.resolved is True
+        assert definition_resolution.payload_kind == "analysis-definition"
+        assert definition_resolution.payload is not None
+        assert definition_resolution.payload["analysis_hash"] == definition.analysis_hash
+
+        assert first_run_resolution.resolved is True
+        assert first_run_resolution.payload_kind == "analysis-run-receipt"
+        assert first_run_resolution.payload is not None
+        assert first_run_resolution.payload["inputs"][0]["evaluation_receipt_id"] == first_evaluation_receipt.receipt_id
+        assert first_run_resolution.payload["archive_generations"] == {
+            "source_generation": first_evaluation_receipt.source_generation,
+            "user_generation": first_evaluation_receipt.user_generation,
+            "index_generation": first_evaluation_receipt.index_generation,
+        }
+        assert first_run_resolution.payload["evaluator_ref"] == "agent:synthetic-analysis-evaluator.v1"
+        assert first_run_resolution.payload["evaluation_world"]["frame_ref"] == "artifact:synthetic-analysis-frame.v1"
+        assert first_run_resolution.payload["privacy_stamp"]["contains_raw_content"] is False
+        assert first_run_resolution.payload["retention_stamp"]["retention_class"] == "fixture"
+
+        assert second_run_resolution.resolved is True
+        assert second_run_resolution.payload is not None
+        assert second_run_resolution.payload["receipt_id"] != first_run_resolution.payload["receipt_id"]
+        assert second_run_resolution.payload["inputs"][0]["result_set_ref"] == f"result-set:{second_result_set_id}"
+        assert second_run_resolution.payload["evaluator_ref"] == "agent:synthetic-analysis-evaluator.v2"
+
+        assert finding_resolution.resolved is True
+        assert finding_resolution.payload_kind == "finding-provenance"
+        assert finding_resolution.payload is not None
+        assert "body_text" not in finding_resolution.payload
+        assert finding_resolution.payload["analysis_run_ref"] == first_run.ref
+        assert finding_resolution.payload["staleness_verdict"] == "current"
+        evidence_state = {item["ref"]: item["resolvable"] for item in finding_resolution.payload["evidence"]}
+        assert evidence_state == {
+            query.ref: True,
+            f"result-set:{first_result_set_id}": True,
+            first_run.ref: True,
+        }
+    finally:
+        await archive.close()
