+
+def _analysis_privacy_from_payload(payload: Mapping[str, JsonValue]) -> AnalysisPrivacyStamp:
+    contains_raw_content = payload.get("contains_raw_content")
+    if not isinstance(contains_raw_content, bool):
+        raise ValueError("analysis privacy contains_raw_content must be a boolean")
+    details = payload.get("details", {})
+    if not isinstance(details, dict):
+        raise ValueError("analysis privacy details must be an object")
+    return AnalysisPrivacyStamp(
+        classification=_non_empty(payload.get("classification"), label="analysis privacy classification"),
+        policy_ref=normalize_object_ref_text(
+            _non_empty(payload.get("policy_ref"), label="analysis privacy policy_ref")
+        ),
+        contains_raw_content=contains_raw_content,
+        details=_canonical_json_mapping(details, label="analysis privacy details"),
+    )
+
+
+def _analysis_retention_from_payload(payload: Mapping[str, JsonValue]) -> AnalysisRetentionStamp:
+    details = payload.get("details", {})
+    if not isinstance(details, dict):
+        raise ValueError("analysis retention details must be an object")
+    return AnalysisRetentionStamp(
+        retention_class=_non_empty(payload.get("retention_class"), label="analysis retention_class"),
+        policy_ref=normalize_object_ref_text(
+            _non_empty(payload.get("policy_ref"), label="analysis retention policy_ref")
+        ),
+        excision_policy_ref=normalize_object_ref_text(
+            _non_empty(payload.get("excision_policy_ref"), label="analysis excision_policy_ref")
+        ),
+        details=_canonical_json_mapping(details, label="analysis retention details"),
+    )
