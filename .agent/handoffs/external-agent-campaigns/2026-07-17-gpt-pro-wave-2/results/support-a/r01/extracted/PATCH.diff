+def _validated_analysis_inputs(
+    conn: sqlite3.Connection,
+    inputs: Sequence[AnalysisRunInput],
+) -> tuple[AnalysisRunInput, ...]:
+    if not inputs:
+        raise ValueError("analysis run must bind at least one query evidence input")
+    normalized: list[AnalysisRunInput] = []
+    seen_keys: set[str] = set()
+    for item in inputs:
+        input_key = _non_empty(item.input_key, label="analysis input_key")
+        if input_key in seen_keys:
+            raise ValueError(f"analysis input keys must be unique: {input_key!r}")
+        seen_keys.add(input_key)
+        result_set = get_result_set(conn, item.result_set_id)
+        if result_set is None:
+            raise KeyError(f"result-set:{item.result_set_id}")
+        receipt = get_evaluation_receipt(conn, item.evaluation_receipt_id)
+        if receipt is None:
+            raise KeyError(f"query-evaluation-receipt:{item.evaluation_receipt_id}")
+        if result_set.query_hash != item.query_hash:
+            raise ValueError("analysis input result set must belong to its query")
+        if receipt.query_hash != item.query_hash or receipt.result_set_id != item.result_set_id:
+            raise ValueError("analysis input evaluation receipt must bind the same query result set")
+        normalized.append(
+            AnalysisRunInput(
+                input_key=input_key,
+                query_hash=item.query_hash,
+                result_set_id=item.result_set_id,
+                evaluation_receipt_id=item.evaluation_receipt_id,
+            )
+        )
+    return tuple(sorted(normalized, key=lambda item: item.input_key))
+
+
+def _analysis_receipt_payload(
+    *,
+    analysis_hash: str,
+    inputs: Sequence[AnalysisRunInput],
+    archive_generations: AnalysisArchiveGenerations,
+    evaluator_ref: str,
+    evaluation_world: AnalysisEvaluationWorld,
+    privacy_stamp: AnalysisPrivacyStamp,
+    retention_stamp: AnalysisRetentionStamp,
+    receipt_protocol_version: str,
+    created_at_ms: int,
+) -> dict[str, JsonValue]:
+    return {
+        "analysis_hash": analysis_hash,
+        "archive_generations": {
+            "source_generation": archive_generations.source_generation,
+            "user_generation": archive_generations.user_generation,
+            "index_generation": archive_generations.index_generation,
+        },
+        "created_at_ms": created_at_ms,
+        "evaluation_world": _analysis_world_payload(evaluation_world),
+        "evaluator_ref": evaluator_ref,
+        "inputs": [
+            {
+                "evaluation_receipt_id": item.evaluation_receipt_id,
+                "input_key": item.input_key,
+                "query_hash": item.query_hash,
+                "result_set_id": item.result_set_id,
+            }
+            for item in inputs
+        ],
+        "privacy_stamp": _analysis_privacy_payload(privacy_stamp),
+        "receipt_protocol_version": receipt_protocol_version,
+        "retention_stamp": _analysis_retention_payload(retention_stamp),
+    }
+
+
