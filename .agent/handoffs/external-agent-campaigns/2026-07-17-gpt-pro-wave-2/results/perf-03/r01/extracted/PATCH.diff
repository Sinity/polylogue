+    direct_json_payload = json.loads(direct_json.stdout)
+    direct_ndjson = runner.invoke(cli, ["--no-daemon", *base_args, "--format", "ndjson"])
+    assert direct_ndjson.exit_code == 0, direct_ndjson.output
+    direct_ndjson_payloads = [json.loads(line) for line in direct_ndjson.stdout.splitlines() if line]
+
+    from polylogue.daemon.http import DaemonAPIHandler
+    from polylogue.daemon.uds import DaemonAPIUnixHTTPServer, daemon_socket_path
+
+    socket_path = daemon_socket_path(str(_uds_runtime_dir))
+    server = DaemonAPIUnixHTTPServer(socket_path, DaemonAPIHandler)
+    auth_token = "golden-parity-message-secret"
+    server.auth_token = auth_token
+    monkeypatch.setenv("POLYLOGUE_API_AUTH_TOKEN", auth_token)
+    thread = threading.Thread(target=server.serve_forever, name="golden-parity-messages-uds", daemon=True)
+    thread.start()
+    try:
+        from polylogue.cli.daemon_client import DaemonClient
+
+        client = DaemonClient(socket_path, timeout_s=1.0, auth_token=auth_token)
+        deadline = time.monotonic() + 2.0
+        while time.monotonic() < deadline:
+            if client.request_json("GET", "/api/health") is not None:
+                break
+            time.sleep(0.02)
+        else:
+            pytest.fail("daemon UDS server did not become ready")
+
+        daemon_json = runner.invoke(cli, ["--verbose", *base_args, "--format", "json"])
+        daemon_ndjson = runner.invoke(cli, ["--verbose", *base_args, "--format", "ndjson"])
+    finally:
+        server.shutdown()
+        server.server_close()
+        thread.join(timeout=2)
+
+    assert daemon_json.exit_code == 0, daemon_json.output
+    assert daemon_ndjson.exit_code == 0, daemon_ndjson.output
+    assert "served-by: daemon (uds," in daemon_json.stderr
+    assert "served-by: daemon (uds," in daemon_ndjson.stderr
+    assert json.loads(daemon_json.stdout) == direct_json_payload
+    assert [json.loads(line) for line in daemon_ndjson.stdout.splitlines() if line] == direct_ndjson_payloads
+    assert direct_json_payload["messages"], "fixture message read must not be empty"
+    assert direct_ndjson_payloads, "fixture NDJSON read must not be empty"
+    first = direct_json_payload["messages"][0]
+    assert first["model_name"] == "golden-model-v1"
+    assert first["input_tokens"] == 17
+    assert first["output_tokens"] == 3
+    assert first["cache_read_tokens"] == 5
+    assert first["cache_write_tokens"] == 2
+    assert len(first["content_blocks"]) == 2
+    # Paginated direct reads currently omit stored block metadata/media type;
+    # the daemon path must not widen that established machine contract.
+    assert first["content_blocks"][0]["metadata"] is None
+    assert first["content_blocks"][0]["media_type"] is None
+    assert first["content_blocks"][1]["tool_input"]["code"].startswith("try:")
+    # The current paginated direct API does not hydrate attachments; the daemon
+    # adapter must preserve that existing machine-output contract exactly.
+    assert first["attachment_refs"] == []
