+def test_daemon_target_uses_direct_archive_root_and_layered_auth_without_source_discovery(
+    tmp_path: Path,
+) -> None:
+    """The lightweight target must match direct reads and daemon auth.
+
+    ``Config`` and ``polylogued`` currently own archive identity through
+    ``POLYLOGUE_ARCHIVE_ROOT``/the path substrate, while the layered TOML
+    loader owns API authentication.  A conflicting ``[archive].root`` entry
+    must not split the daemon fast path from its direct fallback.
+
+    Anti-vacuity: taking the root from ``load_polylogue_config`` selects the
+    conflicting TOML archive; resolving through ``get_config`` imports source
+    discovery.  Dropping the layered config load loses the bearer token.
+    """
+
+    direct_archive_root = tmp_path / "direct archive"
+    toml_archive_root = tmp_path / "conflicting toml archive"
+    config_path = tmp_path / "polylogue.toml"
+    config_path.write_text(
+        "\n".join(
+            (
+                "[archive]",
+                f"root = {json.dumps(str(toml_archive_root))}",
+                "[daemon.api]",
+                'auth_token = "secret-token"',
+            )
+        ),
+        encoding="utf-8",
+    )
+    result = _run_python(
+        "import sys; "
+        "from polylogue.cli.daemon_reads import active_daemon_target; "
+        "target=active_daemon_target(); "
+        f"assert str(target.archive_root) == {str(direct_archive_root.resolve())!r}; "
+        "assert target.auth_token == 'secret-token'; "
+        "assert 'polylogue.sources.live' not in sys.modules; "
+        "assert 'polylogue.services' not in sys.modules",
+        env={
+            "POLYLOGUE_CONFIG": str(config_path),
+            "POLYLOGUE_ARCHIVE_ROOT": str(direct_archive_root),
+        },
+    )
+    assert result.returncode == 0, result.stderr
