+def _invoke_find(
+    *,
+    root_args: list[str] | None = None,
+    query_terms: list[str] | None = None,
+    output_format: str = "json",
+    limit: int = 10,
+    cursor: str | None = None,
+    no_daemon: bool = False,
+) -> object:
+    from polylogue.cli import cli
+
+    argv = ["--plain"]
+    if no_daemon:
+        argv.append("--no-daemon")
+    argv.extend(root_args or [])
+    if cursor is not None:
+        argv.extend(["--cursor", cursor])
+    argv.append("find")
+    argv.extend(query_terms or [])
+    argv.extend(["--format", output_format, "--limit", str(limit)])
+    return CliRunner().invoke(cli, argv)
+
+
+def _start_golden_server(runtime_dir: Path, *, auth_token: str = "") -> tuple[object, threading.Thread]:
+    from polylogue.daemon.http import DaemonAPIHandler
+    from polylogue.daemon.uds import DaemonAPIUnixHTTPServer, daemon_socket_path
+
+    socket_path = daemon_socket_path(str(runtime_dir))
+    server = DaemonAPIUnixHTTPServer(socket_path, DaemonAPIHandler)
+    server.auth_token = auth_token
+    thread = threading.Thread(target=server.serve_forever, name="golden-parity-expanded-uds", daemon=True)
+    thread.start()
+
+    from polylogue.cli.daemon_client import DaemonClient
+
+    client = DaemonClient(socket_path, timeout_s=1.0, auth_token=auth_token or None)
+    deadline = time.monotonic() + 2.0
+    while time.monotonic() < deadline:
+        if client.request_json("GET", "/api/health") is not None:
+            return server, thread
+        time.sleep(0.02)
+    server.shutdown()
+    server.server_close()
+    thread.join(timeout=2)
+    pytest.fail("daemon UDS server did not become ready")
+
+
+def _stop_golden_server(server: object, thread: threading.Thread) -> None:
+    server.shutdown()  # type: ignore[attr-defined]
+    server.server_close()  # type: ignore[attr-defined]
+    thread.join(timeout=2)
+
+
+def test_list_cursor_and_second_page_parity_between_direct_and_daemon(
+    golden_parity_workspace: dict[str, Path],
+    _uds_runtime_dir: Path,
+) -> None:
+    """Opaque cursor pagination must resume on the same second page over UDS.
+
+    Production dependencies: the root cursor encoder/decoder, ``/api/cli/query``,
+    ArchiveStore list ordering, and the import-light daemon renderer. Removing
+    lightweight cursor decoding or changing any encoded field breaks this law.
+    """
+
+    del golden_parity_workspace
+    root_args = ["--repo", "polylogue"]
+    direct_first = _invoke_find(root_args=root_args, limit=1, no_daemon=True)
+    assert direct_first.exit_code == 0, direct_first.output  # type: ignore[attr-defined]
+    direct_first_payload = json.loads(direct_first.output)  # type: ignore[attr-defined]
+    cursor = direct_first_payload["next_cursor"]
+    assert isinstance(cursor, str) and cursor
+    assert direct_first_payload["next_offset"] == 1
+
+    direct_second = _invoke_find(root_args=root_args, limit=1, cursor=cursor, no_daemon=True)
+    assert direct_second.exit_code == 0, direct_second.output  # type: ignore[attr-defined]
+    direct_second_payload = json.loads(direct_second.output)  # type: ignore[attr-defined]
+
+    server, thread = _start_golden_server(_uds_runtime_dir)
+    try:
+        daemon_first = _invoke_find(root_args=root_args, limit=1)
+        daemon_second = _invoke_find(root_args=root_args, limit=1, cursor=cursor)
+    finally:
+        _stop_golden_server(server, thread)
+
+    assert daemon_first.exit_code == 0, daemon_first.output  # type: ignore[attr-defined]
+    assert daemon_second.exit_code == 0, daemon_second.output  # type: ignore[attr-defined]
+    daemon_first_payload = json.loads(daemon_first.output)  # type: ignore[attr-defined]
+    daemon_second_payload = json.loads(daemon_second.output)  # type: ignore[attr-defined]
+    assert daemon_first_payload["source"] == "daemon"
+    assert daemon_second_payload["source"] == "daemon"
+    assert _strip_provenance(daemon_first_payload) == direct_first_payload
+    assert _strip_provenance(daemon_second_payload) == direct_second_payload
+    assert daemon_first_payload["next_cursor"] == cursor
+    assert direct_first_payload["items"][0]["id"] != direct_second_payload["items"][0]["id"]
+
+
+@pytest.mark.parametrize("output_format", ["ndjson", "csv", "yaml", "markdown", "plaintext"])
+def test_list_renderer_parity_across_supported_formats(
+    golden_parity_workspace: dict[str, Path],
+    _uds_runtime_dir: Path,
+    output_format: str,
+) -> None:
+    """Every daemon-enabled list format must preserve the direct renderer."""
+
+    del golden_parity_workspace
+    root_args = ["--repo", "polylogue"]
+    direct = _invoke_find(root_args=root_args, output_format=output_format, no_daemon=True)
+    assert direct.exit_code == 0, direct.output  # type: ignore[attr-defined]
+
+    server, thread = _start_golden_server(_uds_runtime_dir)
+    try:
+        daemon = _invoke_find(root_args=root_args, output_format=output_format)
+    finally:
+        _stop_golden_server(server, thread)
+    assert daemon.exit_code == 0, daemon.output  # type: ignore[attr-defined]
+
+    if output_format == "yaml":
+        import yaml
+
+        direct_payload = yaml.safe_load(direct.output)  # type: ignore[attr-defined]
+        daemon_payload = yaml.safe_load(daemon.output)  # type: ignore[attr-defined]
+        daemon_payload.pop("source", None)
+        assert daemon_payload == direct_payload
+    else:
+        assert daemon.output == direct.output  # type: ignore[attr-defined]
+
