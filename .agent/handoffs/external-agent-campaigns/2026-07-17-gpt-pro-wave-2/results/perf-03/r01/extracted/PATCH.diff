@@ -0,0 +1,1163 @@
+"""Focused laws for import-light startup, grammar caching, and daemon-first reads."""
+
+from __future__ import annotations
+
+import json
+import os
+import subprocess
+import sys
+from pathlib import Path
+from types import SimpleNamespace
+from typing import TYPE_CHECKING, Any, cast
+
+import pytest
+
+from polylogue.cli.root_request import RootModeRequest
+from polylogue.cli.shared.types import AppEnv
+from polylogue.config import Config
+from polylogue.services import RuntimeServices
+
+if TYPE_CHECKING:
+    from polylogue.storage.sqlite.archive_tiers.archive import ArchiveSessionSummary
+    from polylogue.storage.sqlite.archive_tiers.write import ArchiveSessionEnvelope
+
+_REPO_ROOT = Path(__file__).resolve().parents[3]
+
+
+def _run_python(source: str, *, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
+    process_env = os.environ.copy()
+    process_env["PYTHONPATH"] = str(_REPO_ROOT)
+    if env:
+        process_env.update(env)
+    return subprocess.run(
+        [sys.executable, "-c", source],
+        cwd=_REPO_ROOT,
+        env=process_env,
+        check=False,
+        capture_output=True,
+        text=True,
+    )
+
+
+def test_lazy_package_exports_remain_visible_to_introspection() -> None:
+    """``dir()`` must expose public names without defeating lazy boundaries.
+
+    Anti-vacuity: omitting ``__dir__`` hides lazy exports; resolving the export
+    inside ``__dir__`` imports the forbidden implementation modules.
+    """
+
+    result = _run_python(
+        "import sys; "
+        "import polylogue.api as api; "
+        "import polylogue.api.sync as sync; "
+        "import polylogue.cli as cli; "
+        "import polylogue.daemon as daemon; "
+        "import polylogue.storage.sqlite as sqlite; "
