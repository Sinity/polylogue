+    class FakeDaemonClient:
+        def __init__(
+            self,
+            path: Path,
+            *,
+            timeout_s: float = 0.1,
+            auth_token: str | None = None,
+        ) -> None:
+            seen.update(path=path, timeout_s=timeout_s, auth_token=auth_token)
+
+        def probe(self, **identity: object) -> dict[str, object]:
+            seen["identity"] = identity
+            return {"daemon_version": "test-build"}
