+def test_expression_parser_is_lazy_and_cache_key_tracks_grammar(
+    tmp_path: Path, monkeypatch: pytest.MonkeyPatch
+) -> None:
+    """Parser construction is lazy and a grammar byte change invalidates cache.
+
+    Anti-vacuity: a fixed cache filename or eager module-level ``Lark(...)``
+    fails the parser-state or path inequality assertion respectively.
+    """
+
+    monkeypatch.setenv("XDG_CACHE_HOME", str(tmp_path))
+    from polylogue.archive.query import expression
+
+    expression._QUERY_PARSER = None
+    assert expression._QUERY_PARSER is None
+    original_grammar = expression._QUERY_GRAMMAR
+    changed_grammar = original_grammar + "\n"
+    original = expression._query_parser_cache_path(original_grammar)
+    changed = expression._query_parser_cache_path(changed_grammar)
+    assert original != changed
+
+    first = expression._build_query_parser(original_grammar)
+    second = expression._build_query_parser(changed_grammar)
+    assert first.parse("repo:polylogue", start="compact_query") is not None
+    assert second.parse("repo:polylogue", start="compact_query") is not None
+    assert original.is_file()
+    assert changed.is_file()
+    assert original.read_bytes()
+    assert changed.read_bytes()
+
