+++ b/devtools/profile_cli_startup.py
@@ -0,0 +1,550 @@
+"""Reproduce Polylogue CLI startup, parser-cache, and exact-read timings.
+
+The import table uses CPython's ``-X importtime`` cumulative interpreter time,
+which is the stable comparison for root startup. Wall-clock subprocess rows are
+host-dependent diagnostics and are labelled as such. Exact direct/daemon reads
+are included when both ``--archive-root`` and ``--session-id`` are supplied.
+
+Examples::
+
+    python devtools/profile_cli_startup.py --repeats 7
+    python devtools/profile_cli_startup.py \
+        --baseline-repo "$BASELINE_REPO" --repeats 7 --json
+    python devtools/profile_cli_startup.py \
+        --archive-root "$ARCHIVE_ROOT" \
+        --session-id "$SESSION_ID" \
+        --runtime-dir "$XDG_RUNTIME_DIR" \
+        --repeats 7 --json
+"""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import re
+import statistics
+import subprocess
+import sys
+import tempfile
+from collections.abc import Sequence
+from dataclasses import asdict, dataclass
+from pathlib import Path
+from time import perf_counter
+
+_IMPORTTIME_RE = re.compile(r"^import time:\s+(\d+)\s+\|\s+(\d+)\s+\|\s+(.+?)\s*$")
+
+
+@dataclass(frozen=True, slots=True)
+class TimingRow:
+    checkout: str
+    scenario: str
+    kind: str
+    unit: str
+    median: float
+    minimum: float
+    maximum: float
+    repeats: int
+    exit_code: int | None = None
+    daemon_proven: bool | None = None
+    note: str | None = None
+
+
+_PROFILE_SECTIONS = ("imports", "grammar", "root-cli", "exact-read")
+
+
+_IMPORT_SCENARIOS: tuple[tuple[str, str], ...] = (
+    ("root-cli", "polylogue.cli.click_app"),
+    ("query-dispatch", "polylogue.cli.query"),
+    ("read-verbs", "polylogue.cli.query_verbs"),
+    ("grammar-module", "polylogue.archive.query.expression"),
+    ("daemon-client", "polylogue.cli.daemon_client"),
+    ("status-module", "polylogue.cli.commands.status"),
+)
+
+
+def _base_env(repo: Path) -> dict[str, str]:
+    env = os.environ.copy()
+    prior = env.get("PYTHONPATH")
+    env["PYTHONPATH"] = str(repo) if not prior else os.pathsep.join((str(repo), prior))
+    env.setdefault("POLYLOGUE_FORCE_PLAIN", "1")
+    return env
+
+
+def _run(
+    command: Sequence[str],
+    *,
+    cwd: Path,
+    env: dict[str, str],
+    expected_exit_codes: frozenset[int],
+    timeout_s: float = 30.0,
+) -> tuple[subprocess.CompletedProcess[str], float]:
+    started = perf_counter()
+    try:
+        completed = subprocess.run(
+            list(command),
+            cwd=cwd,
+            env=env,
+            check=False,
+            capture_output=True,
+            text=True,
+            timeout=timeout_s,
+        )
+    except subprocess.TimeoutExpired as exc:
+        raise RuntimeError(f"command exceeded {timeout_s:.1f}s: {' '.join(command)}") from exc
+    elapsed_ms = (perf_counter() - started) * 1_000
+    if completed.returncode not in expected_exit_codes:
+        raise RuntimeError(
+            f"command exited {completed.returncode}: {' '.join(command)}\n"
+            f"stdout:\n{completed.stdout}\nstderr:\n{completed.stderr}"
+        )
+    return completed, elapsed_ms
+
+
+def _summary_row(
+    scenario: str,
+    kind: str,
+    values: list[float],
+    *,
+    checkout: str = "candidate",
+    unit: str,
+    exit_code: int | None = None,
+    daemon_proven: bool | None = None,
+    note: str | None = None,
+) -> TimingRow:
+    return TimingRow(
+        checkout=checkout,
+        scenario=scenario,
+        kind=kind,
+        unit=unit,
+        median=round(statistics.median(values), 3),
+        minimum=round(min(values), 3),
+        maximum=round(max(values), 3),
+        repeats=len(values),
+        exit_code=exit_code,
+        daemon_proven=daemon_proven,
+        note=note,
+    )
+
+
+def _import_cumulative_ms(
+    python: Path,
+    repo: Path,
+    module: str,
+    *,
+    env: dict[str, str],
+) -> float:
+    completed, _ = _run(
+        [str(python), "-X", "importtime", "-c", f"import {module}"],
+        cwd=repo,
+        env=env,
+        expected_exit_codes=frozenset({0}),
+    )
+    matches: list[tuple[int, str]] = []
+    for line in completed.stderr.splitlines():
+        match = _IMPORTTIME_RE.match(line)
+        if match is None:
+            continue
+        cumulative_us = int(match.group(2))
+        imported = match.group(3).strip()
+        matches.append((cumulative_us, imported))
+    for cumulative_us, imported in reversed(matches):
+        if imported == module:
+            return cumulative_us / 1_000
+    raise RuntimeError(f"no importtime row for {module!r}\nstderr:\n{completed.stderr}")
+
+
+def measure_imports(*, python: Path, repo: Path, repeats: int) -> list[TimingRow]:
+    env = _base_env(repo)
+    rows: list[TimingRow] = []
+    for label, module in _IMPORT_SCENARIOS:
+        samples = [_import_cumulative_ms(python, repo, module, env=env) for _ in range(repeats)]
+        rows.append(
+            _summary_row(
+                label,
+                "interpreter-import",
+                samples,
+                unit="ms",
+                note=f"CPython -X importtime cumulative row for {module}",
+            )
+        )
+    return rows
+
+
+def _measure_command(
+    scenario: str,
+    command: Sequence[str],
+    *,
+    python: Path,
+    repo: Path,
+    env: dict[str, str],
+    repeats: int,
+    expected_exit_code: int,
+    daemon_marker: bool = False,
+    require_daemon_proof: bool = False,
+) -> TimingRow:
+    values: list[float] = []
+    marker_count = 0
+    full_command = [str(python), "-m", "polylogue.cli", *command]
+    for _ in range(repeats):
+        completed, elapsed_ms = _run(
+            full_command,
+            cwd=repo,
+            env=env,
+            expected_exit_codes=frozenset({expected_exit_code}),
+        )
+        values.append(elapsed_ms)
+        marker_count += int("served-by: daemon (uds," in completed.stderr)
+    note = "host-dependent/unverified wall clock"
+    if daemon_marker:
+        note = f"daemon provenance marker in {marker_count}/{repeats} samples; {note}"
+        if require_daemon_proof and marker_count != repeats:
+            raise RuntimeError(
+                "daemon timing was not proven: "
+                f"the production provenance marker appeared in {marker_count}/{repeats} samples"
+            )
+    return _summary_row(
+        scenario,
+        "subprocess-wall",
+        values,
+        unit="ms",
+        exit_code=expected_exit_code,
+        daemon_proven=(marker_count == repeats) if daemon_marker else None,
+        note=note,
+    )
+
+
+def measure_root_cli_wall(
+    *,
+    python: Path,
+    repo: Path,
+    repeats: int,
+) -> list[TimingRow]:
+    env = _base_env(repo)
+    return [
+        _measure_command(
+            "root-help",
+            ("--help",),
+            python=python,
+            repo=repo,
+            env=env,
+            repeats=repeats,
+            expected_exit_code=0,
+        ),
+        _measure_command(
+            "strict-command-floor",
+            ("unsignalled-bare-query",),
+            python=python,
+            repo=repo,
+            env=env,
+            repeats=repeats,
+            expected_exit_code=2,
+        ),
+    ]
+
+
+def measure_exact_read_wall(
+    *,
+    python: Path,
+    repo: Path,
+    repeats: int,
+    archive_root: Path,
+    session_id: str,
+    runtime_dir: Path | None,
+    require_daemon_proof: bool,
+) -> list[TimingRow]:
+    read_env = _base_env(repo)
+    read_env.pop("POLYLOGUE_NO_DAEMON", None)
+    read_env.pop("POLYLOGUE_DAEMON", None)
+    read_env["POLYLOGUE_ARCHIVE_ROOT"] = str(archive_root.resolve())
+    if runtime_dir is not None:
+        read_env["XDG_RUNTIME_DIR"] = str(runtime_dir.resolve())
+    read_args = ("--plain", "--id", session_id, "read", "--format", "json")
+    return [
+        _measure_command(
+            "exact-read-direct",
+            ("--no-daemon", *read_args),
+            python=python,
+            repo=repo,
+            env=read_env,
+            repeats=repeats,
+            expected_exit_code=0,
+        ),
+        _measure_command(
+            "exact-read-daemon",
+            ("--verbose", *read_args),
+            python=python,
+            repo=repo,
+            env=read_env,
+            repeats=repeats,
+            expected_exit_code=0,
+            daemon_marker=True,
+            require_daemon_proof=require_daemon_proof,
+        ),
+    ]
+
+
+def measure_grammar_cache(*, python: Path, repo: Path, repeats: int) -> list[TimingRow]:
+    env = _base_env(repo)
+    command = [
+        str(python),
+        "-c",
+        (
+            "from time import perf_counter; "
+            "started=perf_counter(); "
+            "from polylogue.archive.query.expression import compile_expression; "
+            "compile_expression('repo:polylogue since:7d'); "
+            "print(f'{(perf_counter()-started)*1000:.6f}')"
+        ),
+    ]
+    with tempfile.TemporaryDirectory(prefix="polylogue-grammar-profile-") as cache_home:
+        cache_env = dict(env)
+        cache_env["XDG_CACHE_HOME"] = cache_home
+        cold_completed, cold_ms = _run(
+            command,
+            cwd=repo,
+            env=cache_env,
+            expected_exit_codes=frozenset({0}),
+        )
+        cold_operation_ms = float(cold_completed.stdout.strip().splitlines()[-1])
+        warm_wall_values: list[float] = []
+        warm_operation_values: list[float] = []
+        for _ in range(repeats):
+            completed, wall_ms = _run(
+                command,
+                cwd=repo,
+                env=cache_env,
+                expected_exit_codes=frozenset({0}),
+            )
+            warm_wall_values.append(wall_ms)
+            warm_operation_values.append(float(completed.stdout.strip().splitlines()[-1]))
+    return [
+        _summary_row(
+            "grammar-cold-operation",
+            "timed-operation",
+            [cold_operation_ms],
+            unit="ms",
+            note="module import plus first parse; interpreter/site startup excluded",
+        ),
+        _summary_row(
+            "grammar-warm-operation",
+            "timed-operation",
+            warm_operation_values,
+            unit="ms",
+            note="module import plus first parse; same content-addressed cache",
+        ),
+        _summary_row(
+            "grammar-cold-process",
+            "subprocess-wall",
+            [cold_ms],
+            unit="ms",
+            note="host-dependent/unverified; empty parser-cache directory",
+        ),
+        _summary_row(
+            "grammar-warm-process",
+            "subprocess-wall",
+            warm_wall_values,
+            unit="ms",
+            note="host-dependent/unverified; same content-addressed parser cache",
+        ),
+    ]
+
+
+def _render_table(rows: Sequence[TimingRow]) -> str:
+    headers = ("checkout", "scenario", "kind", "median", "min", "max", "reps", "proof/note")
+    body: list[tuple[str, ...]] = []
+    for row in rows:
+        proof = row.note or ""
+        if row.daemon_proven is not None:
+            proof = f"daemon_proven={str(row.daemon_proven).lower()}; {proof}"
+        body.append(
+            (
+                row.checkout,
+                row.scenario,
+                row.kind,
+                f"{row.median:.3f} {row.unit}",
+                f"{row.minimum:.3f}",
+                f"{row.maximum:.3f}",
+                str(row.repeats),
+                proof,
+            )
+        )
+    widths = [max(len(headers[index]), *(len(row[index]) for row in body)) for index in range(len(headers))]
+    lines = [
+        "  ".join(headers[index].ljust(widths[index]) for index in range(len(headers))),
+        "  ".join("-" * widths[index] for index in range(len(headers))),
+    ]
+    lines.extend("  ".join(row[index].ljust(widths[index]) for index in range(len(headers))) for row in body)
+    return "\n".join(lines)
+
+
+def build_parser() -> argparse.ArgumentParser:
+    parser = argparse.ArgumentParser(description=__doc__)
+    parser.add_argument("--python", type=Path, default=Path(sys.executable), help="Interpreter to profile.")
+    parser.add_argument(
+        "--repo",
+        type=Path,
+        default=Path(__file__).resolve().parents[1],
+        help="Polylogue checkout to place first on PYTHONPATH.",
+    )
+    parser.add_argument(
+        "--baseline-repo",
+        type=Path,
+        default=None,
+        help="Optional clean snapshot checkout measured with the same interpreter and sections.",
+    )
+    parser.add_argument("--repeats", type=int, default=7, help="Fresh-process samples per repeatable row.")
+    parser.add_argument(
+        "--section",
+        action="append",
+        choices=_PROFILE_SECTIONS,
+        help="Profile only this section; repeat the option to select multiple sections.",
+    )
+    parser.add_argument("--archive-root", type=Path, default=None, help="Archive for optional exact-read rows.")
+    parser.add_argument("--session-id", default=None, help="Exact session ref for optional read rows.")
+    parser.add_argument(
+        "--runtime-dir", type=Path, default=None, help="XDG_RUNTIME_DIR containing polylogue/daemon.sock."
+    )
+    parser.add_argument("--json", action="store_true", help="Emit machine-readable JSON.")
+    parser.add_argument("--out", type=Path, default=None, help="Also write the JSON report to this path.")
+    return parser
+
+
+def _absolute_interpreter(path: Path) -> Path:
+    """Return an absolute executable path without dereferencing venv symlinks.
+
+    ``Path.resolve()`` follows ``.venv/bin/python`` to the base interpreter on
+    platforms where virtual environments use symlinks. Executing that resolved
+    path loses the virtual environment's site-packages and makes the profiler
+    measure a different runtime from the one the operator selected.
+    """
+
+    expanded = path.expanduser()
+    return expanded if expanded.is_absolute() else Path.cwd() / expanded
+
+
+def _measure_selected_sections(
+    *,
+    checkout: str,
+    sections: frozenset[str],
+    python: Path,
+    repo: Path,
+    repeats: int,
+    archive_root: Path | None,
+    session_id: str | None,
+    runtime_dir: Path | None,
+) -> list[TimingRow]:
+    rows: list[TimingRow] = []
+    if "imports" in sections:
+        rows.extend(measure_imports(python=python, repo=repo, repeats=repeats))
+    if "grammar" in sections:
+        rows.extend(measure_grammar_cache(python=python, repo=repo, repeats=repeats))
+    if "root-cli" in sections:
+        rows.extend(measure_root_cli_wall(python=python, repo=repo, repeats=repeats))
+    if "exact-read" in sections:
+        assert archive_root is not None
+        assert session_id is not None
+        rows.extend(
+            measure_exact_read_wall(
+                python=python,
+                repo=repo,
+                repeats=repeats,
+                archive_root=archive_root,
+                session_id=session_id,
+                runtime_dir=runtime_dir,
+                require_daemon_proof=checkout == "candidate",
+            )
+        )
+    return [TimingRow(**{**asdict(row), "checkout": checkout}) for row in rows]
+
+
+def _comparison_rows(rows: Sequence[TimingRow]) -> list[dict[str, object]]:
+    by_key = {(row.checkout, row.scenario, row.kind, row.unit): row for row in rows}
+    comparisons: list[dict[str, object]] = []
+    for key, candidate in sorted(by_key.items()):
+        checkout, scenario, kind, unit = key
+        if checkout != "candidate":
+            continue
+        baseline = by_key.get(("baseline", scenario, kind, unit))
+        if baseline is None:
+            continue
+        delta = candidate.median - baseline.median
+        reduction_pct = None
+        if baseline.median != 0:
+            reduction_pct = round((baseline.median - candidate.median) / baseline.median * 100, 3)
+        comparisons.append(
+            {
+                "scenario": scenario,
+                "kind": kind,
+                "unit": unit,
+                "baseline_median": baseline.median,
+                "candidate_median": candidate.median,
+                "delta": round(delta, 3),
+                "reduction_percent": reduction_pct,
+            }
+        )
+    return comparisons
+
+
+def main(argv: list[str] | None = None) -> int:
+    args = build_parser().parse_args(argv)
+    repeats = max(1, args.repeats)
+    repo = args.repo.resolve()
+    python = _absolute_interpreter(args.python)
+    if args.section:
+        sections = frozenset(args.section)
+    else:
+        default_sections = ["imports", "grammar", "root-cli"]
+        if args.archive_root is not None and args.session_id is not None:
+            default_sections.append("exact-read")
+        sections = frozenset(default_sections)
+    if "exact-read" in sections and (args.archive_root is None or args.session_id is None):
+        raise SystemExit("--section exact-read requires --archive-root and --session-id")
+
+    rows: list[TimingRow] = []
+    if args.baseline_repo is not None:
+        rows.extend(
+            _measure_selected_sections(
+                checkout="baseline",
+                sections=sections,
+                python=python,
+                repo=args.baseline_repo.resolve(),
+                repeats=repeats,
+                archive_root=args.archive_root,
+                session_id=args.session_id,
+                runtime_dir=args.runtime_dir,
+            )
+        )
+    rows.extend(
+        _measure_selected_sections(
+            checkout="candidate",
+            sections=sections,
+            python=python,
+            repo=repo,
+            repeats=repeats,
+            archive_root=args.archive_root,
+            session_id=args.session_id,
+            runtime_dir=args.runtime_dir,
+        )
+    )
+    report = {
+        "version": 3,
+        "python": str(python),
+        "repo": str(repo),
+        "repeats": repeats,
+        "sections": sorted(sections),
+        "rows": [asdict(row) for row in rows],
+        "comparisons": _comparison_rows(rows),
+    }
+    if args.out is not None:
+        args.out.parent.mkdir(parents=True, exist_ok=True)
+        args.out.write_text(json.dumps(report, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    if args.json:
+        print(json.dumps(report, indent=2, sort_keys=True))
+    else:
+        print(_render_table(rows))
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
