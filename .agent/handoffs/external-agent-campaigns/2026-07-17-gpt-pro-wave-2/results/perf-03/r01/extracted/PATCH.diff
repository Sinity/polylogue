@@ -0,0 +1,1084 @@
+"""Import-light daemon-first adapters for latency-sensitive CLI reads."""
+
+from __future__ import annotations
+
+import base64
+import csv
+import io
+import json
+import os
+import re
+from collections.abc import Callable, Mapping
+from dataclasses import dataclass
+from pathlib import Path
+from typing import TYPE_CHECKING, Any, NoReturn, cast
+from urllib.parse import urlencode
+
+import click
+
+if TYPE_CHECKING:
+    from polylogue.cli.daemon_client import DaemonClient
+    from polylogue.cli.root_request import RootModeRequest
+    from polylogue.cli.shared.types import AppEnv
+
+_NATIVE_REF_RE = re.compile(r"(?=.*\d)[A-Za-z0-9][A-Za-z0-9_.:-]{11,}")
+# Health plus one read remain within a nominal sub-100 ms fallback budget.
+_DAEMON_FAST_PATH_TIMEOUT_S = 0.045
+_DAEMON_LIST_ITEM_KEEP_KEYS = (
+    "id",
+    "origin",
+    "title",
+    "target_ref",
+    "anchor",
+    "actions",
+    "created_at",
+    "updated_at",
+    "message_count",
+    "tags",
+    "summary",
+    "words",
+    "repo",
+    "cwd_display",
+    "flags",
+)
+
+
+@dataclass(frozen=True, slots=True)
+class DaemonTarget:
+    """Configuration identity required by the local daemon read transport."""
+
+    archive_root: Path
+    auth_token: str | None = None
+
+
+class _UnsetAuthToken:
+    """Sentinel distinguishing inherited daemon auth from explicit no-auth."""
+
+
+_UNSET_AUTH_TOKEN = _UnsetAuthToken()
+
+
+def daemon_reads_disabled(*, flag: bool = False) -> bool:
+    """Return whether the process or command explicitly disabled daemon reads."""
+
+    if flag:
+        return True
+    if os.environ.get("POLYLOGUE_NO_DAEMON", "").lower() in {"1", "true", "yes", "on"}:
+        return True
+    return os.environ.get("POLYLOGUE_DAEMON", "").lower() == "off"
+
+
+def default_daemon_socket_path() -> Path:
+    """Return the local daemon's canonical Unix-domain socket path."""
+
+    runtime_root = os.environ.get("XDG_RUNTIME_DIR") or "/tmp"
+    return Path(runtime_root) / "polylogue" / "daemon.sock"
+
+
+def active_daemon_target() -> DaemonTarget:
+    """Resolve archive identity and auth without runtime-service construction.
+
+    ``load_polylogue_config`` applies the same site/user TOML and environment
+    precedence used by the daemon, but unlike ``Config`` construction it does
+    not discover source roots or import the live ingestion stack.
+    """
+
+    from polylogue.config import load_polylogue_config
+    from polylogue.paths import archive_root
+
+    config = load_polylogue_config()
+    return DaemonTarget(
+        # Follow the same path owner as direct SQLite execution. The layered
+        # product config still supplies the bearer token, but a TOML-only root
+        # must not make the fast path read a different archive than fallback.
+        archive_root=archive_root().expanduser().resolve(),
+        auth_token=config.api_auth_token,
+    )
+
+
+def active_archive_root() -> Path:
+    """Return the direct-read archive root used for daemon identity."""
+
+    return active_daemon_target().archive_root
+
+
+def _runtime_config_auth_token(config: object) -> str | None | _UnsetAuthToken:
+    """Return an explicitly injected token, or inherit layered daemon auth.
+
+    ``Config`` historically has no declared API-token field, but tests and a
+    few embedding surfaces attach one dynamically.  Treat only ``str`` and
+    explicit ``None`` as authoritative; mocks or unrelated values must not
+    accidentally disable the normal layered-config token.
+    """
+
+    value = getattr(config, "api_auth_token", _UNSET_AUTH_TOKEN)
+    if value is None or isinstance(value, str):
+        return value
+    return _UNSET_AUTH_TOKEN
+
+
+def _initialized_daemon_overrides(
+    env: AppEnv,
+) -> tuple[Path | None, str | None | _UnsetAuthToken]:
+    """Return injected archive/auth overrides without constructing services."""
+
+    try:
+        config = env.config_if_initialized
+    except AttributeError:
+        return None, _UNSET_AUTH_TOKEN
+    if config is None:
+        return None, _UNSET_AUTH_TOKEN
+    return config.archive_root, _runtime_config_auth_token(config)
+
+
+def matching_daemon_client(
+    archive_root: Path | None = None,
+    *,
+    auth_token: str | None | _UnsetAuthToken = _UNSET_AUTH_TOKEN,
+    disabled: bool = False,
+) -> DaemonClient | None:
+    """Return a health-checked client for the exact archive/schema/build tuple."""
+
+    if daemon_reads_disabled(flag=disabled):
+        return None
+    socket_path = default_daemon_socket_path()
+    # The common daemon-down case must fail before git/build identity work.
+    if not socket_path.exists():
+        return None
+
+    try:
+        target: DaemonTarget | None = None
+        if archive_root is None or isinstance(auth_token, _UnsetAuthToken):
+            target = active_daemon_target()
+        if archive_root is None:
+            assert target is not None
+            archive_root = target.archive_root
+        if isinstance(auth_token, _UnsetAuthToken):
+            assert target is not None
+            auth_token = target.auth_token
+
+        from polylogue.cli.daemon_client import DaemonClient
+        from polylogue.storage.sqlite.archive_tiers.versions import INDEX_SCHEMA_VERSION
+
+        client = DaemonClient(
+            socket_path,
+            timeout_s=_DAEMON_FAST_PATH_TIMEOUT_S,
+            auth_token=auth_token,
+        )
+        health = client.probe(
+            archive_root=str(archive_root.expanduser().resolve()),
+            index_schema_version=INDEX_SCHEMA_VERSION,
+        )
+        if health is None:
+            return None
+
+        # Build identity may consult Git for an editable checkout. Resolve it
+        # only after a live daemon has answered and matched archive + schema.
+        from polylogue.version import get_polylogue_version
+
+        if health.get("daemon_version") != get_polylogue_version():
+            return None
+    except Exception:
+        # Daemon reads are optional. Config, build-identity, and transport
+        # failures must preserve the direct executor's diagnostics and exits.
+        return None
+    return client
+
+
+def matching_daemon_client_for_env(
+    env: AppEnv,
+    *,
+    disabled: bool = False,
+) -> DaemonClient | None:
+    """Match the daemon to an invocation's injected root and auth identity."""
+
+    archive_root, auth_token = _initialized_daemon_overrides(env)
+    return matching_daemon_client(
+        archive_root,
+        auth_token=auth_token,
+        disabled=disabled,
+    )
+
+
+def matching_daemon_client_for_config(
+    config: object,
+    *,
+    disabled: bool = False,
+) -> DaemonClient | None:
+    """Match a daemon for an already-resolved runtime config."""
+
+    archive_root = getattr(config, "archive_root", None)
+    if not isinstance(archive_root, Path):
+        return None
+    return matching_daemon_client(
+        archive_root,
+        auth_token=_runtime_config_auth_token(config),
+        disabled=disabled,
+    )
+
+
+def fetch_daemon_payload(
+    archive_root: Path | None,
+    path: str,
+    *,
+    body: dict[str, object] | None = None,
+    auth_token: str | None | _UnsetAuthToken = _UNSET_AUTH_TOKEN,
+    disabled: bool = False,
+) -> dict[str, Any] | None:
+    """Fetch one matched-daemon JSON object, returning ``None`` on any miss."""
+
+    client = matching_daemon_client(
+        archive_root,
+        auth_token=auth_token,
+        disabled=disabled,
+    )
+    if client is None:
+        return None
+    payload = client.request_json("POST" if body is not None else "GET", path, body)
+    if payload is not None and client.last_elapsed_ms is not None:
+        payload["_daemon_elapsed_ms"] = client.last_elapsed_ms
+    return payload
+
+
+def fetch_daemon_payload_for_env(
+    env: AppEnv,
+    path: str,
+    *,
+    body: dict[str, object] | None = None,
+    disabled: bool = False,
+) -> dict[str, Any] | None:
+    """Fetch through the daemon using invocation-scoped identity overrides."""
+
+    archive_root, auth_token = _initialized_daemon_overrides(env)
+    return fetch_daemon_payload(
+        archive_root,
+        path,
+        body=body,
+        auth_token=auth_token,
+        disabled=disabled,
+    )
+
+
+def fetch_daemon_payload_for_config(
+    config: object,
+    path: str,
+    *,
+    body: dict[str, object] | None = None,
+    disabled: bool = False,
+) -> dict[str, Any] | None:
+    """Fetch through the daemon for an already-resolved runtime config."""
+
+    archive_root = getattr(config, "archive_root", None)
+    if not isinstance(archive_root, Path):
+        return None
+    return fetch_daemon_payload(
+        archive_root,
+        path,
+        body=body,
+        auth_token=_runtime_config_auth_token(config),
+        disabled=disabled,
+    )
+
+
+def exact_session_ref_from_request(request: RootModeRequest) -> str | None:
+    """Return one unambiguous exact-session ref without compiling the DSL."""
+
+    params = request.params
+    explicit = params.get("conv_id")
+    session_ref: str | None = None
+    if isinstance(explicit, str) and explicit.strip() and not request.query_terms:
+        session_ref = explicit.strip()
+    elif len(request.query_terms) == 1:
+        token = request.query_terms[0].strip()
+        lowered = token.lower()
+        for prefix in ("id:", "session:"):
+            if lowered.startswith(prefix) and token[len(prefix) :].strip():
+                session_ref = token[len(prefix) :].strip()
+                break
+        else:
+            if _NATIVE_REF_RE.fullmatch(token):
+                session_ref = token
+    if session_ref is None:
+        return None
+
+    competing_keys = (
+        "contains",
+        "exclude_text",
+        "origin",
+        "exclude_origin",
+        "tag",
+        "exclude_tag",
+        "repo",
+        "has_type",
+        "tool",
+        "exclude_tool",
+        "action",
+        "exclude_action",
+        "action_sequence",
+        "action_text",
+        "referenced_path",
+        "cwd_prefix",
+        "title",
+        "min_messages",
+        "max_messages",
+        "min_words",
+        "max_words",
+        "since",
+        "until",
+        "filter_has_paste",
+        "filter_has_tool_use",
+        "filter_has_thinking",
+        "latest",
+        "sample",
+        "similar_text",
+        "project",
+        "typed_only",
+        "message_type",
+        "since_session_id",
+        "stats_only",
+        "stats_by",
+        "count_only",
+        "stream",
+        "set_meta",
+        "add_tag",
+        "delete_matched",
+        "dry_run",
+        "force",
+        "open_result",
+        "list_mode",
+    )
+    if any(_has_value(params.get(key)) for key in competing_keys):
+        return None
+    return session_ref
+
+
+def try_execute_exact_session_read(
+    env: AppEnv,
+    request: RootModeRequest,
+    *,
+    output_format: str | None = None,
+    fields: str | None = None,
+    destination: str = "stdout",
+    out_path: str | None = None,
+    disabled: bool = False,
+) -> bool:
+    """Read one exact session from the matched daemon before SQLite imports."""
+
+    session_ref = exact_session_ref_from_request(request)
+    if session_ref is None or destination not in {"terminal", "stdout"} or out_path is not None:
+        return False
+    params = request.params
+    fmt = output_format or str(params.get("output_format") or "markdown")
+    if fmt not in {"json", "ndjson", "yaml", "markdown", "plaintext"}:
+        return False
+    if daemon_reads_disabled(flag=disabled or bool(params.get("no_daemon"))):
+        return False
+
+    try:
+        payload = fetch_daemon_payload_for_env(
+            env,
+            "/api/cli/read",
+            body={"session_id": session_ref},
+            disabled=disabled or bool(params.get("no_daemon")),
+        )
+    except Exception:
+        return False
+    if payload is None or not _canonical_session_payload(payload):
+        return False
+
+    elapsed_ms = payload.pop("_daemon_elapsed_ms", None)
+    if bool(params.get("verbose")) and isinstance(elapsed_ms, int):
+        click.echo(f"served-by: daemon (uds, {elapsed_ms}ms)", err=True)
+    _emit_session_payload(payload, output_format=fmt, fields=fields)
+    return True
+
+
+def try_execute_exact_messages_read(
+    env: AppEnv,
+    request: RootModeRequest,
+    *,
+    output_format: str | None,
+    destination: str,
+    out_path: str | None,
+    limit: int | None,
+    offset: int,
+    full: bool,
+    fields: str | None,
+    disabled: bool = False,
+) -> bool:
+    """Read one exact session's machine-form messages through the daemon.
+
+    Markdown rendering deliberately stays on the direct path because it needs
+    the semantic-card renderer. JSON and NDJSON share a finite canonical
+    payload with direct ``read --view messages`` and can avoid all cold API and
+    SQLite initialization in the CLI process.
+    """
+
+    session_ref = exact_session_ref_from_request(request)
+    if session_ref is None or output_format not in {"json", "ndjson"}:
+        return False
+    if destination not in {"terminal", "stdout"} or out_path is not None or fields is not None:
+        return False
+    if offset < 0 or (limit is not None and limit < 1):
+        return False
+    if daemon_reads_disabled(flag=disabled or bool(request.params.get("no_daemon"))):
+        return False
+
+    effective_limit = limit if limit is not None else 50
+    try:
+        payload = fetch_daemon_payload_for_env(
+            env,
+            "/api/cli/read",
+            body={
+                "session_id": session_ref,
+                "view": "messages",
+                "limit": effective_limit,
+                "offset": offset,
+                "full": full,
+            },
+            disabled=disabled or bool(request.params.get("no_daemon")),
+        )
+    except Exception:
+        return False
+    if payload is None or not _canonical_messages_payload(payload):
+        return False
+
+    elapsed_ms = payload.pop("_daemon_elapsed_ms", None)
+    if bool(request.params.get("verbose")) and isinstance(elapsed_ms, int):
+        click.echo(f"served-by: daemon (uds, {elapsed_ms}ms)", err=True)
+    if output_format == "json":
+        click.echo(json.dumps(payload, indent=2))
+    else:
+        for message in cast(list[object], payload["messages"]):
+            click.echo(json.dumps(message))
+    return True
+
+
+def _canonical_messages_payload(payload: Mapping[str, object]) -> bool:
+    return (
+        isinstance(payload.get("session_id"), str)
+        and isinstance(payload.get("messages"), list)
+        and isinstance(payload.get("total"), int)
+        and isinstance(payload.get("limit"), int)
+        and isinstance(payload.get("offset"), int)
+    )
+
+
+def try_execute_public_ref_read(
+    env: AppEnv,
+    ref: str,
+    *,
+    output_format: str | None,
+    destination: str,
+    disabled: bool = False,
+    verbose: bool = False,
+) -> bool:
+    """Resolve a positional public ref through the existing daemon route."""
+
+    if output_format not in {None, "json"} or destination not in {"terminal", "stdout"}:
+        return False
+    if daemon_reads_disabled(flag=disabled):
+        return False
+    try:
+        payload = fetch_daemon_payload_for_env(
+            env,
+            "/api/refs/resolve?" + urlencode({"ref": ref}),
+            disabled=disabled,
+        )
+    except Exception:
+        return False
+    if payload is None or not _canonical_public_ref_payload(payload):
+        return False
+
+    elapsed_ms = payload.pop("_daemon_elapsed_ms", None)
+    if verbose and isinstance(elapsed_ms, int):
+        click.echo(f"served-by: daemon (uds, {elapsed_ms}ms)", err=True)
+    # ``serialize_surface_payload`` uses Pydantic's UTF-8-preserving JSON;
+    # preserve that byte contract while avoiding a model import in the CLI.
+    click.echo(json.dumps(payload, indent=2, ensure_ascii=False))
+    return True
+
+
+def _canonical_public_ref_payload(payload: Mapping[str, object]) -> bool:
+    return (
+        payload.get("mode") == "ref-resolution"
+        and isinstance(payload.get("ref"), str)
+        and isinstance(payload.get("resolved"), bool)
+    )
+
+
+def _canonical_session_payload(payload: Mapping[str, object]) -> bool:
+    return (
+        payload.get("mode") == "session"
+        and isinstance(payload.get("session_id"), str)
+        and isinstance(payload.get("messages"), list)
+    )
+
+
+def _emit_session_payload(
+    payload: dict[str, Any],
+    *,
+    output_format: str,
+    fields: str | None,
+) -> None:
+    if output_format == "json":
+        click.echo(json.dumps(_project_payload(payload, fields), indent=2, sort_keys=True))
+        return
+    if output_format == "yaml":
+        import yaml
+
+        click.echo(yaml.safe_dump(_project_payload(payload, fields), sort_keys=False, allow_unicode=True), nl=False)
+        return
+    if output_format == "ndjson":
+        for message in cast(list[object], payload["messages"]):
+            click.echo(json.dumps(message, sort_keys=True))
+        return
+    click.echo(_session_payload_text(payload))
+
+
+def _session_payload_text(payload: Mapping[str, object]) -> str:
+    from polylogue.surfaces.archive_session import archive_session_payload_text
+
+    return archive_session_payload_text(payload)
+
+
+def try_execute_root_query(env: AppEnv, request: RootModeRequest) -> bool:
+    """Execute a conservative list/search request before importing SQLite.
+
+    Unsupported or structurally ambiguous shapes return ``False`` so the
+    established direct executor remains the sole source of diagnostics and
+    validation for those cases.
+    """
+
+    params = dict(request.params)
+    if try_execute_exact_session_read(
+        env,
+        request,
+        output_format=_optional_str(params.get("output_format")),
+        fields=_optional_str(params.get("fields")),
+        destination=str(params.get("output") or "stdout"),
+        disabled=bool(params.get("no_daemon")),
+    ):
+        return True
+    if not _early_root_query_supported(request, params):
+        return False
+
+    try:
+        limit = _positive_int(params.get("limit"), default=20)
+        offset = _positive_int(params.get("offset"), default=0, allow_zero=True)
+        cursor_token = _optional_str(params.get("cursor"))
+        if cursor_token is not None:
+            cursor_offset = _cursor_offset(cursor_token)
+            if cursor_offset is None:
+                return False
+            offset = cursor_offset
+        daemon_params = daemon_session_query_params(request, params, limit=limit, offset=offset)
+        payload = fetch_daemon_payload_for_env(
+            env,
+            "/api/cli/query",
+            body={"params": daemon_params},
+            disabled=bool(params.get("no_daemon")),
+        )
+    except Exception:
+        return False
+    if payload is None or _daemon_payload_is_degraded(payload):
+        return False
+
+    elapsed_ms = payload.pop("_daemon_elapsed_ms", None)
+    if bool(params.get("verbose")) and isinstance(elapsed_ms, int):
+        click.echo(f"served-by: daemon (uds, {elapsed_ms}ms)", err=True)
+
+    output_format = str(params.get("output_format") or "markdown")
+    fields = _optional_str(params.get("fields"))
+    origin = _single_origin(params.get("origin"))
+    query = " ".join(term for term in request.query_terms if term).strip()
+    if isinstance(payload.get("hits"), list):
+        emit_daemon_search_payload(
+            payload,
+            query=query or str(daemon_params.get("query") or ""),
+            limit=limit,
+            offset=offset,
+            output_format=output_format,
+            origin=origin,
+            fields=fields,
+            typo_hint=_subcommand_typo_hint(request.query_terms),
+        )
+        return True
+    if isinstance(payload.get("items"), list):
+        emit_daemon_list_payload(
+            payload,
+            limit=limit,
+            offset=offset,
+            output_format=output_format,
+            origin=origin,
+            fields=fields,
+        )
+        return True
+    return False
+
+
+def _early_root_query_supported(request: RootModeRequest, params: Mapping[str, object]) -> bool:
+    if daemon_reads_disabled(flag=bool(params.get("no_daemon"))):
+        return False
+    raw_limit = params.get("limit")
+    if raw_limit is not None and (not isinstance(raw_limit, int) or isinstance(raw_limit, bool) or raw_limit < 1):
+        return False
+    raw_offset = params.get("offset")
+    if raw_offset is not None and (not isinstance(raw_offset, int) or isinstance(raw_offset, bool) or raw_offset < 0):
+        return False
+    cursor_token = _optional_str(params.get("cursor"))
+    if cursor_token is not None and _cursor_offset(cursor_token) is None:
+        return False
+    if str(params.get("output") or "stdout") != "stdout":
+        return False
+    if str(params.get("output_format") or "markdown") not in {
+        "json",
+        "ndjson",
+        "csv",
+        "yaml",
+        "markdown",
+        "plaintext",
+    }:
+        return False
+    if str(params.get("retrieval_lane") or "auto") not in {"auto", "dialogue"}:
+        return False
+    unsupported = (
+        "stats_only",
+        "stats_by",
+        "count_only",
+        "stream",
+        "set_meta",
+        "add_tag",
+        "delete_matched",
+        "dry_run",
+        "force",
+        "open_result",
+        "conv_id",
+        "latest",
+        "sample",
+        "sort",
+        "reverse",
+        "similar_text",
+        "project",
+        "typed_only",
+        "message_type",
+        "since_session_id",
+        "explain_query",
+    )
+    if any(_has_value(params.get(key)) for key in unsupported):
+        return False
+
+    raw_query = " ".join(request.query_terms).strip()
+    lowered = raw_query.lower()
+    if not raw_query:
+        return True
+    if any(marker in lowered for marker in (" where ", " with ", "|", "{", "}")):
+        return False
+    # Exact identity and compact DSL clauses retain the direct compiler's
+    # cardinality/error behavior until their daemon parity is explicitly proven.
+    return ":" not in raw_query and _NATIVE_REF_RE.fullmatch(raw_query) is None
+
+
+def daemon_session_query_params(
+    request: RootModeRequest,
+    params: Mapping[str, object],
+    *,
+    limit: int,
+    offset: int,
+) -> dict[str, object]:
+    query_params: dict[str, object] = {"limit": limit, "offset": offset}
+    raw_query = " ".join(term for term in request.query_terms if term).strip()
+    if raw_query:
+        query_params["query"] = raw_query
+    for source_key, dest_key in (
+        ("contains", "contains"),
+        ("origin", "origin"),
+        ("exclude_origin", "exclude_origin"),
+        ("tag", "tag"),
+        ("exclude_tag", "exclude_tag"),
+        ("repo", "repo"),
+        ("has_type", "has_type"),
+        ("tool", "tool"),
+        ("exclude_tool", "exclude_tool"),
+        ("action", "action"),
+        ("exclude_action", "exclude_action"),
+        ("action_sequence", "action_sequence"),
+        ("action_text", "action_text"),
+        ("referenced_path", "referenced_path"),
+        ("cwd_prefix", "cwd_prefix"),
+        ("title", "title"),
+        ("min_messages", "min_messages"),
+        ("max_messages", "max_messages"),
+        ("min_words", "min_words"),
+        ("max_words", "max_words"),
+        ("since", "since"),
+        ("until", "until"),
+    ):
+        value = params.get(source_key)
+        if _has_value(value):
+            query_params[dest_key] = value
+    for source_key, dest_key in (
+        ("filter_has_paste", "has_paste_evidence"),
+        ("filter_has_tool_use", "has_tool_use"),
+        ("filter_has_thinking", "has_thinking"),
+    ):
+        if bool(params.get(source_key)):
+            query_params[dest_key] = "1"
+    return query_params
+
+
+def _daemon_payload_is_degraded(payload: Mapping[str, object]) -> bool:
+    route_state = payload.get("route_state")
+    return isinstance(route_state, Mapping) and route_state.get("state") == "degraded"
+
+
+def emit_daemon_list_payload(
+    payload: Mapping[str, object],
+    *,
+    limit: int,
+    offset: int,
+    output_format: str,
+    origin: str | None,
+    fields: str | None,
+) -> None:
+    items = [
+        _normalize_list_item(item)
+        for item in cast(list[object], payload.get("items") or [])
+        if isinstance(item, Mapping)
+    ]
+    total = _object_int(payload.get("total"), default=len(items))
+    next_cursor = _next_page_cursor(
+        items,
+        total=total,
+        offset=offset,
+        retrieval_lane="dialogue",
+    )
+    envelope: dict[str, object] = {
+        "mode": "list",
+        "origin": origin,
+        "items": items,
+        "total": total,
+        "limit": limit,
+        "offset": offset,
+        "next_offset": offset + limit if next_cursor is not None else None,
+        "next_cursor": next_cursor,
+        "source": "daemon",
+    }
+    _emit_rows(envelope, items, output_format=output_format, text_line=_summary_line, fields=fields)
+
+
+def emit_daemon_search_payload(
+    payload: Mapping[str, object],
+    *,
+    query: str,
+    limit: int,
+    offset: int,
+    output_format: str,
+    origin: str | None,
+    fields: str | None,
+    typo_hint: str | None,
+) -> None:
+    _emit_degraded_daemon_search_payload(
+        payload,
+        query=query,
+        output_format=output_format,
+        fields=fields,
+    )
+    hits = [dict(item) for item in cast(list[object], payload.get("hits") or []) if isinstance(item, Mapping)]
+    total = _object_int(payload.get("total"), default=len(hits))
+    retrieval_lane = str(payload.get("retrieval_lane") or "dialogue")
+    next_cursor = _next_page_cursor(
+        hits,
+        total=total,
+        offset=offset,
+        retrieval_lane=retrieval_lane,
+    )
+    envelope: dict[str, object] = {
+        "mode": "search",
+        "origin": origin,
+        "query": query,
+        "retrieval_lane": retrieval_lane,
+        "items": hits,
+        "total": total,
+        "limit": limit,
+        "offset": offset,
+        "next_offset": offset + limit if next_cursor is not None else None,
+        "next_cursor": next_cursor,
+        "source": "daemon",
+    }
+    if not hits:
+        _emit_no_results(
+            envelope,
+            output_format=output_format,
+            typo_hint=typo_hint,
+        )
+    _emit_rows(envelope, hits, output_format=output_format, text_line=_hit_line, fields=fields)
+
+
+def _emit_degraded_daemon_search_payload(
+    payload: Mapping[str, object],
+    *,
+    query: str,
+    output_format: str,
+    fields: str | None,
+) -> None:
+    """Preserve the established daemon degraded-search diagnostic contract."""
+
+    route_state = payload.get("route_state")
+    if not isinstance(route_state, Mapping) or route_state.get("state") != "degraded":
+        return
+    reason = str(route_state.get("reason") or "Search index unavailable.")
+    envelope: dict[str, object] = {
+        "mode": "search",
+        "query": query,
+        "retrieval_lane": str(payload.get("retrieval_lane") or "dialogue"),
+        "items": [],
+        "total": None,
+        "source": "daemon",
+        "route_state": dict(route_state),
+    }
+    diagnostics = payload.get("diagnostics")
+    if isinstance(diagnostics, Mapping):
+        envelope["diagnostics"] = dict(diagnostics)
+    if output_format in {"json", "yaml"}:
+        _emit_rows(envelope, [], output_format=output_format, text_line=_hit_line, fields=fields)
+    elif output_format not in {"ndjson", "csv"}:
+        click.echo(reason, err=True)
+    raise SystemExit(1)
+
+
+def _normalize_list_item(item: Mapping[str, object]) -> dict[str, object]:
+    normalized = dict(item)
+    if "words" not in normalized and "word_count" in normalized:
+        normalized["words"] = normalized.get("word_count")
+    return {
+        key: normalized[key] for key in _DAEMON_LIST_ITEM_KEEP_KEYS if key in normalized and normalized[key] is not None
+    }
+
+
+def _emit_rows(
+    envelope: dict[str, object],
+    items: list[dict[str, object]],
+    *,
+    output_format: str,
+    text_line: Callable[[dict[str, object]], str],
+    fields: str | None,
+) -> None:
+    projected_items = [_project_payload(item, fields) for item in items]
+    if output_format == "json":
+        click.echo(json.dumps({**envelope, "items": projected_items}, indent=2, sort_keys=True))
+        return
+    if output_format == "ndjson":
+        for item in projected_items:
+            click.echo(json.dumps(item, sort_keys=True))
+        return
+    if output_format == "csv":
+        click.echo(_csv(projected_items), nl=False)
+        return
+    if output_format == "yaml":
+        import yaml
+
+        click.echo(
+            yaml.safe_dump({**envelope, "items": projected_items}, sort_keys=False, allow_unicode=True), nl=False
+        )
+        return
+    click.echo("\n".join(text_line(item) for item in items))
+
+
+def _emit_no_results(
+    envelope: dict[str, object],
+    *,
+    output_format: str,
+    typo_hint: str | None = None,
+) -> NoReturn:
+    from polylogue.cli.convergence_feedback import convergence_warning_line
+
+    warning = convergence_warning_line()
+    empty = {**envelope, "items": [], "total": 0}
+    if warning is not None:
+        empty["archive_converging"] = True
+        empty["convergence_warning"] = warning
+    if output_format == "json":
+        click.echo(json.dumps(empty, indent=2, sort_keys=True))
+    elif output_format == "yaml":
+        import yaml
+
+        click.echo(yaml.safe_dump(empty, sort_keys=False, allow_unicode=True), nl=False)
+    elif output_format not in {"ndjson", "csv"}:
+        if warning is not None:
+            click.echo(warning)
+        click.echo("No sessions matched.")
+        if typo_hint is not None:
+            click.echo(typo_hint)
+    raise SystemExit(2)
+
+
+def _subcommand_typo_hint(query_terms: tuple[str, ...]) -> str | None:
+    if len(query_terms) != 1:
+        return None
+    token = query_terms[0].strip()
+    if not token or " " in token:
+        return None
+    from polylogue.cli.click_app import cli
+    from polylogue.cli.parser_diagnostics import looks_like_subcommand_typo
+
+    suggestions = looks_like_subcommand_typo(token, sorted(cli.commands))
+    if not suggestions:
+        return None
+    return (
+        "Note: query-first dispatch interpreted "
+        f"`{token}` as a search query. If you meant a subcommand, try: "
+        + ", ".join(f"`polylogue {suggestion}`" for suggestion in suggestions)
+    )
+
+
+def _summary_line(item: dict[str, object]) -> str:
+    session_id = str(item["id"])
+    title = _snippet(item.get("title") or session_id, max_chars=50)
+    date = str(item.get("updated_at") or item.get("created_at") or "unknown")[:10]
+    origin = str(item["origin"])
+    message_count = item.get("message_count") or 0
+    return f"{session_id[:24]:24s}  {date:10s}  {origin:24s}  {title} ({message_count} msgs)"
+
+
+def _hit_line(item: dict[str, object]) -> str:
+    session = item.get("session")
+    match = item.get("match")
+    if not isinstance(session, dict) or not isinstance(match, dict):
+        return str(item)
+    title = _snippet(session.get("title") or session.get("id"), max_chars=96)
+    snippet = _snippet(match.get("snippet"), max_chars=320)
+    return f"{match['rank']}. {session['origin']}  {title}  {snippet}"
+
+
+def _snippet(value: object, *, max_chars: int = 96) -> str:
+    text = " ".join(str(value or "").split())
+    return text if len(text) <= max_chars else f"{text[: max_chars - 3]}..."
+
+
+def _project_payload(payload: dict[str, object], fields: str | None) -> dict[str, object]:
+    if not fields:
+        return dict(payload)
+    selected = frozenset(field.strip() for field in fields.split(",") if field.strip())
+    return {key: value for key, value in payload.items() if key in selected}
+
+
+def _csv(items: list[dict[str, object]]) -> str:
+    if not items:
+        return ""
+    buf = io.StringIO()
+    writer = csv.DictWriter(buf, fieldnames=list(items[0]))
+    writer.writeheader()
+    writer.writerows(items)
+    return buf.getvalue()
+
+
+def _cursor_offset(token: str) -> int | None:
+    """Decode only the stable cursor fields needed by the import-light path."""
+
+    padded = token + "=" * (-len(token) % 4)
+    try:
+        raw = base64.urlsafe_b64decode(padded.encode("ascii"))
+        body = json.loads(raw.decode("utf-8"))
+    except (UnicodeDecodeError, ValueError, TypeError, json.JSONDecodeError):
+        return None
+    if not isinstance(body, dict) or body.get("v") != 1:
+        return None
+    rank = body.get("r")
+    session_id = body.get("c")
+    lane = body.get("l")
+    if not isinstance(rank, int) or isinstance(rank, bool) or rank < 0:
+        return None
+    if not isinstance(session_id, str) or not session_id:
+        return None
+    if not isinstance(lane, str) or not lane:
+        return None
+    return rank
+
+
+def _next_page_cursor(
+    items: list[dict[str, object]],
+    *,
+    total: int,
+    offset: int,
+    retrieval_lane: str,
+) -> str | None:
+    """Mint the exact root-CLI cursor shape when another page exists."""
+
+    if not items or total <= offset + len(items):
+        return None
+    last = items[-1]
+    session_id: object = last.get("id")
+    if not isinstance(session_id, str):
+        session = last.get("session")
+        session_id = session.get("id") if isinstance(session, Mapping) else None
+    if not isinstance(session_id, str) or not session_id:
+        return None
+    body = {
+        "v": 1,
+        "r": offset + len(items),
+        "s": None,
+        "c": session_id,
+        "l": retrieval_lane,
+        "q": None,
+    }
+    raw = json.dumps(body, separators=(",", ":"), ensure_ascii=False).encode("utf-8")
+    return base64.urlsafe_b64encode(raw).decode("ascii").rstrip("=")
+
+
+def _object_int(value: object, *, default: int) -> int:
+    if not isinstance(value, (str, bytes, bytearray, int, float)):
+        return default
+    try:
+        return int(value)
+    except (TypeError, ValueError):
+        return default
+
+
+def _positive_int(value: object, *, default: int, allow_zero: bool = False) -> int:
+    if isinstance(value, int) and (value > 0 or (allow_zero and value == 0)):
+        return value
+    return default
+
+
+def _has_value(value: object) -> bool:
+    if value is None or value is False:
+        return False
+    return value != "" and value != () and value != []
+
+
+def _optional_str(value: object) -> str | None:
+    if value is None:
+        return None
+    text = str(value).strip()
+    return text or None
+
+
+def _single_origin(value: object) -> str | None:
+    if not value:
+        return None
+    values = tuple(token.strip() for token in str(value).split(",") if token.strip())
+    return values[0] if len(values) == 1 else None
+
+
+__all__ = [
+    "DaemonTarget",
+    "active_archive_root",
+    "active_daemon_target",
+    "daemon_reads_disabled",
+    "daemon_session_query_params",
+    "default_daemon_socket_path",
+    "emit_daemon_list_payload",
+    "emit_daemon_search_payload",
+    "exact_session_ref_from_request",
+    "fetch_daemon_payload",
+    "fetch_daemon_payload_for_config",
+    "fetch_daemon_payload_for_env",
+    "matching_daemon_client",
+    "matching_daemon_client_for_config",
+    "matching_daemon_client_for_env",
+    "try_execute_exact_messages_read",
+    "try_execute_exact_session_read",
+    "try_execute_public_ref_read",
+    "try_execute_root_query",
+]
