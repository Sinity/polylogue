+    direct_payload = json.loads(direct_result.output)
+    direct_ref_result = runner.invoke(
+        cli,
+        ["--plain", "--no-daemon", "read", public_ref, "--format", "json"],
+    )
+    assert direct_ref_result.exit_code == 0, direct_ref_result.output
+    direct_ref_payload = json.loads(direct_ref_result.output)
+
+    from polylogue.daemon.http import DaemonAPIHandler
+    from polylogue.daemon.uds import DaemonAPIUnixHTTPServer, daemon_socket_path
+
+    socket_path = daemon_socket_path(str(_uds_runtime_dir))
+    server = DaemonAPIUnixHTTPServer(socket_path, DaemonAPIHandler)
+    auth_token = "golden-parity-secret"
+    server.auth_token = auth_token
+    monkeypatch.setenv("POLYLOGUE_API_AUTH_TOKEN", auth_token)
+    thread = threading.Thread(target=server.serve_forever, name="golden-parity-read-uds", daemon=True)
+    thread.start()
+    try:
+        from polylogue.cli.daemon_client import DaemonClient
+
+        client = DaemonClient(socket_path, timeout_s=1.0, auth_token=auth_token)
+        deadline = time.monotonic() + 2.0
+        while time.monotonic() < deadline:
+            if client.request_json("GET", "/api/health") is not None:
+                break
+            time.sleep(0.02)
+        else:
+            pytest.fail("daemon UDS server did not become ready")
+
+        daemon_result = runner.invoke(
+            cli,
+            ["--plain", "--verbose", "--id", session_id, "read", "--format", "json"],
+        )
+        daemon_ref_result = runner.invoke(
+            cli,
+            ["--plain", "--verbose", "read", public_ref, "--format", "json"],
+        )
+    finally:
+        server.shutdown()
+        server.server_close()
+        thread.join(timeout=2)
+
+    assert daemon_result.exit_code == 0, daemon_result.output
+    assert "served-by: daemon (uds," in daemon_result.stderr
+    assert json.loads(daemon_result.stdout) == direct_payload
+    assert direct_payload["messages"], "fixture read must contain messages, or parity is vacuous"
+    assert daemon_ref_result.exit_code == 0, daemon_ref_result.output
+    assert "served-by: daemon (uds," in daemon_ref_result.stderr
+    assert json.loads(daemon_ref_result.stdout) == direct_ref_payload
+    assert direct_ref_payload["resolved"] is True
