+def _query_parser_cache_path(grammar: str = _QUERY_GRAMMAR) -> Path:
+    """Return the versioned cache path for one exact grammar definition."""
+
+    configured_cache_root = os.environ.get("XDG_CACHE_HOME")
+    cache_root = Path(configured_cache_root) if configured_cache_root else Path.home() / ".cache"
+    identity = {
+        "cache_format": _QUERY_PARSER_CACHE_FORMAT,
+        "grammar": grammar,
+        "lark": lark_version,
+        "python": [sys.version_info.major, sys.version_info.minor],
+        "parser": "lalr",
+        "starts": _QUERY_PARSER_STARTS,
+        "maybe_placeholders": False,
+    }
+    digest = hashlib.sha256(json.dumps(identity, sort_keys=True, separators=(",", ":")).encode("utf-8")).hexdigest()
+    return cache_root / "polylogue" / "query-grammar" / f"{digest}.lark-cache"
+
+
+def _build_query_parser(grammar: str = _QUERY_GRAMMAR) -> Lark:
+    """Build the parser, using a persistent cache when the cache is writable."""
+
+    options = {
+        "parser": "lalr",
+        "start": list(_QUERY_PARSER_STARTS),
+        "maybe_placeholders": False,
+    }
+    cache_path = _query_parser_cache_path(grammar)
+    had_cache = cache_path.is_file()
+    try:
+        cache_path.parent.mkdir(parents=True, exist_ok=True)
+        return Lark(grammar, cache=str(cache_path), **options)
+    except Exception:
+        # A truncated or incompatible entry should not permanently disable the
+        # warm path for every later process. Remove only a file that predated
+        # this build attempt, then let Lark regenerate the exact-key cache once.
+        if had_cache:
+            try:
+                cache_path.unlink()
+            except OSError:
+                pass
+            else:
+                try:
+                    return Lark(grammar, cache=str(cache_path), **options)
+                except Exception:
+                    pass
+        # Read-only homes and transient cache failures must never change query
+        # semantics. Rebuilding without disk caching either succeeds identically
+        # or re-raises the grammar's own diagnostic.
+        return Lark(grammar, cache=False, **options)
+
