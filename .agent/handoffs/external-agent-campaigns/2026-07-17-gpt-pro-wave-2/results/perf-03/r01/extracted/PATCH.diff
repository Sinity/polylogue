+) -> None:
+    """Finite message-body reads preserve both machine-output contracts."""
+
+    import sqlite3
+
+    from polylogue.cli import cli
+
+    index_db = golden_parity_workspace["archive_root"] / "index.db"
+    with sqlite3.connect(index_db) as conn:
