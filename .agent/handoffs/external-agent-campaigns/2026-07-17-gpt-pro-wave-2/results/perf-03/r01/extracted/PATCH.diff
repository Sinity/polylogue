+def test_free_text_search_and_zero_result_exit_parity(
+    golden_parity_workspace: dict[str, Path],
+    _uds_runtime_dir: Path,
+) -> None:
+    """Ranked search and its exit-2 empty contract both use the warm daemon."""
+
+    del golden_parity_workspace
+    direct_hit = _invoke_find(query_terms=["Python"], no_daemon=True)
+    direct_miss = _invoke_find(query_terms=["nevermatchwordxyz"], no_daemon=True)
+    assert direct_hit.exit_code == 0, direct_hit.output  # type: ignore[attr-defined]
+    assert direct_miss.exit_code == 2, direct_miss.output  # type: ignore[attr-defined]
+
+    server, thread = _start_golden_server(_uds_runtime_dir)
+    try:
+        daemon_hit = _invoke_find(query_terms=["Python"])
+        daemon_miss = _invoke_find(query_terms=["nevermatchwordxyz"])
+    finally:
+        _stop_golden_server(server, thread)
+
+    assert daemon_hit.exit_code == 0, daemon_hit.output  # type: ignore[attr-defined]
+    assert daemon_miss.exit_code == 2, daemon_miss.output  # type: ignore[attr-defined]
+    direct_hit_payload = json.loads(direct_hit.output)  # type: ignore[attr-defined]
+    daemon_hit_payload = json.loads(daemon_hit.output)  # type: ignore[attr-defined]
+    direct_miss_payload = json.loads(direct_miss.output)  # type: ignore[attr-defined]
+    daemon_miss_payload = json.loads(daemon_miss.output)  # type: ignore[attr-defined]
+    assert daemon_hit_payload["source"] == "daemon"
+    assert daemon_miss_payload["source"] == "daemon"
+    assert _strip_provenance(daemon_hit_payload) == direct_hit_payload
+    assert _strip_provenance(daemon_miss_payload) == direct_miss_payload
+    assert direct_hit_payload["items"], "fixture search must produce a ranked hit"
+    assert direct_miss_payload["items"] == []
