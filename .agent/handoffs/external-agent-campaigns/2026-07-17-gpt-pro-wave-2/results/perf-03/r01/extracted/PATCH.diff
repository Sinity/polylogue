+def test_matching_daemon_client_inherits_layered_auth_token(
+    tmp_path: Path,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """Configured bearer auth must be present on both health and read calls.
+
+    Anti-vacuity: defaulting ``auth_token`` to ``None`` constructs the fake
+    client without the configured token and fails the captured assertion.
+    """
+
+    archive_root = tmp_path / "archive"
+    runtime_dir = tmp_path / "runtime"
+    socket_path = runtime_dir / "polylogue" / "daemon.sock"
+    socket_path.parent.mkdir(parents=True)
+    socket_path.touch()
+    monkeypatch.setenv("XDG_RUNTIME_DIR", str(runtime_dir))
+    monkeypatch.setenv("POLYLOGUE_ARCHIVE_ROOT", str(archive_root))
+    monkeypatch.setenv("POLYLOGUE_API_AUTH_TOKEN", "secret-token")
+
+    import polylogue.cli.daemon_client as daemon_client
+    import polylogue.version as version
+    from polylogue.cli.daemon_reads import matching_daemon_client
+
+    seen: dict[str, object] = {}
+
+    class FakeDaemonClient:
+        def __init__(
+            self,
+            path: Path,
+            *,
+            timeout_s: float = 0.1,
+            auth_token: str | None = None,
+        ) -> None:
+            seen["path"] = path
+            seen["timeout_s"] = timeout_s
+            seen["auth_token"] = auth_token
+
+        def probe(self, **identity: object) -> dict[str, object]:
+            seen["identity"] = identity
+            return {"ready": True, "daemon_version": "test-build"}
+
+    monkeypatch.setattr(daemon_client, "DaemonClient", FakeDaemonClient)
+    monkeypatch.setattr(version, "get_polylogue_version", lambda: "test-build")
+
+    client = matching_daemon_client()
+    assert isinstance(client, FakeDaemonClient)
+    assert seen["path"] == socket_path
+    assert seen["timeout_s"] < 0.05
+    assert seen["auth_token"] == "secret-token"
+    identity = seen["identity"]
+    assert isinstance(identity, dict)
+    assert identity["archive_root"] == str(archive_root.resolve())
+    assert "daemon_version" not in identity
+
