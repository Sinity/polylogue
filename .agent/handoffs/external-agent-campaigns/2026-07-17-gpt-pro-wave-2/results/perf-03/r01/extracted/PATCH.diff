+def test_absolute_interpreter_preserves_virtualenv_symlink(monkeypatch: pytest.MonkeyPatch, tmp_path: Path) -> None:
+    """Replacing the selected venv executable with its real target drops its site-packages."""
+
+    bin_dir = tmp_path / ".venv" / "bin"
+    bin_dir.mkdir(parents=True)
+    base_python = tmp_path / "python-base"
+    base_python.touch()
+    venv_python = bin_dir / "python"
+    venv_python.symlink_to(base_python)
+    monkeypatch.chdir(tmp_path)
+
+    selected = profile_cli_startup._absolute_interpreter(Path(".venv/bin/python"))
+
+    assert selected == venv_python
+    assert selected.resolve() == base_python
+
+
+def test_candidate_daemon_timing_requires_provenance_marker(monkeypatch: pytest.MonkeyPatch, tmp_path: Path) -> None:
+    """Removing the proof check would let direct fallback masquerade as daemon timing."""
+
+    completed = subprocess.CompletedProcess(
+        args=["python"],
+        returncode=0,
+        stdout="{}\n",
+        stderr="",
+    )
+    monkeypatch.setattr(profile_cli_startup, "_run", lambda *_args, **_kwargs: (completed, 12.5))
+
+    with pytest.raises(RuntimeError, match="daemon timing was not proven"):
+        profile_cli_startup._measure_command(
+            "exact-read-daemon",
+            ("--verbose", "read"),
+            python=tmp_path / "python",
+            repo=tmp_path,
+            env={},
+            repeats=2,
+            expected_exit_code=0,
+            daemon_marker=True,
+            require_daemon_proof=True,
+        )
+
+
+def test_baseline_daemon_timing_records_unproven_fallback(monkeypatch: pytest.MonkeyPatch, tmp_path: Path) -> None:
+    """A historical checkout can still be measured while clearly reporting no proof."""
+
+    completed = subprocess.CompletedProcess(
+        args=["python"],
+        returncode=0,
+        stdout="{}\n",
+        stderr="",
+    )
+    monkeypatch.setattr(profile_cli_startup, "_run", lambda *_args, **_kwargs: (completed, 12.5))
+
+    row = profile_cli_startup._measure_command(
+        "exact-read-daemon",
+        ("--verbose", "read"),
+        python=tmp_path / "python",
+        repo=tmp_path,
+        env={},
+        repeats=2,
