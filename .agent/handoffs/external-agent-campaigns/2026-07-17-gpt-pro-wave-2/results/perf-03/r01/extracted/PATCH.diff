+def test_exact_read_environment_overrides_inherited_daemon_escape_hatches(
+    monkeypatch: pytest.MonkeyPatch,
+    tmp_path: Path,
+) -> None:
+    """Operator shell state must not silently invalidate the profiler's daemon row."""
+
+    captured: list[dict[str, str]] = []
+
+    def capture_command(*_args: object, env: dict[str, str], **_kwargs: object) -> profile_cli_startup.TimingRow:
+        captured.append(dict(env))
