@@ -0,0 +1,163 @@
+"""Canonical CLI projections for one archive session.
+
+The helpers are intentionally model-light. They accept the archive envelope
+under ``TYPE_CHECKING`` only so daemon and CLI callers share one byte-shape
+contract without importing the SQLite writer module during fast-path setup.
+"""
+
+from __future__ import annotations
+
+from collections.abc import Mapping
+from typing import TYPE_CHECKING, cast
+
+if TYPE_CHECKING:
+    from polylogue.storage.sqlite.archive_tiers.archive import ArchiveSessionSearchHit, ArchiveSessionSummary
+    from polylogue.storage.sqlite.archive_tiers.write import ArchiveSessionEnvelope
+
+
+def _snippet(value: object, *, max_chars: int) -> str:
+    text = " ".join(str(value or "").split())
+    if len(text) <= max_chars:
+        return text
+    return f"{text[: max_chars - 3]}..."
+
+
+def archive_search_hit_payload(
+    hit: ArchiveSessionSearchHit,
+    *,
+    summary: ArchiveSessionSummary,
+    retrieval_lane: str,
+) -> dict[str, object]:
+    """Return the canonical CLI search-hit projection for an archive row.
+
+    Imports stay local so summary-only daemon reads retain the model-light
+    startup path while direct SQLite and daemon search share one schema.
+    """
+
+    from polylogue.surfaces.payloads import (
+        SessionSearchHitPayload,
+        SessionSearchMatchPayload,
+        SessionSummaryPayload,
+        TargetRefPayload,
+        model_json_document,
+        reader_anchor,
+        reader_message_actions,
+    )
+
+    session_id = str(summary.session_id)
+    message_id = str(hit.message_id)
+    return cast(
+        "dict[str, object]",
+        model_json_document(
+            SessionSearchHitPayload(
+                session=SessionSummaryPayload(
+                    id=session_id,
+                    origin=summary.origin,
+                    title=_snippet(summary.title or session_id, max_chars=96),
+                    message_count=summary.message_count,
+                    target_ref=TargetRefPayload.session(session_id),
+                    anchor=reader_anchor("session", session_id),
+                ),
+                match=SessionSearchMatchPayload(
+                    rank=hit.rank,
+                    retrieval_lane=retrieval_lane,
+                    match_surface="message",
+                    target_ref=TargetRefPayload.message(
+                        session_id=session_id,
+                        message_id=message_id,
+                    ),
+                    anchor=reader_anchor("message", message_id),
+                    actions=reader_message_actions(),
+                    message_id=message_id,
+                    snippet=_snippet(hit.snippet, max_chars=320),
+                    score=None,
+                    score_kind=None,
+                ),
+            ),
+            exclude_none=True,
+        ),
+    )
+
+
+def archive_session_payload(envelope: ArchiveSessionEnvelope) -> dict[str, object]:
+    """Return the canonical full-session CLI document."""
+
+    return {
+        "mode": "session",
+        "session_id": envelope.session_id,
+        "native_id": envelope.native_id,
+        "origin": envelope.origin,
+        "source": envelope.origin,
+        "title": envelope.title,
+        "active_leaf_message_id": envelope.active_leaf_message_id,
+        "messages": [
+            {
+                "message_id": message.message_id,
+                "native_id": message.native_id,
+                "role": message.role,
+                "position": message.position,
+                "variant_index": message.variant_index,
+                "is_active_path": message.is_active_path,
+                "is_active_leaf": message.is_active_leaf,
+                "blocks": [
+                    {
+                        "block_id": block.block_id,
+                        "message_id": block.message_id,
+                        "block_type": block.block_type,
+                        "text": block.text,
+                        "tool_name": block.tool_name,
+                        "tool_id": block.tool_id,
+                        "semantic_type": block.semantic_type,
+                    }
+                    for block in message.blocks
+                ],
+            }
+            for message in envelope.messages
+        ],
+    }
+
+
+def archive_session_payload_text(payload: Mapping[str, object]) -> str:
+    """Render a canonical session payload as Markdown/plaintext."""
+
+    session_id = str(payload["session_id"])
+    lines = [f"# {payload.get('title') or session_id}", "", f"`{session_id}`", ""]
+    raw_messages = payload.get("messages")
+    messages = raw_messages if isinstance(raw_messages, list) else []
+    for raw_message in messages:
+        if not isinstance(raw_message, Mapping):
+            continue
+        lines.append(f"## {raw_message.get('role') or ''}")
+        raw_blocks = raw_message.get("blocks")
+        blocks = raw_blocks if isinstance(raw_blocks, list) else []
+        lines.append(
+            "\n".join(str(block["text"]) for block in blocks if isinstance(block, Mapping) and block.get("text"))
+        )
+        lines.append("")
+    return "\n".join(lines).rstrip()
+
+
+def archive_session_text(envelope: ArchiveSessionEnvelope) -> str:
+    """Return the canonical Markdown/plaintext full-session rendering."""
+
+    return archive_session_payload_text(
+        {
+            "session_id": envelope.session_id,
+            "title": envelope.title,
+            "messages": [
+                {
+                    "role": message.role,
+                    "blocks": [{"text": block.text} for block in message.blocks],
+                }
+                for message in envelope.messages
+            ],
+        }
+    )
+
+
+__all__ = [
+    "archive_search_hit_payload",
+    "archive_session_payload",
+    "archive_session_payload_text",
+    "archive_session_text",
+]
