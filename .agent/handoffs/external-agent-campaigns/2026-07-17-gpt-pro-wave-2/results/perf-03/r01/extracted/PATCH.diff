+    @classmethod
+    def from_archive_row(
+        cls,
+        message: Any,
+        *,
+        session_id: object,
+    ) -> SessionMessageRowPayload:
+        """Project a split-tier row into the paginated CLI message contract.
+
+        The archive-envelope row is richer than the paginated async query in a
+        few places (notably attachments), while its block query deliberately
+        omits metadata. Build the same domain ``Message`` that the direct
+        paginator hydrates, then reuse ``from_message`` as the single payload
+        renderer. This keeps MCP's broader ``SessionMessagePayload`` mapping
+        unchanged.
+        """
+
+        from polylogue.archive.message.models import Message
+        from polylogue.core.enums import MaterialOrigin, MessageType, Role
+
+        blocks: list[dict[str, object]] = []
+        text_parts: list[str] = []
+        for block in tuple(getattr(message, "blocks", ())):
+            block_text = getattr(block, "text", None)
+            if block_text is not None:
+                text_parts.append(str(block_text))
+            tool_input = _parse_archive_json_value(getattr(block, "tool_input", None))
+            semantic_type = getattr(block, "semantic_type", None)
+            blocks.append(
+                {
+                    "id": str(getattr(block, "block_id", "") or ""),
+                    "type": str(getattr(block, "block_type", getattr(block, "type", ""))),
+                    "text": block_text,
+                    "tool_name": getattr(block, "tool_name", None),
+                    "tool_id": getattr(block, "tool_id", None),
+                    "tool_input": tool_input,
+                    "media_type": None,
+                    "metadata": None,
+                    "semantic_type": str(semantic_type) if semantic_type is not None else None,
+                    "tool_result_is_error": getattr(block, "tool_result_is_error", None),
+                    "tool_result_exit_code": getattr(block, "tool_result_exit_code", None),
+                }
+            )
+
+        occurred_at = _parse_optional_datetime(getattr(message, "occurred_at", None))
+        if occurred_at is None:
+            sort_key = getattr(message, "sort_key", None)
+            if isinstance(sort_key, int | float) and not isinstance(sort_key, bool):
+                occurred_at = datetime.fromtimestamp(float(sort_key), UTC)
+            else:
+                occurred_at_ms = getattr(message, "occurred_at_ms", None)
+                if isinstance(occurred_at_ms, int | float) and not isinstance(occurred_at_ms, bool):
+                    occurred_at = datetime.fromtimestamp(float(occurred_at_ms) / 1000.0, UTC)
+
+        domain_message = Message(
+            id=str(message.message_id),
+            role=Role.normalize(str(getattr(message, "role", "unknown") or "unknown")),
+            text="\n".join(text_parts) if text_parts else None,
+            timestamp=occurred_at,
+            attachments=[],
+            blocks=blocks,
+            message_type=MessageType.normalize(getattr(message, "message_type", "message")),
+            material_origin=MaterialOrigin.normalize(getattr(message, "material_origin", "unknown")),
+            parent_id=getattr(message, "parent_message_id", None),
+            branch_index=int(getattr(message, "variant_index", getattr(message, "branch_index", 0)) or 0),
+            has_tool_use=bool(getattr(message, "has_tool_use", False)),
+            has_thinking=bool(getattr(message, "has_thinking", False)),
+            has_paste=bool(getattr(message, "has_paste", False)),
+            paste_boundary_state=getattr(message, "paste_boundary_state", None),
+            input_tokens=int(getattr(message, "input_tokens", 0) or 0),
+            output_tokens=int(getattr(message, "output_tokens", 0) or 0),
+            cache_read_tokens=int(getattr(message, "cache_read_tokens", 0) or 0),
+            cache_write_tokens=int(getattr(message, "cache_write_tokens", 0) or 0),
+            duration_ms=int(getattr(message, "duration_ms", 0) or 0),
+            model_name=getattr(message, "model_name", None),
+        )
+        return cls.from_message(domain_message, session_id=session_id)
+
 
