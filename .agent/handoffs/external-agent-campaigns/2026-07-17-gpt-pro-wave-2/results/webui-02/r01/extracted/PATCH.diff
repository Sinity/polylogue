+
+
+class TestWebUIV2Vertical:
+    def test_semantic_ssr_and_continuation_identity_use_the_real_daemon(
+        self,
+        workspace_env: dict[str, Path],
+    ) -> None:
+        """Exercise the production server, archive store, renderers, and pager.
+
+        Production dependencies: ``DaemonAPIHTTPServer``, split-archive list and
+        message reads, ``QueryTransaction`` continuations, and both WebUI v2 SSR
+        renderers. Replacing either SSR route with an empty mount, bypassing the
+        archive, or advancing by an offset reconstructed by the caller breaks
+        the assertions below.
+        """
+
+        with _running_server(workspace_env) as (_, base_url):
+            list_status, list_type, list_document = _get_text(base_url, "/app")
+            first_page = cast(dict[str, object], _get_json(base_url, "/api/sessions?limit=1"))
+            continuation = cast(str, first_page["continuation"])
+            second_page = cast(
+                dict[str, object],
+                _get_json(
+                    base_url,
+                    f"/api/sessions?continuation={quote(continuation, safe='')}",
+                ),
+            )
+            read_status, read_type, read_document = _get_text(
+                base_url,
+                f"/app/s/{quote(C1, safe='')}",
+            )
+            message_page = cast(
+                dict[str, object],
+                _get_json(base_url, f"/api/sessions/{quote(C1, safe='')}/messages?limit=1"),
+            )
+            js_status, js_type, js_body = _get_text(base_url, "/app/assets/webui-v2.js")
+            css_status, css_type, css_body = _get_text(base_url, "/app/assets/webui-v2.css")
+
+        list_state = _webui_v2_state(list_document)
+        list_state_page = cast(dict[str, object], list_state["page"])
+        read_state = _webui_v2_state(read_document)
+        read_state_page = cast(dict[str, object], read_state["page"])
+        read_items = cast(list[dict[str, object]], read_state_page["items"])
+
+        assert list_status == 200
+        assert "text/html" in list_type
+        assert '<form class="filter-panel" method="get" action="/app">' in list_document
+        assert '<ol class="session-list" aria-label="Archive sessions">' in list_document
+        assert list_document.index('<ol class="session-list"') < list_document.index('id="webui-v2-state"')
