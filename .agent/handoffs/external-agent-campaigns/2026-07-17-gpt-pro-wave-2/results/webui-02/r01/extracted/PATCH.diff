+});
diff --git a/webui/src/components/SessionRead.tsx b/webui/src/components/SessionRead.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..129a6ae04ed0dddcc10a21cf750d859abf2df24a
--- /dev/null
+++ b/webui/src/components/SessionRead.tsx
@@ -0,0 +1,394 @@
+import { useState } from "preact/hooks";
+
+import type {
+  Attachment,
+  ContinuationPage,
+  MessageBlock,
+  SessionHeader,
+  SessionMessage,
+  SessionTopology,
+} from "../lib/contracts";
+import { fetchContinuationPage } from "../lib/continuation";
+import {
+  evidenceMessage,
+  formatBytes,
+  formatCount,
+  formatDate,
+  formatEvidenceCount,
+  routeStateClass,
+} from "../lib/format";
+
+export interface SessionReadProps {
+  endpoint: string;
+  session: SessionHeader;
+  initialPage: ContinuationPage<SessionMessage>;
+  topology: SessionTopology;
+}
+
+function jsonText(value: unknown): string {
+  if (value === null || value === undefined || value === "") {
+    return "not recorded";
+  }
+  if (typeof value === "string") {
+    return value;
+  }
+  return JSON.stringify(value, null, 2);
+}
+
+function outcomeLabel(block: MessageBlock): string {
+  if (block.tool_result_outcome === "failed") {
+    return "Failed tool result";
+  }
+  if (block.tool_result_outcome === "ok") {
+    return "Successful tool result";
+  }
+  return "Tool result outcome unknown";
+}
+
+function outcomeEvidence(block: MessageBlock): string {
+  if (block.tool_result_exit_code !== null) {
+    return `exit code ${block.tool_result_exit_code}`;
+  }
+  if (block.tool_result_is_error !== null) {
+    return `provider error flag ${String(block.tool_result_is_error)}`;
+  }
+  return "no structured outcome flag";
+}
+
+function BlockView({
+  block,
+  openOverride,
+}: {
+  block: MessageBlock;
+  openOverride: boolean | null;
+}) {
+  if (block.type === "tool_use") {
+    return (
+      <details class="tool-block tool-block--use" open={openOverride === true}>
+        <summary>Tool use: {block.tool_name || "unnamed tool"}</summary>
+        <dl class="block-facts">
+          <div>
+            <dt>Tool ID</dt>
+            <dd>
+              <code>{block.tool_id || "not recorded"}</code>
+            </dd>
+          </div>
+          <div>
+            <dt>Semantic type</dt>
+            <dd>
+              <code>{block.semantic_type || "unknown"}</code>
+            </dd>
+          </div>
+        </dl>
+        <pre>{jsonText(block.tool_input)}</pre>
+      </details>
+    );
+  }
+  if (block.type === "tool_result") {
+    const failed = block.tool_result_outcome === "failed";
+    return (
+      <details
+        class={`tool-block tool-block--result tool-block--${block.tool_result_outcome ?? "unknown"}`}
+        data-outcome={block.tool_result_outcome ?? "unknown"}
+        open={openOverride ?? failed}
+      >
+        <summary>
+          <strong>{outcomeLabel(block)}</strong>
+          <span>{outcomeEvidence(block)}</span>
+        </summary>
+        {block.text ? (
+          <pre>{block.text}</pre>
+        ) : (
+          <p>No textual result body was stored.</p>
+        )}
+      </details>
+    );
+  }
+  if (block.type === "thinking" || block.type === "reasoning") {
+    return (
+      <details class="thinking-block" open={openOverride === true}>
+        <summary>{block.type}</summary>
+        <pre>{block.text || "No text stored."}</pre>
+      </details>
+    );
+  }
+  if (block.type === "code") {
+    return (
+      <pre class="code-block">
+        <code>{block.text ?? ""}</code>
+      </pre>
+    );
+  }
+  return block.text ? (
+    <p class={`content-block content-block--${block.type}`}>{block.text}</p>
+  ) : null;
+}
+
+function AttachmentList({ attachments }: { attachments: Attachment[] }) {
+  if (attachments.length === 0) {
+    return null;
+  }
+  return (
+    <section class="attachments" aria-label="Message attachments">
+      <h3>Attachments</h3>
+      <ul>
+        {attachments.map((attachment) => (
+          <li key={attachment.attachment_id} data-state={attachment.state}>
+            <strong>{attachment.name || attachment.attachment_id}</strong>
+            <span>{attachment.mime_type || "type unknown"}</span>
+            <span>{formatBytes(attachment.size_bytes)}</span>
+            <code>{attachment.state || "unknown"}</code>
+          </li>
+        ))}
+      </ul>
+    </section>
+  );
+}
+
+function MessageView({
+  message,
+  openOverride,
+}: {
+  message: SessionMessage;
+  openOverride: boolean | null;
+}) {
+  return (
+    <li>
+      <article
+        id={message.anchor}
+        class={`message-card message-card--${message.role}`}
+        data-message-id={message.id}
+        data-role={message.role}
+        data-material-origin={message.material_origin}
+      >
+        <header>
+          <div class="message-identities">
+            <span>
+              role <code>{message.role}</code>
+            </span>
+            <span>
+              material_origin <code>{message.material_origin}</code>
+            </span>
+            <span>
+              message_type <code>{message.message_type}</code>
+            </span>
+          </div>
+          {message.timestamp ? (
+            <time dateTime={message.timestamp}>
+              {formatDate(message.timestamp)}
+            </time>
+          ) : null}
+        </header>
+        <div class="stable-ref-row">
+          <code class="stable-ref">{message.id}</code>
+          {message.anchor ? (
+            <a class="permalink" href={`#${message.anchor}`}>
+              Permalink
+            </a>
+          ) : null}
+        </div>
+        {message.inherited_prefix ? (
+          <p class="lineage-chip">
+            Inherited prefix from <code>{message.source_session_id}</code>
+          </p>
+        ) : null}
+        <div class="message-blocks">
+          {message.blocks.length > 0 ? (
+            message.blocks.map((block) => (
+              <BlockView
+                block={block}
+                openOverride={openOverride}
+                key={block.id}
+              />
+            ))
+          ) : (
+            <p>{message.text || "No textual body was stored."}</p>
+          )}
+        </div>
+        <AttachmentList attachments={message.attachments} />
+      </article>
+    </li>
+  );
+}
+
+function familyLabel(topology: SessionTopology): string {
+  const kinds = [
+    ...new Set(topology.edges.map((edge) => edge.kind).filter(Boolean)),
+  ];
+  return kinds.length > 0 ? `${kinds.join(" / ")} family` : "isolated session";
+}
+
+function LineageBanner({ topology }: { topology: SessionTopology }) {
+  const incoming = topology.edges.find(
+    (edge) => edge.child_id === topology.target_id,
+  );
+  return (
+    <aside
+      class={`lineage-banner lineage-banner--${topology.readiness}`}
+      aria-labelledby="lineage-heading"
+    >
+      <div>
+        <h2 id="lineage-heading">Lineage: {familyLabel(topology)}</h2>
+        <p>
+          {topology.readiness === "ok"
+            ? "The daemon returned a complete bounded family view."
+            : topology.readiness === "partial"
+              ? "The family view is partial; unresolved, truncated, or cyclic evidence is present."
+              : "No parent or descendant lineage is currently recorded."}
+        </p>
+      </div>
+      <dl class="lineage-facts">
+        <div>
+          <dt>Root</dt>
+          <dd>
+            {topology.root_id ? (
+              <a href={`/app/s/${encodeURIComponent(topology.root_id)}`}>
+                {topology.root_id}
+              </a>
+            ) : (
+              "unknown"
+            )}
+          </dd>
+        </div>
+        <div>
+          <dt>Parent relation</dt>
+          <dd>{incoming?.kind ?? "none recorded"}</dd>
+        </div>
+        <div>
+          <dt>Family sessions</dt>
+          <dd>{formatEvidenceCount(topology.total_node_count)}</dd>
+        </div>
+        <div>
+          <dt>Unresolved edges</dt>
+          <dd>{formatEvidenceCount(topology.unresolved_edge_count)}</dd>
+        </div>
+      </dl>
+      {topology.nodes.length > 1 ? (
+        <ul class="family-links" aria-label="Lineage family sessions">
+          {topology.nodes.map((node) => (
+            <li key={node.session_id}>
+              <a href={`/app/s/${encodeURIComponent(node.session_id)}`}>
+                {node.title || node.session_id}
+              </a>
+              {node.session_id === topology.target_id ? (
+                <strong> current</strong>
+              ) : null}
+            </li>
+          ))}
+        </ul>
+      ) : null}
+    </aside>
+  );
+}
+
+export function SessionRead({
+  endpoint,
+  session,
+  initialPage,
+  topology,
+}: SessionReadProps) {
+  const [page, setPage] = useState(initialPage);
+  const [messages, setMessages] = useState(initialPage.items);
+  const [openOverride, setOpenOverride] = useState<boolean | null>(null);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  async function loadNext() {
+    if (!page.continuation || loading) {
+      return;
+    }
+    setLoading(true);
+    setError(null);
+    try {
+      const next = await fetchContinuationPage<SessionMessage>(endpoint, page);
+      setMessages((current) => [...current, ...next.items]);
+      setPage(next);
+    } catch (reason) {
+      setError(
+        reason instanceof Error ? reason.message : "Message page failed",
+      );
+    } finally {
+      setLoading(false);
+    }
+  }
+
+  const exactZero = page.total_relation === "exact" && page.total === 0;
+  const unknownEmpty =
+    messages.length === 0 && page.total_relation === "unknown";
+
+  return (
+    <div class="session-read-island" data-island="session-read">
+      <LineageBanner topology={topology} />
+      <section class="transcript" aria-labelledby="transcript-heading">
+        <header class="transcript-header">
+          <div>
+            <h2 id="transcript-heading">Message flow</h2>
+            <p>
+              {formatCount(page.total, page.total_relation, "messages")};{" "}
+              {messages.length} rendered.
+            </p>
+          </div>
+          <div class="expand-controls" aria-label="Tool block visibility">
+            <button type="button" onClick={() => setOpenOverride(true)}>
+              Expand all blocks
+            </button>
+            <button type="button" onClick={() => setOpenOverride(false)}>
+              Collapse all blocks
+            </button>
+          </div>
+        </header>
+        <p
+          class={routeStateClass(page.route_state)}
+          data-total-relation={page.total_relation}
+        >
+          {evidenceMessage(page)}
+        </p>
+        {session.lineage_complete === false ? (
+          <p class="evidence-state evidence-state--partial">
+            Composed transcript lineage is incomplete:{" "}
+            {session.lineage_truncation_reason ?? "reason unknown"}.
+          </p>
+        ) : null}
+        {error ? (
+          <p class="request-error" role="alert">
+            {error}
+          </p>
+        ) : null}
+        {exactZero ? (
+          <p class="empty-state">This session has no stored messages.</p>
+        ) : null}
+        {unknownEmpty ? (
+          <p class="empty-state empty-state--unknown">
+            No message rows were returned, but the archive did not establish a
+            zero total.
+          </p>
+        ) : null}
+        {messages.length > 0 ? (
+          <ol class="message-flow" aria-label="Session messages">
+            {messages.map((message) => (
+              <MessageView
+                message={message}
+                openOverride={openOverride}
+                key={message.id}
+              />
+            ))}
+          </ol>
+        ) : null}
+        <div class="paging-controls">
+          <button
+            type="button"
+            onClick={loadNext}
+            disabled={loading || !page.continuation}
+          >
+            {loading
+              ? "Loading…"
+              : page.continuation
+                ? "Load next page"
+                : "End of transcript"}
+          </button>
+          <code title="Stable result reference">{page.result_ref}</code>
+        </div>
+      </section>
+    </div>
+  );
+}
