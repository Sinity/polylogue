+def _document(
+    *,
+    title: str,
+    heading: str,
+    intro: str,
+    main: str,
+    intro_is_html: bool = False,
+) -> str:
+    intro_markup = intro if intro_is_html else _h(intro)
+    return (
+        '<!doctype html><html lang="en"><head><meta charset="utf-8">'
+        '<meta name="viewport" content="width=device-width,initial-scale=1">'
+        f"<title>{_h(title)}</title>"
+        '<link rel="stylesheet" href="/app/assets/webui-v2.css">'
+        "</head><body>"
+        '<header class="site-header"><a href="/app">Polylogue</a><p>WebUI v2</p></header>'
+        '<main id="main-content">'
+        f'<header class="page-heading"><div><h1>{_h(heading)}</h1><p>{intro_markup}</p></div></header>'
+        f"{main}</main>"
+        '<script type="module" src="/app/assets/webui-v2.js"></script>'
+        "</body></html>"
+    )
