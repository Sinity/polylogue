+def _render_session_read_island(
+    session: Mapping[str, object],
+    page: Mapping[str, object],
+    topology: Mapping[str, object],
+) -> str:
+    messages = _mapping_items(page)
+    relation = _total_relation(page)
+    total = _int_or_none(page.get("total"))
+    exact_zero = relation == "exact" and total == 0
+    unknown_empty = not messages and relation == "unknown"
+    lineage_warning = ""
+    if session.get("lineage_complete") is False:
+        reason = session.get("lineage_truncation_reason") or "reason unknown"
+        lineage_warning = (
+            '<p class="evidence-state evidence-state--partial">Composed transcript lineage is incomplete: '
+            f"{_h(reason)}.</p>"
+        )
+    empty = ""
+    if exact_zero:
+        empty = '<p class="empty-state">This session has no stored messages.</p>'
+    elif unknown_empty:
+        empty = (
+            '<p class="empty-state empty-state--unknown">No message rows were returned, '
+            "but the archive did not establish a zero total.</p>"
+        )
+    flow = ""
+    if messages:
+        flow = (
+            '<ol class="message-flow" aria-label="Session messages">'
+            + "".join(_render_message(message) for message in messages)
+            + "</ol>"
+        )
+    continuation = page.get("continuation")
+    button_text = "Load next page" if isinstance(continuation, str) and continuation else "End of transcript"
+    disabled = "" if isinstance(continuation, str) and continuation else " disabled"
+    return (
+        '<div class="session-read-island" data-island="session-read">'
+        f"{_render_lineage_banner(topology)}"
+        '<section class="transcript" aria-labelledby="transcript-heading">'
+        '<header class="transcript-header"><div><h2 id="transcript-heading">Message flow</h2>'
+        f"<p>{_h(_format_count(total, relation, 'messages'))}; {len(messages)} rendered.</p></div>"
+        '<div class="expand-controls" aria-label="Tool block visibility">'
+        '<button type="button">Expand all blocks</button><button type="button">Collapse all blocks</button>'
+        "</div></header>"
+        f'<p class="{_a(_route_state_class(page))}" data-total-relation="{relation}">'
+        f"{_h(_evidence_message(page))}</p>{lineage_warning}{empty}{flow}"
+        '<div class="paging-controls">'
+        f'<button type="button"{disabled}>{button_text}</button>'
+        f'<code title="Stable result reference">{_h(page.get("result_ref"))}</code></div>'
+        "</section></div>"
+    )
+
+
+def _render_lineage_banner(topology: Mapping[str, object]) -> str:
+    nodes = _mapping_sequence(topology.get("nodes"))
+    edges = _mapping_sequence(topology.get("edges"))
+    kinds = list(dict.fromkeys(_string(edge.get("kind")) for edge in edges if edge.get("kind")))
+    family = f"{' / '.join(kinds)} family" if kinds else "isolated session"
+    readiness = _string(topology.get("readiness") or "empty")
+    if readiness == "ok":
+        description = "The daemon returned a complete bounded family view."
+    elif readiness == "partial":
+        description = "The family view is partial; unresolved, truncated, or cyclic evidence is present."
+    else:
+        description = "No parent or descendant lineage is currently recorded."
+    target_id = _string(topology.get("target_id"))
+    incoming = next((edge for edge in edges if edge.get("child_id") == target_id), None)
+    parent_relation = incoming.get("kind") if incoming is not None else "none recorded"
+    family_links = ""
+    if len(nodes) > 1:
+        family_links = (
+            '<ul class="family-links" aria-label="Lineage family sessions">'
+            + "".join(_render_family_link(node, target_id) for node in nodes)
+            + "</ul>"
+        )
+    root_id = _string(topology.get("root_id"))
+    root_markup = f'<a href="/app/s/{quote(root_id, safe="")}">{_h(root_id)}</a>' if root_id else "unknown"
+    return (
+        f'<aside class="lineage-banner lineage-banner--{_a(readiness)}" aria-labelledby="lineage-heading">'
+        f'<div><h2 id="lineage-heading">Lineage: {_h(family)}</h2><p>{_h(description)}</p></div>'
+        '<dl class="lineage-facts">'
+        f"<div><dt>Root</dt><dd>{root_markup}</dd></div>"
+        f"<div><dt>Parent relation</dt><dd>{_h(parent_relation)}</dd></div>"
+        f"<div><dt>Family sessions</dt><dd>{_h(_format_evidence_count(topology.get('total_node_count')))}</dd></div>"
+        f"<div><dt>Unresolved edges</dt><dd>{_h(_format_evidence_count(topology.get('unresolved_edge_count')))}</dd></div>"
+        f"</dl>{family_links}</aside>"
+    )
+
+
+def _render_family_link(node: Mapping[str, object], target_id: str) -> str:
+    session_id = _string(node.get("session_id"))
+    title = _string(node.get("title") or session_id)
+    current = "<strong> current</strong>" if session_id == target_id else ""
+    return f'<li><a href="/app/s/{quote(session_id, safe="")}">{_h(title)}</a>{current}</li>'
+
+
+def _render_message(message: Mapping[str, object]) -> str:
+    message_id = _string(message.get("id"))
+    role = _string(message.get("role") or "unknown")
+    material_origin = _string(message.get("material_origin") or "unknown")
+    message_type = _string(message.get("message_type") or "message")
+    inherited = ""
+    if message.get("inherited_prefix") is True:
+        inherited = (
+            f'<p class="lineage-chip">Inherited prefix from <code>{_h(message.get("source_session_id"))}</code></p>'
+        )
+    blocks = _mapping_sequence(message.get("blocks"))
+    if blocks:
+        block_markup = "".join(_render_block(block) for block in blocks)
+    else:
+        block_markup = f"<p>{_h(message.get('text') or 'No textual body was stored.')}</p>"
+    attachments = _mapping_sequence(message.get("attachments"))
+    attachments_markup = _render_attachments(attachments)
+    time_markup = _time_markup(message.get("timestamp"), omit_unknown=True)
+    anchor = _string(message.get("anchor"))
+    permalink = f'<a class="permalink" href="#{_a(anchor)}">Permalink</a>' if anchor else ""
+    return (
+        "<li>"
+        f'<article id="{_a(anchor)}" class="message-card message-card--{_a(role)}" '
+        f'data-message-id="{_a(message_id)}" data-role="{_a(role)}" '
+        f'data-material-origin="{_a(material_origin)}">'
+        '<header><div class="message-identities">'
+        f"<span>role <code>{_h(role)}</code></span>"
+        f"<span>material_origin <code>{_h(material_origin)}</code></span>"
+        f"<span>message_type <code>{_h(message_type)}</code></span>"
+        f'</div>{time_markup}</header><div class="stable-ref-row"><code class="stable-ref">{_h(message_id)}</code>'
+        f"{permalink}</div>"
+        f'{inherited}<div class="message-blocks">{block_markup}</div>{attachments_markup}</article></li>'
+    )
+
+
+def _render_block(block: Mapping[str, object]) -> str:
+    block_type = _string(block.get("type") or "text")
+    if block_type == "tool_use":
+        return (
+            '<details class="tool-block tool-block--use"><summary>Tool use: '
+            f"{_h(block.get('tool_name') or 'unnamed tool')}</summary>"
+            '<dl class="block-facts">'
+            f"<div><dt>Tool ID</dt><dd><code>{_h(block.get('tool_id') or 'not recorded')}</code></dd></div>"
+            f"<div><dt>Semantic type</dt><dd><code>{_h(block.get('semantic_type') or 'unknown')}</code></dd></div>"
+            f"</dl><pre>{_h(_json_text(block.get('tool_input')))}</pre></details>"
+        )
+    if block_type == "tool_result":
+        outcome = _string(block.get("tool_result_outcome") or "unknown")
+        if outcome == "failed":
+            label = "Failed tool result"
+        elif outcome == "ok":
+            label = "Successful tool result"
+        else:
+            label = "Tool result outcome unknown"
+        exit_code = _int_or_none(block.get("tool_result_exit_code"))
+        is_error = block.get("tool_result_is_error")
+        if exit_code is not None:
+            evidence = f"exit code {exit_code}"
+        elif isinstance(is_error, bool):
+            evidence = f"provider error flag {str(is_error).lower()}"
+        else:
+            evidence = "no structured outcome flag"
+        body = block.get("text")
+        result_body = (
+            f"<pre>{_h(body)}</pre>" if isinstance(body, str) and body else "<p>No textual result body was stored.</p>"
+        )
+        open_attr = " open" if outcome == "failed" else ""
+        return (
+            f'<details class="tool-block tool-block--result tool-block--{_a(outcome)}" '
+            f'data-outcome="{_a(outcome)}"{open_attr}><summary><strong>{_h(label)}</strong>'
+            f"<span>{_h(evidence)}</span></summary>{result_body}</details>"
+        )
+    if block_type in {"thinking", "reasoning"}:
+        return (
+            f'<details class="thinking-block"><summary>{_h(block_type)}</summary>'
+            f"<pre>{_h(block.get('text') or 'No text stored.')}</pre></details>"
+        )
+    if block_type == "code":
+        return f'<pre class="code-block"><code>{_h(block.get("text") or "")}</code></pre>'
+    text = block.get("text")
+    return f'<p class="content-block content-block--{_a(block_type)}">{_h(text)}</p>' if text else ""
+
+
+def _render_attachments(attachments: Sequence[Mapping[str, object]]) -> str:
+    if not attachments:
+        return ""
+    rows = "".join(
+        '<li data-state="{state}"><strong>{name}</strong><span>{mime}</span><span>{size}</span>'
+        "<code>{state_text}</code></li>".format(
+            state=_a(attachment.get("state")),
+            name=_h(attachment.get("name") or attachment.get("attachment_id")),
+            mime=_h(attachment.get("mime_type") or "type unknown"),
+            size=_h(_format_bytes(_int_or_none(attachment.get("size_bytes")))),
+            state_text=_h(attachment.get("state") or "unknown"),
+        )
+        for attachment in attachments
+    )
+    return (
+        f'<section class="attachments" aria-label="Message attachments"><h3>Attachments</h3><ul>{rows}</ul></section>'
+    )
+
+
+def _mapping_items(page: Mapping[str, object]) -> list[Mapping[str, object]]:
+    return _mapping_sequence(page.get("items"))
+
+
+def _mapping_sequence(value: object) -> list[Mapping[str, object]]:
+    if not isinstance(value, list):
+        return []
+    return [cast(Mapping[str, object], item) for item in value if isinstance(item, Mapping)]
+
+
+def _route_state(page: Mapping[str, object]) -> Mapping[str, object]:
+    value = page.get("route_state")
+    return cast(Mapping[str, object], value) if isinstance(value, Mapping) else {}
+
+
+def _route_state_class(page: Mapping[str, object]) -> str:
+    state = _string(_route_state(page).get("state") or "unknown")
+    safe_name = "".join(char if char.isalnum() or char in "_-" else "-" for char in state)
+    return f"evidence-state evidence-state--{safe_name}"
+
+
+def _total_relation(page: Mapping[str, object]) -> TotalRelation:
+    relation = page.get("total_relation")
+    return cast(TotalRelation, relation) if relation in {"exact", "at_least", "unknown"} else "unknown"
+
+
+def _format_count(value: int | None, relation: TotalRelation, noun: str) -> str:
+    if relation == "exact" and value is not None:
+        return f"{value} {noun}"
+    if relation == "at_least" and value is not None:
+        return f"At least {value} {noun}"
+    return f"{noun.capitalize()} total unknown"
+
+
+def _format_evidence_count(value: object) -> str:
+    count = _int_or_none(value)
+    return str(count) if count is not None and count >= 0 else "unknown"
+
+
+def _evidence_message(page: Mapping[str, object]) -> str:
+    relation = _total_relation(page)
+    reason = _route_state(page).get("reason")
+    if relation == "unknown":
+        return (
+            f"Total unknown: {reason}"
+            if reason
+            else "Total unknown: the archive did not provide converged count evidence."
+        )
+    if relation == "at_least":
+        return "The displayed total is a lower bound, not an exact count."
+    return _string(reason or "The archive supplied an exact count for this query.")
+
+
+def _time_markup(value: object, *, omit_unknown: bool = False) -> str:
+    if not isinstance(value, str) or not value:
+        return "" if omit_unknown else "unknown"
+    return f'<time datetime="{_a(value)}">{_h(value)}</time>'
+
+
+def _format_bytes(value: int | None) -> str:
+    if value is None or value < 0:
+        return "size unknown"
+    if value < 1024:
+        return f"{value} B"
+    if value < 1024 * 1024:
+        return f"{value / 1024:.1f} KiB"
+    return f"{value / (1024 * 1024):.1f} MiB"
+
+
+def _json_text(value: object) -> str:
+    if value is None or value == "":
+        return "not recorded"
+    if isinstance(value, str):
+        return value
+    return json.dumps(value, ensure_ascii=False, indent=2, default=str)
+
+
+def _decode_json_value(value: object) -> object:
+    if not isinstance(value, str) or not value:
+        return value
+    try:
+        return json.loads(value)
+    except (TypeError, ValueError):
+        return value
+
+
+def _int_or_none(value: object) -> int | None:
+    return value if isinstance(value, int) and not isinstance(value, bool) else None
+
+
+def _string(value: object) -> str:
+    return "" if value is None else str(value)
+
+
+def _h(value: object) -> str:
+    return html.escape(_string(value), quote=False)
+
+
+def _a(value: object) -> str:
+    return html.escape(_string(value), quote=True)
+
+
+__all__ = [
+    "LIST_OPERATION",
+    "LIST_PROJECTION",
+    "LIST_STABLE_ORDER",
+    "MESSAGES_OPERATION",
+    "MESSAGES_PROJECTION",
+    "MESSAGES_STABLE_ORDER",
+    "WEBUI_V2_ASSET_CONTENT_TYPES",
+    "WEBUI_V2_LIST_PAGE_SIZE",
+    "WEBUI_V2_READ_PAGE_SIZE",
+    "archive_block_payload",
+    "continuation_page_payload",
+    "decode_list_continuation",
+    "decode_message_continuation",
+    "list_filters",
+    "list_page_request",
+    "message_block_payload",
+    "message_page_request",
+    "render_not_found_document",
+    "render_session_list_document",
+    "render_session_read_document",
+    "session_header_payload",
+    "webui_v2_asset_path",
+]
