+export type Role = "user" | "assistant" | "system" | "tool" | "unknown";
+
+export type MessageType =
+  | "message"
+  | "summary"
+  | "tool_use"
+  | "tool_result"
+  | "thinking"
+  | "context"
+  | "protocol";
+
+export type MaterialOrigin =
+  | "human_authored"
+  | "assistant_authored"
+  | "operator_command"
+  | "runtime_protocol"
+  | "runtime_context"
+  | "tool_result"
+  | "generated_context_pack"
+  | "generated_analysis_pack"
+  | "unknown";
+
+export type TotalRelation = "exact" | "at_least" | "unknown";
+export type ToolResultOutcome = "ok" | "failed" | "unknown";
+
+export interface RouteState {
+  state: string;
+  route: string;
+  reason?: string | null;
+  component?: string | null;
+  stale_available?: boolean | null;
+}
+
+export interface ContinuationPage<T> {
+  items: T[];
+  total: number | null;
+  total_relation: TotalRelation;
+  limit: number;
+  offset: number;
+  page_count: number;
+  has_more: boolean;
+  next_offset: number | null;
+  query_ref: string;
+  result_ref: string;
+  continuation: string | null;
+  route_state: RouteState;
+}
+
+export interface SessionSummary {
+  id: string;
+  session_id: string;
+  title: string;
+  origin: string;
+  anchor: string;
+  created_at: string | null;
+  updated_at: string | null;
+  date: string | null;
+  message_count: number | null;
+  word_count: number | null;
+  repo: string | null;
+  cwd_display: string | null;
+  tags: string[];
+  summary: string | null;
+}
+
+export interface SessionListFilters {
+  origin: string;
+  since: string;
+  until: string;
+  repo: string;
+}
+
+export interface Attachment {
+  attachment_id: string;
+  session_id: string;
+  message_id: string | null;
+  name: string;
+  mime_type: string | null;
+  size_bytes: number | null;
+  path: string | null;
+  state: string;
+}
+
+export interface MessageBlock {
+  id: string;
+  type: string;
+  text: string | null;
+  tool_name: string | null;
+  tool_id: string | null;
+  semantic_type: string | null;
+  tool_input: unknown;
+  metadata: unknown;
+  language: string | null;
+  tool_result_is_error: boolean | null;
+  tool_result_exit_code: number | null;
+  tool_result_outcome: ToolResultOutcome | null;
+}
+
+export interface SessionMessage {
+  id: string;
+  role: Role;
+  text: string | null;
+  anchor: string;
+  timestamp: string | null;
+  message_type: MessageType;
+  material_origin: MaterialOrigin;
+  duration_ms: number | null;
+  parent_message_id: string | null;
+  variant_index: number;
+  is_active_path?: boolean | null;
+  is_active_leaf?: boolean | null;
+  source_session_id?: string | null;
+  inherited_prefix?: boolean | null;
+  word_count: number | null;
+  blocks: MessageBlock[];
+  attachments: Attachment[];
+}
+
+export interface SessionHeader {
+  id: string;
+  session_id: string;
+  title: string;
+  display_title: string;
+  origin: string;
+  anchor: string;
+  created_at: string | null;
+  updated_at: string | null;
+  message_count: number | null;
+  word_count: number | null;
+  repo: string | null;
+  cwd_display: string | null;
+  tags: string[];
+  branch_type: string | null;
+  parent_id: string | null;
+  lineage_complete: boolean | null;
+  lineage_truncation_reason: string | null;
+}
+
+export interface TopologyNode {
+  session_id: string;
+  origin: string;
+  title: string | null;
+  depth: number;
+  is_root: boolean;
+}
+
+export interface TopologyEdge {
+  child_id: string;
+  parent_id: string | null;
+  parent_native_id: string | null;
+  kind: string;
+  resolved: boolean;
+}
+
+export interface SessionTopology {
+  target_id: string;
+  root_id: string;
+  nodes: TopologyNode[];
+  edges: TopologyEdge[];
+  node_count: number;
+  total_node_count: number | null;
+  truncated_count: number | null;
+  unresolved_edge_count: number | null;
+  cycle_detected: boolean;
+  readiness: "ok" | "partial" | "empty";
+  node_limit: number;
+}
+
+export interface SessionListIslandState {
+  kind: "session-list";
+  endpoint: string;
+  page: ContinuationPage<SessionSummary>;
+  filters: SessionListFilters;
+  origins: string[];
+}
+
+export interface SessionReadIslandState {
+  kind: "session-read";
+  endpoint: string;
+  session: SessionHeader;
+  page: ContinuationPage<SessionMessage>;
+  topology: SessionTopology;
+}
+
+export type WebUIIslandState = SessionListIslandState | SessionReadIslandState;
