+
+def _state_script(state: Mapping[str, object]) -> str:
+    raw = json.dumps(state, ensure_ascii=False, separators=(",", ":"), default=str)
+    safe = (
+        raw.replace("&", "\\u0026")
+        .replace("<", "\\u003c")
+        .replace(">", "\\u003e")
+        .replace("\u2028", "\\u2028")
+        .replace("\u2029", "\\u2029")
+    )
+    return f'<script id="webui-v2-state" type="application/json">{safe}</script>'
+
+
+def _render_session_list_island(page: Mapping[str, object], filters: Mapping[str, str]) -> str:
+    items = _mapping_items(page)
+    relation = _total_relation(page)
+    total = _int_or_none(page.get("total"))
+    rendered_count = len(items)
+    exact_zero = relation == "exact" and total == 0
+    unknown_empty = not items and relation == "unknown"
+    options = ['<option value="">Any origin</option>']
+    selected_origin = filters.get("origin", "")
+    for origin in Origin:
+        selected = " selected" if selected_origin == origin.value else ""
+        options.append(f'<option value="{_a(origin.value)}"{selected}>{_h(origin.value)}</option>')
+    form = (
+        '<form class="filter-panel" method="get" action="/app">'
+        '<label>Origin<select name="origin">' + "".join(options) + "</select></label>"
+        f'<label>Since<input name="since" type="date" value="{_a(filters.get("since", ""))}"></label>'
+        f'<label>Until<input name="until" type="date" value="{_a(filters.get("until", ""))}"></label>'
+        "<label>Repository"
+        f'<input name="repo" value="{_a(filters.get("repo", ""))}" placeholder="owner/repo or URL"></label>'
+        '<button type="submit">Apply filters</button></form>'
+    )
+    status = (
+        '<div class="list-status" aria-live="polite">'
+        f"<strong>{_h(_format_count(total, relation, 'sessions'))}</strong>"
+        f"<span>{rendered_count} rendered</span></div>"
+        f'<p class="{_a(_route_state_class(page))}" data-total-relation="{relation}">'
+        f"{_h(_evidence_message(page))}</p>"
+    )
+    empty = ""
+    if exact_zero:
+        empty = '<p class="empty-state">No sessions matched the current filters.</p>'
+    elif unknown_empty:
+        empty = (
+            '<p class="empty-state empty-state--unknown">No session rows were returned, '
+            "but the archive did not establish a zero total.</p>"
+        )
+    rows = ""
+    if items:
+        rows = (
+            '<ol class="session-list" aria-label="Archive sessions">'
+            + "".join(_render_session_row(item) for item in items)
+            + "</ol>"
+        )
+    continuation = page.get("continuation")
+    button_text = "Load next page" if isinstance(continuation, str) and continuation else "End of results"
+    disabled = "" if isinstance(continuation, str) and continuation else " disabled"
+    paging = (
+        '<div class="paging-controls">'
+        f'<button type="button"{disabled}>{button_text}</button>'
+        f'<code title="Stable result reference">{_h(page.get("result_ref"))}</code></div>'
+    )
+    return f'<div class="session-list-island" data-island="session-list">{form}{status}{empty}{rows}{paging}</div>'
+
+
+def _render_session_row(session: Mapping[str, object]) -> str:
+    session_id = _string(session.get("session_id") or session.get("id"))
+    title = _string(session.get("title") or session_id)
+    anchor = _string(session.get("anchor"))
+    timestamp = session.get("updated_at") or session.get("created_at") or session.get("date")
+    time_markup = _time_markup(timestamp)
+    tags = session.get("tags")
+    tag_markup = ""
+    if isinstance(tags, list) and tags:
+        tag_markup = (
+            '<ul class="tag-list" aria-label="Session tags">' + "".join(f"<li>{_h(tag)}</li>" for tag in tags) + "</ul>"
+        )
+    summary = session.get("summary")
+    summary_markup = f"<p>{_h(summary)}</p>" if isinstance(summary, str) and summary else ""
+    message_count = session.get("message_count")
+    return (
+        "<li>"
+        f'<article id="{_a(anchor)}" class="session-card" data-session-id="{_a(session_id)}">'
+        "<header><div><h2>"
+        f'<a href="/app/s/{quote(session_id, safe="")}">{_h(title)}</a>'
+        f'</h2><code class="stable-ref">{_h(session_id)}</code></div>'
+        f'<span class="origin-token">{_h(session.get("origin"))}</span></header>'
+        f'{summary_markup}<dl class="metadata-grid">'
+        f"<div><dt>Messages</dt><dd>{_h(message_count if message_count is not None else 'unknown')}</dd></div>"
+        f"<div><dt>Updated</dt><dd>{time_markup}</dd></div>"
+        f"<div><dt>Repository</dt><dd>{_h(session.get('repo') or 'not recorded')}</dd></div>"
+        f"<div><dt>Working directory</dt><dd>{_h(session.get('cwd_display') or 'not recorded')}</dd></div>"
+        f"</dl>{tag_markup}</article></li>"
+    )
+
+
+def _render_session_header(session: Mapping[str, object]) -> str:
