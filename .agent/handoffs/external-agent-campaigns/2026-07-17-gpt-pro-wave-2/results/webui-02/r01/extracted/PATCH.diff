+  padding: 0.45rem 0.8rem;
+  border: 1px solid var(--accent);
+  border-radius: 0.4rem;
+  background: var(--accent);
+  color: white;
+  font-weight: 750;
+}
+
+.list-status {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  margin: 1rem 0 0.35rem;
+}
+.list-status span {
+  color: var(--muted);
+}
+.evidence-state {
+  margin: 0.35rem 0 1rem;
+  padding: 0.65rem 0.8rem;
+  border-left: 0.25rem solid var(--accent);
+  background: var(--accent-soft);
+}
+.evidence-state--degraded,
+.evidence-state--partial {
+  border-color: var(--warning);
+  background: var(--warning-soft);
+}
+.evidence-state--error {
+  border-color: var(--danger);
+  background: var(--danger-soft);
+}
+.request-error {
+  padding: 0.75rem;
+  border: 1px solid var(--danger);
+  background: var(--danger-soft);
+  color: var(--danger);
+}
+.empty-state {
+  padding: 2rem;
+  border: 1px dashed var(--line);
+  border-radius: 0.75rem;
+  text-align: center;
+  background: var(--panel);
+}
+.empty-state--unknown {
+  border-color: var(--warning);
+  background: var(--warning-soft);
+}
+
+.session-list,
+.message-flow {
+  list-style: none;
+  padding: 0;
+  margin: 0;
+  display: grid;
+  gap: 0.85rem;
+}
+.session-card,
+.message-card,
+.lineage-banner,
+.transcript {
+  border: 1px solid var(--line);
+  border-radius: 0.75rem;
+  background: var(--panel);
+  box-shadow: 0 0.35rem 1rem rgb(20 33 50 / 0.05);
+}
+.session-card {
+  padding: 1rem;
+}
+.session-card > header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  align-items: flex-start;
+}
+.session-card h2 {
+  margin: 0 0 0.2rem;
+  font-size: 1.15rem;
+}
+.metadata-grid,
+.lineage-facts,
+.session-facts,
+.block-facts {
+  display: grid;
+  grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
+  gap: 0.6rem 1rem;
+}
+dl div {
+  min-width: 0;
+}
+dt {
+  color: var(--muted);
+  font-size: 0.76rem;
+  font-weight: 750;
+  text-transform: uppercase;
+  letter-spacing: 0.05em;
+}
+dd {
+  margin: 0.12rem 0 0;
+  overflow-wrap: anywhere;
+}
+.tag-list,
+.family-links {
+  list-style: none;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.4rem;
+  padding: 0;
+  margin: 0.8rem 0 0;
+}
+.tag-list li {
+  border: 1px solid var(--line);
+  border-radius: 999px;
+  padding: 0.12rem 0.5rem;
+  font-size: 0.75rem;
+}
+
+.session-header-card {
+  padding: 1rem;
+  border: 1px solid var(--line);
+  border-radius: 0.75rem;
+  background: var(--panel);
+  margin-bottom: 1rem;
+}
+.session-header-card h1 {
+  margin: 0;
+}
+.session-facts {
+  margin-bottom: 0;
+}
+.lineage-banner {
+  padding: 1rem;
+  margin-bottom: 1rem;
+  border-left: 0.35rem solid var(--accent);
+}
+.lineage-banner--partial {
+  border-left-color: var(--warning);
+}
+.lineage-banner--empty {
+  border-left-color: var(--muted);
+}
+.lineage-banner h2 {
+  margin: 0;
+  font-size: 1.15rem;
+}
+.lineage-banner p {
+  margin: 0.25rem 0 0.8rem;
+  color: var(--muted);
+}
+
+.transcript {
+  padding: 1rem;
+}
+.transcript-header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  align-items: flex-start;
+}
+.transcript-header h2 {
+  margin: 0;
+}
+.transcript-header p {
+  margin: 0.2rem 0 0;
+  color: var(--muted);
+}
+.expand-controls {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.45rem;
+}
+.expand-controls button {
+  background: var(--panel);
+  color: var(--accent);
+}
+.message-card {
+  padding: 1rem;
+  scroll-margin-top: 1rem;
+}
+.message-card > header {
+  display: flex;
+  justify-content: space-between;
+  gap: 1rem;
+  align-items: flex-start;
+  margin-bottom: 0.35rem;
+}
+.message-identities {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.5rem 0.8rem;
+}
+.message-identities span {
+  color: var(--muted);
+  font-size: 0.82rem;
+}
+.message-blocks {
+  display: grid;
+  gap: 0.6rem;
+  margin-top: 0.8rem;
+}
+.message-blocks p {
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+}
+pre {
+  max-width: 100%;
+  overflow: auto;
+  white-space: pre-wrap;
+  overflow-wrap: anywhere;
+  padding: 0.75rem;
+  border-radius: 0.4rem;
+  background: color-mix(in srgb, var(--surface) 80%, var(--panel));
+}
+details {
+  border: 1px solid var(--line);
+  border-radius: 0.5rem;
+  padding: 0.55rem 0.7rem;
+}
+details summary {
+  cursor: pointer;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.4rem 0.8rem;
+  align-items: baseline;
+}
+.tool-block--failed {
+  border-color: var(--danger);
+  background: var(--danger-soft);
+}
+.tool-block--failed summary {
+  color: var(--danger);
+}
+.tool-block--ok {
+  border-color: var(--success);
+  background: var(--success-soft);
+}
+.tool-block--unknown {
+  border-color: var(--warning);
+  background: var(--warning-soft);
+}
+
+.attachments {
+  margin-top: 0.8rem;
+}
+.attachments h3 {
+  font-size: 0.9rem;
+  margin: 0 0 0.35rem;
+}
+.attachments ul {
+  list-style: none;
+  padding: 0;
+  margin: 0;
+  display: grid;
+  gap: 0.35rem;
+}
+.attachments li {
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.35rem 0.75rem;
+  padding: 0.45rem 0.55rem;
+  border: 1px solid var(--line);
+  border-radius: 0.4rem;
+}
+.attachments li span,
+.attachments li code {
+  color: var(--muted);
+  font-size: 0.78rem;
+}
+
+.paging-controls {
+  display: flex;
+  justify-content: space-between;
+  align-items: center;
+  gap: 1rem;
+  margin-top: 1rem;
+}
+.paging-controls code {
+  color: var(--muted);
+  font-size: 0.72rem;
+  overflow-wrap: anywhere;
+}
+
+@media (prefers-color-scheme: dark) {
+  :root {
+    --surface: #11161e;
+    --panel: #1a212c;
+    --ink: #edf1f7;
+    --muted: #a7b0bf;
+    --line: #364151;
+    --accent: #78bce8;
+    --accent-soft: #17374a;
+    --danger: #ff9696;
+    --danger-soft: #3b2025;
+    --warning: #f0ca72;
+    --warning-soft: #392f16;
+    --success: #86d79f;
+    --success-soft: #173524;
+  }
+  .filter-panel button,
+  .paging-controls button {
+    color: #0d2332;
+  }
+}
+
+@media (max-width: 850px) {
+  .filter-panel {
+    grid-template-columns: 1fr 1fr;
+  }
+  .filter-panel button {
+    grid-column: 1 / -1;
+  }
+  .page-heading,
+  .transcript-header,
+  .session-card > header,
+  .message-card > header {
+    flex-direction: column;
+  }
+}
+
+@media (max-width: 520px) {
+  main {
+    width: min(100% - 1rem, 1120px);
+    padding-top: 1rem;
+  }
+  .site-header {
+    padding: 0.8rem;
+  }
+  .filter-panel {
+    grid-template-columns: 1fr;
+  }
+  .paging-controls {
+    align-items: stretch;
+    flex-direction: column;
+  }
+}
+
+.stable-ref-row {
+  align-items: baseline;
+  display: flex;
+  flex-wrap: wrap;
+  gap: 0.65rem;
+}
+
+.permalink {
+  font-size: 0.8rem;
+}
