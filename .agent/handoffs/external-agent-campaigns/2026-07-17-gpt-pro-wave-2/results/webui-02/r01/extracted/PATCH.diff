+def session_header_payload(session: Mapping[str, object]) -> dict[str, object]:
+    """Keep the read island's session bootstrap bounded to its exact fields."""
+
+    session_id = _string(session.get("session_id") or session.get("id"))
+    title = _string(session.get("title") or session_id)
+    display_title = _string(session.get("display_title") or title)
+    raw_tags = session.get("tags")
