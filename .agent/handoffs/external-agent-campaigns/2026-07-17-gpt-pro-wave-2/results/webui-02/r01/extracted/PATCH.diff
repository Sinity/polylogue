diff --git a/webui/src/components/SessionList.test.tsx b/webui/src/components/SessionList.test.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..9811ba8419158a9b56a18644ec13741ab440d9d5
--- /dev/null
+++ b/webui/src/components/SessionList.test.tsx
@@ -0,0 +1,92 @@
+import { fireEvent, render, screen, waitFor } from "@testing-library/preact";
+import { expect, test, vi } from "vitest";
+
+import listFixture from "../fixtures/session-list-page.json";
+import type { ContinuationPage, SessionSummary } from "../lib/contracts";
+import { SessionList } from "./SessionList";
+
+const firstPage = listFixture as ContinuationPage<SessionSummary>;
+
+function response(body: unknown): Response {
+  return new Response(JSON.stringify(body), {
+    status: 200,
+    headers: { "Content-Type": "application/json" },
+  });
+}
+
+test("pages by daemon continuation without reconstructing filters or offsets", async () => {
+  const secondPage: ContinuationPage<SessionSummary> = {
+    ...firstPage,
+    items: [
+      {
+        ...firstPage.items[0]!,
+        id: "codex-session:fixture-second",
+        session_id: "codex-session:fixture-second",
+        title: "Second sanitized session",
+        origin: "codex-session",
+        anchor: "session-codex-session-fixture-second",
+      },
+    ],
+    offset: 1,
+    has_more: false,
+    next_offset: null,
+    continuation: null,
+  };
+  const fetchMock = vi
+    .spyOn(window, "fetch")
+    .mockResolvedValueOnce(response({ ok: true }))
+    .mockResolvedValueOnce(response(secondPage));
+
+  render(
+    <SessionList
+      endpoint="/api/sessions"
+      initialPage={firstPage}
+      initialFilters={{ origin: "claude-code-session", since: "", until: "", repo: "example/repo" }}
+      origins={["claude-code-session", "codex-session"]}
+    />,
+  );
+
+  fireEvent.click(screen.getByRole("button", { name: "Load next page" }));
+  await screen.findByRole("link", { name: "Second sanitized session" });
+
+  expect(fetchMock).toHaveBeenCalledTimes(2);
+  const nextUrl = new URL(String(fetchMock.mock.calls[1]?.[0]));
+  expect(nextUrl.pathname).toBe("/api/sessions");
+  expect([...nextUrl.searchParams.keys()]).toEqual(["continuation"]);
+  expect(nextUrl.searchParams.get("continuation")).toBe("q1.fixture-list-next");
+  expect(nextUrl.searchParams.has("offset")).toBe(false);
+  expect(nextUrl.searchParams.has("origin")).toBe(false);
+  expect(screen.getByText("2 rendered")).toBeTruthy();
+  expect((screen.getByRole("button", { name: "End of results" }) as HTMLButtonElement).disabled).toBe(true);
+});
+
+test("does not misstate an unknown empty page as zero", async () => {
+  const unknownPage: ContinuationPage<SessionSummary> = {
+    ...firstPage,
+    items: [],
+    total: null,
+    total_relation: "unknown",
+    page_count: 0,
+    has_more: false,
+    next_offset: null,
+    continuation: null,
+    route_state: {
+      state: "degraded",
+      route: "/api/sessions",
+      reason: "Count evidence is unconverged.",
+    },
+  };
+  render(
+    <SessionList
+      endpoint="/api/sessions"
+      initialPage={unknownPage}
+      initialFilters={{ origin: "", since: "", until: "", repo: "" }}
+      origins={[]}
+    />,
+  );
+
+  expect(screen.getByText("Sessions total unknown")).toBeTruthy();
+  expect(screen.getByText(/did not establish a zero total/i)).toBeTruthy();
+  expect(screen.queryByText("No sessions matched the current filters.")).toBeNull();
+  await waitFor(() => expect(screen.getByText(/Count evidence is unconverged/)).toBeTruthy());
+});
diff --git a/webui/src/components/SessionList.tsx b/webui/src/components/SessionList.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..dda37ec903b832600b339569a5bb86c63f950d74
--- /dev/null
+++ b/webui/src/components/SessionList.tsx
@@ -0,0 +1,211 @@
+import { useRef, useState } from "preact/hooks";
+
+import type {
+  ContinuationPage,
+  SessionListFilters,
+  SessionSummary,
+} from "../lib/contracts";
+import { fetchContinuationPage, fetchFirstPage } from "../lib/continuation";
+import { evidenceMessage, formatCount, formatDate, routeStateClass } from "../lib/format";
+
+export interface SessionListProps {
+  endpoint: string;
+  initialPage: ContinuationPage<SessionSummary>;
+  initialFilters: SessionListFilters;
+  origins: string[];
+}
+
+function SessionRow({ session }: { session: SessionSummary }) {
+  const href = `/app/s/${encodeURIComponent(session.session_id)}`;
+  const timestamp = session.updated_at ?? session.created_at ?? session.date;
+  return (
+    <li>
+      <article id={session.anchor} class="session-card" data-session-id={session.session_id}>
+        <header>
+          <div>
+            <h2>
+              <a href={href}>{session.title || session.session_id}</a>
+            </h2>
+            <code class="stable-ref">{session.session_id}</code>
+          </div>
+          <span class="origin-token">{session.origin}</span>
+        </header>
+        {session.summary ? <p>{session.summary}</p> : null}
+        <dl class="metadata-grid">
+          <div>
+            <dt>Messages</dt>
+            <dd>{session.message_count ?? "unknown"}</dd>
+          </div>
+          <div>
+            <dt>Updated</dt>
+            <dd>{timestamp ? <time dateTime={timestamp}>{formatDate(timestamp)}</time> : "unknown"}</dd>
+          </div>
+          <div>
+            <dt>Repository</dt>
+            <dd>{session.repo ?? "not recorded"}</dd>
+          </div>
+          <div>
+            <dt>Working directory</dt>
+            <dd>{session.cwd_display ?? "not recorded"}</dd>
+          </div>
+        </dl>
+        {session.tags.length > 0 ? (
+          <ul class="tag-list" aria-label="Session tags">
+            {session.tags.map((tag) => (
+              <li key={tag}>{tag}</li>
+            ))}
+          </ul>
+        ) : null}
+      </article>
+    </li>
+  );
+}
+
+export function SessionList({ endpoint, initialPage, initialFilters, origins }: SessionListProps) {
+  const [page, setPage] = useState(initialPage);
+  const [items, setItems] = useState(initialPage.items);
+  const [filters, setFilters] = useState(initialFilters);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const requestSequence = useRef(0);
+
+  async function applyFilters(event: SubmitEvent) {
+    event.preventDefault();
+    const sequence = ++requestSequence.current;
+    setLoading(true);
+    setError(null);
+    try {
+      const params = new URLSearchParams();
+      for (const [name, value] of Object.entries(filters)) {
+        if (value.trim()) {
+          params.set(name, value.trim());
+        }
+      }
+      params.set("limit", String(initialPage.limit));
+      const next = await fetchFirstPage<SessionSummary>(endpoint, params);
+      if (sequence !== requestSequence.current) {
+        return;
+      }
+      setPage(next);
+      setItems(next.items);
+    } catch (reason) {
+      if (sequence === requestSequence.current) {
+        setError(reason instanceof Error ? reason.message : "Session query failed");
+      }
+    } finally {
+      if (sequence === requestSequence.current) {
+        setLoading(false);
+      }
+    }
+  }
+
+  async function loadNext() {
+    if (!page.continuation || loading) {
+      return;
+    }
+    const sequence = ++requestSequence.current;
+    setLoading(true);
+    setError(null);
+    try {
+      const next = await fetchContinuationPage<SessionSummary>(endpoint, page);
+      if (sequence !== requestSequence.current) {
+        return;
+      }
+      setItems((current) => [...current, ...next.items]);
+      setPage(next);
+    } catch (reason) {
+      if (sequence === requestSequence.current) {
+        setError(reason instanceof Error ? reason.message : "Session page failed");
+      }
+    } finally {
+      if (sequence === requestSequence.current) {
+        setLoading(false);
+      }
+    }
+  }
+
+  const exactZero = page.total_relation === "exact" && page.total === 0;
+  const unknownEmpty = items.length === 0 && page.total_relation === "unknown";
+
+  return (
+    <div class="session-list-island" data-island="session-list">
+      <form class="filter-panel" method="get" action="/app" onSubmit={applyFilters}>
+        <label>
+          Origin
+          <select
+            name="origin"
+            value={filters.origin}
+            onInput={(event) => setFilters({ ...filters, origin: event.currentTarget.value })}
+          >
+            <option value="">Any origin</option>
+            {origins.map((origin) => (
+              <option value={origin} key={origin}>
+                {origin}
+              </option>
+            ))}
+          </select>
+        </label>
+        <label>
+          Since
+          <input
+            name="since"
+            type="date"
+            value={filters.since}
+            onInput={(event) => setFilters({ ...filters, since: event.currentTarget.value })}
+          />
+        </label>
+        <label>
+          Until
+          <input
+            name="until"
+            type="date"
+            value={filters.until}
+            onInput={(event) => setFilters({ ...filters, until: event.currentTarget.value })}
+          />
+        </label>
+        <label>
+          Repository
+          <input
+            name="repo"
+            value={filters.repo}
+            placeholder="owner/repo or URL"
+            onInput={(event) => setFilters({ ...filters, repo: event.currentTarget.value })}
+          />
+        </label>
+        <button type="submit" disabled={loading}>
+          Apply filters
+        </button>
+      </form>
+
+      <div class="list-status" aria-live="polite">
+        <strong>{formatCount(page.total, page.total_relation, "sessions")}</strong>
+        <span>{items.length} rendered</span>
+      </div>
+      <p class={routeStateClass(page.route_state)} data-total-relation={page.total_relation}>
+        {evidenceMessage(page)}
+      </p>
+      {error ? <p class="request-error" role="alert">{error}</p> : null}
+
+      {exactZero ? <p class="empty-state">No sessions matched the current filters.</p> : null}
+      {unknownEmpty ? (
+        <p class="empty-state empty-state--unknown">
+          No session rows were returned, but the archive did not establish a zero total.
+        </p>
+      ) : null}
+      {items.length > 0 ? (
+        <ol class="session-list" aria-label="Archive sessions">
+          {items.map((session) => (
+            <SessionRow session={session} key={session.session_id} />
+          ))}
+        </ol>
+      ) : null}
+
+      <div class="paging-controls">
+        <button type="button" onClick={loadNext} disabled={loading || !page.continuation}>
+          {loading ? "Loading…" : page.continuation ? "Load next page" : "End of results"}
+        </button>
+        <code title="Stable result reference">{page.result_ref}</code>
+      </div>
+    </div>
+  );
+}
