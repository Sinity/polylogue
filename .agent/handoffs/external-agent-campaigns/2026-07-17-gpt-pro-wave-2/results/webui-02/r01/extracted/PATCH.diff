+def test_live_list_payload_keeps_session_id_for_hydrated_links() -> None:
+    """The non-split archive path emits the stable key used by the island.
+
+    Production dependency: ``DaemonAPIHandler._do_list``. Anti-vacuity
+    mutation: removing the explicit ``session_id`` field leaves SSR able to
+    fall back to ``id`` but makes hydrated links encode ``undefined``.
+    """
+
+    handler = _make_handler("GET", "/api/sessions", auth_header="Bearer secret")
+    summary = SimpleNamespace(
+        id="codex-session:fixture-live",
+        display_title="Sanitized live session",
+        origin="codex-session",
+        display_date=None,
+        created_at=None,
+        updated_at=None,
+        message_count=1,
+        word_count=3,
+        git_repository_url="example/polylogue-fixture",
+        working_directories=("/workspace/fixture",),
+        tags=[],
+        summary=None,
+    )
+    session_filter = SimpleNamespace(list_summaries=AsyncMock(return_value=[summary]))
+    spec = SimpleNamespace(
+        query_terms=(),
+        contains_terms=(),
+        similar_text=None,
+        similar_session_id=None,
+        build_filter=MagicMock(return_value=session_filter),
+        count=AsyncMock(return_value=1),
+        has_filters=MagicMock(return_value=False),
+    )
+    poly = SimpleNamespace(config=object())
+
+    with (
+        patch("polylogue.archive.query.spec.SessionQuerySpec.from_params", return_value=spec),
+        patch("polylogue.daemon.http._build_flags_from_session", return_value=None),
+    ):
+        result = asyncio.run(handler._do_list(cast(Any, poly), {}, 25, 0))
+
+    page = cast(dict[str, object], result)
+    item = cast(dict[str, object], cast(list[object], page["items"])[0])
+    assert item["id"] == "codex-session:fixture-live"
+    assert item["session_id"] == item["id"]
+
