@@ -0,0 +1,39 @@
+import { hydrate } from "preact";
+
+import { SessionList } from "./components/SessionList";
+import { SessionRead } from "./components/SessionRead";
+import type { WebUIIslandState } from "./lib/contracts";
+import "./styles.css";
+
+function stateFromDocument(): WebUIIslandState | null {
+  const stateNode = document.getElementById("webui-v2-state");
+  if (!stateNode?.textContent) {
+    return null;
+  }
+  return JSON.parse(stateNode.textContent) as WebUIIslandState;
+}
+
+const root = document.getElementById("webui-v2-island");
+const state = stateFromDocument();
+
+if (root && state?.kind === "session-list") {
+  hydrate(
+    <SessionList
+      endpoint={state.endpoint}
+      initialPage={state.page}
+      initialFilters={state.filters}
+      origins={state.origins}
+    />,
+    root,
+  );
+} else if (root && state?.kind === "session-read") {
+  hydrate(
+    <SessionRead
+      endpoint={state.endpoint}
+      session={state.session}
+      initialPage={state.page}
+      topology={state.topology}
+    />,
+    root,
+  );
+}
