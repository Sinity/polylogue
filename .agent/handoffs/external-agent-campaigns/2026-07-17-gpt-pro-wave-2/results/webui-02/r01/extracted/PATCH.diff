index 0000000000000000000000000000000000000000..2786db51f40db707175a67b3c0366046b56b5152
--- /dev/null
+++ b/webui/src/lib/continuation.ts
@@ -0,0 +1,194 @@
+import type { ContinuationPage } from "./contracts";
+
+export type FetchLike = (input: RequestInfo | URL, init?: RequestInit) => Promise<Response>;
+
+let credentialPromise: Promise<void> | null = null;
+
+function sameOriginUrl(path: string): URL {
+  const url = new URL(path, window.location.origin);
+  if (url.origin !== window.location.origin) {
+    throw new Error("Polylogue WebUI requests must remain same-origin");
+  }
+  return url;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value);
+}
+
+function isInteger(value: unknown, minimum = 0): value is number {
+  return typeof value === "number" && Number.isInteger(value) && value >= minimum;
+}
+
+function invalidPage(detail: string): never {
+  throw new Error(`Invalid continuation page: ${detail}`);
+}
+
+function parsePage<T>(payload: unknown): ContinuationPage<T> {
+  if (!isRecord(payload)) {
+    return invalidPage("response body is not an object");
+  }
+  if (!Array.isArray(payload.items)) {
+    return invalidPage("items is not an array");
+  }
+  if (payload.total !== null && !isInteger(payload.total)) {
+    return invalidPage("total is neither a non-negative integer nor null");
+  }
+  if (!["exact", "at_least", "unknown"].includes(String(payload.total_relation))) {
+    return invalidPage("total_relation is not recognized");
+  }
+  if (!isInteger(payload.limit, 1)) {
+    return invalidPage("limit is not a positive integer");
+  }
+  if (!isInteger(payload.offset)) {
+    return invalidPage("offset is not a non-negative integer");
+  }
+  if (!isInteger(payload.page_count) || payload.page_count !== payload.items.length) {
+    return invalidPage("page_count does not match items.length");
+  }
+  if (payload.page_count > payload.limit) {
+    return invalidPage("page_count exceeds the bounded page limit");
+  }
+  if (typeof payload.has_more !== "boolean") {
+    return invalidPage("has_more is not boolean");
+  }
+  if (payload.next_offset !== null && !isInteger(payload.next_offset)) {
+    return invalidPage("next_offset is neither a non-negative integer nor null");
+  }
+  if (typeof payload.query_ref !== "string" || !payload.query_ref.startsWith("query:")) {
+    return invalidPage("query_ref is missing or malformed");
+  }
+  if (typeof payload.result_ref !== "string" || !payload.result_ref.startsWith("result:")) {
+    return invalidPage("result_ref is missing or malformed");
+  }
+  if (payload.continuation !== null && typeof payload.continuation !== "string") {
+    return invalidPage("continuation is neither a string nor null");
+  }
+  if (payload.has_more !== (payload.continuation !== null)) {
+    return invalidPage("has_more and continuation disagree");
+  }
+  if (payload.has_more && payload.next_offset === null) {
+    return invalidPage("advancing page is missing next_offset");
+  }
+  if (payload.has_more && payload.page_count === 0) {
+    return invalidPage("advancing page contains no rows");
+  }
+  if (payload.has_more && payload.next_offset !== payload.offset + payload.page_count) {
+    return invalidPage("next_offset does not advance by page_count");
+  }
+  if (!payload.has_more && payload.next_offset !== null) {
+    return invalidPage("terminal page exposes next_offset");
+  }
+  if (!isRecord(payload.route_state)) {
+    return invalidPage("route_state is not an object");
+  }
+  if (typeof payload.route_state.state !== "string" || typeof payload.route_state.route !== "string") {
+    return invalidPage("route_state lacks state or route");
+  }
+
+  return payload as unknown as ContinuationPage<T>;
+}
+
+function validateAdvance<T>(current: ContinuationPage<T>, next: ContinuationPage<T>): void {
+  if (current.continuation === null || current.next_offset === null) {
+    throw new Error("The current page does not expose an advancing continuation");
+  }
+  if (next.query_ref !== current.query_ref) {
+    throw new Error("Continuation query reference changed between pages");
+  }
+  if (next.result_ref !== current.result_ref) {
+    throw new Error("Continuation result reference changed between pages");
+  }
+  if (next.offset !== current.next_offset) {
+    throw new Error("Continuation page did not begin at the daemon-issued next offset");
+  }
+  if (next.limit !== current.limit) {
+    throw new Error("Continuation page size changed between pages");
+  }
+  if (next.continuation === current.continuation) {
+    throw new Error("Continuation did not advance");
+  }
+}
+
+export function resetCredentialBootstrapForTests(): void {
+  credentialPromise = null;
+}
+
+export function ensureWebCredential(fetcher: FetchLike = window.fetch.bind(window)): Promise<void> {
+  if (credentialPromise !== null) {
+    return credentialPromise;
+  }
+  credentialPromise = (async () => {
+    const response = await fetcher(sameOriginUrl("/api/web-auth/session"), {
+      method: "POST",
+      credentials: "same-origin",
+      headers: { "X-Polylogue-Web-Client": "1" },
+    });
+    if (!response.ok) {
+      throw new Error(`Web credential bootstrap failed (${response.status})`);
+    }
+  })().catch((error: unknown) => {
+    credentialPromise = null;
+    throw error;
+  });
+  return credentialPromise;
+}
+
+async function readPage<T>(response: Response): Promise<ContinuationPage<T>> {
+  if (!response.ok) {
+    let detail = `request failed (${response.status})`;
+    try {
+      const payload = (await response.json()) as { detail?: unknown; error?: unknown };
+      const candidate = payload.detail ?? payload.error;
+      if (typeof candidate === "string" && candidate.trim()) {
+        detail = candidate;
+      }
+    } catch {
+      // Preserve the status-derived message when the body is not JSON.
+    }
+    throw new Error(detail);
+  }
+  return parsePage<T>(await response.json());
+}
+
+export async function fetchFirstPage<T>(
+  endpoint: string,
+  params: URLSearchParams,
+  fetcher: FetchLike = window.fetch.bind(window),
+): Promise<ContinuationPage<T>> {
+  const url = sameOriginUrl(endpoint);
+  await ensureWebCredential(fetcher);
+  url.search = params.toString();
+  return readPage<T>(
+    await fetcher(url, {
+      method: "GET",
+      credentials: "same-origin",
+      headers: { Accept: "application/json" },
+    }),
+  );
+}
+
+export async function fetchContinuationPage<T>(
+  endpoint: string,
+  current: ContinuationPage<T>,
+  fetcher: FetchLike = window.fetch.bind(window),
+): Promise<ContinuationPage<T>> {
+  const source = parsePage<T>(current);
+  if (!source.continuation) {
+    throw new Error("A daemon-issued continuation is required");
+  }
+  const url = sameOriginUrl(endpoint);
+  await ensureWebCredential(fetcher);
+  // Deliberately send only the opaque continuation. The daemon owns the
+  // original filters, page size, offset, projection, and stable ordering.
+  url.search = new URLSearchParams({ continuation: source.continuation }).toString();
+  const next = await readPage<T>(
+    await fetcher(url, {
+      method: "GET",
+      credentials: "same-origin",
+      headers: { Accept: "application/json" },
+    }),
+  );
+  validateAdvance(source, next);
+  return next;
+}
