+def message_block_payload(block: Mapping[str, object]) -> dict[str, object]:
+    """Project one hydrated domain block without reclassifying its semantics."""
+
+    block_type = _string(block.get("type") or block.get("block_type") or "text")
+    raw_is_error = block.get("tool_result_is_error", block.get("is_error"))
+    if isinstance(raw_is_error, bool):
+        is_error: bool | None = raw_is_error
+    elif isinstance(raw_is_error, int):
+        is_error = bool(raw_is_error)
+    else:
+        is_error = None
+    raw_exit_code = block.get("tool_result_exit_code", block.get("exit_code"))
+    exit_code = _int_or_none(raw_exit_code)
+    outcome = tool_result_outcome(int(is_error) if is_error is not None else None, exit_code)
+    return {
+        "id": _string(block.get("id") or block.get("block_id")),
+        "type": block_type,
+        "text": block.get("text") if isinstance(block.get("text"), str) else None,
+        "tool_name": block.get("tool_name") if isinstance(block.get("tool_name"), str) else None,
+        "tool_id": block.get("tool_id") if isinstance(block.get("tool_id"), str) else None,
+        "semantic_type": block.get("semantic_type") if isinstance(block.get("semantic_type"), str) else None,
+        "tool_input": _decode_json_value(block.get("tool_input")),
+        "metadata": _decode_json_value(block.get("metadata")),
+        "language": block.get("language") if isinstance(block.get("language"), str) else None,
+        "tool_result_is_error": is_error,
+        "tool_result_exit_code": exit_code,
+        "tool_result_outcome": outcome if block_type == "tool_result" else None,
+    }
+
+
+def archive_block_payload(block: object) -> dict[str, object]:
+    """Project one ``ArchiveBlockRow`` through the domain-block contract."""
+
+    return message_block_payload(
+        {
+            "id": getattr(block, "block_id", None),
+            "type": getattr(block, "block_type", None),
+            "text": getattr(block, "text", None),
+            "tool_name": getattr(block, "tool_name", None),
+            "tool_id": getattr(block, "tool_id", None),
+            "semantic_type": getattr(block, "semantic_type", None),
+            "tool_input": getattr(block, "tool_input", None),
+            "metadata": getattr(block, "metadata", None),
+            "language": getattr(block, "language", None),
+            "tool_result_is_error": getattr(block, "tool_result_is_error", None),
+            "tool_result_exit_code": getattr(block, "tool_result_exit_code", None),
+        }
+    )
+
