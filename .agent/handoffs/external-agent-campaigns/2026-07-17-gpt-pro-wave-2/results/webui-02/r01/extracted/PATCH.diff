+  gap: 0.3rem;
+  color: var(--muted);
+  font-size: 0.82rem;
+  font-weight: 700;
+}
+.filter-panel input,
+.filter-panel select {
+  width: 100%;
+  min-height: 2.5rem;
+  padding: 0.45rem 0.55rem;
