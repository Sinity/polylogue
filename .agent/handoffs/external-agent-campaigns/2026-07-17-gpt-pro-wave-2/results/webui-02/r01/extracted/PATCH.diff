+  --danger: #9c2f2f;
+  --danger-soft: #fff0f0;
+  --warning: #795400;
+  --warning-soft: #fff8db;
+  --success: #236b3c;
+  --success-soft: #ecf8ef;
+  --mono:
+    ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
+    monospace;
+  --sans:
