+def test_message_continuation_cannot_cross_session_boundaries(tmp_path: Path) -> None:
+    """The route rejects a valid token issued for a different stable session ref."""
+
+    request = message_page_request("codex-session:fixture-a", page_size=1)
+    first = continuation_page_payload(
