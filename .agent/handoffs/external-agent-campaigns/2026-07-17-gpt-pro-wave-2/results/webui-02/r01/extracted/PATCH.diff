+    has_more: false,
+    next_offset: null,
+    continuation: null,
+    ...overrides,
+  };
+}
+
+test.each([
+  ["query_ref", "query:unrelated"],
+  ["result_ref", "result:unrelated"],
+] as const)("rejects continuation %s drift before rows can be merged", async (field, value) => {
+  const fetcher = vi
+    .fn()
+    .mockResolvedValueOnce(response({ credential: { state: "ready" } }))
+    .mockResolvedValueOnce(response(terminalPage({ [field]: value })));
+
+  await expect(
+    fetchContinuationPage("/api/sessions", firstPage, fetcher),
+  ).rejects.toThrow(field === "query_ref" ? /query reference changed/i : /result reference changed/i);
+
+  const pageUrl = new URL(String(fetcher.mock.calls[1]?.[0]));
+  expect([...pageUrl.searchParams.keys()]).toEqual(["continuation"]);
+});
+
+test("rejects a page that does not start at the daemon-issued next offset", async () => {
+  const fetcher = vi
+    .fn()
+    .mockResolvedValueOnce(response({ credential: { state: "ready" } }))
+    .mockResolvedValueOnce(response(terminalPage({ offset: 7 })));
+
+  await expect(
+    fetchContinuationPage("/api/sessions", firstPage, fetcher),
+  ).rejects.toThrow(/daemon-issued next offset/i);
+});
+
+test("rejects a continuation that changes the daemon-owned page size", async () => {
+  const fetcher = vi
+    .fn()
+    .mockResolvedValueOnce(response({ credential: { state: "ready" } }))
+    .mockResolvedValueOnce(response(terminalPage({ limit: 2 })));
+
+  await expect(
+    fetchContinuationPage("/api/sessions", firstPage, fetcher),
+  ).rejects.toThrow(/page size changed/i);
+});
+
+test("rejects malformed page envelopes instead of trusting a TypeScript cast", async () => {
+  const fetcher = vi
+    .fn()
+    .mockResolvedValueOnce(response({ credential: { state: "ready" } }))
+    .mockResolvedValueOnce(response(terminalPage({ page_count: 99 })));
+
+  await expect(
+    fetchContinuationPage("/api/sessions", firstPage, fetcher),
+  ).rejects.toThrow(/page_count does not match/i);
+});
+
+test("rejects malformed SSR state before credential bootstrap or paging", async () => {
+  const fetcher = vi.fn();
+  const malformedCurrent = { ...firstPage, page_count: 99 };
+
+  await expect(
+    fetchContinuationPage("/api/sessions", malformedCurrent, fetcher),
+  ).rejects.toThrow(/page_count does not match/i);
+  expect(fetcher).not.toHaveBeenCalled();
+});
+
+test("rejects cross-origin endpoints before issuing any network request", async () => {
+  const fetcher = vi.fn();
+
+  await expect(
+    fetchContinuationPage("https://example.invalid/api/sessions", firstPage, fetcher),
+  ).rejects.toThrow(/same-origin/i);
+  expect(fetcher).not.toHaveBeenCalled();
+});
diff --git a/webui/src/lib/continuation.ts b/webui/src/lib/continuation.ts
