+        },
+        archive_root=tmp_path,
+        request=request,
+        items_key="messages",
+        items_alias="messages",
+        mode="session-message-page",
+    )
+    continuation = cast(str, first["continuation"])
+    handler = _make_handler(
+        "GET",
+        f"/api/sessions/codex-session%3Afixture-b/messages?continuation={quote(continuation, safe='')}",
+        auth_header="Bearer secret",
+    )
+    send_error, send_json = _capture_responses(handler)
+    handler._do_archive_get_messages = MagicMock()  # type: ignore[method-assign]
+
+    with patch("polylogue.daemon.http._web_reader_archive_root", return_value=tmp_path):
+        handler.do_GET()
