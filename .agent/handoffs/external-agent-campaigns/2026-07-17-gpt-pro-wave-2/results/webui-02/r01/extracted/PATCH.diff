index 0000000000000000000000000000000000000000..00ea3f5bd18063765bc24fb09176724a986f8c52
--- /dev/null
+++ b/webui/src/lib/format.ts
@@ -0,0 +1,60 @@
+import type { ContinuationPage, RouteState, TotalRelation } from "./contracts";
+
+export function formatCount(
+  value: number | null,
+  relation: TotalRelation,
+  noun: string,
+): string {
+  if (relation === "exact" && value !== null) {
+    return `${value} ${noun}`;
+  }
+  if (relation === "at_least" && value !== null) {
+    return `At least ${value} ${noun}`;
+  }
+  return `${noun[0]?.toUpperCase() ?? "T"}${noun.slice(1)} total unknown`;
+}
+
+export function evidenceMessage<T>(page: ContinuationPage<T>): string {
+  if (page.total_relation === "unknown") {
+    return page.route_state.reason
+      ? `Total unknown: ${page.route_state.reason}`
+      : "Total unknown: the archive did not provide converged count evidence.";
+  }
+  if (page.total_relation === "at_least") {
+    return "The displayed total is a lower bound, not an exact count.";
+  }
+  return (
+    page.route_state.reason ??
+    "The archive supplied an exact count for this query."
+  );
+}
+
+export function routeStateClass(routeState: RouteState): string {
+  return `evidence-state evidence-state--${routeState.state.replaceAll(/[^a-z0-9_-]/gi, "-")}`;
+}
+
+export function formatDate(value: string | null): string {
+  if (!value) {
+    return "unknown time";
+  }
+  return value;
+}
+
+export function formatBytes(value: number | null): string {
+  if (value === null || value < 0) {
+    return "size unknown";
+  }
+  if (value < 1024) {
+    return `${value} B`;
+  }
+  if (value < 1024 * 1024) {
+    return `${(value / 1024).toFixed(1)} KiB`;
+  }
+  return `${(value / (1024 * 1024)).toFixed(1)} MiB`;
+}
+
+export function formatEvidenceCount(value: number | null | undefined): string {
+  return value !== null && value !== undefined && value >= 0
+    ? String(value)
+    : "unknown";
+}
