+
+import readFixture from "../fixtures/session-read-page.json";
+import type {
+  ContinuationPage,
+  SessionHeader,
+  SessionMessage,
+  SessionTopology,
+} from "../lib/contracts";
+import { SessionRead } from "./SessionRead";
+
+const fixture = readFixture as {
+  session: SessionHeader;
+  page: ContinuationPage<SessionMessage>;
+  topology: SessionTopology;
+};
+
+test("renders raw role/material-origin tokens, provider failure evidence, attachments, and fork family", () => {
+  const { container } = render(
+    <SessionRead
+      endpoint={`/api/sessions/${encodeURIComponent(fixture.session.session_id)}/messages`}
+      session={fixture.session}
+      initialPage={fixture.page}
+      topology={fixture.topology}
+    />,
+  );
+
+  expect(screen.getByText("Lineage: fork / resume family")).toBeTruthy();
+  expect(screen.getByText("assistant_authored")).toBeTruthy();
+  expect(screen.getAllByText("tool_result").length).toBeGreaterThan(0);
+  expect(screen.getByText("Failed tool result")).toBeTruthy();
+  expect(screen.getByText("exit code 2")).toBeTruthy();
+  expect(screen.getByText("Synthetic failure output.")).toBeTruthy();
+  expect(screen.getByText("synthetic-log.txt")).toBeTruthy();
+  expect(container.querySelector('[data-message-id="claude-code-session:fixture-child:message-2"]')).not.toBeNull();
+  expect(
+    container.querySelector(
+      'a.permalink[href="#message-claude-code-session-fixture-child-message-2"]',
+    ),
+  ).not.toBeNull();
+
+  let failedResult = container.querySelector<HTMLDetailsElement>('details[data-outcome="failed"]');
+  expect(failedResult?.open).toBe(true);
+  fireEvent.click(screen.getByRole("button", { name: "Collapse all blocks" }));
+  failedResult = container.querySelector<HTMLDetailsElement>('details[data-outcome="failed"]');
+  expect(failedResult?.open).toBe(false);
+  fireEvent.click(screen.getByRole("button", { name: "Expand all blocks" }));
