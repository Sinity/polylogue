+  background: var(--panel);
+}
+.site-header a {
+  color: inherit;
+  font-weight: 800;
+  text-decoration: none;
+  letter-spacing: 0.02em;
+}
+.site-header p {
+  margin: 0;
+  color: var(--muted);
+}
+
+main {
+  width: min(1120px, calc(100% - 2rem));
+  margin: 0 auto;
+  padding: 2rem 0 4rem;
+}
