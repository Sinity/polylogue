@@ -0,0 +1,833 @@
+"""Semantic SSR documents and continuation contracts for WebUI v2.
+
+This module is intentionally a narrow daemon adapter. Archive semantics stay in
+``ArchiveStore``/``Polylogue``; the browser receives the same role,
+material-origin, lineage, and structured tool-result facts without reclassifying
+them. Preact hydrates the server-rendered list/read islands when JavaScript is
+available, while the first page remains useful semantic HTML without it.
+"""
+
+from __future__ import annotations
+
+import html
+import json
+from collections.abc import Mapping, Sequence
+from pathlib import Path
+from typing import Literal, cast
+from urllib.parse import quote
+
+from polylogue.archive.actions.parsing import tool_result_outcome
+from polylogue.archive.query.transaction import (
+    QueryContinuation,
+    QueryResultPage,
+    QueryTransaction,
+    QueryTransactionRequest,
+)
+from polylogue.core.enums import Origin
+
+WEBUI_V2_LIST_PAGE_SIZE = 25
+WEBUI_V2_READ_PAGE_SIZE = 40
+WEBUI_V2_ASSET_NAMES = frozenset({"webui-v2.css", "webui-v2.js"})
+WEBUI_V2_ASSET_CONTENT_TYPES: Mapping[str, str] = {
+    "webui-v2.css": "text/css; charset=utf-8",
+    "webui-v2.js": "text/javascript; charset=utf-8",
+}
+
+LIST_OPERATION = "http.sessions.list"
+LIST_PROJECTION = "session-list"
+LIST_STABLE_ORDER = "updated_at_desc,session_id"
+MESSAGES_OPERATION = "http.sessions.messages"
+MESSAGES_PROJECTION = "session-message-flow"
+MESSAGES_STABLE_ORDER = "position,variant_index,message_id"
+
+TotalRelation = Literal["exact", "at_least", "unknown"]
+
+
+def webui_v2_asset_path(name: str) -> Path | None:
+    """Return one committed WebUI asset path, rejecting traversal and drift."""
+
+    if name not in WEBUI_V2_ASSET_NAMES:
+        return None
+    return Path(__file__).with_name("static") / "dist" / name
+
+
+def _canonical_filter_params(params: Mapping[str, Sequence[str]]) -> dict[str, list[str]]:
+    """Copy logical query parameters while excluding all paging mechanisms."""
+
+    excluded = {"continuation", "cursor", "limit", "offset"}
+    return {
+        str(key): [str(value) for value in values]
+        for key, values in sorted(params.items())
+        if key not in excluded and values
+    }
+
+
+def list_page_request(
+    params: Mapping[str, Sequence[str]],
+    *,
+    page_size: int,
+    offset: int = 0,
+) -> QueryTransactionRequest:
+    return QueryTransactionRequest(
+        operation=LIST_OPERATION,
+        arguments={"params": _canonical_filter_params(params)},
+        page_size=page_size,
+        offset=offset,
+        projection=LIST_PROJECTION,
+        stable_order=LIST_STABLE_ORDER,
+    )
+
+
+def message_page_request(
+    session_id: str,
+    *,
+    page_size: int,
+    offset: int = 0,
+) -> QueryTransactionRequest:
+    return QueryTransactionRequest(
+        operation=MESSAGES_OPERATION,
+        arguments={"session_id": session_id},
+        page_size=page_size,
+        offset=offset,
+        projection=MESSAGES_PROJECTION,
+        stable_order=MESSAGES_STABLE_ORDER,
+    )
+
+
+def decode_list_continuation(token: str, archive_root: Path) -> tuple[QueryTransactionRequest, dict[str, list[str]]]:
+    continuation = _decode_continuation(
+        token,
+        archive_root,
+        operation=LIST_OPERATION,
+        projection=LIST_PROJECTION,
+        stable_order=LIST_STABLE_ORDER,
+    )
+    raw_params = continuation.request.arguments.get("params")
+    if not isinstance(raw_params, Mapping):
+        raise ValueError("invalid session-list continuation arguments")
+    params: dict[str, list[str]] = {}
+    for key, values in raw_params.items():
+        if (
+            not isinstance(key, str)
+            or not isinstance(values, list)
+            or not all(isinstance(value, str) for value in values)
+        ):
+            raise ValueError("invalid session-list continuation parameters")
+        params[key] = list(values)
+    return continuation.request, params
+
+
+def decode_message_continuation(
+    token: str,
+    archive_root: Path,
+    *,
+    session_id: str,
+) -> QueryTransactionRequest:
+    continuation = _decode_continuation(
+        token,
+        archive_root,
+        operation=MESSAGES_OPERATION,
+        projection=MESSAGES_PROJECTION,
+        stable_order=MESSAGES_STABLE_ORDER,
+    )
+    continuation_session_id = continuation.request.arguments.get("session_id")
+    if continuation_session_id != session_id:
+        raise ValueError("query continuation belongs to a different session")
+    return continuation.request
+
+
+def _decode_continuation(
+    token: str,
+    archive_root: Path,
+    *,
+    operation: str,
+    projection: str,
+    stable_order: str,
+) -> QueryContinuation:
+    continuation = QueryContinuation.decode(token)
+    request = continuation.request
+    if request.operation != operation or request.projection != projection or request.stable_order != stable_order:
+        raise ValueError("query continuation does not match this route")
+    expected_result_ref = QueryTransaction(archive_root, request).result_ref
+    if continuation.result_ref != expected_result_ref:
+        raise ValueError("query continuation result reference does not match its request")
+    return continuation
+
+
+def continuation_page_payload(
+    payload: Mapping[str, object],
+    *,
+    archive_root: Path,
+    request: QueryTransactionRequest,
+    items_key: str,
+    items_alias: str | None = None,
+    mode: str,
+) -> dict[str, object]:
+    """Attach shared query/result identity and an opaque advancing token.
+
+    Existing route fields remain in place for compatibility. WebUI v2 consumes
+    ``items`` and the continuation vocabulary only; it never reconstructs the
+    request's offset or filters.
+    """
+
+    raw_items = payload.get(items_key)
+    if not isinstance(raw_items, list):
+        raise ValueError(f"paged payload is missing list field {items_key!r}")
+    items = cast(list[object], raw_items)
+
+    raw_total = payload.get("total")
+    total = raw_total if isinstance(raw_total, int) and not isinstance(raw_total, bool) else None
+    explicit_relation = payload.get("total_relation")
+    if explicit_relation in {"exact", "at_least", "unknown"}:
+        total_relation = cast(TotalRelation, explicit_relation)
+    else:
+        total_relation = "exact" if total is not None else "unknown"
+
+    explicit_has_more = payload.get("has_more")
+    if isinstance(explicit_has_more, bool):
+        has_more = explicit_has_more
+    elif total is not None:
+        has_more = request.offset + len(items) < total
+    else:
+        has_more = False
+
+    if total_relation == "at_least" and total is None:
+        total = request.offset + len(items)
+
+    transaction = QueryTransaction(archive_root, request)
+    page = QueryResultPage(
+        items=tuple(items),
+        request=request,
+        has_more=has_more and bool(items),
+        result_ref=transaction.result_ref,
+    )
+    result = dict(payload)
+    result["items"] = items
+    if items_alias is not None:
+        result[items_alias] = items
+    result.update(
+        {
+            "mode": mode,
+            "total": total,
+            "total_relation": total_relation,
+            "limit": request.page_size,
+            "offset": request.offset,
+            "page_count": len(items),
+            "has_more": page.has_more,
+            "next_offset": page.next_offset,
+            "query_ref": request.query_ref,
+            "result_ref": transaction.result_ref,
+            "continuation": page.continuation,
+        }
+    )
+    return result
+
+
+def list_filters(params: Mapping[str, Sequence[str]]) -> dict[str, str]:
+    return {
+        key: str(values[0]) if values else ""
+        for key, values in {
+            "origin": params.get("origin", ()),
+            "since": params.get("since", ()),
+            "until": params.get("until", ()),
+            "repo": params.get("repo", ()),
+        }.items()
+    }
