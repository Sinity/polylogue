+  color: var(--muted);
+}
+.stable-ref {
+  display: inline-block;
+  max-width: 100%;
+  overflow-wrap: anywhere;
+  color: var(--muted);
+  font-size: 0.78rem;
+}
+.origin-token,
+.lineage-chip {
