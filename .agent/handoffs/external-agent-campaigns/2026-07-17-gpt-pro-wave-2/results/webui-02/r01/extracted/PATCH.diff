+        "parent_id": session.get("parent_id") if isinstance(session.get("parent_id"), str) else None,
+        "lineage_complete": lineage_complete if isinstance(lineage_complete, bool) else None,
+        "lineage_truncation_reason": (
+            session.get("lineage_truncation_reason")
+            if isinstance(session.get("lineage_truncation_reason"), str)
