+        assert str(list_state_page["query_ref"]).startswith("query:")
+        assert str(list_state_page["result_ref"]).startswith("result:")
+
+        assert first_page["offset"] == 0
+        assert second_page["offset"] == first_page["next_offset"] == 1
+        assert second_page["query_ref"] == first_page["query_ref"]
+        assert second_page["result_ref"] == first_page["result_ref"]
+        first_items = cast(list[dict[str, object]], first_page["items"])
+        second_items = cast(list[dict[str, object]], second_page["items"])
+        assert first_items[0]["session_id"] != second_items[0]["session_id"]
+
+        assert read_status == 200
+        assert "text/html" in read_type
+        assert f'data-session-id="{C1}"' in read_document
+        assert f'data-message-id="{M_C1}"' in read_document
+        assert '<ol class="message-flow" aria-label="Session messages">' in read_document
+        assert read_document.index('<ol class="message-flow"') < read_document.index('id="webui-v2-state"')
+        assert read_state["kind"] == "session-read"
+        assert read_state["endpoint"] == f"/api/sessions/{quote(C1, safe='')}/messages"
+        assert read_state_page["total_relation"] == "exact"
+        api_message = cast(list[dict[str, object]], message_page["items"])[0]
+        assert read_items[0]["id"] == api_message["id"] == M_C1
+        assert read_items[0]["role"] == api_message["role"]
+        assert read_items[0]["material_origin"] == api_message["material_origin"]
+
+        assert js_status == css_status == 200
+        assert "text/javascript" in js_type
+        assert "text/css" in css_type
