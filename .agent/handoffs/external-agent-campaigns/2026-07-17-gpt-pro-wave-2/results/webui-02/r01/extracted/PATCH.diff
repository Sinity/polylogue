+def test_list_api_continuation_restores_filters_and_stable_result_ref(tmp_path: Path) -> None:
+    """An API advance uses only the opaque daemon token and restores its query."""
+
+    request = list_page_request({"origin": ["codex-session"]}, page_size=2)
+    first = continuation_page_payload(
+        {
+            "items": [_session("codex-session:a"), _session("codex-session:b")],
+            "total": 3,
+            "route_state": _ready_state("/api/sessions"),
+        },
+        archive_root=tmp_path,
+        request=request,
+        items_key="items",
+        mode="session-list-page",
+    )
+    continuation = cast(str, first["continuation"])
+    handler = _make_handler(
+        "GET",
+        f"/api/sessions?continuation={quote(continuation, safe='')}",
+        auth_header="Bearer secret",
+    )
+    send_error, send_json = _capture_responses(handler)
+    handler._do_archive_list_sessions = MagicMock(  # type: ignore[method-assign]
+        return_value={
+            "items": [_session("codex-session:c")],
+            "total": 3,
+            "limit": 2,
+            "offset": 2,
+            "route_state": _ready_state("/api/sessions"),
+        }
+    )
+
+    with patch("polylogue.daemon.http._web_reader_archive_root", return_value=tmp_path):
+        handler.do_GET()
+
+    send_error.assert_not_called()
+    handler._do_archive_list_sessions.assert_called_once_with(
+        tmp_path,
+        {"origin": ["codex-session"]},
+        2,
+        2,
+        "/api/sessions",
+        request=request.next(offset=2),
+    )
+    send_json.assert_called_once()
+    status, page = send_json.call_args.args
+    assert status is HTTPStatus.OK
+    assert page["query_ref"] == first["query_ref"]
+    assert page["result_ref"] == first["result_ref"]
+    assert page["offset"] == 2
+    assert page["page_count"] == 1
+    assert page["continuation"] is None
+    assert [item["session_id"] for item in page["items"]] == ["codex-session:c"]
+
