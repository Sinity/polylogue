+  min-width: 320px;
+  background: var(--surface);
+  color: var(--ink);
+  font-family: var(--sans);
+}
+body {
+  margin: 0;
+  line-height: 1.5;
+}
+a {
+  color: var(--accent);
+  text-underline-offset: 0.16em;
+}
+code,
+pre {
+  font-family: var(--mono);
+}
+button,
+input,
+select {
+  font: inherit;
+}
+button {
+  cursor: pointer;
+}
+button:disabled {
+  cursor: not-allowed;
+  opacity: 0.58;
+}
+
+.site-header {
+  display: flex;
+  align-items: center;
+  justify-content: space-between;
+  gap: 1rem;
+  padding: 1rem clamp(1rem, 4vw, 3rem);
