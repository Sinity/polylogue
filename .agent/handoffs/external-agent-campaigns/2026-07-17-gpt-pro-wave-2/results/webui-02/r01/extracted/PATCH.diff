+
+
+def _session(session_id: str) -> dict[str, object]:
+    return {
+        "id": session_id,
+        "session_id": session_id,
+        "title": "Sanitized session",
+        "origin": "codex-session",
+        "anchor": f"session-{session_id.replace(':', '-')}",
+        "date": "2026-01-02T10:30:00Z",
+        "created_at": "2026-01-02T10:00:00Z",
+        "updated_at": "2026-01-02T10:30:00Z",
+        "message_count": 2,
+        "word_count": 42,
+        "repo": "example/polylogue-fixture",
+        "cwd_display": "/workspace/fixture",
+        "tags": ["sanitized"],
+        "summary": "Synthetic content only.",
+    }
+
+
+def _ready_state(route: str) -> dict[str, object]:
+    return {
+        "state": "ready",
+        "route": route,
+        "reason": None,
+        "component": None,
+        "generated_at": "2026-01-02T12:00:00Z",
+        "stale_available": False,
+    }
+
+
+def test_session_list_route_ssr_emits_semantic_first_page(tmp_path: Path) -> None:
+    """The real /app dispatch must emit a useful document before island JS runs.
+
+    Production dependency: ``DaemonAPIHandler._do_archive_list_sessions``.
+    Anti-vacuity mutation: bypassing ``_serve_webui_v2_session_list`` or
+    replacing its renderer with an empty mount div removes the asserted form,
+    list article, stable ref, and first-page state.
+    """
+
+    handler = _make_handler("GET", "/app?origin=codex-session")
+    handler._send_html = MagicMock()  # type: ignore[method-assign]
+    handler._do_archive_list_sessions = MagicMock(  # type: ignore[method-assign]
+        return_value={
+            "items": [_session("codex-session:fixture-list")],
+            "total": 1,
+            "limit": 25,
+            "offset": 0,
+            "route_state": _ready_state("/app"),
+        }
+    )
+
+    with patch("polylogue.daemon.http._web_reader_archive_root", return_value=tmp_path):
+        handler.do_GET()
+
+    handler._send_html.assert_called_once()
+    status, document = handler._send_html.call_args.args
+    assert status is HTTPStatus.OK
+    assert document.startswith("<!doctype html>")
+    assert '<form class="filter-panel" method="get" action="/app">' in document
+    assert '<ol class="session-list" aria-label="Archive sessions">' in document
+    assert 'data-session-id="codex-session:fixture-list"' in document
+    assert '<code class="stable-ref">codex-session:fixture-list</code>' in document
+    assert 'href="/app/s/codex-session%3Afixture-list"' in document
+    assert 'id="webui-v2-state" type="application/json"' in document
+    assert 'href="/app/assets/webui-v2.css"' in document
+    assert 'src="/app/assets/webui-v2.js"' in document
+    assert '"total_relation":"exact"' in document
+    assert '"query_ref":"query:' in document
+    assert '"result_ref":"result:' in document
+
+
+def test_session_list_ssr_escapes_visible_content_and_json_bootstrap(tmp_path: Path) -> None:
+    """Stored text cannot terminate the state script or become executable HTML.
+
+    Production dependency: ``render_session_list_document`` and its distinct
+    text/attribute/JSON escaping boundaries. Removing ``_state_script``'s
+    less-than escaping or rendering titles as trusted markup breaks this test.
+    """
+
+    hostile_title = '</script><script data-owned="1">synthetic()</script>'
+    session = _session("codex-session:fixture-xss")
+    session["title"] = hostile_title
+    request = list_page_request({}, page_size=25)
+    page = continuation_page_payload(
+        {
+            "items": [session],
+            "total": 1,
+            "route_state": _ready_state("/app"),
+        },
+        archive_root=tmp_path,
+        request=request,
+        items_key="items",
+        mode="session-list-page",
+    )
+
+    document = render_session_list_document(page, {"origin": "", "since": "", "until": "", "repo": ""})
+    state_match = re.search(
+        r'<script id="webui-v2-state" type="application/json">(.*?)</script>',
+        document,
+    )
+
+    assert hostile_title not in document
+    assert '&lt;/script&gt;&lt;script data-owned="1"&gt;synthetic()&lt;/script&gt;' in document
+    assert state_match is not None
+    state_source = state_match.group(1)
+    assert "<" not in state_source
+    state = json.loads(state_source)
+    assert state["page"]["items"][0]["title"] == hostile_title
+
+
+def test_webui_v2_asset_route_rejects_encoded_traversal() -> None:
+    """Only the two committed bundle names may cross the HTTP file boundary."""
+
+    handler = _make_handler("GET", "/app/assets/..%2Fhttp.py")
+    handler._send_error = MagicMock()  # type: ignore[method-assign]
+
+    handler.do_GET()
+
+    handler._send_error.assert_called_once()
+    assert handler._send_error.call_args.args[:2] == (HTTPStatus.NOT_FOUND, "not_found")
+
+
+def test_session_read_route_ssr_renders_failure_attachment_and_fork_family(tmp_path: Path) -> None:
+    """The /app/s route renders source semantics, not a client-only placeholder.
+
+    Production dependency: ``_do_archive_webui_v2_session_read`` supplies the
+    exact archive roles, material origins, block outcome columns, attachments,
+    and canonical topology. Removing any projection makes this test fail.
+    """
+
+    session_id = "claude-code-session:fixture-child"
+    message_id = "message:fixture-tool-result"
+    session = {
+        **_session(session_id),
+        "display_title": "Sanitized fork child",
+        "branch_type": "fork",
+        "parent_id": "claude-code-session:fixture-parent",
+        "lineage_complete": True,
+        "lineage_truncation_reason": None,
+    }
+    raw_page = {
+        "messages": [
+            {
+                "id": message_id,
+                "role": "tool",
+                "text": "Synthetic command failed.",
+                "anchor": "message-message-fixture-tool-result",
+                "timestamp": "2026-01-02T11:02:00Z",
+                "message_type": "tool_result",
+                "material_origin": "tool_result",
+                "duration_ms": 10,
+                "parent_message_id": None,
+                "variant_index": 0,
+                "is_active_path": True,
+                "is_active_leaf": True,
+                "source_session_id": session_id,
+                "inherited_prefix": False,
+                "word_count": 3,
+                "blocks": [
+                    {
+                        "id": "block:fixture-result",
+                        "type": "tool_result",
+                        "text": "Synthetic command failed.",
