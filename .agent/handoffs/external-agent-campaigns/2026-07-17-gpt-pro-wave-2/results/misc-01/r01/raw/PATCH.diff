+def _nested_toml(path: str, value: object) -> str:
+    root: dict[str, object] = {}
+    cursor = root
+    parts = path.split(".")
+    for part in parts[:-1]:
+        child: dict[str, object] = {}
+        cursor[part] = child
+        cursor = child
+    cursor[parts[-1]] = value
+    return tomli_w.dumps(root)
+
