+def test_no_runtime_module_directly_reads_an_inventoried_environment_setting() -> None:
+    """Mutation: add ``os.environ.get(POLYLOGUE_...)`` in a consumer and this fails."""
+    repository = Path(__file__).resolve().parents[3]
+    inventoried = {entry.env_var for entry in config_inventory() if entry.env_var}
+    offenders: list[str] = []
+
+    for path in sorted((repository / "polylogue").rglob("*.py")):
+        if path == repository / "polylogue" / "config.py":
+            continue
+        tree = ast.parse(path.read_text(encoding="utf-8"), filename=str(path))
+        for node in ast.walk(tree):
+            value: str | None = None
+            if isinstance(node, ast.Call):
+                if isinstance(node.func, ast.Attribute) and node.func.attr in {"get", "getenv"}:
+                    value = _call_literal(node)
+                for keyword in node.keywords:
+                    if keyword.arg == "envvar" and isinstance(keyword.value, ast.Constant):
+                        candidate = keyword.value.value
+                        if isinstance(candidate, str):
+                            value = candidate
+            elif (
+                isinstance(node, ast.Subscript)
+                and isinstance(node.ctx, ast.Load)
+                and isinstance(node.slice, ast.Constant)
+            ):
+                candidate = node.slice.value
+                if isinstance(candidate, str):
+                    value = candidate
+            if value in inventoried:
+                offenders.append(f"{path.relative_to(repository)}:{node.lineno}: {value}")
+
+    assert not offenders, "inventoried environment bypasses:\n" + "\n".join(offenders)
