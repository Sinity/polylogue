+def test_parent_shortening_degrades_then_semantic_reingest_restores_cut(tmp_path: Path) -> None:
+    """A missing cut is typed, bounded, rollback-safe data rather than a crash.
+
+    Production dependencies: exact-prefix witness retention on degradation and
+    semantic rebinding on later identity churn. Clearing the witness when the
+    parent shortens makes the final reingest permanently unreadable.
+    """
+    conn = _connect(tmp_path / "shorten-restore.db")
+    parent = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="parent",
+        updated_at="2027-01-01T00:00:01Z",
+        messages=[
+            _msg("p0", Role.USER, "root", 0),
+            _msg("p1", Role.ASSISTANT, "reply", 1),
+        ],
+    )
+    parent_id = write_parsed_session_to_archive(conn, parent)
+    child = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="child",
+        parent_session_provider_id="parent",
+        branch_type=BranchType.FORK,
+        updated_at="2027-01-01T00:00:02Z",
+        messages=[
+            _msg("c0", Role.USER, "root", 0),
+            _msg("c1", Role.ASSISTANT, "reply", 1),
+            _msg("c2", Role.USER, "child tail", 2),
+        ],
+    )
+    child_id = write_parsed_session_to_archive(conn, child)
+    child_physical = _physical_message_oracle(conn, child_id)
+    original_witness = _witness_oracle(conn, child_id)
+
+    shortened = parent.model_copy(
+        update={
+            "updated_at": "2027-01-01T00:00:03Z",
+            "messages": [_msg("s0", Role.USER, "root", 0)],
+        }
+    )
+    write_parsed_session_to_archive(conn, shortened)
+
+    assert _physical_message_oracle(conn, child_id) == child_physical == [("c2", 2, 0)]
+    assert _link_oracle(conn, child_id) == (
+        parent_id,
+        f"{parent_id}:p1",
+        "prefix-sharing",
+        "dangling_branch_point",
+    )
+    assert _witness_oracle(conn, child_id) == original_witness
+    assert _composed_oracle(conn, child_id) == (["child tail"], False, "dangling_branch_point")
+
+    restored = parent.model_copy(
+        update={
+            "updated_at": "2027-01-01T00:00:04Z",
+            "messages": [
+                _msg("q0", Role.USER, "root", 0),
+                _msg("q1", Role.ASSISTANT, "reply", 1),
+            ],
+        }
+    )
+    write_parsed_session_to_archive(conn, restored)
+
+    assert _physical_message_oracle(conn, child_id) == child_physical
+    assert _link_oracle(conn, child_id) == (
+        parent_id,
+        f"{parent_id}:q1",
+        "prefix-sharing",
+        None,
+    )
+    restored_witness = _witness_oracle(conn, child_id)
+    assert restored_witness is not None
+    assert restored_witness[0] == 2
+    assert len(restored_witness[1]) == 64
+    assert _composed_oracle(conn, child_id) == (["root", "reply", "child tail"], True, None)
+    conn.close()
+
