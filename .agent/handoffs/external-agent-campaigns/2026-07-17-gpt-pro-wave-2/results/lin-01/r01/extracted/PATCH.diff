+            _link_oracle(conn, child_id),
+            _witness_oracle(conn, parent_id),
+            _witness_oracle(conn, child_id),
+            _composed_oracle(conn, child_id),
+        )
+        states[order] = state
+        conn.close()
+
+    for state in states.values():
+        parent_rows, child_rows, parent_link, child_link, parent_witness, child_witness, composed = state
+        assert parent_rows == [("p2", 2, 0)]
+        assert child_rows == [("c3", 2, 0)]
+        assert parent_link == (
+            "codex-session:root",
+            "codex-session:root:r1",
+            "prefix-sharing",
+            None,
+        )
+        assert child_link == (
+            "codex-session:parent",
+            "codex-session:root:r1",
+            "prefix-sharing",
+            None,
+        )
+        assert parent_witness is not None
+        assert child_witness is not None
+        assert parent_witness[0] == child_witness[0] == 2
+        assert parent_witness[1] == child_witness[1]
+        assert len(parent_witness[1]) == 64
+        assert composed == (["root prompt", "root reply", "child tail"], True, None)
+    assert len({repr(state) for state in states.values()}) == 1
