+        assert parent_rows == expected_parent
+        assert child_rows == expected_child
+        assert link == expected_link
+        assert witness is not None
+        assert witness[0] == 3
+        assert len(witness[1]) == 64
+        assert composed == (["root", "primary", "sibling", "child tail"], True, None)
