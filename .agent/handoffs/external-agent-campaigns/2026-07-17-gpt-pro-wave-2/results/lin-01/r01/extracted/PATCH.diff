+def test_ancestor_rebind_refreshes_descendant_delegation_fact(tmp_path: Path) -> None:
+    """A nested cut rebind must refresh the affected parent delegation cohort.
+
+    The subagent child's cut is inside context inherited by its immediate
+    parent. Replacing the root with equivalent messages changes that cut's
+    canonical identity without directly writing either descendant. Removing
+    the descendant ``refresh_delegation_facts_for_session`` loop from
+    ``_resolve_session_graph`` leaves the materialized fact naming ``r1``
+    while the canonical session link names ``q1``.
+    """
+    conn = _connect(tmp_path / "delegation-rebind.db")
+    root = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="root",
+        messages=[
+            _msg("r0", Role.USER, "root prompt", 0),
+            _msg("r1", Role.ASSISTANT, "root reply", 1),
+        ],
+    )
+    root_id = write_parsed_session_to_archive(conn, root)
+
+    dispatch = ParsedMessage(
+        provider_message_id="dispatch",
+        role=Role.ASSISTANT,
+        position=2,
+        blocks=[
+            ParsedContentBlock(
+                type=BlockType.TOOL_USE,
+                tool_name="Task",
+                tool_id="task-1",
+                tool_input={"prompt": "audit the child"},
+            )
+        ],
+    )
+    parent = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="parent",
+        parent_session_provider_id="root",
+        branch_type=BranchType.FORK,
+        messages=[
+            _msg("p0", Role.USER, "root prompt", 0),
+            _msg("p1", Role.ASSISTANT, "root reply", 1),
+            dispatch,
+        ],
+    )
+    parent_id = write_parsed_session_to_archive(conn, parent)
+    child = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="child",
+        parent_session_provider_id="parent",
+        branch_type=BranchType.SUBAGENT,
+        messages=[
+            _msg("c0", Role.USER, "root prompt", 0),
+            _msg("c1", Role.ASSISTANT, "root reply", 1),
+            _msg("c2", Role.USER, "child work", 2),
+        ],
+    )
+    child_id = write_parsed_session_to_archive(conn, child)
+
+    before = conn.execute(
+        """
+        SELECT child_session_id, branch_point_message_id, mapping_state,
+               instruction_message_id
+        FROM delegation_facts
+        WHERE parent_session_id = ?
+        """,
+        (parent_id,),
+    ).fetchone()
+    assert before is not None
+    assert tuple(before) == (
+        child_id,
+        f"{root_id}:r1",
+        "resolved",
+        f"{parent_id}:dispatch",
+    )
+
+    replacement = root.model_copy(
+        update={
+            "messages": [
+                _msg("q0", Role.USER, "root prompt", 0),
+                _msg("q1", Role.ASSISTANT, "root reply", 1),
+            ]
+        }
+    )
+    write_parsed_session_to_archive(conn, replacement)
+
+    # Physical oracle: neither descendant's owned tail was rewritten.
+    assert _physical_message_oracle(conn, parent_id) == [("dispatch", 2, 0)]
+    assert _physical_message_oracle(conn, child_id) == [("c2", 2, 0)]
+    # Link oracle: both inherited cuts now name the replacement root identity.
+    assert _link_oracle(conn, parent_id) == (
+        root_id,
+        f"{root_id}:q1",
+        "prefix-sharing",
+        None,
+    )
+    assert _link_oracle(conn, child_id) == (
+        parent_id,
+        f"{root_id}:q1",
+        "prefix-sharing",
+        None,
+    )
+    # Materialized-write oracle: the cached descendant fact moved in the same
+    # transaction rather than retaining the deleted root message identity.
+    after = conn.execute(
+        """
+        SELECT child_session_id, branch_point_message_id, mapping_state,
+               instruction_message_id
+        FROM delegation_facts
+        WHERE parent_session_id = ?
+        """,
+        (parent_id,),
+    ).fetchone()
+    assert after is not None
+    assert tuple(after) == (
+        child_id,
+        f"{root_id}:q1",
+        "resolved",
+        f"{parent_id}:dispatch",
+    )
+    # Composed-read oracle remains complete and bounded through the nested cut.
+    assert _composed_oracle(conn, child_id) == (
+        ["root prompt", "root reply", "child work"],
+        True,
+        None,
+    )
+
