+def _lineage_prefix_witness(
+    conn: sqlite3.Connection,
+    *,
+    src_session_id: str,
+    dst_origin: str,
+    dst_native_id: str,
+    link_type: str,
+) -> tuple[int, str] | None:
+    row = conn.execute(
+        """
+        SELECT prefix_length, semantic_prefix_hash
+        FROM lineage_prefix_witnesses
+        WHERE src_session_id = ? AND dst_origin = ? AND dst_native_id = ? AND link_type = ?
+        """,
+        (src_session_id, dst_origin, dst_native_id, link_type),
+    ).fetchone()
+    if row is None:
+        return None
+    return (int(row[0]), str(row[1]))
+
+
+def _prefix_through_message(
+    parent_composed: Sequence[tuple[str, str]],
+    branch_point_message_id: str,
+) -> list[tuple[str, str]] | None:
+    prefix: list[tuple[str, str]] = []
+    for message_id, signature in parent_composed:
+        prefix.append((message_id, signature))
+        if message_id == branch_point_message_id:
+            return prefix
+    return None
+
+
+def _semantic_witness_matches_prefix(
+    witness: tuple[int, str] | None,
+    parent_composed: Sequence[tuple[str, str]],
+) -> bool:
+    if witness is None:
+        return False
+    prefix_length, semantic_prefix_hash = witness
+    if prefix_length > len(parent_composed):
+        return False
+    return _semantic_prefix_witness(parent_composed[:prefix_length]) == (prefix_length, semantic_prefix_hash)
+
+
+def _reconcile_prefix_sharing_edge_db(
+    conn: sqlite3.Connection,
+    *,
+    src_session_id: str,
+    parent_session_id: str,
+    dst_origin: str,
+    dst_native_id: str,
+    link_type: str,
+    branch_point_message_id: str,
+    status: str | None,
+    cache: dict[str, list[tuple[str, str]]] | None = None,
+    composed_cache: dict[str, list[tuple[str, str]]] | None = None,
+) -> tuple[bool, bool]:
+    """Converge one prefix cut against its parent's accepted composition.
+
+    Exact message identity remains authoritative.  When identity churned, the
+    complete persisted semantic-prefix witness must match the new parent prefix
+    position-for-position before rebinding.  Anything less is an explicit
+    dangling state; no nearest-row or shorter-prefix content is fabricated.
+    Returns ``(changed, branch_point_rebound)``.
+    """
+    if status == "quarantined":
+        return (False, False)
+
+    local_composed_cache = composed_cache if composed_cache is not None else {}
+    parent_composed = _composed_db_signatures(
+        conn,
+        parent_session_id,
+        cache=cache,
+        composed_cache=local_composed_cache,
+    )
+    witness = _lineage_prefix_witness(
+        conn,
+        src_session_id=src_session_id,
+        dst_origin=dst_origin,
+        dst_native_id=dst_native_id,
+        link_type=link_type,
+    )
+
+    target_branch_point = branch_point_message_id
+    target_status: str | None = "dangling_branch_point"
+    target_witness = witness
+
+    surviving_prefix = _prefix_through_message(parent_composed, branch_point_message_id)
+    if surviving_prefix is not None:
+        # Stable identity is the strongest authority. Refresh the digest too:
+        # later identity churn must map the newest accepted parent semantics,
+        # not content observed before a same-id replacement.
+        target_status = None
+        target_witness = _semantic_prefix_witness(surviving_prefix)
+    elif _semantic_witness_matches_prefix(witness, parent_composed):
+        assert witness is not None
+        prefix_length = witness[0]
+        target_witness = _semantic_prefix_witness(parent_composed[:prefix_length])
+        target_branch_point = parent_composed[prefix_length - 1][0]
+        target_status = None
+    elif witness is None:
+        # Rebuild-only v39 guarantees witnesses for newly parsed rows. Keep the
+        # pre-v39 deterministic mapper solely as a compatibility repair for
+        # manually imported/witnessless rows; it is never preferred over proof.
+        suffix = _suffix_after_session_id(branch_point_message_id, parent_session_id)
+        replacement = (
+            _replacement_for_stale_prefix_branch_point(parent_composed, suffix) if suffix is not None else None
+        )
+        if replacement is not None:
+            replacement_prefix = _prefix_through_message(parent_composed, replacement)
+            if replacement_prefix is not None:
+                target_branch_point = replacement
+                target_status = None
+                target_witness = _semantic_prefix_witness(replacement_prefix)
+
+    branch_point_rebound = target_branch_point != branch_point_message_id
+    edge_changed = branch_point_rebound or target_status != status
+    if edge_changed:
+        conn.execute(
+            """
+            UPDATE session_links
+            SET branch_point_message_id = ?, status = ?
+            WHERE src_session_id = ?
+              AND dst_origin = ?
+              AND dst_native_id = ?
+              AND link_type = ?
+              AND inheritance = 'prefix-sharing'
+              AND status IS NOT 'quarantined'
+            """,
+            (
+                target_branch_point,
+                target_status,
+                src_session_id,
+                dst_origin,
+                dst_native_id,
+                link_type,
+            ),
+        )
+
+    witness_changed = target_witness != witness
+    if witness_changed:
+        _replace_lineage_prefix_witness(
+            conn,
+            src_session_id=src_session_id,
+            dst_origin=dst_origin,
+            dst_native_id=dst_native_id,
+            link_type=link_type,
+            witness=target_witness,
+        )
+    if composed_cache is not None:
+        composed_cache.pop(src_session_id, None)
+    return (edge_changed or witness_changed, branch_point_rebound)
+
+
+def _reconcile_prefix_sharing_subtree(
+    conn: sqlite3.Connection,
+    parent_session_ids: Iterable[str],
+    *,
+    cache: dict[str, list[tuple[str, str]]] | None = None,
+    composed_cache: dict[str, list[tuple[str, str]]] | None = None,
+) -> set[str]:
+    """Reconcile every reachable prefix-sharing descendant, parent first.
+
+    Parent normalization or replacement can alter the composed identities seen
+    by grandchildren without touching their immediate parent's own rows.  This
+    indexed breadth-first walk closes that transitive gap while a visited set
+    bounds quarantined or malformed cycles.
+    """
+    local_composed_cache = composed_cache if composed_cache is not None else {}
+    queue = list(dict.fromkeys(str(session_id) for session_id in parent_session_ids))
+    visited: set[str] = set()
+    impacted: set[str] = set(queue)
+    cursor = 0
+    while cursor < len(queue):
+        parent_session_id = queue[cursor]
+        cursor += 1
+        if parent_session_id in visited:
+            continue
+        visited.add(parent_session_id)
+        rows = conn.execute(
+            """
+            SELECT src_session_id, dst_origin, dst_native_id, link_type,
+                   branch_point_message_id, status
+            FROM session_links
+            WHERE resolved_dst_session_id = ?
+              AND inheritance = 'prefix-sharing'
+              AND branch_point_message_id IS NOT NULL
+              AND status IS NOT 'quarantined'
+            ORDER BY src_session_id, dst_origin, dst_native_id, link_type
+            """,
+            (parent_session_id,),
+        ).fetchall()
+        for row in rows:
+            child_session_id = str(row[0])
+            _reconcile_prefix_sharing_edge_db(
+                conn,
+                src_session_id=child_session_id,
+                parent_session_id=parent_session_id,
+                dst_origin=str(row[1]),
+                dst_native_id=str(row[2]),
+                link_type=str(row[3]),
+                branch_point_message_id=str(row[4]),
+                status=str(row[5]) if row[5] is not None else None,
+                cache=cache,
+                composed_cache=local_composed_cache,
+            )
+            impacted.add(child_session_id)
+            if child_session_id not in visited:
+                queue.append(child_session_id)
+    return impacted
+
