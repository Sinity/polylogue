+def test_full_replace_without_parent_clears_witness_when_foreign_keys_suspended(
+    tmp_path: Path,
+) -> None:
+    """A rebuild-time relation removal must not strand an edge-owned witness.
+
+    Bulk rebuilds disable foreign-key enforcement, so the witness table's
+    ``ON DELETE CASCADE`` cannot protect this transition. Removing the explicit
+    witness delete from ``_clear_session_projection_rows`` leaves one orphan
+    row and makes ``PRAGMA foreign_key_check`` fail after the replacement.
+    """
+    conn = _connect(tmp_path / "index.db")
+    parent = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="parent",
+        messages=[_msg("p0", Role.USER, "shared", 0)],
+    )
+    write_parsed_session_to_archive(conn, parent)
+    child = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="child",
+        parent_session_provider_id="parent",
+        branch_type=BranchType.FORK,
+        messages=[
+            _msg("c0", Role.USER, "shared", 0),
+            _msg("c1", Role.ASSISTANT, "child tail", 1),
+        ],
+    )
+    child_id = write_parsed_session_to_archive(conn, child)
+    assert _witness_oracle(conn, child_id) is not None
+    conn.commit()
+
+    conn.execute("PRAGMA foreign_keys = OFF")
+    conn.execute("BEGIN IMMEDIATE")
+    standalone = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="child",
+        messages=[_msg("n0", Role.USER, "standalone replacement", 0)],
+    )
+    write_parsed_session_to_archive(
+        conn,
+        standalone,
+        force_replace=True,
+        manage_transaction=False,
+    )
+
+    # Physical oracle: the accepted standalone replacement owns one row.
+    assert _physical_message_oracle(conn, child_id) == [("n0", 0, 0)]
+    # Link-row oracle: both the relation and its compact proof are gone.
+    assert (
+        conn.execute(
+            "SELECT COUNT(*) FROM session_links WHERE src_session_id = ?",
+            (child_id,),
+        ).fetchone()[0]
+        == 0
+    )
+    assert _witness_oracle(conn, child_id) is None
+    assert conn.execute("PRAGMA foreign_key_check").fetchall() == []
+    # Composed-read oracle: no stale parent prefix remains observable.
+    assert _composed_oracle(conn, child_id) == (["standalone replacement"], True, None)
+
+    conn.commit()
+    conn.execute("PRAGMA foreign_keys = ON")
+    assert conn.execute("PRAGMA foreign_key_check").fetchall() == []
+    conn.close()
+
