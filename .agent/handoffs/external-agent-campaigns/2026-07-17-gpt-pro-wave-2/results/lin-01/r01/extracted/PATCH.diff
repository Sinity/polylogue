+def test_semantic_prefix_witness_converges_all_sibling_replacement_orders(tmp_path: Path) -> None:
+    """Equivalent accepted histories converge across all six arrival orders.
+
+    Production dependencies: full-replace tail extraction, delayed parent
+    normalization, semantic witness persistence, subtree reconciliation, and
+    the independent composed envelope reader. Removing witness matching or
+    descendant reconciliation makes the ``old-parent -> child -> final-parent``
+    histories retain the stale cut while the other permutations remain complete.
+    """
+
+    def _session(kind: str) -> ParsedSession:
+        if kind == "old-parent":
+            return ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="parent",
+                updated_at="2027-01-01T00:00:01Z",
+                messages=[
+                    _msg("p0", Role.USER, "root", 0),
+                    _msg("p1", Role.ASSISTANT, "primary", 1),
+                    _msg("p1-alt", Role.ASSISTANT, "sibling", 1, variant_index=1),
+                ],
+            )
+        if kind == "final-parent":
+            return ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id="parent",
+                updated_at="2027-01-01T00:00:03Z",
+                messages=[
+                    _msg("q0", Role.USER, "root", 0),
+                    _msg("q1", Role.ASSISTANT, "primary", 1),
+                    _msg("q1-alt", Role.ASSISTANT, "sibling", 1, variant_index=1),
+                ],
+            )
+        return ParsedSession(
+            source_name=Provider.CODEX,
+            provider_session_id="child",
+            parent_session_provider_id="parent",
+            branch_type=BranchType.FORK,
+            updated_at="2027-01-01T00:00:02Z",
+            messages=[
+                _msg("c0", Role.USER, "root", 0),
+                _msg("c1", Role.ASSISTANT, "primary", 1),
+                _msg("c1-alt", Role.ASSISTANT, "sibling", 1, variant_index=1),
+                _msg("c2", Role.USER, "child tail", 2),
+            ],
+        )
+
+    states: dict[tuple[str, ...], tuple[object, ...]] = {}
+    for order in permutations(("old-parent", "child", "final-parent")):
+        conn = _connect(tmp_path / f"direct-{'-'.join(order)}.db")
+        for transition in order:
+            write_parsed_session_to_archive(conn, _session(transition))
+
+        parent_id = "codex-session:parent"
+        child_id = "codex-session:child"
+        state = (
+            _physical_message_oracle(conn, parent_id),
+            _physical_message_oracle(conn, child_id),
+            _link_oracle(conn, child_id),
+            _witness_oracle(conn, child_id),
+            _composed_oracle(conn, child_id),
+        )
+        states[order] = state
+        conn.close()
+
+    expected_parent = [("q0", 0, 0), ("q1", 1, 0), ("q1-alt", 1, 1)]
+    expected_child = [("c2", 2, 0)]
