+    artifact_matches = False
+    rows_array_seen = False
+    try:
+        with path.open("rb") as handle:
+            for prefix, event, value in ijson.parse(handle):
+                if prefix == "schema_version" and event == "string":
+                    schema_matches = value == hermes_verification.VERIFICATION_EXPORT_SCHEMA
+                elif prefix == "artifact_kind" and event == "string":
+                    artifact_matches = value == hermes_verification.VERIFICATION_ARTIFACT_KIND
+                elif prefix == "rows" and event == "start_array":
+                    rows_array_seen = True
+                if schema_matches and artifact_matches and rows_array_seen:
+                    return True
+    except (ijson.common.JSONError, UnicodeError):
+        decoded = _decoders._decode_json_bytes(path.read_bytes())
+        if decoded is None:
+            return False
+        try:
+            payload = json.loads(decoded)
+        except json.JSONDecodeError:
+            return False
+        return isinstance(payload, dict) and hermes_verification.looks_like_verification_evidence_payload(payload)
+    return False
