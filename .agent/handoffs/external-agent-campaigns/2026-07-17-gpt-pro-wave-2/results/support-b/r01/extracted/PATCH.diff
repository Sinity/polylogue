diff --git a/polylogue/sources/parsers/hermes_verification.py b/polylogue/sources/parsers/hermes_verification.py
new file mode 100644
index 0000000000000000000000000000000000000000..fcefb12c065fa450b01cd8faffb2388da9133bdc
--- /dev/null
+++ b/polylogue/sources/parsers/hermes_verification.py
@@ -0,0 +1,497 @@
+"""Hermes verification-ledger export normalization.
+
+The on-disk ``verification_evidence.db`` artifact is identified by the
+artifact taxonomy but is deliberately not opened here.  A producer-side or
+paired local acquisition lane exports selected rows into the versioned JSON
+envelope defined by :data:`VERIFICATION_EXPORT_SCHEMA`; those retained JSON
+bytes then travel through the ordinary raw -> parser -> normalized archive
+route.
+
+The fixture checked into this repository is synthetic and only exercises that
+stable boundary.  No field mapping in this module is promoted to ``exact``
+until a local lane validates the envelope against retained real producer bytes.
+"""
+
+from __future__ import annotations
+
+from collections import defaultdict
+from collections.abc import Mapping, Sequence
+from dataclasses import dataclass
+
+from polylogue.archive.message.roles import Role
+from polylogue.archive.session.hermes_verification import HermesVerificationRowState
+from polylogue.core.enums import BlockType, MaterialOrigin, Provider
+from polylogue.core.hashing import hash_payload, hash_text_short
+from polylogue.core.json import JSONDocument, JSONValue, json_document
+
+from .base import ParsedContentBlock, ParsedMessage, ParsedSession, ParsedSessionEvent
+from .hermes_state import HermesFidelityCapability, HermesImportFidelity
+
+VERIFICATION_EXPORT_SCHEMA = "polylogue.hermes.verification-evidence/v1"
+VERIFICATION_ARTIFACT_KIND = "hermes_verification_evidence"
+VERIFICATION_EVENT_TYPE = "hermes_verification_evidence"
+VERIFICATION_ARTIFACT_EVENT_TYPE = "hermes_verification_artifact"
+
+_SUCCESS_STATUSES = frozenset({"completed", "ok", "pass", "passed", "succeeded", "success"})
+_FAILURE_STATUSES = frozenset({"error", "errored", "fail", "failed", "failure"})
+_CORE_FIELDS = ("command", "canonical_command", "kind", "scope", "status", "changed_paths")
+
+
+@dataclass(frozen=True, slots=True)
+class _NormalizedRow:
+    source_index: int
+    evidence_id: str
+    row_state: HermesVerificationRowState
+    target_session_native_id: str | None
+    target_session_id: str | None
+    command: str | None
+    canonical_command: str | None
+    kind: str | None
+    scope: str | None
+    status: str | None
+    exit_code: int | None
+    is_error: bool | None
+    output_summary: str | None
+    changed_paths: tuple[str, ...] | None
+    observed_at: str | None
+
+    @property
+    def correlation_key(self) -> str | None:
+        return self.target_session_native_id or self.target_session_id
+
+
+def looks_like_verification_evidence_payload(payload: JSONDocument) -> bool:
+    """Return whether *payload* is the versioned verification export envelope."""
+
+    return (
+        payload.get("schema_version") == VERIFICATION_EXPORT_SCHEMA
+        and payload.get("artifact_kind") == VERIFICATION_ARTIFACT_KIND
+        and isinstance(payload.get("rows"), list)
+    )
+
+
+def parse_verification_evidence_document(payload: JSONDocument, fallback_id: str) -> list[ParsedSession]:
+    """Normalize one versioned verification export into observer sessions.
+
+    Rows are grouped by producer-positive session identity, while rows without
+    identity are retained in a deterministic missing-identity group.  Every
+    object row becomes a paired ``tool_use``/``tool_result`` message so the
+    existing ``actions`` relation exposes command and structural outcome.
+    Malformed non-object rows remain visible as typed events with unknown
+    normalized fields rather than being dropped or converted into prose.
+    """
+
+    if not looks_like_verification_evidence_payload(payload):
+        raise ValueError("payload is not a Hermes verification-evidence v1 export")
+
+    export_id = _optional_string(payload.get("export_id")) or fallback_id
+    raw_rows = payload.get("rows")
+    rows: list[JSONValue] = raw_rows if isinstance(raw_rows, list) else []
+    normalized = [_normalize_row(value, source_index=index, export_id=export_id) for index, value in enumerate(rows)]
+
+    grouped: dict[str | None, list[_NormalizedRow]] = defaultdict(list)
+    for row in normalized:
+        grouped[row.correlation_key].append(row)
+    if not grouped:
+        grouped[None] = []
+
+    artifact_payload = _artifact_payload(payload, export_id=export_id)
+    sessions = [
+        _session_for_rows(
+            export_id=export_id,
+            correlation_key=correlation_key,
+            rows=group_rows,
+            artifact_payload=artifact_payload,
+        )
+        for correlation_key, group_rows in sorted(grouped.items(), key=lambda item: item[0] or "")
+    ]
+    return sessions
+
+
+def import_fidelity_declaration(sessions: Sequence[ParsedSession]) -> HermesImportFidelity:
+    """Declare what this boundary proves without claiming real producer bytes."""
+
+    evidence_events = [
+        event for session in sessions for event in session.session_events if event.event_type == VERIFICATION_EVENT_TYPE
+    ]
+    total = len(evidence_events)
+    malformed = sum(
+        event.payload.get("row_state") == HermesVerificationRowState.MALFORMED.value for event in evidence_events
+    )
+    partial = sum(
+        event.payload.get("row_state") == HermesVerificationRowState.PARTIAL.value for event in evidence_events
+    )
+    conflicts = sum(
+        event.payload.get("row_state") == HermesVerificationRowState.OUTCOME_CONFLICT.value for event in evidence_events
+    )
+    missing_identity = sum(
+        event.payload.get("target_session_native_id") is None and event.payload.get("target_session_id") is None
+        for event in evidence_events
+    )
+
+    def inferred(name: str, detail: str) -> HermesFidelityCapability:
+        observed = sum(event.payload.get(name) is not None for event in evidence_events)
+        return HermesFidelityCapability(
+            status="inferred" if observed else "absent",
+            observed=observed,
+            expected=total,
+            counts={},
+            detail=detail,
+        )
+
+    capabilities: dict[str, HermesFidelityCapability] = {
+        "artifact_identity": HermesFidelityCapability(
+            status="inferred",
+            observed=sum(
+                event.event_type == VERIFICATION_ARTIFACT_EVENT_TYPE
+                for session in sessions
+                for event in session.session_events
+            ),
+            expected=max(len(sessions), 1),
+            counts={},
+            detail="The JSON envelope records source-artifact identity, but its mapping to real verification_evidence.db bytes is not locally validated in this lane.",
+        ),
+        "command": inferred(
+            "command",
+            "Command is copied only from the structured export column; it is never recovered from output prose.",
+        ),
+        "canonical_command": inferred(
+            "canonical_command",
+            "Canonical command is producer/export supplied; the parser does not invent one from command text.",
+        ),
+        "kind": inferred("kind", "Verification kind is copied from the structured export row."),
+        "scope": inferred("scope", "Verification scope is copied from the structured export row."),
+        "status": inferred("status", "Status is normalized from the explicit structured status token."),
+        "exit_code": inferred("exit_code", "Exit code remains NULL when the structured row does not establish it."),
+        "output_summary": inferred(
+            "output_summary",
+            "Only the structured output-summary column is imported; no transcript or arbitrary output body is synthesized.",
+        ),
+        "changed_paths": inferred(
+            "changed_paths", "Changed paths preserve NULL (unknown) separately from an explicit empty list."
+        ),
+        "session_correlation": HermesFidelityCapability(
+            status="degraded" if missing_identity else "inferred",
+            observed=total - missing_identity,
+            expected=total,
+            counts={"missing_identity": missing_identity},
+            detail="Read-side correlation uses producer-positive native/raw session identifiers and fails closed for zero or multiple matches.",
+        ),
+        "row_quality": HermesFidelityCapability(
+            status="degraded" if malformed or partial or conflicts else "inferred",
+            observed=total - malformed,
+            expected=total,
+            counts={"malformed": malformed, "partial": partial, "outcome_conflict": conflicts},
+            detail="Malformed, partial, and structurally conflicting rows remain visible as typed states.",
+        ),
+    }
+    caveats = (
+        "Synthetic producer-shaped rows exercise the stable JSON boundary; no real ~/.hermes verification_evidence.db bytes were supplied to this lane.",
+        "The local real-byte lane must validate table/column names, types, status vocabulary, canonical-command semantics, changed-path encoding, session identity, ordering, and artifact revision/hash rules before any mapping becomes exact.",
+    )
+    return HermesImportFidelity(
+        producer="Hermes verification_evidence.db via Polylogue v1 JSON acquisition boundary (real-byte mapping unverified)",
+        schema_version=1,
+        profile_namespace=None,
+        acquisition_method="verification_evidence_json_export",
+        retained_blob_reproducibility=HermesFidelityCapability(
+            status="exact",
+            observed=len(sessions),
+            expected=len(sessions),
+            counts={},
+            detail="The exported JSON artifact bytes use the ordinary retained-raw path and reproduce the same normalized rows on replay; this does not prove the upstream SQLite-to-JSON mapping.",
+        ),
+        capabilities=capabilities,
+        caveats=caveats,
+    )
+
+
+def _session_for_rows(
+    *,
+    export_id: str,
+    correlation_key: str | None,
+    rows: list[_NormalizedRow],
+    artifact_payload: dict[str, object],
+) -> ParsedSession:
+    export_component = hash_text_short(export_id, 16)
+    correlation_component = hash_text_short(correlation_key or "missing_identity", 16)
+    provider_session_id = f"verification:{export_component}:{correlation_component}"
+
+    messages: list[ParsedMessage] = []
+    events: list[ParsedSessionEvent] = [
+        ParsedSessionEvent(event_type=VERIFICATION_ARTIFACT_EVENT_TYPE, payload=dict(artifact_payload))
+    ]
+    for row in rows:
+        source_message_provider_id = None
+        if row.row_state is not HermesVerificationRowState.MALFORMED:
+            source_message_provider_id = f"verification-row:{row.source_index}:{hash_text_short(row.evidence_id, 16)}"
+            tool_id = f"verification:{row.source_index}:{hash_text_short(row.evidence_id, 16)}"
+            tool_input: dict[str, object] = {}
+            for key, value in (
+                ("command", row.command),
+                ("canonical_command", row.canonical_command),
+                ("kind", row.kind),
+                ("scope", row.scope),
+                ("status", row.status),
+                ("session_native_id", row.target_session_native_id),
+                ("session_id", row.target_session_id),
+            ):
+                if value is not None:
+                    tool_input[key] = value
+            if row.changed_paths is not None:
+                tool_input["changed_paths"] = list(row.changed_paths)
+                if len(row.changed_paths) == 1:
+                    tool_input["path"] = row.changed_paths[0]
+            messages.append(
+                ParsedMessage(
+                    provider_message_id=source_message_provider_id,
+                    role=Role.ASSISTANT,
+                    timestamp=row.observed_at,
+                    position=row.source_index,
+                    material_origin=MaterialOrigin.RUNTIME_PROTOCOL,
+                    blocks=[
+                        ParsedContentBlock(
+                            type=BlockType.TOOL_USE,
+                            tool_name="hermes_verification",
+                            tool_id=tool_id,
+                            tool_input=tool_input,
+                        ),
+                        ParsedContentBlock(
+                            type=BlockType.TOOL_RESULT,
+                            tool_id=tool_id,
+                            text=row.output_summary,
+                            is_error=row.is_error,
+                            exit_code=row.exit_code,
+                        ),
+                    ],
+                )
+            )
+
+        events.append(
+            ParsedSessionEvent(
+                event_type=VERIFICATION_EVENT_TYPE,
+                timestamp=row.observed_at,
+                source_message_provider_id=source_message_provider_id,
+                payload=_event_payload(row, export_id=export_id),
+            )
+        )
+
+    flags: list[str] = ["hermes:verification-evidence"]
+    if correlation_key is None:
+        flags.append("degraded:hermes-verification-missing-identity")
+    if any(row.row_state is HermesVerificationRowState.MALFORMED for row in rows):
+        flags.append("degraded:hermes-verification-malformed-row")
+    if any(
+        row.row_state in {HermesVerificationRowState.PARTIAL, HermesVerificationRowState.OUTCOME_CONFLICT}
+        for row in rows
+    ):
+        flags.append("degraded:hermes-verification-partial-row")
+
+    created = next((row.observed_at for row in rows if row.observed_at is not None), None)
+    updated = next((row.observed_at for row in reversed(rows) if row.observed_at is not None), None)
+    return ParsedSession(
+        source_name=Provider.HERMES,
+        provider_session_id=provider_session_id,
+        title=f"Hermes verification evidence: {correlation_key or 'missing identity'}",
+        created_at=created,
+        updated_at=updated,
+        messages=messages,
+        session_events=events,
+        ingest_flags=flags,
+    )
+
+
+def _normalize_row(value: JSONValue, *, source_index: int, export_id: str) -> _NormalizedRow:
+    row = json_document(value)
+    if not row:
+        malformed_evidence_id = (
+            f"malformed-{hash_payload({'export_id': export_id, 'source_index': source_index, 'row': value})[:24]}"
+        )
+        return _NormalizedRow(
+            source_index=source_index,
+            evidence_id=malformed_evidence_id,
+            row_state=HermesVerificationRowState.MALFORMED,
+            target_session_native_id=None,
+            target_session_id=None,
+            command=None,
+            canonical_command=None,
+            kind=None,
+            scope=None,
+            status=None,
+            exit_code=None,
+            is_error=None,
+            output_summary=None,
+            changed_paths=None,
+            observed_at=None,
+        )
+
+    invalid = False
+    evidence_id = _optional_string(row.get("evidence_id"))
+    if evidence_id is None:
+        invalid = True
+        evidence_id = f"row-{hash_payload({'export_id': export_id, 'source_index': source_index, 'row': row})[:24]}"
+
+    target_session_native_id, invalid_native = _string_field(row, "session_native_id")
+    target_session_id, invalid_session = _string_field(row, "session_id")
+    command, invalid_command = _string_field(row, "command")
+    canonical_command, invalid_canonical = _string_field(row, "canonical_command")
+    kind, invalid_kind = _token_field(row, "kind")
+    scope, invalid_scope = _token_field(row, "scope")
+    status, invalid_status = _token_field(row, "status")
+    output_summary, invalid_summary = _string_field(row, "output_summary")
+    observed_at, invalid_timestamp = _string_field(row, "observed_at")
+    changed_paths, invalid_paths = _changed_paths(row)
+    exit_code, invalid_exit = _exit_code(row)
+
+    invalid = invalid or any(
+        (
+            invalid_native,
+            invalid_session,
+            invalid_command,
+            invalid_canonical,
+            invalid_kind,
+            invalid_scope,
+            invalid_status,
+            invalid_summary,
+            invalid_timestamp,
+            invalid_paths,
+            invalid_exit,
+        )
+    )
+    invalid = invalid or any(row.get(field) is None for field in _CORE_FIELDS)
+
+    is_error = _structural_is_error(status=status, exit_code=exit_code)
+    conflict = _outcome_conflicts(status=status, exit_code=exit_code)
+    row_state = (
+        HermesVerificationRowState.OUTCOME_CONFLICT
+        if conflict
+        else HermesVerificationRowState.PARTIAL
+        if invalid
+        else HermesVerificationRowState.COMPLETE
+    )
+    return _NormalizedRow(
+        source_index=source_index,
+        evidence_id=evidence_id,
+        row_state=row_state,
+        target_session_native_id=target_session_native_id,
+        target_session_id=target_session_id,
+        command=command,
+        canonical_command=canonical_command,
+        kind=kind,
+        scope=scope,
+        status=status,
+        exit_code=exit_code,
+        is_error=is_error,
+        output_summary=output_summary,
+        changed_paths=changed_paths,
+        observed_at=observed_at,
+    )
+
+
+def _event_payload(row: _NormalizedRow, *, export_id: str) -> dict[str, object]:
+    return {
+        "export_id": export_id,
+        "source_index": row.source_index,
+        "evidence_id": row.evidence_id,
+        "row_state": row.row_state.value,
+        "target_session_native_id": row.target_session_native_id,
+        "target_session_id": row.target_session_id,
+        "command": row.command,
+        "canonical_command": row.canonical_command,
+        "kind": row.kind,
+        "scope": row.scope,
+        "status": row.status,
+        "exit_code": row.exit_code,
+        "output_summary": row.output_summary,
+        "changed_paths": None if row.changed_paths is None else list(row.changed_paths),
+        "observed_at": row.observed_at,
+    }
+
+
+def _artifact_payload(payload: JSONDocument, *, export_id: str) -> dict[str, object]:
+    return {
+        "schema_version": VERIFICATION_EXPORT_SCHEMA,
+        "artifact_kind": VERIFICATION_ARTIFACT_KIND,
+        "export_id": export_id,
+        "source_artifact": _optional_string(payload.get("source_artifact")),
+        "source_sha256": _optional_string(payload.get("source_sha256")),
+        "producer_schema_version": _optional_string(payload.get("producer_schema_version")),
+        "fixture_provenance": _optional_string(payload.get("fixture_provenance")),
+    }
+
+
+def _optional_string(value: object) -> str | None:
+    if not isinstance(value, str):
+        return None
+    candidate = value.strip()
+    return candidate or None
+
+
+def _string_field(row: Mapping[str, object], key: str) -> tuple[str | None, bool]:
+    if key not in row or row.get(key) is None:
+        return None, False
+    value = _optional_string(row.get(key))
+    return value, value is None
+
+
+def _token_field(row: Mapping[str, object], key: str) -> tuple[str | None, bool]:
+    value, invalid = _string_field(row, key)
+    if value is None:
+        return None, invalid
+    return value.lower().replace("-", "_").replace(" ", "_"), False
+
+
+def _exit_code(row: Mapping[str, object]) -> tuple[int | None, bool]:
+    if "exit_code" not in row or row.get("exit_code") is None:
+        return None, False
+    value = row.get("exit_code")
+    if isinstance(value, int) and not isinstance(value, bool):
+        return value, False
+    return None, True
+
+
+def _changed_paths(row: Mapping[str, object]) -> tuple[tuple[str, ...] | None, bool]:
+    if "changed_paths" not in row or row.get("changed_paths") is None:
+        return None, False
+    raw = row.get("changed_paths")
+    if not isinstance(raw, list):
+        return None, True
+    paths: list[str] = []
+    invalid = False
+    for value in raw:
+        path = _optional_string(value)
+        if path is None:
+            invalid = True
+            continue
+        paths.append(path)
+    return tuple(dict.fromkeys(paths)), invalid
+
+
+def _status_outcome(status: str | None) -> bool | None:
+    if status in _SUCCESS_STATUSES:
+        return False
+    if status in _FAILURE_STATUSES:
+        return True
+    return None
+
+
+def _structural_is_error(*, status: str | None, exit_code: int | None) -> bool | None:
+    if exit_code is not None:
+        return exit_code != 0
+    return _status_outcome(status)
+
+
+def _outcome_conflicts(*, status: str | None, exit_code: int | None) -> bool:
+    status_outcome = _status_outcome(status)
+    return exit_code is not None and status_outcome is not None and status_outcome != (exit_code != 0)
+
+
+__all__ = [
+    "VERIFICATION_ARTIFACT_EVENT_TYPE",
+    "VERIFICATION_ARTIFACT_KIND",
+    "VERIFICATION_EVENT_TYPE",
+    "VERIFICATION_EXPORT_SCHEMA",
+    "import_fidelity_declaration",
+    "looks_like_verification_evidence_payload",
+    "parse_verification_evidence_document",
+]
