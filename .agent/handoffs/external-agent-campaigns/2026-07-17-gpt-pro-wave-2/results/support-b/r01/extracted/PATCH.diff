@@ -0,0 +1,293 @@
+"""Hermes verification-ledger boundary, normalization, and query tests."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+from collections.abc import AsyncIterator
+from pathlib import Path
+
+import pytest
+
+from polylogue.archive.artifact_taxonomy import ArtifactKind, classify_artifact, classify_artifact_path
+from polylogue.archive.message.roles import Role
+from polylogue.archive.session.hermes_verification import (
+    HermesVerificationCorrelationState,
+    HermesVerificationRowState,
+)
+from polylogue.config import Config, Source
+from polylogue.core.enums import Provider
+from polylogue.pipeline.services.acquisition import AcquisitionService
+from polylogue.pipeline.services.parsing import ParsingService
+from polylogue.sources.dispatch import detect_provider, parse_payload
+from polylogue.sources.import_explain import explain_import_path
+from polylogue.sources.parsers import hermes_verification
+from polylogue.sources.parsers.base import ParsedMessage, ParsedSession
+from polylogue.sources.source_parsing import parse_one_source_path
+from polylogue.storage.blob_store import BlobStore
+from polylogue.storage.repository import SessionRepository
+from polylogue.storage.sqlite.async_sqlite import SQLiteBackend
+from tests.infra.live_ingest import ingest_session
+
+FIXTURE = Path("tests/fixtures/hermes/verification_evidence/synthetic-v1.json")
+
+
+@pytest.fixture
+async def async_backend(test_db: Path) -> AsyncIterator[SQLiteBackend]:
+    backend = SQLiteBackend(db_path=test_db)
+    yield backend
+    await backend.close()
+
+
+def _payload() -> dict[str, object]:
+    payload = json.loads(FIXTURE.read_text(encoding="utf-8"))
+    assert isinstance(payload, dict)
+    return payload
+
+
+def _target_session() -> ParsedSession:
+    return ParsedSession(
+        source_name=Provider.HERMES,
+        provider_session_id="session-a@profile-profile-a",
+        title="Synthetic target session",
+        created_at="2026-07-17T11:00:00Z",
+        updated_at="2026-07-17T11:00:00Z",
+        messages=[
+            ParsedMessage(
+                provider_message_id="target-message",
+                role=Role.USER,
+                text="synthetic target",
+                timestamp="2026-07-17T11:00:00Z",
+            )
+        ],
+    )
+
+
+def test_artifact_boundary_distinguishes_sqlite_sidecar_from_versioned_export(tmp_path: Path) -> None:
+    sqlite_sidecar = classify_artifact_path(
+        tmp_path / "verification_evidence.db",
+        provider=Provider.HERMES,
+    )
+    assert sqlite_sidecar is not None
+    assert sqlite_sidecar.kind is ArtifactKind.VERIFICATION_EVIDENCE
+    assert sqlite_sidecar.parse_as_session is False
+    assert sqlite_sidecar.schema_eligible is False
+    assert "requires versioned JSON acquisition export" in sqlite_sidecar.reason
+
+    payload = _payload()
+    exported = classify_artifact(payload, provider=Provider.HERMES, source_path=FIXTURE)
+    assert exported.kind is ArtifactKind.VERIFICATION_EVIDENCE
+    assert exported.parse_as_session is True
+    assert detect_provider(payload) is Provider.HERMES
+
+
+def test_raw_file_reaches_shared_dispatch_and_preserves_synthetic_provenance(tmp_path: Path) -> None:
+    source = tmp_path / "verification-export.json"
+    source.write_bytes(FIXTURE.read_bytes())
+
+    emitted = list(
+        parse_one_source_path(
+            str(source),
+            file_mtime="2026-07-17T12:06:00Z",
+            source_name=Provider.HERMES.value,
+            sidecar_data={},
+            capture_raw=True,
+            blob_root=tmp_path / "blobs",
+        )
+    )
+
+    assert len(emitted) == 3
+    assert all(raw is not None for raw, _session in emitted)
+    expected_hash = hashlib.sha256(FIXTURE.read_bytes()).hexdigest()
+    assert all(raw is not None and raw.source_path == str(source) for raw, _session in emitted)
+    assert all(raw is not None and raw.blob_hash == expected_hash for raw, _session in emitted)
+    assert all(raw is not None and raw.blob_size == source.stat().st_size for raw, _session in emitted)
+    assert BlobStore(tmp_path / "blobs").read_all(expected_hash) == FIXTURE.read_bytes()
+    assert all("hermes:verification-evidence" in session.ingest_flags for _raw, session in emitted)
+    artifact_events = [
+        event
+        for _raw, session in emitted
+        for event in session.session_events
+        if event.event_type == hermes_verification.VERIFICATION_ARTIFACT_EVENT_TYPE
+    ]
+    assert len(artifact_events) == 3
+    assert all(
+        event.payload["fixture_provenance"] == "synthetic; no real Hermes producer bytes" for event in artifact_events
+    )
+    assert all(event.payload["source_sha256"] is None for event in artifact_events)
+
+
+def test_import_explain_declares_synthetic_fidelity_without_real_byte_claims() -> None:
+    [entry] = explain_import_path(FIXTURE, source_name=Provider.HERMES.value).entries
+
+    assert entry.artifact_kind == ArtifactKind.VERIFICATION_EVIDENCE.value
+    assert entry.produced.sessions == 3
+    assert entry.produced.actions == 6
+    assert entry.fidelity is not None
+    assert entry.fidelity.acquisition_method == "verification_evidence_json_export"
+    assert entry.fidelity.retained_blob_reproducibility.status == "exact"
+    assert entry.fidelity.capabilities["artifact_identity"].status == "inferred"
+    assert entry.fidelity.capabilities["session_correlation"].status == "degraded"
+    assert entry.fidelity.capabilities["row_quality"].counts == {
+        "malformed": 1,
+        "partial": 1,
+        "outcome_conflict": 1,
+    }
+    assert all(capability.status != "exact" for capability in entry.fidelity.capabilities.values())
+    assert any("no real ~/.hermes" in caveat for caveat in entry.caveats)
+
+
+def test_parser_is_deterministic_and_retains_partial_malformed_and_missing_identity_rows() -> None:
+    payload = _payload()
+    first = parse_payload(Provider.HERMES, payload, "fallback")
+    second = parse_payload(Provider.HERMES, payload, "fallback")
+    assert [session.model_dump(mode="json") for session in first] == [
+        session.model_dump(mode="json") for session in second
+    ]
+
+    events = [
+        event
+        for session in first
+        for event in session.session_events
+        if event.event_type == hermes_verification.VERIFICATION_EVENT_TYPE
+    ]
+    by_id = {event.payload["evidence_id"]: event for event in events}
+    assert len(events) == 7
+    assert by_id["verify-running-003"].payload["row_state"] == HermesVerificationRowState.PARTIAL.value
+    assert by_id["verify-running-003"].payload["changed_paths"] is None
+    assert by_id["verify-missing-identity-006"].payload["target_session_id"] is None
+
+    malformed = [event for event in events if event.payload["row_state"] == HermesVerificationRowState.MALFORMED.value]
+    assert len(malformed) == 1
+    assert malformed[0].source_message_provider_id is None
+    assert malformed[0].payload["command"] is None
+
+    fidelity = hermes_verification.import_fidelity_declaration(first)
+    assert fidelity.capabilities["artifact_identity"].status == "inferred"
+    assert fidelity.capabilities["session_correlation"].status == "degraded"
+    assert all(capability.status != "exact" for capability in fidelity.capabilities.values())
+    assert "no real ~/.hermes" in fidelity.caveats[0]
+
+
+async def test_end_to_end_replay_outcomes_correlation_and_typed_query(
+    async_backend: SQLiteBackend, tmp_path: Path
+) -> None:
+    target_id = await ingest_session(_target_session(), async_backend)
+    assert target_id == "hermes-session:session-a@profile-profile-a"
+
+    source = tmp_path / "verification-export.json"
+    source.write_bytes(FIXTURE.read_bytes())
+    source_config = Source(name=Provider.HERMES.value, path=source)
+    config = Config(
+        archive_root=tmp_path,
+        render_root=tmp_path / "render",
+        sources=[source_config],
+    )
+    acquired = await AcquisitionService(backend=async_backend).acquire_sources([source_config])
+    assert acquired.acquired == 1
+    assert len(acquired.raw_ids) == 1
+    [raw_id] = acquired.raw_ids
+    stored_raw = await async_backend.get_raw_session(raw_id)
+    assert stored_raw is not None
+    assert stored_raw.blob_hash == hashlib.sha256(FIXTURE.read_bytes()).hexdigest()
+    assert stored_raw.blob_size == FIXTURE.stat().st_size
+    assert BlobStore(tmp_path / "blob").read_all(stored_raw.blob_hash) == FIXTURE.read_bytes()
+
+    parser = ParsingService(
+        repository=SessionRepository(backend=async_backend),
+        archive_root=tmp_path,
+        config=config,
+        ingest_workers=1,
+    )
+    first_parse = await parser.parse_from_raw(raw_ids=acquired.raw_ids)
+    assert first_parse.parse_failures == 0
+    assert first_parse.counts["sessions"] == 3
+    first_observer_ids = sorted(first_parse.processed_ids)
+    first = await async_backend.get_hermes_verification_evidence()
+
+    async with async_backend.connection() as conn:
+        first_counts = {
+            table: int((await (await conn.execute(f"SELECT COUNT(*) FROM {table}")).fetchone())[0])
+            for table in ("sessions", "messages", "blocks", "session_events", "actions")
+        }
+
+    second_parse = await parser.parse_from_raw(raw_ids=acquired.raw_ids)
+    assert second_parse.parse_failures == 0
+    second = await async_backend.get_hermes_verification_evidence()
+    async with async_backend.connection() as conn:
+        second_counts = {
+            table: int((await (await conn.execute(f"SELECT COUNT(*) FROM {table}")).fetchone())[0])
+            for table in ("sessions", "messages", "blocks", "session_events", "actions")
+        }
+
+    assert len(first_observer_ids) == 3
+    assert second_parse.processed_ids == set()
+    assert second_counts == first_counts
+    assert [item.model_dump(mode="json") for item in second] == [item.model_dump(mode="json") for item in first]
+
+    by_id = {item.evidence_id: item for item in second}
+    passed = by_id["verify-pass-001"]
+    assert passed.correlation_state is HermesVerificationCorrelationState.MATCHED
+    assert passed.target_session_native_id == "session-a@profile-profile-a"
+    assert passed.target_raw_session_id == "session-a"
+    assert str(passed.target_session_id) == target_id
+    assert passed.command == "pytest -q tests/unit/test_widget.py"
+    assert passed.canonical_command == "pytest tests/unit/test_widget.py -q"
+    assert passed.kind == "test"
+    assert passed.scope == "repository"
+    assert passed.status == "passed"
+    assert passed.exit_code == 0
+    assert passed.is_error is False
+    assert passed.output_summary == "1 passed"
+    assert passed.changed_paths == ("tests/unit/test_widget.py",)
+
+    failed = by_id["verify-fail-002"]
+    assert failed.exit_code == 2
+    assert failed.is_error is True
+
+    unknown = by_id["verify-running-003"]
+    assert unknown.row_state is HermesVerificationRowState.PARTIAL
+    assert unknown.status == "running"
+    assert unknown.canonical_command is None
+    assert unknown.exit_code is None
+    assert unknown.is_error is None
+    assert unknown.changed_paths is None
+
+    conflict = by_id["verify-conflict-004"]
+    assert conflict.row_state is HermesVerificationRowState.OUTCOME_CONFLICT
+    assert conflict.status == "passed"
+    assert conflict.exit_code == 1
+    assert conflict.is_error is True
+
+    unmatched = by_id["verify-unmatched-005"]
+    assert unmatched.correlation_state is HermesVerificationCorrelationState.UNMATCHED_IDENTITY
+    assert unmatched.target_raw_session_id == "missing-session"
+    assert unmatched.target_session_id is None
+    assert unmatched.status == "skipped"
+    assert unmatched.exit_code is None
+    assert unmatched.is_error is None
+    assert unmatched.changed_paths == ()
+
+    missing = by_id["verify-missing-identity-006"]
+    assert missing.correlation_state is HermesVerificationCorrelationState.MISSING_IDENTITY
+    assert missing.target_session_native_id is None
+    assert missing.target_raw_session_id is None
+    assert missing.target_session_id is None
+    assert missing.status == "success"
+    assert missing.exit_code is None
+    assert missing.is_error is False
+
+    malformed = [item for item in second if item.row_state is HermesVerificationRowState.MALFORMED]
+    assert len(malformed) == 1
+    assert malformed[0].source_message_id is None
+    assert malformed[0].command is None
+    assert malformed[0].is_error is None
+
+    repository = SessionRepository(backend=async_backend)
+    matched_only = await repository.get_hermes_verification_evidence(target_session_id=target_id)
+    assert {item.evidence_id for item in matched_only} == {
+        "verify-pass-001",
+        "verify-fail-002",
+        "verify-running-003",
+        "verify-conflict-004",
+    }
