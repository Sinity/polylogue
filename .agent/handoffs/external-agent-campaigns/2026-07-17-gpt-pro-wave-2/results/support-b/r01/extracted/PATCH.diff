index 0000000000000000000000000000000000000000..3db1f95ff383289ece74d108fe7cdc02ef47a3f1
--- /dev/null
+++ b/polylogue/archive/session/hermes_verification.py
@@ -0,0 +1,67 @@
+"""Typed Hermes verification-evidence read models."""
+
+from __future__ import annotations
+
+from datetime import datetime
+from enum import StrEnum
+
+from pydantic import BaseModel, ConfigDict
+
+from polylogue.core.types import MessageId, SessionEventId, SessionId
+
+
+class HermesVerificationCorrelationState(StrEnum):
+    """Read-side correlation between evidence and an archived Hermes session."""
+
+    MATCHED = "matched"
+    MISSING_IDENTITY = "missing_identity"
+    UNMATCHED_IDENTITY = "unmatched_identity"
+    AMBIGUOUS_IDENTITY = "ambiguous_identity"
+
+
+class HermesVerificationRowState(StrEnum):
+    """Parser-visible quality of one producer row."""
+
+    COMPLETE = "complete"
+    PARTIAL = "partial"
+    MALFORMED = "malformed"
+    OUTCOME_CONFLICT = "outcome_conflict"
+
+
+class HermesVerificationEvidence(BaseModel):
+    """One normalized Hermes verification ledger row.
+
+    ``None`` is preserved for every field the producer/export boundary did not
+    establish. In particular, unknown outcome state is never reconstructed by
+    scanning ``output_summary`` text.
+    """
+
+    model_config = ConfigDict(frozen=True)
+
+    evidence_id: str
+    observer_session_id: SessionId
+    observer_event_id: SessionEventId
+    source_message_id: MessageId | None = None
+    source_index: int
+    row_state: HermesVerificationRowState
+    correlation_state: HermesVerificationCorrelationState
+    target_session_native_id: str | None = None
+    target_raw_session_id: str | None = None
+    target_session_id: SessionId | None = None
+    command: str | None = None
+    canonical_command: str | None = None
+    kind: str | None = None
+    scope: str | None = None
+    status: str | None = None
+    exit_code: int | None = None
+    is_error: bool | None = None
+    output_summary: str | None = None
+    changed_paths: tuple[str, ...] | None = None
+    observed_at: datetime | None = None
+
+
+__all__ = [
+    "HermesVerificationCorrelationState",
+    "HermesVerificationEvidence",
+    "HermesVerificationRowState",
+]
