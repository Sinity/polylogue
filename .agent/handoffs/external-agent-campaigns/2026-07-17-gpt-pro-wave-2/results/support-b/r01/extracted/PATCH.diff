+def _looks_like_hermes_verification_export(path: Path, provider: Provider) -> bool:
+    """Identify the versioned JSON envelope without materializing its rows.
+
+    This acquisition-side sniff exists only to decide whether the exact source
+    artifact must be retained before normal dispatch.  The parser remains the
+    authority for validation and normalization.
+    """
