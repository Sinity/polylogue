+    identity = target_session_native_id or target_raw_session_id
+    if identity is None:
+        return HermesVerificationCorrelationState.MISSING_IDENTITY, None
+
+    native_id = _candidate_native_id(identity)
+    exact = sessions_by_native_id.get(native_id)
+    if exact is not None:
+        return HermesVerificationCorrelationState.MATCHED, SessionId(exact)
+
+    if "@profile-" in native_id:
+        return HermesVerificationCorrelationState.UNMATCHED_IDENTITY, None
+
+    prefix = f"{native_id}@profile-"
+    candidates = sorted(
+        session_id
+        for candidate_native_id, session_id in sessions_by_native_id.items()
+        if candidate_native_id.startswith(prefix)
+    )
+    if len(candidates) == 1:
+        return HermesVerificationCorrelationState.MATCHED, SessionId(candidates[0])
+    if len(candidates) > 1:
+        return HermesVerificationCorrelationState.AMBIGUOUS_IDENTITY, None
+    return HermesVerificationCorrelationState.UNMATCHED_IDENTITY, None
+
+
+async def get_hermes_verification_evidence(
+    conn: aiosqlite.Connection,
+    *,
+    observer_session_id: str | None = None,
+    target_session_id: str | None = None,
+) -> list[HermesVerificationEvidence]:
+    """Read normalized verification rows through events plus ``actions``.
+
+    The paired action row is the authority for command/output/is_error/exit
+    code, preserving the archive-wide structural outcome convention. Session
+    correlation is computed from producer-positive identity only and fails
+    closed for missing, zero-match, or multi-profile matches.
+    """
+
+    clauses = ["se.event_type = 'hermes_verification_evidence'"]
+    params: list[object] = []
+    if observer_session_id is not None:
+        clauses.append("se.session_id = ?")
+        params.append(observer_session_id)
+    evidence_rows = await (
+        await conn.execute(
+            f"""
+            SELECT
+                se.event_id,
+                se.session_id AS observer_session_id,
+                se.source_message_id,
+                se.position,
+                se.payload_json,
+                se.occurred_at_ms,
+                a.tool_command,
+                a.output_text,
+                a.is_error,
+                a.exit_code
+            FROM session_events AS se
+            LEFT JOIN actions AS a
+              ON a.message_id = se.source_message_id
+             AND a.tool_name = 'hermes_verification'
+            WHERE {" AND ".join(clauses)}
+            ORDER BY se.session_id, se.position
+            """,
+            tuple(params),
+        )
+    ).fetchall()
+
+    session_rows = await (
+        await conn.execute(
+            """
+            SELECT session_id, native_id
+            FROM sessions
+            WHERE origin = 'hermes-session'
+              AND native_id NOT LIKE 'observer:%'
+              AND native_id NOT LIKE 'verification:%'
+            ORDER BY native_id
+            """
+        )
+    ).fetchall()
+    sessions_by_native_id = {str(row["native_id"]): str(row["session_id"]) for row in session_rows}
+
+    evidence: list[HermesVerificationEvidence] = []
+    for row in evidence_rows:
+        payload = _payload(row["payload_json"])
+        target_native_id = _optional_text(payload.get("target_session_native_id"))
+        target_raw_id = _optional_text(payload.get("target_session_id"))
+        correlation_state, resolved_target_id = _correlate_verification_identity(
+            target_session_native_id=target_native_id,
+            target_raw_session_id=target_raw_id,
+            sessions_by_native_id=sessions_by_native_id,
+        )
+        if target_session_id is not None and str(resolved_target_id or "") != target_session_id:
+            continue
+        source_message_id = row["source_message_id"]
+        row_state_value = _optional_text(payload.get("row_state")) or HermesVerificationRowState.MALFORMED.value
+        evidence.append(
+            HermesVerificationEvidence(
+                evidence_id=_optional_text(payload.get("evidence_id")) or f"event:{row['event_id']}",
+                observer_session_id=SessionId(str(row["observer_session_id"])),
+                observer_event_id=SessionEventId(str(row["event_id"])),
+                source_message_id=MessageId(str(source_message_id)) if source_message_id is not None else None,
+                source_index=_optional_int(payload.get("source_index")) or 0,
+                row_state=HermesVerificationRowState(row_state_value),
+                correlation_state=correlation_state,
+                target_session_native_id=target_native_id,
+                target_raw_session_id=target_raw_id,
+                target_session_id=resolved_target_id,
+                command=_optional_text(row["tool_command"]),
+                canonical_command=_optional_text(payload.get("canonical_command")),
+                kind=_optional_text(payload.get("kind")),
+                scope=_optional_text(payload.get("scope")),
+                status=_optional_text(payload.get("status")),
+                exit_code=_optional_int(row["exit_code"]),
+                is_error=_optional_bool(row["is_error"]),
+                output_summary=_optional_text(row["output_text"]),
+                changed_paths=_changed_paths(payload.get("changed_paths")),
+                observed_at=(
+                    datetime.fromtimestamp(int(row["occurred_at_ms"]) / 1000.0, tz=timezone.utc)
+                    if row["occurred_at_ms"] is not None
+                    else None
+                ),
+            )
+        )
+    return evidence
+
+
