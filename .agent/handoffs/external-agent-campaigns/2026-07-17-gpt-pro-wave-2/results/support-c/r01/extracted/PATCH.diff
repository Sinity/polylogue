@@ -0,0 +1,443 @@
+"""Cross-surface certification for the canonical resumable read transaction."""
+
+from __future__ import annotations
+
+import json
+import threading
+from collections.abc import Iterator
+from contextlib import contextmanager
+from http import HTTPStatus
+from pathlib import Path
+from types import SimpleNamespace
+from typing import cast
+from unittest.mock import patch
+from urllib.error import HTTPError
+from urllib.parse import quote
+from urllib.request import Request, urlopen
+
+import pytest
+
+from polylogue.api import Polylogue
+from polylogue.archive.message.roles import Role
+from polylogue.archive.query.expression import parse_unit_source_expression
+from polylogue.archive.query.transaction import (
+    QueryContinuation,
+    QueryContinuationError,
+    QueryContinuationExpiredError,
+    QueryContinuationStaleError,
+    QueryExecutionLimits,
+    QueryTransactionBudgetExceededError,
+    QueryTransactionDeadlineExceededError,
+    QueryTransactionExecutionError,
+)
+from polylogue.core.enums import BlockType, Provider
+from polylogue.core.identity_law import message_id as archive_message_id
+from polylogue.mcp.server_support import MCP_RESPONSE_BUDGET_BYTES
+from polylogue.sources.parsers.base import ParsedContentBlock, ParsedMessage, ParsedSession
+from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore
+from polylogue.surfaces.payloads import MessageQueryRowPayload
+from tests.infra.mcp import MCPServerUnderTest, invoke_surface, invoke_surface_async
+
+pytestmark = pytest.mark.xdist_group("query-transaction-certification")
+
+
+@contextmanager
+def _running_http_server() -> Iterator[str]:
+    from polylogue.daemon.http import DaemonAPIHandler, DaemonAPIHTTPServer
+
+    server = DaemonAPIHTTPServer(("127.0.0.1", 0), DaemonAPIHandler)
+    server.auth_token = ""
+    server.api_host = "127.0.0.1"
+    thread = threading.Thread(target=server.serve_forever, name="query-transaction-http", daemon=True)
+    thread.start()
+    try:
+        yield f"http://127.0.0.1:{server.server_address[1]}"
+    finally:
+        server.shutdown()
+        server.server_close()
+        thread.join(timeout=2.0)
+
+
+def _http_json(base_url: str, path: str) -> tuple[int, dict[str, object]]:
+    request = Request(f"{base_url}{path}")
+    try:
+        with urlopen(request, timeout=10) as response:
+            return response.status, cast(dict[str, object], json.loads(response.read()))
+    except HTTPError as exc:
+        return exc.code, cast(dict[str, object], json.loads(exc.read()))
+
+
+def _seed_overflow_corpus(archive_root: Path, *, members: int = 20, start: int = 0) -> list[str]:
+    expected: list[str] = []
+    with ArchiveStore(archive_root) as archive:
+        for index in range(start, start + members):
+            native_id = f"transaction-certification-{index:03d}"
+            native_message_id = f"transaction-message-{index:03d}"
+            minute, second = divmod(index, 60)
+            timestamp = f"2026-01-01T00:{minute:02d}:{second:02d}+00:00"
+            text = f"certificationneedle member-{index:03d} " + ("x" * 3500)
+            session_id = archive.write_parsed(
+                ParsedSession(
+                    source_name=Provider.CODEX,
+                    provider_session_id=native_id,
+                    title=f"Transaction certification {index:03d}",
+                    created_at=timestamp,
+                    updated_at=timestamp,
+                    messages=[
+                        ParsedMessage(
+                            provider_message_id=native_message_id,
+                            role=Role.USER,
+                            text=text,
+                            timestamp=timestamp,
+                            blocks=[ParsedContentBlock(type=BlockType.TEXT, text=text)],
+                        )
+                    ],
+                )
+            )
+            expected.append(archive_message_id(session_id, native_message_id, position=0))
+    return expected
+
+
+def _page_member_ids(page: dict[str, object]) -> list[str]:
+    items = cast(list[dict[str, object]], page["items"])
+    return [str(item["message_id"]) for item in items]
+
+
+def _mcp_page(payload: dict[str, object]) -> tuple[dict[str, object], str | None]:
+    if payload.get("status") == "response_budget_exceeded":
+        page = cast(dict[str, object], payload["page"])
+        continuation = cast(dict[str, object], payload["continuation"])
+        arguments = cast(dict[str, object], continuation["arguments"])
+        return page, str(arguments["continuation"])
+    return payload, cast(str | None, payload.get("continuation"))
+
+
+def _tamper(token: str) -> str:
+    position = len(token) // 2
+    replacement = "A" if token[position] != "A" else "B"
+    return token[:position] + replacement + token[position + 1 :]
+
+
+@pytest.mark.asyncio
+async def test_overflowing_corpus_exhausts_losslessly_through_api_mcp_and_http(
+    workspace_env: dict[str, Path],
+    mcp_server: MCPServerUnderTest,
+) -> None:
+    """Exercise production grammar, SQL, transaction, MCP budget, API, and HTTP routes.
+
+    Anti-vacuity: reducing the corpus text below the MCP byte budget, removing
+    cursor rebasing, or changing any adapter to reconstruct filters/offsets
+    makes the explicit overflow and ordered-member assertions fail.
+    """
+
+    archive_root = workspace_env["archive_root"]
+    expected = _seed_overflow_corpus(archive_root)
+    expression = "messages where text:certificationneedle | sort by time asc"
+
+    discovery_raw = invoke_surface(mcp_server._resource_manager._resources["polylogue://capabilities/query"].fn)
+    discovery = cast(dict[str, object], json.loads(discovery_raw))
+    for unit in cast(list[dict[str, object]], discovery["units"]):
+        example = str(unit["example"])
+        assert parse_unit_source_expression(example) is not None, example
+
+    api = Polylogue(archive_root=archive_root)
+    api_first = await api.query_units(expression, limit=9)
+    api_ids: list[str] = []
+    api_refs: set[tuple[str | None, str | None]] = set()
+    api_window: tuple[int, int | None] | None = None
+    api_page = api_first
+    api_first_cursor = api_first.continuation
+    while True:
+        api_ids.extend(item.message_id for item in cast(tuple[MessageQueryRowPayload, ...], api_page.items))
+        api_refs.add((api_page.query_ref, api_page.result_ref))
+        if api_page.continuation is None:
+            break
+        cursor_state = QueryContinuation.decode(api_page.continuation)
+        window = (cursor_state.issued_at_ms, cursor_state.expires_at_ms)
+        api_window = window if api_window is None else api_window
+        assert window == api_window
+        api_page = await api.query_units(continuation=api_page.continuation)
+
+    assert len(api_first.items) == 9
+    assert api_first_cursor is not None
+    assert api_first_cursor.startswith("q2.")
+
+    with (
+        patch("polylogue.mcp.server._get_config") as mock_get_config,
+        patch("polylogue.mcp.server._get_polylogue") as mock_get_polylogue,
+    ):
+        mock_get_config.return_value = SimpleNamespace(
+            archive_root=archive_root,
+            db_path=archive_root / "index.db",
+        )
+        mock_get_polylogue.side_effect = AssertionError("query_units must use the shared archive transaction")
+        mcp_raw = cast(
+            str,
+            await invoke_surface_async(
+                mcp_server._tool_manager._tools["query_units"].fn,
+                expression=expression,
+                limit=9,
+            ),
+        )
+        mcp_payload = cast(dict[str, object], json.loads(mcp_raw))
+        assert mcp_payload["status"] == "response_budget_exceeded"
+        original_bytes = mcp_payload["original_bytes"]
+        returned_items = mcp_payload["returned_items"]
+        assert isinstance(original_bytes, int) and original_bytes > MCP_RESPONSE_BUDGET_BYTES
+        assert isinstance(returned_items, int) and 0 < returned_items < 9
+
+        mcp_ids: list[str] = []
+        mcp_refs: set[tuple[str, str]] = set()
+        mcp_window: tuple[int, int | None] | None = None
+        for _ in range(100):
+            page, cursor = _mcp_page(mcp_payload)
+            mcp_ids.extend(_page_member_ids(page))
+            mcp_refs.add((str(page["query_ref"]), str(page["result_ref"])))
+            if cursor is None:
+                break
+            cursor_state = QueryContinuation.decode(cursor)
+            window = (cursor_state.issued_at_ms, cursor_state.expires_at_ms)
+            mcp_window = window if mcp_window is None else mcp_window
+            assert window == mcp_window
+            mcp_raw = cast(
+                str,
+                await invoke_surface_async(
+                    mcp_server._tool_manager._tools["query_units"].fn,
+                    continuation=cursor,
+                ),
+            )
+            mcp_payload = cast(dict[str, object], json.loads(mcp_raw))
+        else:
+            pytest.fail("MCP continuation did not exhaust")
+
+    http_ids: list[str] = []
+    http_refs: set[tuple[str, str]] = set()
+    http_window: tuple[int, int | None] | None = None
+    with _running_http_server() as base_url:
+        path = f"/api/query-units?expression={quote(expression, safe='')}&limit=9"
+        http_first: dict[str, object] | None = None
+        for _ in range(100):
+            status, page = _http_json(base_url, path)
+            assert status == HTTPStatus.OK
+            if http_first is None:
+                http_first = page
+            http_ids.extend(_page_member_ids(page))
+            http_refs.add((str(page["query_ref"]), str(page["result_ref"])))
+            cursor = cast(str | None, page.get("continuation"))
+            if cursor is None:
+                break
+            cursor_state = QueryContinuation.decode(cursor)
+            window = (cursor_state.issued_at_ms, cursor_state.expires_at_ms)
+            http_window = window if http_window is None else http_window
+            assert window == http_window
+            path = f"/api/query-units?continuation={quote(cursor, safe='')}"
+        else:
+            pytest.fail("HTTP continuation did not exhaust")
+
+    assert http_first is not None
+    assert len(cast(list[object], http_first["items"])) == 9
+    assert http_first["continuation"] is not None
+    assert api_ids == mcp_ids == http_ids == expected
+    assert len(api_ids) == len(set(api_ids))
+    assert len(api_refs) == len(mcp_refs) == len(http_refs) == 1
+    assert api_refs == mcp_refs == http_refs
+
+    assert api_first_cursor is not None
+    with (
+        patch("polylogue.mcp.server._get_config") as mock_get_config,
+        patch("polylogue.mcp.server._get_polylogue") as mock_get_polylogue,
+    ):
+        mock_get_config.return_value = SimpleNamespace(
+            archive_root=archive_root,
+            db_path=archive_root / "index.db",
+        )
+        mock_get_polylogue.side_effect = AssertionError("cross-surface resume must stay on the transaction")
+        cross_mcp = json.loads(
+            cast(
+                str,
+                await invoke_surface_async(
+                    mcp_server._tool_manager._tools["query_units"].fn,
+                    continuation=api_first_cursor,
+                ),
+            )
+        )
+    cross_mcp_page, _ = _mcp_page(cast(dict[str, object], cross_mcp))
+    assert cross_mcp_page["offset"] == 9
+    assert cross_mcp_page["result_ref"] == api_first.result_ref
+
+    with _running_http_server() as base_url:
+        cross_status, cross_http = _http_json(
+            base_url,
+            f"/api/query-units?continuation={quote(api_first_cursor, safe='')}",
+        )
+    assert cross_status == HTTPStatus.OK
+    assert cross_http["offset"] == 9
+    assert cross_http["result_ref"] == api_first.result_ref
+
+    decoded = QueryContinuation.decode(api_first_cursor)
+    expired = QueryContinuation(
+        request=decoded.request,
+        result_ref=decoded.result_ref,
+        issued_at_ms=1,
+        expires_at_ms=2,
+    ).encode()
+    tampered = _tamper(api_first_cursor)
+
+    with pytest.raises(QueryContinuationExpiredError):
+        await api.query_units(continuation=expired)
+    with pytest.raises(QueryContinuationError):
+        await api.query_units(continuation=tampered)
+
+    with (
+        patch("polylogue.mcp.server._get_config") as mock_get_config,
+        patch("polylogue.mcp.server._get_polylogue") as mock_get_polylogue,
+    ):
+        mock_get_config.return_value = SimpleNamespace(
+            archive_root=archive_root,
+            db_path=archive_root / "index.db",
+        )
+        mock_get_polylogue.side_effect = AssertionError("cursor validation must not restart through the facade")
+        expired_mcp = json.loads(
+            cast(
+                str,
+                await invoke_surface_async(
+                    mcp_server._tool_manager._tools["query_units"].fn,
+                    continuation=expired,
+                ),
+            )
+        )
+        invalid_mcp = json.loads(
+            cast(
+                str,
+                await invoke_surface_async(
+                    mcp_server._tool_manager._tools["query_units"].fn,
+                    continuation=tampered,
+                ),
+            )
+        )
+    assert expired_mcp["code"] == "query_continuation_expired"
+    assert invalid_mcp["code"] == "invalid_continuation"
+    assert "items" not in expired_mcp and "items" not in invalid_mcp
+
+    with _running_http_server() as base_url:
+        expired_status, expired_http = _http_json(
+            base_url,
+            f"/api/query-units?continuation={quote(expired, safe='')}",
+        )
+        invalid_status, invalid_http = _http_json(
+            base_url,
+            f"/api/query-units?continuation={quote(tampered, safe='')}",
+        )
+    assert expired_status == invalid_status == HTTPStatus.BAD_REQUEST
+    assert expired_http["error"] == "query_continuation_expired"
+    assert invalid_http["error"] == "invalid_continuation"
+    assert "items" not in expired_http and "items" not in invalid_http
+
+    _seed_overflow_corpus(archive_root, members=1, start=100)
+    with pytest.raises(QueryContinuationStaleError):
+        await api.query_units(continuation=api_first_cursor)
+
+    with (
+        patch("polylogue.mcp.server._get_config") as mock_get_config,
+        patch("polylogue.mcp.server._get_polylogue") as mock_get_polylogue,
+    ):
+        mock_get_config.return_value = SimpleNamespace(
+            archive_root=archive_root,
+            db_path=archive_root / "index.db",
+        )
+        mock_get_polylogue.side_effect = AssertionError("stale cursor validation must not restart the query")
+        stale_mcp = json.loads(
+            cast(
+                str,
+                await invoke_surface_async(
+                    mcp_server._tool_manager._tools["query_units"].fn,
+                    continuation=api_first_cursor,
+                ),
+            )
+        )
+    assert stale_mcp["code"] == "query_continuation_stale"
+
+    with _running_http_server() as base_url:
+        stale_status, stale_http = _http_json(
+            base_url,
+            f"/api/query-units?continuation={quote(api_first_cursor, safe='')}",
+        )
+    assert stale_status == HTTPStatus.CONFLICT
+    assert stale_http["error"] == "query_continuation_stale"
+
+
+@pytest.mark.asyncio
+@pytest.mark.parametrize(
+    ("limits", "error_type", "code"),
+    [
+        (QueryExecutionLimits(timeout_s=0.0), QueryTransactionDeadlineExceededError, "query_deadline_exceeded"),
+        (
+            QueryExecutionLimits(timeout_s=None, sqlite_vm_step_budget=1),
+            QueryTransactionBudgetExceededError,
+            "query_work_budget_exceeded",
+        ),
+    ],
+)
+async def test_deadline_and_budget_failures_keep_receipts_on_every_surface(
+    workspace_env: dict[str, Path],
+    mcp_server: MCPServerUnderTest,
+    monkeypatch: pytest.MonkeyPatch,
+    limits: QueryExecutionLimits,
+    error_type: type[QueryTransactionExecutionError],
+    code: str,
+) -> None:
+    archive_root = workspace_env["archive_root"]
+    _seed_overflow_corpus(archive_root, members=2)
+    expression = "messages where text:certificationneedle | sort by time asc"
+    monkeypatch.setattr(
+        "polylogue.archive.query.transaction.query_execution_limits",
+        lambda _operation: limits,
+    )
+
+    api = Polylogue(archive_root=archive_root)
+    with pytest.raises(error_type) as api_failure:
+        await api.query_units(expression, limit=1)
+    api_receipt = api_failure.value.receipt.to_dict()
+
+    with (
+        patch("polylogue.mcp.server._get_config") as mock_get_config,
+        patch("polylogue.mcp.server._get_polylogue") as mock_get_polylogue,
+    ):
+        mock_get_config.return_value = SimpleNamespace(
+            archive_root=archive_root,
+            db_path=archive_root / "index.db",
+        )
+        mock_get_polylogue.side_effect = AssertionError("failure path must remain on the transaction")
+        mcp_failure = cast(
+            dict[str, object],
+            json.loads(
+                cast(
+                    str,
+                    await invoke_surface_async(
+                        mcp_server._tool_manager._tools["query_units"].fn,
+                        expression=expression,
+                        limit=1,
+                    ),
+                )
+            ),
+        )
+
+    with _running_http_server() as base_url:
+        http_status, http_failure = _http_json(
+            base_url,
+            f"/api/query-units?expression={quote(expression, safe='')}&limit=1",
+        )
+
+    assert mcp_failure["code"] == code
+    assert http_status == HTTPStatus.SERVICE_UNAVAILABLE
+    assert http_failure["error"] == code
+    for raw_receipt in (api_receipt, mcp_failure["receipt"], http_failure["receipt"]):
+        receipt = cast(dict[str, object], raw_receipt)
+        query_ref = receipt["query_ref"]
+        result_ref = receipt["result_ref"]
+        assert isinstance(query_ref, str) and query_ref.startswith("query:")
+        assert isinstance(result_ref, str) and result_ref.startswith("result:")
+        assert receipt["offset"] == 0
+        retry = receipt["retry_continuation"]
+        assert isinstance(retry, str) and retry.startswith("q2.")
+        assert QueryContinuation.decode(retry).request.offset == 0
