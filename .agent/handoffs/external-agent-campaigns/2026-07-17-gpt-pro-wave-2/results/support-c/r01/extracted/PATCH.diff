+def test_transaction_rechecks_epoch_inside_the_owned_snapshot(tmp_path: Path) -> None:
+    archive_root = tmp_path / "archive"
+    ArchiveStore(archive_root).close()
+    request = QueryTransactionRequest(
+        operation="query_units",
+        arguments={"expression": "messages where text:needle", "session_filters": {}},
+        page_size=5,
+        projection="terminal-unit-envelope",
+        archive_epoch=archive_query_epoch(archive_root),
+    )
+
+    with sqlite3.connect(archive_root / "index.db") as conn:
+        version = int(conn.execute("PRAGMA user_version").fetchone()[0])
+        conn.execute(f"PRAGMA user_version = {version + 1}")
+        conn.commit()
+
+    transaction = QueryTransaction(
+        archive_root,
+        request,
+        limits=QueryExecutionLimits(timeout_s=None),
