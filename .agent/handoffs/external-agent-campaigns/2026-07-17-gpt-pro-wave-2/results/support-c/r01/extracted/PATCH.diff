+def test_resumed_transaction_preserves_the_original_continuation_window(tmp_path: Path) -> None:
+    request = _framed_request(offset=7)
+    seed = QueryContinuation(
+        request=request,
+        result_ref=request.result_ref,
+        issued_at_ms=1_000,
+        expires_at_ms=10_000,
+    )
+    transaction = QueryTransaction(
+        tmp_path,
+        request,
+        limits=QueryExecutionLimits(timeout_s=None),
+        resume=seed,
+    )
+
+    advanced = QueryContinuation.decode(
+        transaction.continuation_for(request.next(offset=14)).encode(),
+        now_ms=2_000,
+    )
+    retry = QueryContinuation.decode(transaction.failure_receipt().retry_continuation or "", now_ms=2_000)
+
+    assert advanced.request.offset == 14
+    assert retry.request.offset == 7
+    assert advanced.issued_at_ms == retry.issued_at_ms == seed.issued_at_ms
+    assert advanced.expires_at_ms == retry.expires_at_ms == seed.expires_at_ms
+
