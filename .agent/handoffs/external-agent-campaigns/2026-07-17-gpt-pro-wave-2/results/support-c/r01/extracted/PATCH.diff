+    user_db = tmp_path / "user.db"
+    _make_user_db(user_db)
+
+    assert archive_user_epoch(user_db) == "user:v11:0:0:0"
+    assert archive_query_epoch(tmp_path) == "index:v24:0:0:0|user:v11:0:0:0"
+
+    with sqlite3.connect(user_db) as conn:
+        conn.execute("INSERT INTO assertions VALUES ('a1', 1000)")
+        conn.commit()
+    assert archive_query_epoch(tmp_path) == "index:v24:0:0:0|user:v11:1:1:1000"
+
+    with sqlite3.connect(user_db) as conn:
+        conn.execute("UPDATE assertions SET updated_at_ms = 2000 WHERE assertion_id = 'a1'")
+        conn.commit()
+    assert archive_query_epoch(tmp_path) == "index:v24:0:0:0|user:v11:1:1:2000"
+
+    store = ArchiveStore.open_existing(tmp_path)
+    try:
