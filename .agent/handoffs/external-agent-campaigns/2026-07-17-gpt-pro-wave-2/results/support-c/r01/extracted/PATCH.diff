+@pytest.mark.asyncio
+async def test_cancelled_transaction_attaches_resumable_failure_receipt(tmp_path: Path) -> None:
+    archive_root = tmp_path / "archive"
+    ArchiveStore(archive_root).close()
+    request = QueryTransactionRequest(
+        operation="query_units",
+        arguments={"expression": "messages where text:needle", "session_filters": {}},
+        page_size=5,
+        projection="terminal-unit-envelope",
+        archive_epoch=archive_query_epoch(archive_root),
+    )
+    transaction = QueryTransaction(
+        archive_root,
+        request,
+        limits=QueryExecutionLimits(timeout_s=None),
+    )
+    started = threading.Event()
+    release = threading.Event()
+
+    def work(_archive: ArchiveStore) -> None:
+        started.set()
+        release.wait(timeout=2.0)
+
+    task = asyncio.create_task(transaction.run(work))
+    assert await asyncio.to_thread(started.wait, 1.0)
+    task.cancel()
+    release.set()
+
+    with pytest.raises(asyncio.CancelledError) as raised:
+        await task
+
+    receipt = cast(QueryTransactionFailureReceipt, raised.value.__dict__["query_receipt"])
+    assert receipt.query_ref == request.query_ref
+    assert receipt.result_ref == request.result_ref
+    assert receipt.offset == 0
+    assert receipt.retry_continuation is not None
+    assert QueryContinuation.decode(receipt.retry_continuation).request == request
