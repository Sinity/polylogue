+    return ToolContract(
+        name=name,
+        minimum_role=_minimum_role(source_names),
+        purpose=purpose,
+        source_declarations=source_names,
+        result_semantics=_semantics(source_names),
+        arguments=arguments,
+        examples=examples,
+        supports_continuation=supports_continuation,
+        emits_result_ref=emits_result_ref,
+    )
+
