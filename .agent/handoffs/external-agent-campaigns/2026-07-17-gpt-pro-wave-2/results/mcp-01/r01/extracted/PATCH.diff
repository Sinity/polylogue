+        "default_read_tools": list(DEFAULT_READ_TOOLS),
+        "privileged_tools": list(PRIVILEGED_TOOLS),
+        "target_tools": list(ALL_TARGET_TOOLS),
+        "resources": [item.uri_template for item in TARGET_RESOURCES],
