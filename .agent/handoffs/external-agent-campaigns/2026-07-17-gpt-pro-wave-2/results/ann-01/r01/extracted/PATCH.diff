+def _seed_tag(conn: sqlite3.Connection) -> str:
+    tag = upsert_assertion(
+        conn,
+        assertion_id="assertion-source-tag",
+        target_ref="session:tagged-session",
+        kind=AssertionKind.TAG,
+        key="procurement",
