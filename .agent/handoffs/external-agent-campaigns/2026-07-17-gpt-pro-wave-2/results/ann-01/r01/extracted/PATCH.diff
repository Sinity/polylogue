+        author_ref="user:local",
+        author_kind="user",
+        status=AssertionStatus.ACTIVE,
+        context_policy={"inject": False},
+        require_promotion=False,
+        now_ms=10,
+    )
+    conn.commit()
+    return f"assertion:{tag.assertion_id}"
