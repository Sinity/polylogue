+import { describe, expect, test } from 'vitest';
+
+import {
+  buildContinuationSearchParameters,
+  buildInitialSearchParameters,
+  buildQueryTransactionRequest,
+  isWebSearchDocument,
+  parseWebSearchDocument,
+} from './web-search';
+import { webSearchFixture } from '../test/web-search-fixture';
+
+describe('WebSearchResponse runtime contract', () => {
+  test('accepts the complete generated-server projection', () => {
+    const response = webSearchFixture();
+    expect(isWebSearchDocument(response)).toBe(true);
+    expect(parseWebSearchDocument(response)).toBe(response);
+  });
+
+  test('rejects incoherent continuation, rank, provenance, and facet selection', () => {
+    const continuation = webSearchFixture({ page: { has_more: false, continuation: 'q1.impossible' } });
+    expect(isWebSearchDocument(continuation)).toBe(false);
+
+    const badRank = webSearchFixture({ hits: [{ ...webSearchFixture().hits[0]!, rank: 2 }] });
+    expect(isWebSearchDocument(badRank)).toBe(false);
+
+    const hit = webSearchFixture().hits[0]!;
+    const badProvenance = webSearchFixture({
+      hits: [{
+        ...hit,
+        provenance: { ...hit.provenance, message_ref: 'message:other' },
+      }],
+    });
+    expect(isWebSearchDocument(badProvenance)).toBe(false);
+
+    const badSelection = webSearchFixture({
+      facets: {
+        ...webSearchFixture().facets,
+        origin: [{ value: 'codex-session', count: 1, selected: true }],
+      },
+    });
+    expect(isWebSearchDocument(badSelection)).toBe(false);
+  });
+});
+
+describe('search request builders', () => {
+  const values = {
+    expression: ' repo:polylogue ',
+    origins: ['codex-session', 'codex-session'],
+    repos: ['polylogue'],
+    time: '7d' as const,
+    retrievalLane: 'dialogue' as const,
+    pageSize: 20,
+  };
+
+  test('emits the complete shared QueryTransaction request shape', () => {
+    expect(buildQueryTransactionRequest(values, '2026-07-17T12:00:00Z')).toEqual({
+      operation: 'query',
+      arguments: {
+        expression: 'repo:polylogue',
+        facets: {
+          origin: ['codex-session'],
+          repo: ['polylogue'],
+          time: '7d',
+        },
+        retrieval_lane: 'dialogue',
+        as_of: '2026-07-17T12:00:00Z',
+      },
+      page_size: 20,
+      offset: 0,
+      projection: 'web-search.v1',
+      stable_order: 'rank-score-session-id',
+    });
+  });
+
+  test('keeps initial parameters complete and continuations cursor-only', () => {
+    expect(buildInitialSearchParameters(values)).toEqual({
+      q: 'repo:polylogue',
+      origin: ['codex-session'],
+      repo: ['polylogue'],
+      time: '7d',
+      retrieval_lane: 'dialogue',
+      page_size: 20,
+    });
+    expect(buildContinuationSearchParameters('q1.next')).toEqual({ continuation: 'q1.next' });
+  });
+});
