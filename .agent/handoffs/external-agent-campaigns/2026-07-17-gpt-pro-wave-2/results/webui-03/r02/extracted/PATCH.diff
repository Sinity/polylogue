@@ -0,0 +1,614 @@
+import type { ProjectWebSearchParameters } from '../api/generated';
+
+export const WEB_SEARCH_SCHEMA = 'web-search.v1' as const;
+export const WEB_SEARCH_STABLE_ORDER = 'rank-score-session-id' as const;
+export const QUERY_RETRIEVAL_LANES = ['auto', 'dialogue', 'actions', 'hybrid'] as const;
+export const SEARCH_TIME_BUCKETS = ['24h', '7d', '30d', 'all'] as const;
+export const MAX_WEB_PAGE_SIZE = 100;
+
+export type QueryRetrievalLane = (typeof QUERY_RETRIEVAL_LANES)[number];
+export type SearchTimeBucket = (typeof SEARCH_TIME_BUCKETS)[number];
+
+export interface SearchFormValues {
+  readonly expression: string;
+  readonly origins: readonly string[];
+  readonly repos: readonly string[];
+  readonly time: SearchTimeBucket | null;
+  readonly retrievalLane: QueryRetrievalLane;
+  readonly pageSize: number;
+}
+
+export interface SearchQueryTransactionRequest {
+  readonly operation: 'query';
+  readonly arguments: {
+    readonly expression: string;
+    readonly facets: {
+      readonly origin: readonly string[];
+      readonly repo: readonly string[];
+      readonly time: SearchTimeBucket | null;
+    };
+    readonly retrieval_lane: QueryRetrievalLane;
+    readonly as_of: string;
+  };
+  readonly page_size: number;
+  readonly offset: number;
+  readonly projection: typeof WEB_SEARCH_SCHEMA;
+  readonly stable_order: typeof WEB_SEARCH_STABLE_ORDER;
+}
+
+export type SearchStateKind =
+  | 'ready'
+  | 'empty'
+  | 'parse_error'
+  | 'invalid_request'
+  | 'archive_unavailable'
+  | 'fts_lagging'
+  | 'fts_unavailable'
+  | 'embeddings_absent'
+  | 'failed';
+
+export type SearchCoverage =
+  | { readonly kind: 'exact'; readonly value: number }
+  | { readonly kind: 'at_least'; readonly value: number }
+  | { readonly kind: 'unknown'; readonly value: null };
+
+export interface SearchFacetArguments {
+  readonly origin: readonly string[];
+  readonly repo: readonly string[];
+  readonly time: SearchTimeBucket | null;
+}
+
+export interface SearchRequestArguments {
+  readonly expression: string;
+  readonly facets: SearchFacetArguments;
+  readonly retrieval_lane: QueryRetrievalLane;
+  readonly as_of: string;
+}
+
+export interface SearchRequest extends SearchQueryTransactionRequest {
+  readonly arguments: SearchRequestArguments;
+  readonly query_ref: string;
+  readonly result_ref: string;
+}
+
+export interface SearchState {
+  readonly kind: SearchStateKind;
+  readonly message: string;
+  readonly detail: string | null;
+  readonly field: string | null;
+  readonly corrected_example: string | null;
+  readonly stale_available: boolean;
+}
+
+export interface FacetOption {
+  readonly value: string;
+  readonly label?: string;
+  readonly count: number;
+  readonly selected: boolean;
+}
+
+export interface SearchHitProvenance {
+  readonly origin: string;
+  readonly session_id: string;
+  readonly session_ref: string;
+  readonly message_id: string | null;
+  readonly message_ref: string | null;
+  readonly message_anchor: string;
+}
+
+export interface SearchHit {
+  readonly rank: number;
+  readonly title: string;
+  readonly snippet: string | null;
+  readonly retrieval_lane: string;
+  readonly occurred_at: string | null;
+  readonly repo: string | null;
+  readonly reader_href: string;
+  readonly provenance: SearchHitProvenance;
+}
+
+export interface SearchExample {
+  readonly expression: string;
+  readonly source: string;
+  readonly line: number;
+}
+
+export interface WebSearchDocument {
+  readonly schema: typeof WEB_SEARCH_SCHEMA;
+  readonly generated_at: string;
+  readonly request: SearchRequest;
+  readonly state: SearchState;
+  readonly coverage: SearchCoverage;
+  readonly hits: readonly SearchHit[];
+  readonly facets: {
+    readonly origin: readonly FacetOption[];
+    readonly repo: readonly FacetOption[];
+    readonly time: readonly FacetOption[];
+  };
+  readonly page: {
+    readonly has_more: boolean;
+    readonly continuation: string | null;
+  };
+  readonly resolved_retrieval_lane: string;
+  readonly diagnostics: Readonly<Record<string, unknown>> | null;
+  readonly examples: readonly SearchExample[];
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function hasOnlyKeys(value: Record<string, unknown>, allowed: readonly string[]): boolean {
+  const keys = new Set(allowed);
+  return Object.keys(value).every((key) => keys.has(key));
+}
+
+function isNullableString(value: unknown): value is string | null {
+  return typeof value === 'string' || value === null;
+}
+
+function isNonEmptyString(value: unknown): value is string {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function isNonNegativeInteger(value: unknown): value is number {
+  return typeof value === 'number' && Number.isInteger(value) && value >= 0;
+}
+
+function isPositiveInteger(value: unknown): value is number {
+  return typeof value === 'number' && Number.isInteger(value) && value > 0;
+}
+
+function isStringArray(value: unknown): value is string[] {
+  return Array.isArray(value) && value.every((item) => typeof item === 'string');
+}
+
+function hasUniqueNonEmptyStrings(value: unknown): value is string[] {
+  return (
+    isStringArray(value) &&
+    value.every((item) => item.trim() === item && item.length > 0) &&
+    new Set(value).size === value.length
+  );
+}
+
+export function isQueryRetrievalLane(value: unknown): value is QueryRetrievalLane {
+  return QUERY_RETRIEVAL_LANES.some((candidate) => candidate === value);
+}
+
+export function isSearchTimeBucket(value: unknown): value is SearchTimeBucket {
+  return SEARCH_TIME_BUCKETS.some((candidate) => candidate === value);
+}
+
+export function isTimezoneAwareIsoTimestamp(value: unknown): value is string {
+  return (
+    typeof value === 'string' &&
+    /(?:Z|[+-]\d{2}:\d{2})$/i.test(value) &&
+    !Number.isNaN(Date.parse(value))
+  );
+}
+
+function normalizeMany(values: readonly string[]): string[] {
+  const normalized: string[] = [];
+  const seen = new Set<string>();
+  for (const value of values) {
+    const token = value.trim();
+    if (token === '' || seen.has(token)) continue;
+    seen.add(token);
+    normalized.push(token);
+  }
+  return normalized;
+}
+
+function validatePageSize(pageSize: number): void {
+  if (!Number.isInteger(pageSize) || pageSize < 1 || pageSize > MAX_WEB_PAGE_SIZE) {
+    throw new Error(`search page size must be between 1 and ${MAX_WEB_PAGE_SIZE}`);
+  }
+}
+
+export function buildQueryTransactionRequest(
+  values: SearchFormValues,
+  asOf: string,
+  offset = 0,
+): SearchQueryTransactionRequest {
+  if (!isTimezoneAwareIsoTimestamp(asOf)) {
+    throw new Error('search query request requires a timezone-aware as_of execution frame');
+  }
+  validatePageSize(values.pageSize);
+  if (!Number.isInteger(offset) || offset < 0) {
+    throw new Error('search query offset must be a non-negative integer');
+  }
+  return {
+    operation: 'query',
+    arguments: {
+      expression: values.expression.trim(),
+      facets: {
+        origin: normalizeMany(values.origins),
+        repo: normalizeMany(values.repos),
+        time: values.time === 'all' ? null : values.time,
+      },
+      retrieval_lane: values.retrievalLane,
+      as_of: asOf,
+    },
+    page_size: values.pageSize,
+    offset,
+    projection: WEB_SEARCH_SCHEMA,
+    stable_order: WEB_SEARCH_STABLE_ORDER,
+  };
+}
+
+export function buildInitialSearchParameters(values: SearchFormValues): ProjectWebSearchParameters {
+  validatePageSize(values.pageSize);
+  const expression = values.expression.trim();
+  const origin = normalizeMany(values.origins);
+  const repo = normalizeMany(values.repos);
+  return {
+    ...(expression === '' ? {} : { q: expression }),
+    ...(origin.length === 0 ? {} : { origin }),
+    ...(repo.length === 0 ? {} : { repo }),
+    ...(values.time === null ? {} : { time: values.time }),
+    retrieval_lane: values.retrievalLane,
+    page_size: values.pageSize,
+  };
+}
+
+export function buildContinuationSearchParameters(continuation: string): ProjectWebSearchParameters {
+  if (!continuation.startsWith('q1.') || continuation.length <= 3) {
+    throw new Error('search continuation must be a non-empty q1 token');
+  }
+  return { continuation };
+}
+
+function appendParameters(params: URLSearchParams, values: ProjectWebSearchParameters): void {
+  for (const [name, value] of Object.entries(values)) {
+    if (value === undefined) continue;
+    if (Array.isArray(value)) {
+      for (const item of value) params.append(name, String(item));
+    } else {
+      params.set(name, String(value));
+    }
+  }
+}
+
+export function buildSearchUrl(
+  parameters: ProjectWebSearchParameters,
+  endpoint = '/api/web-search',
+): string {
+  const params = new URLSearchParams();
+  appendParameters(params, parameters);
+  const query = params.toString();
+  return query === '' ? endpoint : `${endpoint}?${query}`;
+}
+
+export function browserPageUrl(apiUrl: string): string {
+  const parsed = new URL(apiUrl, window.location.origin);
+  parsed.pathname = '/app/search';
+  parsed.hash = '';
+  return `${parsed.pathname}${parsed.search}`;
+}
+
+export function searchParametersFromUrl(
+  value: string | URL,
+): ProjectWebSearchParameters {
+  const parsed = new URL(value, window.location.origin);
+  const continuation = parsed.searchParams.getAll('continuation');
+  if (continuation.length > 0) {
+    if (continuation.length !== 1 || parsed.searchParams.size !== 1) {
+      throw new Error('search continuation URLs must contain exactly one continuation parameter');
+    }
+    return buildContinuationSearchParameters(continuation[0] ?? '');
+  }
+
+  const pageSizeValue = parsed.searchParams.get('page_size');
+  const pageSize = pageSizeValue === null ? 20 : Number(pageSizeValue);
+  validatePageSize(pageSize);
+  const laneValue = parsed.searchParams.get('retrieval_lane') ?? 'auto';
+  if (!isQueryRetrievalLane(laneValue)) {
+    throw new Error('search URL has an invalid retrieval lane');
+  }
+  const timeValue = parsed.searchParams.get('time');
+  if (timeValue !== null && !isSearchTimeBucket(timeValue)) {
+    throw new Error('search URL has an invalid time facet');
+  }
+  return buildInitialSearchParameters({
+    expression: parsed.searchParams.get('q') ?? '',
+    origins: parsed.searchParams.getAll('origin'),
+    repos: parsed.searchParams.getAll('repo'),
+    time: timeValue,
+    retrievalLane: laneValue,
+    pageSize,
+  });
+}
+
+export function searchApiUrlForBrowserPage(
+  pageUrl: string | URL = window.location.href,
+): string {
+  const parsed = new URL(pageUrl, window.location.origin);
+  parsed.pathname = '/api/web-search';
+  parsed.hash = '';
+  return `${parsed.pathname}${parsed.search}`;
+}
+
+export function searchFormValues(form: HTMLFormElement, pageSize: number): SearchFormValues {
+  const data = new FormData(form);
+  const selected = (name: string): string[] => data.getAll(name).map(String).filter(Boolean);
+  const requestedTime = String(data.get('time') ?? '');
+  const requestedLane = String(data.get('retrieval_lane') ?? 'auto');
+  return {
+    expression: String(data.get('q') ?? ''),
+    origins: selected('origin'),
+    repos: selected('repo'),
+    time: requestedTime !== 'all' && isSearchTimeBucket(requestedTime) ? requestedTime : null,
+    retrievalLane: isQueryRetrievalLane(requestedLane) ? requestedLane : 'auto',
+    pageSize,
+  };
+}
+
+function isCoverage(value: unknown): value is SearchCoverage {
+  if (!isRecord(value) || !hasOnlyKeys(value, ['kind', 'value'])) return false;
+  if (value.kind === 'unknown') return value.value === null;
+  return (
+    (value.kind === 'exact' || value.kind === 'at_least') &&
+    isNonNegativeInteger(value.value)
+  );
+}
+
+function isSearchState(value: unknown): value is SearchState {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, [
+      'kind',
+      'message',
+      'detail',
+      'field',
+      'corrected_example',
+      'stale_available',
+    ])
+  ) {
+    return false;
+  }
+  const kinds: readonly SearchStateKind[] = [
+    'ready',
+    'empty',
+    'parse_error',
+    'invalid_request',
+    'archive_unavailable',
+    'fts_lagging',
+    'fts_unavailable',
+    'embeddings_absent',
+    'failed',
+  ];
+  return (
+    kinds.some((kind) => kind === value.kind) &&
+    isNonEmptyString(value.message) &&
+    isNullableString(value.detail) &&
+    isNullableString(value.field) &&
+    isNullableString(value.corrected_example) &&
+    typeof value.stale_available === 'boolean'
+  );
+}
+
+function isFacetOption(value: unknown, labeled: boolean): value is FacetOption {
+  if (!isRecord(value)) return false;
+  const allowed = labeled
+    ? ['value', 'label', 'count', 'selected']
+    : ['value', 'count', 'selected'];
+  return (
+    hasOnlyKeys(value, allowed) &&
+    isNonEmptyString(value.value) &&
+    (!labeled || isNonEmptyString(value.label)) &&
+    isNonNegativeInteger(value.count) &&
+    typeof value.selected === 'boolean'
+  );
+}
+
+function readerHrefIsCanonical(value: string, provenance: SearchHitProvenance): boolean {
+  try {
+    const url = new URL(value, 'http://polylogue.invalid');
+    if (url.origin !== 'http://polylogue.invalid' || url.search !== '') return false;
+    const encodedSession = url.pathname.slice('/s/'.length);
+    return (
+      url.pathname.startsWith('/s/') &&
+      !encodedSession.includes('/') &&
+      decodeURIComponent(encodedSession) === provenance.session_id &&
+      decodeURIComponent(url.hash.slice(1)) === provenance.message_anchor
+    );
+  } catch {
+    return false;
+  }
+}
+
+function isSearchHit(value: unknown): value is SearchHit {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, [
+      'rank',
+      'title',
+      'snippet',
+      'retrieval_lane',
+      'occurred_at',
+      'repo',
+      'reader_href',
+      'provenance',
+    ]) ||
+    !isRecord(value.provenance) ||
+    !hasOnlyKeys(value.provenance, [
+      'origin',
+      'session_id',
+      'session_ref',
+      'message_id',
+      'message_ref',
+      'message_anchor',
+    ])
+  ) {
+    return false;
+  }
+  const provenance = value.provenance;
+  const messageIdentityIsCoherent =
+    provenance.message_id === null
+      ? provenance.message_ref === null
+      : provenance.message_ref === `message:${String(provenance.message_id)}`;
+  const typedProvenance = provenance as unknown as SearchHitProvenance;
+  return (
+    isPositiveInteger(value.rank) &&
+    isNonEmptyString(value.title) &&
+    isNullableString(value.snippet) &&
+    isNonEmptyString(value.retrieval_lane) &&
+    (value.occurred_at === null || isTimezoneAwareIsoTimestamp(value.occurred_at)) &&
+    isNullableString(value.repo) &&
+    isNonEmptyString(value.reader_href) &&
+    isNonEmptyString(provenance.origin) &&
+    isNonEmptyString(provenance.session_id) &&
+    provenance.session_ref === `session:${String(provenance.session_id)}` &&
+    isNullableString(provenance.message_id) &&
+    isNullableString(provenance.message_ref) &&
+    messageIdentityIsCoherent &&
+    isNonEmptyString(provenance.message_anchor) &&
+    readerHrefIsCanonical(value.reader_href, typedProvenance)
+  );
+}
+
+function isSearchRequest(value: unknown): value is SearchRequest {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, [
+      'operation',
+      'arguments',
+      'page_size',
+      'offset',
+      'projection',
+      'stable_order',
+      'query_ref',
+      'result_ref',
+    ]) ||
+    !isRecord(value.arguments) ||
+    !hasOnlyKeys(value.arguments, ['expression', 'facets', 'retrieval_lane', 'as_of']) ||
+    !isRecord(value.arguments.facets) ||
+    !hasOnlyKeys(value.arguments.facets, ['origin', 'repo', 'time'])
+  ) {
+    return false;
+  }
+  const args = value.arguments;
+  const facets = args.facets as Record<string, unknown>;
+  return (
+    value.operation === 'query' &&
+    typeof args.expression === 'string' &&
+    hasUniqueNonEmptyStrings(facets.origin) &&
+    hasUniqueNonEmptyStrings(facets.repo) &&
+    (facets.time === null || isSearchTimeBucket(facets.time)) &&
+    isQueryRetrievalLane(args.retrieval_lane) &&
+    isTimezoneAwareIsoTimestamp(args.as_of) &&
+    isPositiveInteger(value.page_size) &&
+    value.page_size <= MAX_WEB_PAGE_SIZE &&
+    isNonNegativeInteger(value.offset) &&
+    value.projection === WEB_SEARCH_SCHEMA &&
+    value.stable_order === WEB_SEARCH_STABLE_ORDER &&
+    typeof value.query_ref === 'string' &&
+    /^query:[0-9a-f]{24}$/.test(value.query_ref) &&
+    typeof value.result_ref === 'string' &&
+    /^result:[0-9a-f]{24}$/.test(value.result_ref)
+  );
+}
+
+function isSearchExample(value: unknown): value is SearchExample {
+  return (
+    isRecord(value) &&
+    hasOnlyKeys(value, ['expression', 'source', 'line']) &&
+    isNonEmptyString(value.expression) &&
+    isNonEmptyString(value.source) &&
+    isPositiveInteger(value.line)
+  );
+}
+
+function facetSelectionMatchesRequest(
+  response: WebSearchDocument,
+): boolean {
+  const selected = (options: readonly FacetOption[]): string[] =>
+    options.filter((option) => option.selected).map((option) => option.value);
+  const equalSets = (left: readonly string[], right: readonly string[]): boolean =>
+    left.length === right.length && left.every((value) => right.includes(value));
+  const requestedTime = response.request.arguments.facets.time ?? 'all';
+  return (
+    equalSets(selected(response.facets.origin), response.request.arguments.facets.origin) &&
+    equalSets(selected(response.facets.repo), response.request.arguments.facets.repo) &&
+    selected(response.facets.time).length === 1 &&
+    selected(response.facets.time)[0] === requestedTime
+  );
+}
+
+export function isWebSearchDocument(value: unknown): value is WebSearchDocument {
+  if (
+    !isRecord(value) ||
+    !hasOnlyKeys(value, [
+      'schema',
+      'generated_at',
+      'request',
+      'state',
+      'coverage',
+      'hits',
+      'facets',
+      'page',
+      'resolved_retrieval_lane',
+      'diagnostics',
+      'examples',
+    ]) ||
+    value.schema !== WEB_SEARCH_SCHEMA ||
+    !isTimezoneAwareIsoTimestamp(value.generated_at) ||
+    !isSearchRequest(value.request) ||
+    !isSearchState(value.state) ||
+    !isCoverage(value.coverage) ||
+    !Array.isArray(value.hits) ||
+    !value.hits.every(isSearchHit) ||
+    !isRecord(value.facets) ||
+    !hasOnlyKeys(value.facets, ['origin', 'repo', 'time']) ||
+    !Array.isArray(value.facets.origin) ||
+    !value.facets.origin.every((option) => isFacetOption(option, false)) ||
+    !Array.isArray(value.facets.repo) ||
+    !value.facets.repo.every((option) => isFacetOption(option, false)) ||
+    !Array.isArray(value.facets.time) ||
+    !value.facets.time.every((option) => isFacetOption(option, true)) ||
+    !isRecord(value.page) ||
+    !hasOnlyKeys(value.page, ['has_more', 'continuation']) ||
+    typeof value.page.has_more !== 'boolean' ||
+    !isNullableString(value.page.continuation) ||
+    !isNonEmptyString(value.resolved_retrieval_lane) ||
+    !(value.diagnostics === null || isRecord(value.diagnostics)) ||
+    !Array.isArray(value.examples) ||
+    !value.examples.every(isSearchExample)
+  ) {
+    return false;
+  }
+
+  const response = value as unknown as WebSearchDocument;
+  const continuationIsCoherent = response.page.has_more
+    ? response.page.continuation?.startsWith('q1.') === true && response.hits.length > 0
+    : response.page.continuation === null;
+  if (!continuationIsCoherent) return false;
+
+  const expectedRanks = response.hits.map((_hit, index) => response.request.offset + index + 1);
+  if (!response.hits.every((hit, index) => hit.rank === expectedRanks[index])) return false;
+
+  const observedEnd = response.request.offset + response.hits.length;
+  if (response.coverage.kind !== 'unknown' && response.coverage.value < observedEnd) return false;
+
+  const rowlessStates: readonly SearchStateKind[] = [
+    'parse_error',
+    'invalid_request',
+    'archive_unavailable',
+    'fts_lagging',
+    'fts_unavailable',
+    'embeddings_absent',
+    'failed',
+  ];
+  if (response.state.kind === 'empty' && response.hits.length !== 0) return false;
+  if (rowlessStates.includes(response.state.kind) && response.hits.length !== 0) return false;
+  if (!facetSelectionMatchesRequest(response)) return false;
+
+  return true;
+}
+
+export function parseWebSearchDocument(value: unknown): WebSearchDocument {
+  if (!isWebSearchDocument(value)) {
+    throw new TypeError('daemon returned an invalid WebSearchResponse');
+  }
+  return value;
+}
diff --git a/webui/src/entrypoints/web-search.tsx b/webui/src/entrypoints/web-search.tsx
