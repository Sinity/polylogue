+import { useCallback, useEffect, useRef, useState } from 'preact/hooks';
+
+import type { ProjectWebSearchParameters } from '../api/generated';
+import {
+  Button,
+  Grid,
+  Surface,
+  VerticalFrame,
+} from '../design-system';
+import {
+  QUERY_RETRIEVAL_LANES,
+  browserPageUrl,
+  buildContinuationSearchParameters,
+  buildInitialSearchParameters,
+  buildSearchUrl,
+  searchFormValues,
+  searchParametersFromUrl,
+  type FacetOption,
+  type SearchHit,
+  type SearchState,
+  type SearchStateKind,
+  type WebSearchDocument,
+} from '../contracts/web-search';
+import { fetchWebSearchPage } from '../lib/api';
+
+export type WebSearchPageLoader = (
+  parameters: ProjectWebSearchParameters,
+  signal: AbortSignal,
+) => Promise<WebSearchDocument>;
+
+export interface WebSearchIslandProps {
+  readonly initial: WebSearchDocument;
+  readonly loadPage?: WebSearchPageLoader;
+}
+
+interface SearchView {
+  readonly document: WebSearchDocument;
+  readonly hits: readonly SearchHit[];
+}
+
+function verticalState(kind: SearchStateKind): 'ready' | 'empty' | 'degraded' | 'error' {
+  if (kind === 'ready') return 'ready';
+  if (kind === 'empty') return 'empty';
+  if (kind === 'parse_error' || kind === 'invalid_request' || kind === 'failed') return 'error';
+  return 'degraded';
+}
+
+function isRequestAbort(error: unknown): boolean {
+  return (
+    (error instanceof DOMException && error.name === 'AbortError') ||
+    (error instanceof Error && error.name === 'RequestAbortedError')
+  );
+}
+
+function coverageLabel(response: WebSearchDocument): string {
+  if (response.coverage.kind === 'exact') {
+    const suffix = response.coverage.value === 1 ? 'match' : 'matches';
+    return `${response.coverage.value.toLocaleString()} exact ${suffix}`;
+  }
+  if (response.coverage.kind === 'at_least') {
+    return `At least ${response.coverage.value.toLocaleString()} matches`;
+  }
+  return 'Match total unknown';
+}
+
+function StateNotice({ state }: { readonly state: SearchState }) {
+  const role =
+    state.kind === 'parse_error' || state.kind === 'invalid_request' || state.kind === 'failed'
+      ? 'alert'
+      : 'status';
+  return (
+    <section
+      class={`web-search-state web-search-state--${state.kind}`}
+      data-search-state={state.kind}
+      role={role}
+      aria-live="polite"
+    >
+      <p class="web-search-state__kind">{state.kind.replaceAll('_', ' ')}</p>
+      <h2>{state.message}</h2>
+      {state.detail ? <p>{state.detail}</p> : null}
+      {state.field ? (
+        <p>
+          <strong>Field:</strong> <code>{state.field}</code>
+        </p>
+      ) : null}
+      {state.corrected_example ? (
+        <p>
+          Try <code>{state.corrected_example}</code>
+        </p>
+      ) : null}
+    </section>
+  );
+}
+
+function FacetGroup({
+  title,
+  name,
+  options,
+  radio = false,
+  onChange,
+}: {
+  readonly title: string;
+  readonly name: 'origin' | 'repo' | 'time';
+  readonly options: readonly FacetOption[];
+  readonly radio?: boolean;
+  readonly onChange: (form: HTMLFormElement) => void;
+}) {
+  return (
+    <fieldset class="web-search-facet" data-facet-group={name}>
+      <legend>{title}</legend>
+      {options.length === 0 ? <p class="web-search-facet-empty">No values available.</p> : null}
+      {options.map((option) => (
+        <label class="web-search-facet-option" key={`${name}:${option.value}`}>
+          <input
+            type={radio ? 'radio' : 'checkbox'}
+            name={name}
+            value={option.value}
+            defaultChecked={option.selected}
+            onChange={(event) => {
+              const form = event.currentTarget.form;
+              if (form) onChange(form);
+            }}
+          />
+          <span class="web-search-facet-option__label">{option.label ?? option.value}</span>
+          <span class="web-search-facet-option__count">{option.count.toLocaleString()}</span>
+        </label>
+      ))}
+    </fieldset>
+  );
+}
+
+function HitList({ hits }: { readonly hits: readonly SearchHit[] }) {
+  if (hits.length === 0) {
+    return <p class="web-search-no-rows">No result rows to display.</p>;
+  }
+  return (
+    <>
+      {hits.map((hit) => (
+        <article
+          class="web-search-hit"
+          data-search-rank={hit.rank}
+          data-session-ref={hit.provenance.session_ref}
+          key={`${hit.rank}:${hit.provenance.session_ref}:${hit.provenance.message_ref ?? ''}`}
+        >
+          <p class="web-search-hit__rank">Result {hit.rank}</p>
+          <h2>
+            <a href={hit.reader_href}>{hit.title}</a>
+          </h2>
+          <div class="web-search-hit__meta">
+            <span class="web-search-origin">{hit.provenance.origin}</span>
+            <code>{hit.provenance.session_ref}</code>
+            {hit.provenance.message_ref ? <code>{hit.provenance.message_ref}</code> : null}
+            {hit.repo ? <span>{hit.repo}</span> : null}
+            {hit.occurred_at ? <time dateTime={hit.occurred_at}>{hit.occurred_at}</time> : null}
+          </div>
+          {hit.snippet ? <p class="web-search-hit__snippet">{hit.snippet}</p> : null}
+        </article>
+      ))}
+    </>
+  );
+}
+
+export function WebSearchIsland({
+  initial,
+  loadPage = fetchWebSearchPage,
+}: WebSearchIslandProps) {
+  const [view, setView] = useState<SearchView>({ document: initial, hits: initial.hits });
+  const [pending, setPending] = useState(false);
+  const [transportError, setTransportError] = useState<string | null>(null);
+  const [liveStatus, setLiveStatus] = useState('');
+  const requestSerial = useRef(0);
+  const activeController = useRef<AbortController | null>(null);
+
+  const beginRequest = useCallback((): { readonly controller: AbortController; readonly serial: number } => {
+    activeController.current?.abort();
+    const controller = new AbortController();
+    const serial = requestSerial.current + 1;
+    requestSerial.current = serial;
+    activeController.current = controller;
+    setPending(true);
+    setTransportError(null);
+    return { controller, serial };
+  }, []);
+
+  const finishRequest = useCallback((serial: number): void => {
+    if (serial !== requestSerial.current) return;
+    activeController.current = null;
+    setPending(false);
+  }, []);
+
+  const replaceFromServer = useCallback(
+    async (
+      parameters: ProjectWebSearchParameters,
+      historyMode: 'push' | 'preserve' = 'push',
+    ): Promise<void> => {
+      const { controller, serial } = beginRequest();
+      setLiveStatus('Loading search results…');
+      try {
+        const next = await loadPage(parameters, controller.signal);
+        if (serial !== requestSerial.current) return;
+        setView({ document: next, hits: next.hits });
+        setLiveStatus(
+          next.hits.length === 0
+            ? next.state.message
+            : `Loaded ${next.hits.length.toLocaleString()} ${next.hits.length === 1 ? 'result' : 'results'}.`,
+        );
+        if (historyMode === 'push') {
+          const apiUrl = buildSearchUrl(parameters);
+          window.history.pushState({ query_ref: next.request.query_ref }, '', browserPageUrl(apiUrl));
+        }
+      } catch (error) {
+        if (serial === requestSerial.current && !isRequestAbort(error)) {
+          const message = error instanceof Error ? error.message : String(error);
+          setTransportError(message);
+          setLiveStatus('The search request failed; the previous results remain visible.');
+        }
+      } finally {
+        finishRequest(serial);
+      }
+    },
+    [beginRequest, finishRequest, loadPage],
+  );
+
+  useEffect(() => {
+    const restoreBrowserEntry = (): void => {
+      try {
+        void replaceFromServer(searchParametersFromUrl(window.location.href), 'preserve');
+      } catch (error) {
+        setTransportError(error instanceof Error ? error.message : String(error));
+      }
+    };
+    window.addEventListener('popstate', restoreBrowserEntry);
+    return () => {
+      window.removeEventListener('popstate', restoreBrowserEntry);
+      activeController.current?.abort();
+    };
+  }, [replaceFromServer]);
+
+  const response = view.document;
+  const submitForm = (form: HTMLFormElement): void => {
+    const values = searchFormValues(form, response.request.page_size);
+    void replaceFromServer(buildInitialSearchParameters(values));
+  };
+
+  const appendContinuation = async (): Promise<void> => {
+    const continuation = response.page.continuation;
+    if (continuation === null) return;
+    const expectedQueryRef = response.request.query_ref;
+    const expectedResultRef = response.request.result_ref;
+    const expectedOffset = response.request.offset + response.hits.length;
+    const { controller, serial } = beginRequest();
+    setLiveStatus('Loading the next result page…');
+    try {
+      const next = await loadPage(buildContinuationSearchParameters(continuation), controller.signal);
+      if (serial !== requestSerial.current) return;
+      if (
+        next.request.query_ref !== expectedQueryRef ||
+        next.request.result_ref !== expectedResultRef ||
+        next.request.offset !== expectedOffset
+      ) {
+        throw new Error('search continuation changed query or page identity');
+      }
+      if (next.state.kind !== 'ready' && next.state.kind !== 'empty') {
+        const detail = next.state.detail ? ` ${next.state.detail}` : '';
+        throw new Error(`${next.state.message}${detail}`);
+      }
+      setView((current) => {
+        if (
+          current.document.request.query_ref !== expectedQueryRef ||
+          current.document.page.continuation !== continuation
+        ) {
+          return current;
+        }
+        return { document: next, hits: [...current.hits, ...next.hits] };
+      });
+      setLiveStatus(
+        next.hits.length === 0
+          ? 'No additional results were returned.'
+          : `Loaded ${next.hits.length.toLocaleString()} additional ${next.hits.length === 1 ? 'result' : 'results'}.`,
+      );
+    } catch (error) {
+      if (serial === requestSerial.current && !isRequestAbort(error)) {
+        const message = error instanceof Error ? error.message : String(error);
+        setTransportError(message);
+        setLiveStatus('The next page could not be loaded; completed results remain visible.');
+      }
+    } finally {
+      finishRequest(serial);
+    }
+  };
+
+  const formKey = response.request.query_ref;
+  const args = response.request.arguments;
+  const continuationHref = response.page.continuation
+    ? `/app/search?${new URLSearchParams({ continuation: response.page.continuation }).toString()}`
+    : null;
+
+  return (
+    <VerticalFrame
+      id="webui-03"
+      state={verticalState(response.state.kind)}
+      title="Search the archive"
+      description="Structured DSL, FTS evidence, and semantic retrieval projected by the daemon."
+      actions={<a href="/app">Archive overview</a>}
+    >
+      <Grid className="web-search-layout" min="15rem">
+        <Surface className="web-search-controls">
+          <form
+            class="web-search-form"
+            method="get"
+            action="/app/search"
+            role="search"
+            aria-label="Archive search"
+            data-search-form
+            key={formKey}
+            onSubmit={(event) => {
+              event.preventDefault();
+              submitForm(event.currentTarget);
+            }}
+          >
+            <input type="hidden" name="page_size" value={response.request.page_size} />
+            <label class="web-search-query-label" for="web-search-query">Query expression</label>
+            <div class="web-search-query-row">
+              <input
+                id="web-search-query"
+                name="q"
+                type="search"
+                defaultValue={args.expression}
+                placeholder={response.examples[1]?.expression ?? response.examples[0]?.expression ?? ''}
+                autoComplete="off"
+              />
+              <Button type="submit" variant="primary" disabled={pending}>Search</Button>
+            </div>
+            <label class="web-search-lane-label" for="web-search-lane">Retrieval lane</label>
+            <select
+              id="web-search-lane"
+              name="retrieval_lane"
+              value={args.retrieval_lane}
+              onChange={(event) => {
+                const form = event.currentTarget.form;
+                if (form) submitForm(form);
+              }}
+            >
+              {QUERY_RETRIEVAL_LANES.map((lane) => (
+                <option value={lane} key={lane}>{lane}</option>
+              ))}
+            </select>
+            <FacetGroup title="Origin" name="origin" options={response.facets.origin} onChange={submitForm} />
+            <FacetGroup title="Repository" name="repo" options={response.facets.repo} onChange={submitForm} />
+            <FacetGroup title="Time" name="time" options={response.facets.time} radio onChange={submitForm} />
+            <Button className="web-search-apply" type="submit" disabled={pending}>Apply filters</Button>
+          </form>
+          <details class="web-search-examples">
+            <summary>Query DSL examples</summary>
+            <ul>
+              {response.examples.map((example) => (
+                <li key={`${example.source}:${example.line}`}>
+                  <code>{example.expression}</code>
+                  <small>{example.source}:{example.line}</small>
+                </li>
+              ))}
+            </ul>
+          </details>
+        </Surface>
+        <section class="pl-surface web-search-results" aria-busy={pending}>
+          <StateNotice state={response.state} />
+          {transportError ? <p class="web-search-transport-error" role="alert">{transportError}</p> : null}
+          <div class="web-search-results__heading">
+            <h2>Results</h2>
+            <p data-search-coverage>{coverageLabel(response)}</p>
+          </div>
+          <div data-search-results><HitList hits={view.hits} /></div>
+          <div class="web-search-paging" data-search-paging>
+            {continuationHref ? (
+              <a
+                class="pl-button pl-button--primary web-search-more"
+                data-search-continuation
+                aria-disabled={pending ? 'true' : undefined}
+                href={continuationHref}
+                onClick={(event) => {
+                  event.preventDefault();
+                  if (!pending) void appendContinuation();
+                }}
+              >
+                {pending ? 'Loading…' : 'Load more results'}
+              </a>
+            ) : null}
+          </div>
+          <p class="web-search-live-status" data-search-live-status role="status" aria-live="polite">
+            {liveStatus}
+          </p>
+        </section>
+      </Grid>
+    </VerticalFrame>
+  );
+}
