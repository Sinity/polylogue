@@ -0,0 +1,118 @@
+import { fireEvent, render, screen, waitFor } from '@testing-library/preact';
+import { describe, expect, test, vi } from 'vitest';
+
+import { WebSearchIsland, type WebSearchPageLoader } from './web-search';
+import { searchHit, webSearchFixture } from '../test/web-search-fixture';
+
+describe('WebSearchIsland', () => {
+  test('appends exactly the server continuation page without client reranking', async () => {
+    const initial = webSearchFixture();
+    const next = webSearchFixture({
+      request: { ...initial.request, offset: 1 },
+      coverage: { kind: 'exact', value: 2 },
+      hits: [searchHit(2, 'session-two', 'Second result')],
+      page: { has_more: false, continuation: null },
+    });
+    const loadPage = vi.fn<WebSearchPageLoader>().mockResolvedValue(next);
+
+    render(<WebSearchIsland initial={initial} loadPage={loadPage} />);
+    fireEvent.click(screen.getByRole('link', { name: 'Load more results' }));
+
+    await screen.findByText('Second result');
+    expect(screen.getByRole('link', { name: 'Result 1' })).toBeTruthy();
+    expect(
+      Array.from(document.querySelectorAll<HTMLElement>('[data-search-rank]')).map(
+        (node) => node.dataset.searchRank,
+      ),
+    ).toEqual(['1', '2']);
+    expect(loadPage).toHaveBeenCalledWith(
+      { continuation: 'q1.next-page' },
+      expect.any(AbortSignal),
+    );
+    expect(screen.queryByRole('link', { name: 'Load more results' })).toBeNull();
+  });
+
+  test('renders parser diagnostics and the server-provided corrected example', () => {
+    const initial = webSearchFixture({
+      state: {
+        kind: 'parse_error',
+        message: 'The query could not be parsed.',
+        detail: "Unexpected token ')' at column 7",
+        field: 'expression',
+        corrected_example: 'repo:polylogue since:7d has:paste',
+        stale_available: false,
+      },
+      coverage: { kind: 'unknown', value: null },
+      hits: [],
+      page: { has_more: false, continuation: null },
+    });
+
+    render(<WebSearchIsland initial={initial} />);
+
+    expect(screen.getByRole('alert').textContent).toContain('The query could not be parsed.');
+    expect(screen.getByText("Unexpected token ')' at column 7")).toBeTruthy();
+    expect(screen.getAllByText('repo:polylogue since:7d has:paste')).toHaveLength(2);
+    expect(screen.getByText('Match total unknown')).toBeTruthy();
+  });
+
+  test('keeps visible hits until the authoritative facet response arrives', async () => {
+    let resolvePage: ((value: ReturnType<typeof webSearchFixture>) => void) | undefined;
+    const pending = new Promise<ReturnType<typeof webSearchFixture>>((resolve) => {
+      resolvePage = resolve;
+    });
+    const loadPage = vi.fn<WebSearchPageLoader>().mockReturnValue(pending);
+    const initial = webSearchFixture();
+    const filtered = webSearchFixture({
+      request: {
+        ...initial.request,
+        query_ref: 'query:333333333333333333333333',
+        result_ref: 'result:444444444444444444444444',
+        arguments: {
+          ...initial.request.arguments,
+          facets: { origin: ['codex-session'], repo: [], time: null },
+        },
+      },
+      coverage: { kind: 'exact', value: 1 },
+      hits: [searchHit(1, 'filtered-session', 'Server-filtered result')],
+      facets: {
+        ...initial.facets,
+        origin: [
+          { value: 'codex-session', count: 1, selected: true },
+          { value: 'claude-code-session', count: 0, selected: false },
+        ],
+      },
+      page: { has_more: false, continuation: null },
+    });
+
+    render(<WebSearchIsland initial={initial} loadPage={loadPage} />);
+    fireEvent.click(screen.getByRole('checkbox', { name: /codex-session/ }));
+
+    expect(screen.getByRole('link', { name: 'Result 1' })).toBeTruthy();
+    expect(screen.queryByText('Server-filtered result')).toBeNull();
+    expect(loadPage).toHaveBeenCalledWith(
+      {
+        q: 'timeout',
+        origin: ['codex-session'],
+        retrieval_lane: 'dialogue',
+        page_size: 20,
+      },
+      expect.any(AbortSignal),
+    );
+
+    resolvePage?.(filtered);
+    await waitFor(() => expect(screen.getByText('Server-filtered result')).toBeTruthy());
+    expect(screen.queryByRole('link', { name: 'Result 1' })).toBeNull();
+    expect(screen.getByRole('checkbox', { name: /codex-session/ })).toHaveProperty('checked', true);
+  });
+
+  test('preserves the completed page when a continuation request fails', async () => {
+    const loadPage = vi.fn<WebSearchPageLoader>().mockRejectedValue(new Error('continuation failed'));
+    render(<WebSearchIsland initial={webSearchFixture()} loadPage={loadPage} />);
+
+    fireEvent.click(screen.getByRole('link', { name: 'Load more results' }));
+
+    expect(await screen.findByRole('alert')).toHaveTextContent('continuation failed');
+    expect(screen.getByRole('link', { name: 'Result 1' })).toBeTruthy();
+    expect(screen.getByRole('link', { name: 'Load more results' })).toBeTruthy();
+  });
+});
