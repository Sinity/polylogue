+.web-search-facet-option__count,
+.web-search-facet-empty,
+.web-search-hit__rank,
+.web-search-results__heading p,
+.web-search-live-status,
+.web-search-examples small {
+  color: var(--pl-color-text-muted);
+  font-size: var(--pl-font-size-sm);
+}
+
+.web-search-apply {
+  justify-self: start;
+}
+
+.web-search-examples {
+  margin-top: var(--pl-space-5);
+}
+
+.web-search-examples summary {
+  cursor: pointer;
+  font-weight: 700;
+}
+
+.web-search-examples ul {
+  margin: var(--pl-space-3) 0 0;
+  padding-left: var(--pl-space-5);
+}
+
+.web-search-examples li {
+  min-width: 0;
+}
+
+.web-search-examples code,
+.web-search-examples small {
+  display: block;
+  overflow-wrap: anywhere;
+}
+
+.web-search-results {
+  min-width: 0;
+}
+
+.web-search-state {
+  margin-bottom: var(--pl-space-5);
+  padding: var(--pl-space-4);
+  border: var(--pl-border-width) solid var(--pl-color-border);
+  border-radius: var(--pl-radius-md);
+  background: var(--pl-color-surface-inset);
+}
+
+.web-search-state--parse_error,
+.web-search-state--invalid_request,
+.web-search-state--failed {
+  border-color: var(--pl-color-accent-strong);
+}
+
+.web-search-state--fts_lagging,
+.web-search-state--fts_unavailable,
+.web-search-state--embeddings_absent,
+.web-search-state--archive_unavailable {
+  border-color: var(--pl-color-border-strong);
+}
+
+.web-search-state__kind {
+  margin-bottom: var(--pl-space-1);
+  color: var(--pl-color-text-muted);
+  font-size: var(--pl-font-size-xs);
+  font-weight: 750;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+.web-search-state h2 {
+  margin-bottom: var(--pl-space-2);
+}
+
+.web-search-state p:last-child {
+  margin-bottom: 0;
+}
+
+.web-search-transport-error {
+  padding: var(--pl-space-3);
+  border-left: 0.25rem solid var(--pl-color-accent-strong);
+  background: var(--pl-color-surface-inset);
+}
+
+.web-search-results__heading {
+  display: flex;
+  align-items: baseline;
+  justify-content: space-between;
+  gap: var(--pl-space-3);
+  padding-bottom: var(--pl-space-3);
+  border-bottom: var(--pl-border-width) solid var(--pl-color-border);
+}
+
+.web-search-results__heading :where(h2, p) {
+  margin-bottom: 0;
+}
+
+.web-search-hit {
+  padding-block: var(--pl-space-5);
+  border-bottom: var(--pl-border-width) solid var(--pl-color-border);
+}
+
+.web-search-hit__rank {
+  margin-bottom: var(--pl-space-1);
+}
+
+.web-search-hit h2 {
+  margin-bottom: var(--pl-space-2);
+}
+
+.web-search-hit__meta {
+  display: flex;
+  flex-wrap: wrap;
+  gap: var(--pl-space-2);
+  align-items: center;
+  color: var(--pl-color-text-muted);
+  font-size: var(--pl-font-size-sm);
+}
+
+.web-search-hit__meta code {
+  max-width: 100%;
+  overflow-wrap: anywhere;
+}
+
+.web-search-origin {
+  padding: 0.1rem var(--pl-space-2);
+  border: var(--pl-border-width) solid var(--pl-color-border-strong);
+  border-radius: 999px;
+  color: var(--pl-color-text);
+  font-weight: 650;
+}
+
+.web-search-hit__snippet {
+  max-width: var(--pl-transcript-measure);
+  margin: var(--pl-space-3) 0 0;
+  overflow-wrap: anywhere;
+  white-space: pre-wrap;
+}
+
+.web-search-no-rows {
+  padding-block: var(--pl-space-5);
+  color: var(--pl-color-text-muted);
+}
+
+.web-search-paging {
+  padding-top: var(--pl-space-5);
+}
+
+.web-search-more[aria-disabled='true'] {
+  pointer-events: none;
+  opacity: 0.6;
+}
+
+.web-search-live-status {
+  min-height: 1.5em;
+  margin: var(--pl-space-3) 0 0;
+}
+
+@media (max-width: 48rem) {
+  .web-search-site-header {
+    align-items: flex-start;
+    flex-direction: column;
+  }
+
+  .web-search-controls {
+    position: static;
+  }
+
+  .web-search-query-row {
+    grid-template-columns: 1fr;
+  }
+}
