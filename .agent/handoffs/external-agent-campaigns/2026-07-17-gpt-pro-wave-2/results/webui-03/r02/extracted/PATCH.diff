@@ -0,0 +1,232 @@
+"""Semantic SSR renderer for the WebUI v2 search vertical.
+
+The renderer consumes the same immutable :class:`WebSearchResponse` that the
+JSON route and Preact island consume.  It emits no inline executable code or
+styles: Vite's manifest is the sole owner of browser assets, while the JSON
+bootstrap contains only the already-projected response.
+"""
+
+from __future__ import annotations
+
+from collections.abc import Sequence
+from html import escape
+from urllib.parse import urlencode
+
+from polylogue.archive.query.spec import QUERY_RETRIEVAL_LANES
+from polylogue.daemon.web_search_contract import (
+    WEB_SEARCH_EXAMPLES,
+    WebSearchFacetOption,
+    WebSearchHit,
+    WebSearchResponse,
+    WebSearchState,
+)
+from polylogue.daemon.webui import WEB_SEARCH_ENTRY_NAME, WebUIAssetBundle
+
+
+def _checked(value: bool) -> str:
+    return ' checked=""' if value else ""
+
+
+def _selected(value: bool) -> str:
+    return ' selected=""' if value else ""
+
+
+def _vertical_state(state: WebSearchState) -> str:
+    if state.kind == "ready":
+        return "ready"
+    if state.kind == "empty":
+        return "empty"
+    if state.kind in {"parse_error", "invalid_request", "failed"}:
+        return "error"
+    return "degraded"
+
+
+def _render_state(state: WebSearchState) -> str:
+    kind = escape(state.kind, quote=True)
+    role = "alert" if state.kind in {"parse_error", "invalid_request", "failed"} else "status"
+    detail = f"<p>{escape(state.detail)}</p>" if state.detail else ""
+    field = f"<p><strong>Field:</strong> <code>{escape(state.field)}</code></p>" if state.field else ""
+    correction = f"<p>Try <code>{escape(state.corrected_example)}</code></p>" if state.corrected_example else ""
+    return (
+        f'<section class="web-search-state web-search-state--{kind}" '
+        f'data-search-state="{kind}" role="{role}" aria-live="polite">'
+        f'<p class="web-search-state__kind">{escape(state.kind.replace("_", " "))}</p>'
+        f"<h2>{escape(state.message)}</h2>{detail}{field}{correction}</section>"
+    )
+
+
+def _render_facet_group(
+    title: str,
+    name: str,
+    options: Sequence[WebSearchFacetOption],
+    *,
+    radio: bool = False,
+) -> str:
+    input_type = "radio" if radio else "checkbox"
+    rows: list[str] = []
+    for option in options:
+        label = str(getattr(option, "label", option.value))
+        rows.append(
+            '<label class="web-search-facet-option">'
+            f'<input type="{input_type}" name="{escape(name, quote=True)}" '
+            f'value="{escape(option.value, quote=True)}"{_checked(option.selected)}>'
+            f'<span class="web-search-facet-option__label">{escape(label)}</span>'
+            f'<span class="web-search-facet-option__count">{option.count:,}</span>'
+            "</label>"
+        )
+    if not rows:
+        rows.append('<p class="web-search-facet-empty">No values available.</p>')
+    return (
+        f'<fieldset class="web-search-facet" data-facet-group="{escape(name, quote=True)}">'
+        f"<legend>{escape(title)}</legend>{''.join(rows)}</fieldset>"
+    )
+
+
+def _render_hits(hits: Sequence[WebSearchHit]) -> str:
+    rows: list[str] = []
+    for hit in hits:
+        provenance = hit.provenance
+        meta = [
+            f'<span class="web-search-origin">{escape(provenance.origin)}</span>',
+            f"<code>{escape(provenance.session_ref)}</code>",
+        ]
+        if provenance.message_ref:
+            meta.append(f"<code>{escape(provenance.message_ref)}</code>")
+        if hit.repo:
+            meta.append(f"<span>{escape(hit.repo)}</span>")
+        if hit.occurred_at:
+            occurred_at = escape(hit.occurred_at)
+            meta.append(f'<time datetime="{escape(hit.occurred_at, quote=True)}">{occurred_at}</time>')
+        snippet = f'<p class="web-search-hit__snippet">{escape(hit.snippet)}</p>' if hit.snippet else ""
+        rows.append(
+            f'<article class="web-search-hit" data-search-rank="{hit.rank}" '
+            f'data-session-ref="{escape(provenance.session_ref, quote=True)}">'
+            f'<p class="web-search-hit__rank">Result {hit.rank}</p>'
+            f'<h2><a href="{escape(hit.reader_href, quote=True)}">{escape(hit.title)}</a></h2>'
+            f'<div class="web-search-hit__meta">{"".join(meta)}</div>{snippet}</article>'
+        )
+    return "".join(rows)
+
+
+def _coverage_label(response: WebSearchResponse) -> str:
+    coverage = response.coverage
+    if coverage.kind == "exact":
+        value = coverage.value or 0
+        return f"{value:,} exact {'match' if value == 1 else 'matches'}"
+    if coverage.kind == "at_least":
+        return f"At least {(coverage.value or 0):,} matches"
+    return "Match total unknown"
+
+
+def _safe_initial_json(response: WebSearchResponse) -> str:
+    return (
+        response.model_dump_json(by_alias=True)
+        .replace("&", "\\u0026")
+        .replace("<", "\\u003c")
+        .replace(">", "\\u003e")
+        .replace("\u2028", "\\u2028")
+        .replace("\u2029", "\\u2029")
+    )
+
+
+def render_web_search_page(bundle: WebUIAssetBundle, response: WebSearchResponse) -> str:
+    """Render one complete search page readable without JavaScript."""
+
+    entry = bundle.entrypoint(WEB_SEARCH_ENTRY_NAME)
+    request = response.request
+    arguments = request.arguments
+    continuation = response.page.continuation
+    stylesheet_links = "\n".join(
+        f'    <link rel="stylesheet" href="/app/assets/{escape(name, quote=True)}">' for name in entry.stylesheets
+    )
+    lane_options = "".join(
+        f'<option value="{escape(value, quote=True)}"{_selected(value == arguments.retrieval_lane)}>'
+        f"{escape(value)}</option>"
+        for value in QUERY_RETRIEVAL_LANES
+    )
+    paging = ""
+    if continuation:
+        href = "/app/search?" + urlencode({"continuation": continuation})
+        paging = (
+            f'<a class="pl-button pl-button--primary web-search-more" '
+            f'data-search-continuation href="{escape(href, quote=True)}">Load more results</a>'
+        )
+    results = _render_hits(response.hits)
+    if not results:
+        results = '<p class="web-search-no-rows">No result rows to display.</p>'
+    examples = "".join(
+        f"<li><code>{escape(example.expression)}</code><small>{escape(example.source)}:{example.line}</small></li>"
+        for example in WEB_SEARCH_EXAMPLES
+    )
+
+    return f"""<!doctype html>
+<html lang="en">
+  <head>
+    <meta charset="utf-8">
+    <meta name="viewport" content="width=device-width, initial-scale=1">
+    <meta name="color-scheme" content="light dark">
+    <title>Search · Polylogue</title>
+{stylesheet_links}
+  </head>
+  <body>
+    <a class="pl-skip-link" href="#main-content">Skip to main content</a>
+    <header class="web-search-site-header">
+      <a class="web-search-wordmark" href="/app">Polylogue</a>
+      <nav aria-label="WebUI views">
+        <a href="/app">Archive overview</a>
+        <a href="/app/search" aria-current="page">Search</a>
+        <a href="/">Legacy reader</a>
+      </nav>
+    </header>
+    <div id="web-search-island" data-island="web-search">
+      <main id="main-content" tabindex="-1" class="pl-main" data-webui-contract="1" data-webui-vertical="webui-03" data-state="{_vertical_state(response.state)}" aria-labelledby="webui-03-heading">
+        <header class="pl-page-header">
+          <div>
+            <p class="pl-eyebrow">webui-03</p>
+            <h1 id="webui-03-heading">Search the archive</h1>
+            <p class="pl-page-description">Structured DSL, FTS evidence, and semantic retrieval projected by the daemon.</p>
+          </div>
+          <div class="pl-page-actions"><a href="/app">Archive overview</a></div>
+        </header>
+        <div class="pl-grid web-search-layout" style="--pl-grid-min:15rem;--pl-grid-space:var(--pl-space-4)">
+          <section class="pl-surface web-search-controls">
+            <form class="web-search-form" method="get" action="/app/search" role="search" aria-label="Archive search" data-search-form>
+              <input type="hidden" name="page_size" value="{request.page_size}">
+              <label class="web-search-query-label" for="web-search-query">Query expression</label>
+              <div class="web-search-query-row">
+                <input id="web-search-query" name="q" type="search" value="{escape(arguments.expression, quote=True)}" placeholder="{escape(WEB_SEARCH_EXAMPLES[1].expression, quote=True)}" autocomplete="off">
+                <button class="pl-button pl-button--primary" type="submit">Search</button>
+              </div>
+              <label class="web-search-lane-label" for="web-search-lane">Retrieval lane</label>
+              <select id="web-search-lane" name="retrieval_lane">{lane_options}</select>
+              {_render_facet_group("Origin", "origin", response.facets.origin)}
+              {_render_facet_group("Repository", "repo", response.facets.repo)}
+              {_render_facet_group("Time", "time", response.facets.time, radio=True)}
+              <button class="pl-button pl-button--secondary web-search-apply" type="submit">Apply filters</button>
+            </form>
+            <details class="web-search-examples">
+              <summary>Query DSL examples</summary>
+              <ul>{examples}</ul>
+            </details>
+          </section>
+          <section class="pl-surface web-search-results" aria-busy="false">
+            {_render_state(response.state)}
+            <div class="web-search-results__heading">
+              <h2>Results</h2>
+              <p data-search-coverage>{escape(_coverage_label(response))}</p>
+            </div>
+            <div data-search-results>{results}</div>
+            <div class="web-search-paging" data-search-paging>{paging}</div>
+            <p class="web-search-live-status" data-search-live-status role="status" aria-live="polite"></p>
+          </section>
+        </div>
+      </main>
+    </div>
+    <script id="web-search-initial" type="application/json">{_safe_initial_json(response)}</script>
+    <script type="module" src="/app/assets/{escape(entry.script, quote=True)}"></script>
+  </body>
+</html>
+"""
+
+
+__all__ = ["render_web_search_page"]
