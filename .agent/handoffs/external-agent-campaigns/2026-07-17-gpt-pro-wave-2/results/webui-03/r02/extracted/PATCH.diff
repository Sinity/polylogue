+
+
+def test_ssr_contains_semantic_skeleton_contract_and_safe_json() -> None:
+    parsed = parse_web_search_request(
+        {"q": ["repo:polylogue <unsafe>"], "origin": ["codex-session"]},
+        now=datetime(2026, 7, 17, 12, tzinfo=UTC),
+    )
