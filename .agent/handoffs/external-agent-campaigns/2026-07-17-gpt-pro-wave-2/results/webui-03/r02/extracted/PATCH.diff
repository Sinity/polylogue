@@ -0,0 +1,23 @@
+import { hydrate } from 'preact';
+
+import { parseWebSearchDocument } from '../contracts/web-search';
+import { WebSearchIsland } from '../islands/web-search';
+import '../design-system/design-system.css';
+import '../web-search.css';
+
+function readBootstrap(): ReturnType<typeof parseWebSearchDocument> | null {
+  const node = document.getElementById('web-search-initial');
+  if (node === null) return null;
+  try {
+    return parseWebSearchDocument(JSON.parse(node.textContent ?? ''));
+  } catch (error) {
+    console.error('Polylogue WebUI search bootstrap was rejected', error);
+    return null;
+  }
+}
+
+const root = document.getElementById('web-search-island');
+const bootstrap = readBootstrap();
+if (root !== null && bootstrap !== null) {
+  hydrate(<WebSearchIsland initial={bootstrap} />, root);
+}
