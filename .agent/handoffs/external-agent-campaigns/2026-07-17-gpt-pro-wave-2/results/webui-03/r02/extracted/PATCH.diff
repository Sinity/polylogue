+"""Typed wire contract for the WebUI v2 search vertical.
+
+The query transaction remains the semantic owner.  These immutable models
+constrain only the browser projection so execution, SSR, and hydration cannot
+drift through ad-hoc dictionaries.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import UTC, datetime
+from http import HTTPStatus
+from typing import Literal, Self, cast
+
+from pydantic import BaseModel, ConfigDict, Field, StrictInt, field_validator, model_validator
+
+from polylogue.archive.query.transaction import QueryCoverage, QueryTransactionRequest
+
+WEB_SEARCH_PROJECTION: Literal["web-search.v1"] = "web-search.v1"
+WEB_SEARCH_OPERATION: Literal["query"] = "query"
+WEB_SEARCH_STABLE_ORDER: Literal["rank-score-session-id"] = "rank-score-session-id"
+DEFAULT_PAGE_SIZE = 20
+MAX_WEB_PAGE_SIZE = 100
+
+WebSearchStateKind = Literal[
+    "ready",
+    "empty",
+    "parse_error",
+    "invalid_request",
+    "archive_unavailable",
+    "fts_lagging",
+    "fts_unavailable",
+    "embeddings_absent",
+    "failed",
+]
+WebSearchRetrievalLane = Literal["auto", "dialogue", "actions", "hybrid"]
+WebSearchTimeBucket = Literal["24h", "7d", "30d", "all"]
+CoverageKind = Literal["exact", "at_least", "unknown"]
+
+
+def _normalize_utc_timestamp(value: str, *, field_name: str) -> str:
+    try:
+        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
+    except ValueError as exc:
+        raise ValueError(f"{field_name} must be an ISO-8601 timestamp") from exc
+    if parsed.tzinfo is None:
+        raise ValueError(f"{field_name} must include a timezone")
+    return parsed.astimezone(UTC).isoformat().replace("+00:00", "Z")
+
+
+class WebSearchContractModel(BaseModel):
+    """Immutable, closed browser-contract model."""
+
+    model_config = ConfigDict(extra="forbid", frozen=True, populate_by_name=True)
+
+
+class DSLExample(WebSearchContractModel):
+    expression: str = Field(min_length=1)
+    source: str = Field(min_length=1)
+    line: StrictInt = Field(gt=0)
+
+
+WEB_SEARCH_EXAMPLES: tuple[DSLExample, ...] = (
+    DSLExample(expression="repo:polylogue", source="tests/unit/cli/test_query_expression.py", line=5345),
+    DSLExample(
+        expression="repo:polylogue since:7d has:paste",
+        source="tests/unit/cli/test_query_expression.py",
+        line=5584,
+    ),
+    DSLExample(
+        expression="exists message(role:assistant AND text:timeout)",
+        source="tests/unit/cli/test_query_expression.py",
+        line=1660,
+    ),
+    DSLExample(
+        expression='near:"semantic search test"',
+        source="tests/unit/cli/test_query_expression.py",
+        line=5433,
+    ),
+)
+
+
+class WebSearchFacetArguments(WebSearchContractModel):
+    origin: tuple[str, ...] = ()
+    repo: tuple[str, ...] = ()
+    time: WebSearchTimeBucket | None = None
+
+    @field_validator("origin", "repo")
+    @classmethod
+    def _non_empty_unique_tokens(cls, values: tuple[str, ...]) -> tuple[str, ...]:
+        normalized = tuple(dict.fromkeys(value.strip() for value in values if value.strip()))
+        if len(normalized) != len(values):
+            raise ValueError("facet values must be non-empty and unique")
+        return normalized
+
+
+class WebSearchRequestArguments(WebSearchContractModel):
+    expression: str
+    facets: WebSearchFacetArguments
+    retrieval_lane: WebSearchRetrievalLane
+    as_of: str
+
+    @field_validator("as_of")
+    @classmethod
+    def _timezone_aware_frame(cls, value: str) -> str:
+        return _normalize_utc_timestamp(value, field_name="as_of")
+
+
+class WebSearchRequest(WebSearchContractModel):
+    operation: Literal["query"] = WEB_SEARCH_OPERATION
+    arguments: WebSearchRequestArguments
+    page_size: StrictInt = Field(gt=0, le=MAX_WEB_PAGE_SIZE)
+    offset: StrictInt = Field(ge=0)
+    projection: Literal["web-search.v1"] = WEB_SEARCH_PROJECTION
+    stable_order: Literal["rank-score-session-id"] = WEB_SEARCH_STABLE_ORDER
+    query_ref: str = Field(pattern=r"^query:")
+    result_ref: str = Field(pattern=r"^result:")
+
+    @classmethod
+    def from_transaction(cls, request: QueryTransactionRequest, result_ref: str) -> Self:
+        return cls(
+            operation=cast("Literal['query']", request.operation),
+            arguments=WebSearchRequestArguments.model_validate(request.arguments),
+            page_size=request.page_size,
+            offset=request.offset,
+            projection=cast("Literal['web-search.v1']", request.projection),
+            stable_order=cast("Literal['rank-score-session-id']", request.stable_order),
+            query_ref=request.query_ref,
+            result_ref=result_ref,
+        )
+
+
+class WebSearchState(WebSearchContractModel):
+    kind: WebSearchStateKind
+    message: str = Field(min_length=1)
+    detail: str | None = None
+    field: str | None = None
+    corrected_example: str | None = None
+    stale_available: bool = False
+
+
+class WebSearchCoverage(WebSearchContractModel):
+    kind: CoverageKind
+    value: StrictInt | None = Field(default=None, ge=0)
+
+    @model_validator(mode="after")
+    def _coherent_qualifier(self) -> Self:
+        if self.kind == "unknown" and self.value is not None:
+            raise ValueError("unknown coverage cannot carry a value")
+        if self.kind != "unknown" and self.value is None:
+            raise ValueError(f"{self.kind} coverage requires a value")
+        return self
+
+    @classmethod
+    def from_query_coverage(cls, coverage: QueryCoverage) -> Self:
+        return cls(kind=coverage.kind, value=coverage.value)
+
+
+class WebSearchFacetOption(WebSearchContractModel):
+    value: str = Field(min_length=1)
+    count: StrictInt = Field(ge=0)
+    selected: bool = False
+
+
+class WebSearchLabeledFacetOption(WebSearchFacetOption):
+    label: str = Field(min_length=1)
+
+
+class WebSearchFacets(WebSearchContractModel):
+    origin: tuple[WebSearchFacetOption, ...] = ()
+    repo: tuple[WebSearchFacetOption, ...] = ()
+    time: tuple[WebSearchLabeledFacetOption, ...] = ()
+
+
+class WebSearchHitProvenance(WebSearchContractModel):
+    origin: str = Field(min_length=1)
+    session_id: str = Field(min_length=1)
+    session_ref: str = Field(pattern=r"^session:")
+    message_id: str | None = None
+    message_ref: str | None = Field(default=None, pattern=r"^message:")
+    message_anchor: str = Field(min_length=1)
+
+    @model_validator(mode="after")
+    def _message_identity_is_coherent(self) -> Self:
+        if (self.message_id is None) != (self.message_ref is None):
+            raise ValueError("message_id and message_ref must be present together")
+        if self.session_ref != f"session:{self.session_id}":
+            raise ValueError("session_ref must identify session_id")
+        if self.message_id is not None and self.message_ref != f"message:{self.message_id}":
+            raise ValueError("message_ref must identify message_id")
+        return self
+
+
+class WebSearchHit(WebSearchContractModel):
+    rank: StrictInt = Field(gt=0)
+    title: str = Field(min_length=1)
+    snippet: str | None = None
+    retrieval_lane: str = Field(min_length=1)
+    occurred_at: str | None = None
+    repo: str | None = None
+    reader_href: str = Field(pattern=r"^/s/")
+    provenance: WebSearchHitProvenance
+
+    @field_validator("occurred_at")
+    @classmethod
+    def _timezone_aware_occurrence(cls, value: str | None) -> str | None:
+        if value is None:
+            return None
+        return _normalize_utc_timestamp(value, field_name="occurred_at")
+
+
+class WebSearchPage(WebSearchContractModel):
+    has_more: bool = False
+    continuation: str | None = Field(default=None, pattern=r"^q1\.")
+
+    @model_validator(mode="after")
+    def _continuation_matches_flag(self) -> Self:
+        if self.has_more != (self.continuation is not None):
+            raise ValueError("page continuation must be present exactly when has_more is true")
+        return self
+
+
+class WebSearchResponse(WebSearchContractModel):
+    schema_: Literal["web-search.v1"] = Field(
+        default=WEB_SEARCH_PROJECTION,
+        alias="schema",
+        serialization_alias="schema",
+    )
+    generated_at: str
+    request: WebSearchRequest
+    state: WebSearchState
+    coverage: WebSearchCoverage
+    hits: tuple[WebSearchHit, ...] = ()
+    facets: WebSearchFacets
+    page: WebSearchPage = WebSearchPage()
+    resolved_retrieval_lane: str = Field(min_length=1)
+    diagnostics: dict[str, object] | None = None
+    examples: tuple[DSLExample, ...] = WEB_SEARCH_EXAMPLES
+
+    @field_validator("generated_at")
+    @classmethod
+    def _timezone_aware_generation(cls, value: str) -> str:
+        return _normalize_utc_timestamp(value, field_name="generated_at")
+
+    @model_validator(mode="after")
+    def _page_evidence_is_coherent(self) -> Self:
+        ranks = tuple(hit.rank for hit in self.hits)
+        if ranks != tuple(sorted(set(ranks))):
+            raise ValueError("search hit ranks must be unique and increasing")
+        if self.hits and self.coverage.value is not None:
+            observed_end = self.request.offset + len(self.hits)
+            if self.coverage.value < observed_end:
+                raise ValueError("coverage cannot be smaller than the observed page")
+        if self.state.kind == "empty" and self.hits:
+            raise ValueError("empty search state cannot carry hits")
+        return self
+
+    def to_payload(self) -> dict[str, object]:
+        return cast("dict[str, object]", self.model_dump(mode="json", by_alias=True))
+
+
+@dataclass(frozen=True, slots=True)
+class WebSearchExecution:
+    status: HTTPStatus
+    response: WebSearchResponse
+
+    @property
+    def payload(self) -> dict[str, object]:
+        return self.response.to_payload()
+
+
+__all__ = [
+    "DEFAULT_PAGE_SIZE",
+    "DSLExample",
+    "MAX_WEB_PAGE_SIZE",
+    "WEB_SEARCH_EXAMPLES",
+    "WEB_SEARCH_OPERATION",
+    "WEB_SEARCH_PROJECTION",
+    "WEB_SEARCH_STABLE_ORDER",
+    "WebSearchCoverage",
+    "WebSearchExecution",
+    "WebSearchFacetArguments",
+    "WebSearchFacetOption",
+    "WebSearchFacets",
+    "WebSearchHit",
+    "WebSearchHitProvenance",
+    "WebSearchLabeledFacetOption",
+    "WebSearchPage",
+    "WebSearchRequest",
+    "WebSearchRequestArguments",
+    "WebSearchResponse",
+    "WebSearchRetrievalLane",
+    "WebSearchState",
+    "WebSearchStateKind",
+    "WebSearchTimeBucket",
+]
