--- /dev/null
+++ b/webui/src/verticals/search/types.ts
@@ -0,0 +1,258 @@
+import {
+  MAX_WEB_PAGE_SIZE,
+  WEB_SEARCH_PROJECTION,
+  WEB_SEARCH_STABLE_ORDER,
+  type QueryRetrievalLane,
+  type SearchTimeBucket,
+  isQueryRetrievalLane,
+  isSearchTimeBucket,
+  isTimezoneAwareIsoTimestamp,
+} from '../../lib/queryRequest';
+
+export const WEB_SEARCH_SCHEMA = WEB_SEARCH_PROJECTION;
+
+export type SearchStateKind =
+  | 'ready'
+  | 'empty'
+  | 'parse_error'
+  | 'invalid_request'
+  | 'archive_unavailable'
+  | 'fts_lagging'
+  | 'fts_unavailable'
+  | 'embeddings_absent'
+  | 'failed';
+
+export type Coverage =
+  | { kind: 'exact'; value: number }
+  | { kind: 'at_least'; value: number }
+  | { kind: 'unknown'; value: null };
+
+export interface SearchFacetArguments {
+  origin: string[];
+  repo: string[];
+  time: SearchTimeBucket | null;
+}
+
+export interface SearchRequestArguments {
+  expression: string;
+  facets: SearchFacetArguments;
+  retrieval_lane: QueryRetrievalLane;
+  as_of: string;
+}
+
+export interface SearchRequest {
+  operation: 'query';
+  arguments: SearchRequestArguments;
+  page_size: number;
+  offset: number;
+  projection: typeof WEB_SEARCH_SCHEMA;
+  stable_order: typeof WEB_SEARCH_STABLE_ORDER;
+  query_ref: string;
+  result_ref: string;
+}
+
+export interface SearchState {
+  kind: SearchStateKind;
+  message: string;
+  detail: string | null;
+  field: string | null;
+  corrected_example: string | null;
+  stale_available: boolean;
+}
+
+export interface FacetOption {
+  value: string;
+  label?: string;
+  count: number;
+  selected: boolean;
+}
+
+export interface SearchHitProvenance {
+  origin: string;
+  session_id: string;
+  session_ref: string;
+  message_id: string | null;
+  message_ref: string | null;
+  message_anchor: string;
+}
+
+export interface SearchHit {
+  rank: number;
+  title: string;
+  snippet: string | null;
+  retrieval_lane: string;
+  occurred_at: string | null;
+  repo: string | null;
+  reader_href: string;
+  provenance: SearchHitProvenance;
+}
+
+export interface SearchExample {
+  expression: string;
+  source: string;
+  line: number;
+}
+
+export interface WebSearchResponse {
+  schema: typeof WEB_SEARCH_SCHEMA;
+  generated_at: string;
+  request: SearchRequest;
+  state: SearchState;
+  coverage: Coverage;
+  hits: SearchHit[];
+  facets: {
+    origin: FacetOption[];
+    repo: FacetOption[];
+    time: FacetOption[];
+  };
+  page: {
+    has_more: boolean;
+    continuation: string | null;
+  };
+  resolved_retrieval_lane: string;
+  diagnostics: unknown;
+  examples: SearchExample[];
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function isNullableString(value: unknown): value is string | null {
+  return typeof value === 'string' || value === null;
+}
+
+function isNonEmptyString(value: unknown): value is string {
+  return typeof value === 'string' && value.length > 0;
+}
+
+function hasUniqueNonEmptyStrings(value: unknown): value is string[] {
+  return isStringArray(value)
+    && value.every((item) => item.trim() === item && item.length > 0)
+    && new Set(value).size === value.length;
+}
+
+function isStringArray(value: unknown): value is string[] {
+  return Array.isArray(value) && value.every((item) => typeof item === 'string');
+}
+
+function isCoverage(value: unknown): value is Coverage {
+  if (!isRecord(value)) return false;
+  if (value.kind === 'unknown') return value.value === null;
+  return (value.kind === 'exact' || value.kind === 'at_least')
+    && typeof value.value === 'number'
+    && Number.isInteger(value.value)
+    && value.value >= 0;
+}
+
+function isSearchState(value: unknown): value is SearchState {
+  if (!isRecord(value)) return false;
+  const kinds: readonly SearchStateKind[] = [
+    'ready',
+    'empty',
+    'parse_error',
+    'invalid_request',
+    'archive_unavailable',
+    'fts_lagging',
+    'fts_unavailable',
+    'embeddings_absent',
+    'failed',
+  ];
+  return kinds.some((kind) => kind === value.kind)
+    && isNonEmptyString(value.message)
+    && isNullableString(value.detail)
+    && isNullableString(value.field)
+    && isNullableString(value.corrected_example)
+    && typeof value.stale_available === 'boolean';
+}
+
+function isFacetOption(value: unknown): value is FacetOption {
+  return isRecord(value)
+    && isNonEmptyString(value.value)
+    && (value.label === undefined || isNonEmptyString(value.label))
+    && typeof value.count === 'number'
+    && Number.isInteger(value.count)
+    && value.count >= 0
+    && typeof value.selected === 'boolean';
+}
+
+function isSearchHit(value: unknown): value is SearchHit {
+  if (!isRecord(value) || !isRecord(value.provenance)) return false;
+  const provenance = value.provenance;
+  const messageIdentityIsCoherent = provenance.message_id === null
+    ? provenance.message_ref === null
+    : provenance.message_ref === `message:${String(provenance.message_id)}`;
+  return typeof value.rank === 'number'
+    && Number.isInteger(value.rank)
+    && value.rank > 0
+    && isNonEmptyString(value.title)
+    && isNullableString(value.snippet)
+    && isNonEmptyString(value.retrieval_lane)
+    && (value.occurred_at === null || isTimezoneAwareIsoTimestamp(value.occurred_at))
+    && isNullableString(value.repo)
+    && typeof value.reader_href === 'string'
+    && value.reader_href.startsWith('/s/')
+    && isNonEmptyString(provenance.origin)
+    && isNonEmptyString(provenance.session_id)
+    && provenance.session_ref === `session:${String(provenance.session_id)}`
+    && isNullableString(provenance.message_id)
+    && isNullableString(provenance.message_ref)
+    && messageIdentityIsCoherent
+    && isNonEmptyString(provenance.message_anchor);
+}
+
+function isSearchRequest(value: unknown): value is SearchRequest {
+  if (!isRecord(value) || !isRecord(value.arguments)) return false;
+  const args = value.arguments;
+  if (!isRecord(args.facets)) return false;
+  return value.operation === 'query'
+    && typeof args.expression === 'string'
+    && hasUniqueNonEmptyStrings(args.facets.origin)
+    && hasUniqueNonEmptyStrings(args.facets.repo)
+    && (args.facets.time === null || isSearchTimeBucket(args.facets.time))
+    && isQueryRetrievalLane(args.retrieval_lane)
+    && isTimezoneAwareIsoTimestamp(args.as_of)
+    && typeof value.page_size === 'number'
+    && Number.isInteger(value.page_size)
+    && value.page_size > 0
+    && value.page_size <= MAX_WEB_PAGE_SIZE
+    && typeof value.offset === 'number'
+    && Number.isInteger(value.offset)
+    && value.offset >= 0
+    && value.projection === WEB_SEARCH_SCHEMA
+    && value.stable_order === WEB_SEARCH_STABLE_ORDER
+    && typeof value.query_ref === 'string'
+    && value.query_ref.startsWith('query:')
+    && typeof value.result_ref === 'string'
+    && value.result_ref.startsWith('result:');
+}
+
+function isSearchExample(value: unknown): value is SearchExample {
+  return isRecord(value)
+    && typeof value.expression === 'string'
+    && typeof value.source === 'string'
+    && typeof value.line === 'number'
+    && Number.isInteger(value.line)
+    && value.line > 0;
+}
+
+export function isWebSearchResponse(value: unknown): value is WebSearchResponse {
+  if (!isRecord(value) || value.schema !== WEB_SEARCH_SCHEMA) return false;
+  if (!isSearchRequest(value.request) || !isSearchState(value.state) || !isCoverage(value.coverage)) return false;
+  if (!Array.isArray(value.hits) || !value.hits.every(isSearchHit)) return false;
+  if (!isRecord(value.facets)) return false;
+  for (const family of ['origin', 'repo', 'time'] as const) {
+    const options = value.facets[family];
+    if (!Array.isArray(options) || !options.every(isFacetOption)) return false;
+  }
+  if (!isRecord(value.page)) return false;
+  if (typeof value.page.has_more !== 'boolean' || !isNullableString(value.page.continuation)) return false;
+  const continuationIsCoherent = value.page.has_more
+    ? typeof value.page.continuation === 'string' && value.page.continuation.startsWith('q1.')
+    : value.page.continuation === null;
+  return continuationIsCoherent
+    && isTimezoneAwareIsoTimestamp(value.generated_at)
+    && isNonEmptyString(value.resolved_retrieval_lane)
+    && Array.isArray(value.examples)
+    && value.examples.every(isSearchExample);
+}
