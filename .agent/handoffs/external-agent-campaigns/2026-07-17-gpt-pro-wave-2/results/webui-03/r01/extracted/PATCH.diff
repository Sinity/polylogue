diff --git a/webui/src/lib/queryRequest.test.ts b/webui/src/lib/queryRequest.test.ts
new file mode 100644
index 0000000000000000000000000000000000000000..f1de368fae3925e16f8cc1eedf8f7f97ca82889b
--- /dev/null
+++ b/webui/src/lib/queryRequest.test.ts
@@ -0,0 +1,109 @@
+import { describe, expect, test } from 'vitest';
+
+import {
+  buildContinuationUrl,
+  buildQueryTransactionRequest,
+  buildSearchUrl,
+  searchApiUrlForBrowserPage,
+  searchFormValues,
+} from './queryRequest';
+
+describe('search query request builders', () => {
+  test('emits the complete logical request with repeated facet parameters', () => {
+    const url = buildSearchUrl({
+      expression: '  repo:polylogue timeout  ',
+      origins: ['codex-session', 'claude-code-session'],
+      repos: ['polylogue', 'infra'],
+      time: '7d',
+      retrievalLane: 'dialogue',
+      pageSize: 25,
+    });
+    const parsed = new URL(url, 'https://polylogue.invalid');
+
+    expect(parsed.pathname).toBe('/api/search');
+    expect(parsed.searchParams.get('q')).toBe('repo:polylogue timeout');
+    expect(parsed.searchParams.getAll('origin')).toEqual(['codex-session', 'claude-code-session']);
+    expect(parsed.searchParams.getAll('repo')).toEqual(['polylogue', 'infra']);
+    expect(parsed.searchParams.get('time')).toBe('7d');
+    expect(parsed.searchParams.get('retrieval_lane')).toBe('dialogue');
+    expect(parsed.searchParams.get('page_size')).toBe('25');
+  });
+
+  test('can emit the shared transport-neutral query transaction shape', () => {
+    const request = buildQueryTransactionRequest({
+      expression: '  near:"semantic search test"  ',
+      origins: ['codex-session', 'codex-session'],
+      repos: ['polylogue'],
+      time: 'all',
+      retrievalLane: 'auto',
+      pageSize: 20,
+    }, '2026-07-17T12:00:00Z');
+
+    expect(request).toEqual({
+      operation: 'query',
+      arguments: {
+        expression: 'near:"semantic search test"',
+        facets: {
+          origin: ['codex-session'],
+          repo: ['polylogue'],
+          time: null,
+        },
+        retrieval_lane: 'auto',
+        as_of: '2026-07-17T12:00:00Z',
+      },
+      page_size: 20,
+      offset: 0,
+      projection: 'web-search.v1',
+      stable_order: 'rank-score-session-id',
+    });
+  });
+
+  test('rejects transaction frames outside the server contract', () => {
+    const values = {
+      expression: 'timeout',
+      origins: [],
+      repos: [],
+      time: null,
+      retrievalLane: 'auto' as const,
+      pageSize: 101,
+    };
+
+    expect(() => buildQueryTransactionRequest(values, '2026-07-17T12:00:00Z')).toThrow(/between 1 and 100/);
+    expect(() => buildQueryTransactionRequest({ ...values, pageSize: 20 }, '2026-07-17T12:00:00')).toThrow(
+      /timezone-aware/,
+    );
+  });
+
+  test('replays an opaque continuation without reconstructing semantic fields', () => {
+    const url = buildContinuationUrl('q1.complete-request');
+    const parsed = new URL(url, 'https://polylogue.invalid');
+
+    expect([...parsed.searchParams.keys()]).toEqual(['continuation']);
+    expect(parsed.searchParams.get('continuation')).toBe('q1.complete-request');
+  });
+
+  test('normalizes the no-time option and rejects a non-canonical retrieval lane', () => {
+    const form = document.createElement('form');
+    form.innerHTML = `
+      <input name="q" value="timeout">
+      <input name="origin" value="codex-session" checked type="checkbox">
+      <input name="time" value="all" checked type="radio">
+      <select name="retrieval_lane"><option value="semantic" selected>semantic</option></select>
+    `;
+
+    expect(searchFormValues(form, 20)).toEqual({
+      expression: 'timeout',
+      origins: ['codex-session'],
+      repos: [],
+      time: null,
+      retrievalLane: 'auto',
+      pageSize: 20,
+    });
+  });
+  test('maps browser history entries back to the JSON route without changing query state', () => {
+    expect(searchApiUrlForBrowserPage('/search?q=timeout&origin=codex-session')).toBe(
+      '/api/search?q=timeout&origin=codex-session',
+    );
+  });
+
+});
diff --git a/webui/src/lib/queryRequest.ts b/webui/src/lib/queryRequest.ts
new file mode 100644
index 0000000000000000000000000000000000000000..9b093a4f55862dde8ee0fba4dc9b0f2df162d837
--- /dev/null
+++ b/webui/src/lib/queryRequest.ts
@@ -0,0 +1,154 @@
+export const WEB_SEARCH_PROJECTION = 'web-search.v1' as const;
+export const WEB_SEARCH_STABLE_ORDER = 'rank-score-session-id' as const;
+export const QUERY_RETRIEVAL_LANES = ['auto', 'dialogue', 'actions', 'hybrid'] as const;
+export const SEARCH_TIME_BUCKETS = ['24h', '7d', '30d', 'all'] as const;
+export const MAX_WEB_PAGE_SIZE = 100;
+
+export type QueryRetrievalLane = typeof QUERY_RETRIEVAL_LANES[number];
+export type SearchTimeBucket = typeof SEARCH_TIME_BUCKETS[number];
+
+export interface SearchFormValues {
+  expression: string;
+  origins: readonly string[];
+  repos: readonly string[];
+  time: SearchTimeBucket | null;
+  retrievalLane: QueryRetrievalLane;
+  pageSize: number;
+}
+
+export interface SearchQueryTransactionRequest {
+  operation: 'query';
+  arguments: {
+    expression: string;
+    facets: {
+      origin: string[];
+      repo: string[];
+      time: string | null;
+    };
+    retrieval_lane: QueryRetrievalLane;
+    as_of: string;
+  };
+  page_size: number;
+  offset: number;
+  projection: typeof WEB_SEARCH_PROJECTION;
+  stable_order: typeof WEB_SEARCH_STABLE_ORDER;
+}
+
+export function isQueryRetrievalLane(value: unknown): value is QueryRetrievalLane {
+  return typeof value === 'string'
+    && QUERY_RETRIEVAL_LANES.some((candidate) => candidate === value);
+}
+
+export function isSearchTimeBucket(value: unknown): value is SearchTimeBucket {
+  return typeof value === 'string'
+    && SEARCH_TIME_BUCKETS.some((candidate) => candidate === value);
+}
+
+export function isTimezoneAwareIsoTimestamp(value: unknown): value is string {
+  return typeof value === 'string'
+    && /(?:Z|[+-]\d{2}:\d{2})$/i.test(value)
+    && !Number.isNaN(Date.parse(value));
+}
+
+function normalizeMany(values: readonly string[]): string[] {
+  const normalized: string[] = [];
+  const seen = new Set<string>();
+  for (const value of values) {
+    const token = value.trim();
+    if (!token || seen.has(token)) continue;
+    seen.add(token);
+    normalized.push(token);
+  }
+  return normalized;
+}
+
+export function buildQueryTransactionRequest(
+  values: SearchFormValues,
+  asOf: string,
+  offset = 0,
+): SearchQueryTransactionRequest {
+  if (!isTimezoneAwareIsoTimestamp(asOf)) {
+    throw new Error('search query request requires a timezone-aware as_of execution frame');
+  }
+  if (!Number.isInteger(values.pageSize) || values.pageSize < 1 || values.pageSize > MAX_WEB_PAGE_SIZE) {
+    throw new Error(`search query page size must be between 1 and ${MAX_WEB_PAGE_SIZE}`);
+  }
+  if (!Number.isInteger(offset) || offset < 0) {
+    throw new Error('search query offset must be a non-negative integer');
+  }
+  return {
+    operation: 'query',
+    arguments: {
+      expression: values.expression.trim(),
+      facets: {
+        origin: normalizeMany(values.origins),
+        repo: normalizeMany(values.repos),
+        time: values.time === 'all' ? null : values.time,
+      },
+      retrieval_lane: values.retrievalLane,
+      as_of: asOf,
+    },
+    page_size: values.pageSize,
+    offset,
+    projection: WEB_SEARCH_PROJECTION,
+    stable_order: WEB_SEARCH_STABLE_ORDER,
+  };
+}
+
+function appendMany(params: URLSearchParams, name: string, values: readonly string[]): void {
+  for (const value of normalizeMany(values)) params.append(name, value);
+}
+
+export function buildSearchUrl(
+  values: SearchFormValues,
+  endpoint = '/api/search',
+): string {
+  const params = new URLSearchParams();
+  const expression = values.expression.trim();
+  if (expression) params.set('q', expression);
+  appendMany(params, 'origin', values.origins);
+  appendMany(params, 'repo', values.repos);
+  if (values.time) params.set('time', values.time);
+  params.set('retrieval_lane', values.retrievalLane);
+  params.set('page_size', String(values.pageSize));
+  return `${endpoint}?${params.toString()}`;
+}
+
+export function buildContinuationUrl(token: string, endpoint = '/api/search'): string {
+  if (!token) throw new Error('search continuation must not be empty');
+  const params = new URLSearchParams();
+  params.set('continuation', token);
+  return `${endpoint}?${params.toString()}`;
+}
+
+export function searchFormValues(form: HTMLFormElement, pageSize: number): SearchFormValues {
+  const data = new FormData(form);
+  const selected = (name: string): string[] => data.getAll(name).map(String).filter(Boolean);
+  const requestedTime = data.get('time');
+  const requestedLane = String(data.get('retrieval_lane') ?? 'auto');
+  return {
+    expression: String(data.get('q') ?? ''),
+    origins: selected('origin'),
+    repos: selected('repo'),
+    time: requestedTime !== null
+      && String(requestedTime) !== 'all'
+      && isSearchTimeBucket(String(requestedTime))
+      ? String(requestedTime) as SearchTimeBucket
+      : null,
+    retrievalLane: isQueryRetrievalLane(requestedLane) ? requestedLane : 'auto',
+    pageSize,
+  };
+}
+
+export function browserPageUrl(apiUrl: string): string {
+  const parsed = new URL(apiUrl, window.location.origin);
+  parsed.pathname = '/search';
+  return `${parsed.pathname}${parsed.search}`;
+}
+
+export function searchApiUrlForBrowserPage(pageUrl: string | URL = window.location.href): string {
+  const parsed = new URL(pageUrl, window.location.origin);
+  parsed.pathname = '/api/search';
+  parsed.hash = '';
+  return `${parsed.pathname}${parsed.search}`;
+}
