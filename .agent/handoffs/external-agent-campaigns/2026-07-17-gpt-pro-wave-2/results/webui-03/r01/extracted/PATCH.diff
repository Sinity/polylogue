+def test_archive_tiers_search_pages_distinct_sessions_before_applying_offset(tmp_path: Path) -> None:
+    first = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="codex-search-page-first",
+        updated_at="2026-01-03T00:00:00Z",
+        messages=[
+            ParsedMessage(
+                provider_message_id="m1",
+                role=Role.USER,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="paging needle first")],
+            ),
+            ParsedMessage(
+                provider_message_id="m2",
+                role=Role.ASSISTANT,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="paging needle repeated")],
+            ),
+        ],
+    )
+    second = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="codex-search-page-second",
+        updated_at="2026-01-02T00:00:00Z",
+        messages=[
+            ParsedMessage(
+                provider_message_id="m1",
+                role=Role.USER,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="paging needle second session")],
+            )
+        ],
+    )
+    root = tmp_path / "archive"
+
+    with ArchiveStore(root) as facade:
+        first_id = facade.write_parsed(first)
+        second_id = facade.write_parsed(second)
+
+    with ArchiveStore.open_existing(root) as facade:
+        complete = facade.search_summaries("paging needle", limit=10)
+        first_page = facade.search_summaries("paging needle", limit=1)
+        second_page = facade.search_summaries("paging needle", limit=1, offset=1)
+
+    assert len(complete) == 2
+    assert {hit.session_id for hit in complete} == {first_id, second_id}
+    assert [hit.session_id for hit in first_page + second_page] == [hit.session_id for hit in complete]
+    assert first_page[0].rank == 1
+    assert second_page[0].rank == 2
+
+
+def test_archive_tiers_selects_representative_messages_for_many_sessions_in_one_projection(tmp_path: Path) -> None:
+    preferred = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="codex-evidence-preferred",
+        updated_at="2026-01-03T00:00:00Z",
+        messages=[
+            ParsedMessage(
+                provider_message_id="system",
+                role=Role.SYSTEM,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="system prelude")],
+            ),
+            ParsedMessage(
+                provider_message_id="user",
+                role=Role.USER,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="preferred user evidence")],
+            ),
+        ],
+    )
+    fallback = ParsedSession(
+        source_name=Provider.CODEX,
+        provider_session_id="codex-evidence-fallback",
+        updated_at="2026-01-02T00:00:00Z",
+        messages=[
+            ParsedMessage(
+                provider_message_id="system",
+                role=Role.SYSTEM,
+                blocks=[ParsedContentBlock(type=BlockType.TEXT, text="fallback system evidence")],
+            )
+        ],
+    )
+    root = tmp_path / "archive"
+
+    with ArchiveStore(root) as facade:
+        preferred_id = facade.write_parsed(preferred)
+        fallback_id = facade.write_parsed(fallback)
+
+    with ArchiveStore.open_existing(root) as facade:
+        rows = facade.query_session_message_evidence([preferred_id, fallback_id, preferred_id])
+
+    by_session = {row.session_id: row for row in rows}
+    assert set(by_session) == {preferred_id, fallback_id}
+    assert by_session[preferred_id].message_id.endswith(":user")
+    assert by_session[preferred_id].text == "preferred user evidence"
+    assert by_session[fallback_id].message_id.endswith(":system")
+    assert by_session[fallback_id].text == "fallback system evidence"
