+    def query_session_message_evidence(
+        self,
+        session_ids: Sequence[str],
+    ) -> list[ArchiveMessageEvidenceRow]:
+        """Return one representative message per session in a single bounded read.
+
+        User and assistant messages are preferred; sessions without either role
+        fall back to their first normalized message.  The per-session window is
+        applied before projection so one page never performs an N+1 message read.
+        """
+
+        normalized_session_ids = tuple(
+            dict.fromkeys(session_id.strip() for session_id in session_ids if session_id.strip())
+        )
+        if not normalized_session_ids:
+            return []
+        placeholders = ", ".join("?" for _ in normalized_session_ids)
+        rows = self._conn.execute(
+            f"""
+            WITH candidate_messages AS MATERIALIZED (
+                SELECT
+                    m.session_id,
+                    m.message_id,
+                    COALESCE((
+                        SELECT group_concat(ordered.search_text, char(10))
+                        FROM (
+                            SELECT b.search_text
+                            FROM blocks b
+                            WHERE b.message_id = m.message_id
+                              AND b.search_text IS NOT NULL
+                            ORDER BY b.position, b.block_id
+                        ) AS ordered
+                    ), '') AS text,
+                    ROW_NUMBER() OVER (
+                        PARTITION BY m.session_id
+                        ORDER BY
+                            CASE WHEN m.role IN ('user', 'assistant') THEN 0 ELSE 1 END,
+                            m.position,
+                            m.variant_index,
+                            m.message_id
+                    ) AS evidence_ordinal
+                FROM messages m INDEXED BY idx_messages_session_sortkey
+                WHERE m.session_id IN ({placeholders})
+            )
+            SELECT session_id, message_id, text
+            FROM candidate_messages
+            WHERE evidence_ordinal = 1
+            ORDER BY session_id
+            """,
+            normalized_session_ids,
