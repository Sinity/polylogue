+"""Semantic SSR renderer for the WebUI v2 search projection."""
+
+from __future__ import annotations
+
+from collections.abc import Sequence
+from html import escape
+from urllib.parse import urlencode
+
+from polylogue.archive.query.spec import QUERY_RETRIEVAL_LANES
+from polylogue.daemon.web_search_contract import (
+    WEB_SEARCH_ASSET,
+    WEB_SEARCH_EXAMPLES,
+    WebSearchFacetOption,
+    WebSearchHit,
+    WebSearchResponse,
+    WebSearchState,
+)
+
+
+def _checked(value: bool) -> str:
+    return " checked" if value else ""
+
+
+def _render_state(state: WebSearchState) -> str:
+    kind = escape(state.kind)
+    body = (
+        f'<section class="search-state search-state--{kind}" role="status" '
+        f'data-search-state="{kind}"><strong>{escape(state.message)}</strong>'
+    )
+    if state.detail:
+        body += f"<p>{escape(state.detail)}</p>"
+    if state.corrected_example:
+        body += f"<p>Try <code>{escape(state.corrected_example)}</code></p>"
+    return body + "</section>"
+
+
+def _render_facet_group(
+    title: str,
+    name: str,
+    options: Sequence[WebSearchFacetOption],
+    *,
+    radio: bool = False,
+) -> str:
+    input_type = "radio" if radio else "checkbox"
+    rows = []
+    for option in options:
+        label = str(getattr(option, "label", option.value))
+        rows.append(
+            '<label class="facet-option">'
+            f'<input type="{input_type}" name="{escape(name)}" value="{escape(option.value, quote=True)}"'
+            f"{_checked(option.selected)}>"
+            f"<span>{escape(label)}</span><small>{option.count}</small></label>"
+        )
+    return f"<fieldset><legend>{escape(title)}</legend>{''.join(rows)}</fieldset>"
+
+
+def _render_hits(hits: Sequence[WebSearchHit]) -> str:
+    rows: list[str] = []
+    for hit in hits:
+        provenance = hit.provenance
+        meta = [
+            f'<span class="origin-badge">{escape(provenance.origin)}</span>',
+            f"<code>{escape(provenance.session_ref)}</code>",
+        ]
+        if provenance.message_ref:
+            meta.append(f"<code>{escape(provenance.message_ref)}</code>")
+        if hit.repo:
+            meta.append(f"<span>{escape(hit.repo)}</span>")
+        if hit.occurred_at:
+            occurred_at = escape(hit.occurred_at)
+            meta.append(f'<time datetime="{escape(hit.occurred_at, quote=True)}">{occurred_at}</time>')
+        snippet = f"<p>{escape(hit.snippet)}</p>" if hit.snippet else ""
+        rows.append(
+            '<article class="search-hit">'
+            f'<h2><a href="{escape(hit.reader_href, quote=True)}">{escape(hit.title)}</a></h2>'
+            f'<div class="hit-meta">{"".join(meta)}</div>{snippet}</article>'
+        )
+    return "".join(rows) or '<p class="empty-results">No result rows to display.</p>'
+
+
+def _coverage_label(response: WebSearchResponse) -> str:
+    coverage = response.coverage
+    if coverage.kind == "exact":
+        return f"{coverage.value} exact matches"
+    if coverage.kind == "at_least":
+        return f"At least {coverage.value} matches"
+    return "Match total unknown"
+
+
+def _safe_initial_json(response: WebSearchResponse) -> str:
+    return (
+        response.model_dump_json(by_alias=True)
+        .replace("<", "\\u003c")
+        .replace("\u2028", "\\u2028")
+        .replace("\u2029", "\\u2029")
+    )
+
+
+def render_web_search_page(response: WebSearchResponse) -> str:
+    """Render a complete first page that remains useful without JavaScript."""
+    request = response.request
+    arguments = request.arguments
+    continuation = response.page.continuation
+    paging = ""
+    if continuation:
+        href = "/search?" + urlencode({"continuation": continuation})
+        paging = f'<a class="load-more" data-search-continuation href="{escape(href, quote=True)}">Load more</a>'
+    lane_options = "".join(
+        f'<option value="{escape(value)}"{" selected" if value == arguments.retrieval_lane else ""}>'
+        f"{escape(value)}</option>"
+        for value in QUERY_RETRIEVAL_LANES
+    )
+
+    return f"""<!doctype html>
+<html lang="en">
+<head>
+<meta charset="utf-8">
+<meta name="viewport" content="width=device-width,initial-scale=1">
+<title>Search · Polylogue</title>
+<style>
+:root{{--search-bg:#f6f6f3;--search-panel:#fff;--search-text:#171714;--search-muted:#64645d;--search-border:#d8d8d0;--search-accent:#245bdb;--search-alert:#fff4d6}}
+*{{box-sizing:border-box}} body{{margin:0;background:var(--search-bg);color:var(--search-text);font:15px/1.5 system-ui,sans-serif}}
+a{{color:var(--search-accent)}} header{{padding:1.25rem max(1rem,4vw);border-bottom:1px solid var(--search-border);background:var(--search-panel)}}
+header h1{{margin:0 0 .25rem;font-size:1.45rem}} header p{{margin:0;color:var(--search-muted)}}
+.search-layout{{display:grid;grid-template-columns:minmax(15rem,20rem) minmax(0,1fr);gap:1.25rem;max-width:92rem;margin:0 auto;padding:1.25rem}}
+.search-panel{{background:var(--search-panel);border:1px solid var(--search-border);border-radius:.6rem;padding:1rem}} .query-row{{display:flex;gap:.6rem}}
+.query-row input{{min-width:0;flex:1;padding:.7rem;border:1px solid var(--search-border);border-radius:.4rem}} button,.load-more{{display:inline-block;padding:.65rem .9rem;border:1px solid var(--search-accent);border-radius:.4rem;background:var(--search-accent);color:#fff;text-decoration:none;cursor:pointer}}
+fieldset{{margin:0 0 1rem;padding:0;border:0}} legend{{font-weight:700;margin-bottom:.35rem}} .facet-option{{display:grid;grid-template-columns:auto 1fr auto;gap:.45rem;align-items:center;padding:.25rem 0}} .facet-option small{{color:var(--search-muted)}}
+.search-state{{margin:0 0 1rem;padding:.8rem;border:1px solid var(--search-border);border-radius:.45rem;background:var(--search-alert)}} .search-state p{{margin:.3rem 0 0}}
+.results-heading{{display:flex;justify-content:space-between;gap:1rem;align-items:baseline}} .results-heading h2{{font-size:1rem;margin:.1rem 0 1rem}} .results-heading span{{color:var(--search-muted)}}
+.search-hit{{padding:1rem 0;border-top:1px solid var(--search-border)}} .search-hit:first-child{{border-top:0}} .search-hit h2{{font-size:1.08rem;margin:0 0 .35rem}} .search-hit p{{margin:.55rem 0 0;white-space:pre-wrap}} .hit-meta{{display:flex;flex-wrap:wrap;gap:.45rem;color:var(--search-muted);font-size:.82rem}} .origin-badge{{padding:.05rem .35rem;border:1px solid var(--search-border);border-radius:999px}} code{{overflow-wrap:anywhere}} .paging{{padding-top:1rem}} .examples{{margin-top:1rem;color:var(--search-muted)}}
+@media(max-width:760px){{.search-layout{{grid-template-columns:1fr}} .query-row{{flex-direction:column}}}}
+</style>
+</head>
+<body>
+<header><h1>Polylogue search</h1><p>FTS, structured DSL, and semantic retrieval over the archive.</p></header>
+<main data-web-search-island class="search-layout">
+<aside class="search-panel">
+<form action="/search" method="get" data-search-form>
+<input type="hidden" name="page_size" value="{request.page_size}">
+<fieldset><legend>Query</legend><div class="query-row"><input name="q" value="{escape(arguments.expression, quote=True)}" placeholder="{escape(WEB_SEARCH_EXAMPLES[1].expression, quote=True)}" aria-label="Search expression"><button type="submit">Search</button></div></fieldset>
+<fieldset><legend>Retrieval lane</legend><select name="retrieval_lane">{lane_options}</select></fieldset>
+{_render_facet_group("Origin", "origin", response.facets.origin)}
+{_render_facet_group("Repository", "repo", response.facets.repo)}
+{_render_facet_group("Time", "time", response.facets.time, radio=True)}
+</form>
+<details class="examples"><summary>DSL examples</summary><ul>{"".join(f"<li><code>{escape(example.expression)}</code></li>" for example in WEB_SEARCH_EXAMPLES)}</ul></details>
+</aside>
+<section class="search-panel" aria-live="polite" aria-busy="false">
+{_render_state(response.state)}
+<div class="results-heading"><h2>Results</h2><span>{escape(_coverage_label(response))}</span></div>
+<div data-search-results>{_render_hits(response.hits)}</div>
+<div class="paging" data-search-paging>{paging}</div>
+</section>
+</main>
+<script id="web-search-initial" type="application/json">{_safe_initial_json(response)}</script>
+<script type="module" src="{WEB_SEARCH_ASSET}"></script>
+</body>
+</html>"""
+
+
+__all__ = ["render_web_search_page"]
