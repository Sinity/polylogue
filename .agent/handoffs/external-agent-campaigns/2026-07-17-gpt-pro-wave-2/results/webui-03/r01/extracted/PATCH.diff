+++ b/webui/src/verticals/search/types.test.ts
@@ -0,0 +1,97 @@
+import { describe, expect, test } from 'vitest';
+
+import { type WebSearchResponse, isWebSearchResponse } from './types';
+
+function validResponse(): WebSearchResponse {
+  return {
+    schema: 'web-search.v1',
+    generated_at: '2026-07-17T12:00:00Z',
+    request: {
+      operation: 'query',
+      arguments: {
+        expression: 'repo:polylogue',
+        facets: { origin: ['codex-session'], repo: [], time: '7d' },
+        retrieval_lane: 'dialogue',
+        as_of: '2026-07-17T12:00:00Z',
+      },
+      page_size: 20,
+      offset: 0,
+      projection: 'web-search.v1',
+      stable_order: 'rank-score-session-id',
+      query_ref: 'query:one',
+      result_ref: 'result:one',
+    },
+    state: {
+      kind: 'ready',
+      message: 'Search results are ready.',
+      detail: null,
+      field: null,
+      corrected_example: null,
+      stale_available: false,
+    },
+    coverage: { kind: 'exact', value: 1 },
+    hits: [{
+      rank: 1,
+      title: 'Result',
+      snippet: 'Matching text',
+      retrieval_lane: 'dialogue',
+      occurred_at: '2026-07-17T11:00:00Z',
+      repo: 'polylogue',
+      reader_href: '/s/session-one#message-message-one',
+      provenance: {
+        origin: 'codex-session',
+        session_id: 'session-one',
+        session_ref: 'session:session-one',
+        message_id: 'message-one',
+        message_ref: 'message:message-one',
+        message_anchor: 'message-message-one',
+      },
+    }],
+    facets: {
+      origin: [{ value: 'codex-session', count: 1, selected: true }],
+      repo: [{ value: 'polylogue', count: 1, selected: false }],
+      time: [{ value: '7d', label: 'Past 7 days', count: 1, selected: true }],
+    },
+    page: { has_more: true, continuation: 'q1.next-page' },
+    resolved_retrieval_lane: 'dialogue',
+    diagnostics: null,
+    examples: [{ expression: 'repo:polylogue', source: 'tests/unit/cli/test_query_expression.py', line: 5345 }],
+  };
+}
+
+describe('WebSearchResponse runtime contract', () => {
+  test('accepts the complete canonical response', () => {
+    expect(isWebSearchResponse(validResponse())).toBe(true);
+  });
+
+  test('rejects a continuation whose has-more flag is false', () => {
+    const response = validResponse();
+    response.page = { has_more: false, continuation: 'q1.impossible' };
+
+    expect(isWebSearchResponse(response)).toBe(false);
+  });
+
+  test('rejects provenance that no longer identifies the projected message', () => {
+    const response = validResponse();
+    const first = response.hits[0];
+    if (!first) throw new Error('fixture requires one hit');
+    first.provenance.message_ref = 'message:other';
+
+    expect(isWebSearchResponse(response)).toBe(false);
+  });
+
+  test('rejects noncanonical time frames and oversized pages', () => {
+    const response = validResponse();
+    response.request.arguments.facets.time = 'forever' as '7d';
+    response.request.page_size = 101;
+
+    expect(isWebSearchResponse(response)).toBe(false);
+  });
+
+  test('rejects timezone-free execution frames', () => {
+    const response = validResponse();
+    response.request.arguments.as_of = '2026-07-17T12:00:00';
+
+    expect(isWebSearchResponse(response)).toBe(false);
+  });
+});
diff --git a/webui/src/verticals/search/types.ts b/webui/src/verticals/search/types.ts
