+import { fireEvent, render, screen, waitFor } from '@testing-library/preact';
+import { describe, expect, test, vi } from 'vitest';
+
+import { SearchIsland } from '../SearchIsland';
+import { type SearchHit, type WebSearchResponse } from '../types';
+
+function hit(id: string, title: string): SearchHit {
+  return {
+    rank: 1,
+    title,
+    snippet: `${title} snippet`,
+    retrieval_lane: 'dialogue',
+    occurred_at: '2026-07-17T12:00:00Z',
+    repo: 'polylogue',
+    reader_href: `/s/${id}#message-${id}`,
+    provenance: {
+      origin: 'codex-session',
+      session_id: id,
+      session_ref: `session:${id}`,
+      message_id: `m-${id}`,
+      message_ref: `message:m-${id}`,
+      message_anchor: `message-m-${id}`,
+    },
+  };
+}
+
+function fixture(overrides: Partial<WebSearchResponse> = {}): WebSearchResponse {
+  return {
+    schema: 'web-search.v1',
+    generated_at: '2026-07-17T12:00:00Z',
+    request: {
+      operation: 'query',
+      arguments: {
+        expression: 'timeout',
+        facets: { origin: [], repo: [], time: null },
+        retrieval_lane: 'dialogue',
+        as_of: '2026-07-17T12:00:00Z',
+      },
+      page_size: 20,
+      offset: 0,
+      projection: 'web-search.v1',
+      stable_order: 'rank-score-session-id',
+      query_ref: 'query:one',
+      result_ref: 'result:one',
+    },
+    state: {
+      kind: 'ready',
+      message: 'Search results are ready.',
+      detail: null,
+      field: null,
+      corrected_example: null,
+      stale_available: false,
+    },
+    coverage: { kind: 'exact', value: 2 },
+    hits: [hit('one', 'First result')],
+    facets: {
+      origin: [
+        { value: 'codex-session', count: 1, selected: false },
+        { value: 'claude-code-session', count: 1, selected: false },
+      ],
+      repo: [{ value: 'polylogue', count: 2, selected: false }],
+      time: [
+        { value: '24h', label: 'Past 24 hours', count: 1, selected: false },
+        { value: 'all', label: 'Any time', count: 2, selected: true },
+      ],
+    },
+    page: { has_more: true, continuation: 'q1.next-page' },
+    resolved_retrieval_lane: 'dialogue',
+    diagnostics: null,
+    examples: [
+      { expression: 'repo:polylogue', source: 'tests/unit/cli/test_query_expression.py', line: 5345 },
+      { expression: 'repo:polylogue since:7d has:paste', source: 'tests/unit/cli/test_query_expression.py', line: 5584 },
+    ],
+    ...overrides,
+  };
+}
+
+function jsonResponse(payload: WebSearchResponse, status = 200): Response {
+  return new Response(JSON.stringify(payload), {
+    status,
+    headers: { 'content-type': 'application/json' },
+  });
+}
+
+describe('SearchIsland', () => {
+  test('replays only the opaque continuation and appends server order verbatim', async () => {
+    const next = fixture({
+      request: { ...fixture().request, offset: 20 },
+      hits: [hit('two', 'Second result'), hit('three', 'Third result')],
+      page: { has_more: false, continuation: null },
+    });
+    const fetchMock = vi.spyOn(globalThis, 'fetch').mockResolvedValue(jsonResponse(next));
+
+    render(<SearchIsland initial={fixture()} />);
+    fireEvent.click(screen.getByRole('link', { name: 'Load more' }));
+
+    await screen.findByText('Third result');
+    expect(fetchMock).toHaveBeenCalledTimes(1);
+    expect(String(fetchMock.mock.calls[0]?.[0])).toBe('/api/search?continuation=q1.next-page');
+    const titles = screen.getAllByRole('heading', { level: 2 }).map((node) => node.textContent);
+    expect(titles).toEqual(['Results', 'First result', 'Second result', 'Third result']);
+  });
+
+  test('keeps the completed page and exposes a typed continuation failure for retry', async () => {
+    const failed = fixture({
+      request: { ...fixture().request, offset: 20 },
+      state: {
+        kind: 'failed',
+        message: 'Archive storage could not complete this search.',
+        detail: 'The result page was withheld because its completeness could not be verified.',
+        field: null,
+        corrected_example: null,
+        stale_available: false,
+      },
+      coverage: { kind: 'unknown', value: null },
+      hits: [],
+      page: { has_more: false, continuation: null },
+    });
+    vi.spyOn(globalThis, 'fetch').mockResolvedValue(jsonResponse(failed, 503));
+
+    render(<SearchIsland initial={fixture()} />);
+    fireEvent.click(screen.getByRole('link', { name: 'Load more' }));
+
+    const alert = await screen.findByRole('alert');
+    expect(alert.textContent).toContain('Archive storage could not complete this search.');
+    expect(screen.getByText('First result')).toBeTruthy();
+    expect(screen.getByRole('link', { name: 'Load more' })).toBeTruthy();
+  });
+
+  test('renders qualified coverage without treating it as an exact total', () => {
+    render(<SearchIsland initial={fixture({ coverage: { kind: 'at_least', value: 23 } })} />);
+
+    expect(screen.getByText('At least 23 matches')).toBeTruthy();
+  });
+
+  test('renders parser diagnostics and the server-provided corrected example', () => {
+    render(<SearchIsland initial={fixture({
+      state: {
+        kind: 'parse_error',
+        message: 'The query could not be parsed.',
+        detail: "Unexpected token ')' at column 7",
+        field: 'expression',
+        corrected_example: 'repo:polylogue since:7d has:paste',
+        stale_available: false,
+      },
+      coverage: { kind: 'unknown', value: null },
+      hits: [],
+      page: { has_more: false, continuation: null },
+    })} />);
+
+    expect(screen.getByText('The query could not be parsed.')).toBeTruthy();
+    expect(screen.getByText("Unexpected token ')' at column 7")).toBeTruthy();
+    expect(screen.getAllByText('repo:polylogue since:7d has:paste')).toHaveLength(2);
+    expect(screen.getByText('Match total unknown')).toBeTruthy();
+  });
+
+  test('keeps visible hits unchanged until the server returns selected facets', async () => {
+    let resolveFetch: ((response: Response) => void) | undefined;
+    const pending = new Promise<Response>((resolve) => { resolveFetch = resolve; });
+    const fetchMock = vi.spyOn(globalThis, 'fetch').mockReturnValue(pending);
+    const next = fixture({
+      request: {
+        ...fixture().request,
+        query_ref: 'query:codex',
+        arguments: {
+          ...fixture().request.arguments,
+          facets: { origin: ['codex-session'], repo: [], time: null },
+        },
+      },
+      hits: [hit('codex', 'Server-filtered result')],
+      facets: {
+        ...fixture().facets,
+        origin: [
+          { value: 'codex-session', count: 1, selected: true },
+          { value: 'claude-code-session', count: 0, selected: false },
+        ],
+      },
+      page: { has_more: false, continuation: null },
+      coverage: { kind: 'exact', value: 1 },
+    });
+
+    render(<SearchIsland initial={fixture()} />);
+    fireEvent.click(screen.getByRole('checkbox', { name: /codex-session/ }));
+
+    expect(screen.getByText('First result')).toBeTruthy();
+    expect(screen.queryByText('Server-filtered result')).toBeNull();
+    const requested = String(fetchMock.mock.calls[0]?.[0]);
+    expect(requested).toContain('/api/search?');
+    expect(requested).toContain('origin=codex-session');
+    expect(requested).toContain('q=timeout');
+
+    resolveFetch?.(jsonResponse(next));
+    await waitFor(() => expect(screen.getByText('Server-filtered result')).toBeTruthy());
+    expect(screen.queryByText('First result')).toBeNull();
+    expect(screen.getByRole('checkbox', { name: /codex-session/ })).toHaveProperty('checked', true);
+  });
+  test('keeps the newest facet response when requests resolve out of order', async () => {
+    let resolveFirst: ((response: Response) => void) | undefined;
+    let resolveSecond: ((response: Response) => void) | undefined;
+    const firstPending = new Promise<Response>((resolve) => { resolveFirst = resolve; });
+    const secondPending = new Promise<Response>((resolve) => { resolveSecond = resolve; });
+    const fetchMock = vi.spyOn(globalThis, 'fetch')
+      .mockReturnValueOnce(firstPending)
+      .mockReturnValueOnce(secondPending);
+    const first = fixture({
+      request: { ...fixture().request, query_ref: 'query:first-response' },
+      hits: [hit('stale', 'Stale response')],
+    });
+    const second = fixture({
+      request: { ...fixture().request, query_ref: 'query:newest-response' },
+      hits: [hit('newest', 'Newest response')],
+    });
+
+    render(<SearchIsland initial={fixture()} />);
+    fireEvent.click(screen.getByRole('checkbox', { name: /codex-session/ }));
+    fireEvent.click(screen.getByRole('checkbox', { name: /claude-code-session/ }));
+
+    expect(fetchMock).toHaveBeenCalledTimes(2);
+    resolveSecond?.(jsonResponse(second));
+    await screen.findByText('Newest response');
+
+    resolveFirst?.(jsonResponse(first));
+    await Promise.resolve();
+    expect(screen.getByText('Newest response')).toBeTruthy();
+    expect(screen.queryByText('Stale response')).toBeNull();
+  });
+
+  test('restores browser history entries through the server without pushing a duplicate entry', async () => {
+    const restored = fixture({
+      request: {
+        ...fixture().request,
+        query_ref: 'query:restored',
+        arguments: {
+          ...fixture().request.arguments,
+          expression: 'restored query',
+        },
+      },
+      hits: [hit('restored', 'Restored result')],
+      page: { has_more: false, continuation: null },
+      coverage: { kind: 'exact', value: 1 },
+    });
+    const fetchMock = vi.spyOn(globalThis, 'fetch').mockResolvedValue(jsonResponse(restored));
+    const pushState = vi.spyOn(window.history, 'pushState');
+
+    render(<SearchIsland initial={fixture()} />);
+    window.history.replaceState({}, '', '/search?q=restored+query&retrieval_lane=dialogue&page_size=20');
+    window.dispatchEvent(new PopStateEvent('popstate'));
+
+    await screen.findByText('Restored result');
+    expect(String(fetchMock.mock.calls[0]?.[0])).toBe(
+      '/api/search?q=restored+query&retrieval_lane=dialogue&page_size=20',
+    );
+    expect(pushState).not.toHaveBeenCalled();
+    expect(window.location.pathname).toBe('/search');
+    window.history.replaceState({}, '', '/');
+  });
+
+  test('offers only the canonical server retrieval lanes', () => {
+    render(<SearchIsland initial={fixture()} />);
+
+    const options = screen.getAllByRole('option').map((option) => option.textContent);
+    expect(options).toEqual(['auto', 'dialogue', 'actions', 'hybrid']);
+    expect(options).not.toContain('semantic');
+  });
+
+});
