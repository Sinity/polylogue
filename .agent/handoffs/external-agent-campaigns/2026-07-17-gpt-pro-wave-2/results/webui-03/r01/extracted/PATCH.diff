@@ -0,0 +1,298 @@
+"""Typed wire contract for the WebUI v2 search vertical.
+
+The query transaction remains the semantic owner.  These immutable models
+constrain only the browser projection so execution, SSR, and hydration cannot
+drift through ad-hoc dictionaries.
+"""
+
+from __future__ import annotations
+
+from dataclasses import dataclass
+from datetime import UTC, datetime
+from http import HTTPStatus
+from typing import Literal, Self, cast
+
+from pydantic import BaseModel, ConfigDict, Field, StrictInt, field_validator, model_validator
+
+from polylogue.archive.query.transaction import QueryCoverage, QueryTransactionRequest
+
+WEB_SEARCH_PROJECTION: Literal["web-search.v1"] = "web-search.v1"
+WEB_SEARCH_OPERATION: Literal["query"] = "query"
+WEB_SEARCH_STABLE_ORDER: Literal["rank-score-session-id"] = "rank-score-session-id"
+DEFAULT_PAGE_SIZE = 20
+MAX_WEB_PAGE_SIZE = 100
+WEB_SEARCH_ASSET = "/assets/web-search.js"
+
+WebSearchStateKind = Literal[
+    "ready",
+    "empty",
+    "parse_error",
+    "invalid_request",
+    "archive_unavailable",
+    "fts_lagging",
+    "fts_unavailable",
+    "embeddings_absent",
+    "failed",
+]
+WebSearchRetrievalLane = Literal["auto", "dialogue", "actions", "hybrid"]
+WebSearchTimeBucket = Literal["24h", "7d", "30d", "all"]
+CoverageKind = Literal["exact", "at_least", "unknown"]
+
+
+def _normalize_utc_timestamp(value: str, *, field_name: str) -> str:
+    try:
+        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
+    except ValueError as exc:
+        raise ValueError(f"{field_name} must be an ISO-8601 timestamp") from exc
+    if parsed.tzinfo is None:
+        raise ValueError(f"{field_name} must include a timezone")
+    return parsed.astimezone(UTC).isoformat().replace("+00:00", "Z")
+
+
+class WebSearchContractModel(BaseModel):
+    """Immutable, closed browser-contract model."""
+
+    model_config = ConfigDict(extra="forbid", frozen=True, populate_by_name=True)
+
+
+class DSLExample(WebSearchContractModel):
+    expression: str = Field(min_length=1)
+    source: str = Field(min_length=1)
+    line: StrictInt = Field(gt=0)
+
+
+WEB_SEARCH_EXAMPLES: tuple[DSLExample, ...] = (
+    DSLExample(expression="repo:polylogue", source="tests/unit/cli/test_query_expression.py", line=5345),
+    DSLExample(
+        expression="repo:polylogue since:7d has:paste",
+        source="tests/unit/cli/test_query_expression.py",
+        line=5584,
+    ),
+    DSLExample(
