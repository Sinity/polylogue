+++ b/webui/src/verticals/search/SearchIsland.tsx
@@ -0,0 +1,305 @@
+import { useCallback, useEffect, useRef, useState } from 'preact/hooks';
+
+import {
+  QUERY_RETRIEVAL_LANES,
+  browserPageUrl,
+  buildContinuationUrl,
+  buildSearchUrl,
+  searchApiUrlForBrowserPage,
+  searchFormValues,
+} from '../../lib/queryRequest';
+import {
+  type FacetOption,
+  type SearchHit,
+  type SearchState,
+  type WebSearchResponse,
+  isWebSearchResponse,
+} from './types';
+
+declare global {
+  interface Window {
+    ensureWebCredential?: () => Promise<unknown>;
+    bootstrapWebCredential?: () => Promise<unknown>;
+  }
+}
+
+const AUTH_FAILURES = new Set([
+  'web_credential_missing',
+  'web_credential_invalid',
+  'web_credential_expired',
+  'web_credential_revoked',
+]);
+
+async function readSearchResponse(
+  url: string,
+  signal: AbortSignal,
+  authRetried = false,
+): Promise<WebSearchResponse> {
+  if (window.ensureWebCredential) await window.ensureWebCredential();
+  const response = await fetch(url, {
+    method: 'GET',
+    credentials: 'same-origin',
+    cache: 'no-store',
+    referrerPolicy: 'no-referrer',
+    headers: { 'X-Polylogue-Web-Client': '1' },
+    signal,
+  });
+  const payload: unknown = await response.json().catch(() => null);
+  if (isWebSearchResponse(payload)) return payload;
+
+  const errorCode = typeof payload === 'object' && payload !== null
+    ? String((payload as { error?: unknown }).error ?? '')
+    : '';
+  if (!authRetried && AUTH_FAILURES.has(errorCode) && window.bootstrapWebCredential) {
+    await window.bootstrapWebCredential();
+    return await readSearchResponse(url, signal, true);
+  }
+  throw new Error(errorCode || `search request failed (${response.status})`);
+}
+
+function isAbortError(error: unknown): boolean {
+  return error instanceof DOMException && error.name === 'AbortError';
+}
+
+function coverageLabel(response: WebSearchResponse): string {
+  if (response.coverage.kind === 'exact') return `${response.coverage.value} exact matches`;
+  if (response.coverage.kind === 'at_least') return `At least ${response.coverage.value} matches`;
+  return 'Match total unknown';
+}
+
+function StateNotice({ state }: { state: SearchState }): preact.JSX.Element {
+  return (
+    <section class={`search-state search-state--${state.kind}`} role="status" data-search-state={state.kind}>
+      <strong>{state.message}</strong>
+      {state.detail ? <p>{state.detail}</p> : null}
+      {state.corrected_example ? <p>Try <code>{state.corrected_example}</code></p> : null}
+    </section>
+  );
+}
+
+interface FacetGroupProps {
+  title: string;
+  name: 'origin' | 'repo' | 'time';
+  options: FacetOption[];
+  radio?: boolean;
+  onChange: (form: HTMLFormElement) => void;
+}
+
+function FacetGroup({ title, name, options, radio = false, onChange }: FacetGroupProps): preact.JSX.Element {
+  return (
+    <fieldset>
+      <legend>{title}</legend>
+      {options.map((option) => (
+        <label class="facet-option" key={`${name}:${option.value}`}>
+          <input
+            type={radio ? 'radio' : 'checkbox'}
+            name={name}
+            value={option.value}
+            defaultChecked={option.selected}
+            onChange={(event) => {
+              const form = event.currentTarget.form;
+              if (form) onChange(form);
+            }}
+          />
+          <span>{option.label ?? option.value}</span>
+          <small>{option.count}</small>
+        </label>
+      ))}
+    </fieldset>
+  );
+}
+
+function HitList({ hits }: { hits: SearchHit[] }): preact.JSX.Element {
+  if (hits.length === 0) return <p class="empty-results">No result rows to display.</p>;
+  return (
+    <>
+      {hits.map((hit, index) => (
+        <article class="search-hit" key={`${hit.provenance.session_id}:${hit.provenance.message_id ?? ''}:${index}`}>
+          <h2><a href={hit.reader_href}>{hit.title}</a></h2>
+          <div class="hit-meta">
+            <span class="origin-badge">{hit.provenance.origin}</span>
+            <code>{hit.provenance.session_ref}</code>
+            {hit.provenance.message_ref ? <code>{hit.provenance.message_ref}</code> : null}
+            {hit.repo ? <span>{hit.repo}</span> : null}
+            {hit.occurred_at ? <time dateTime={hit.occurred_at}>{hit.occurred_at}</time> : null}
+          </div>
+          {hit.snippet ? <p>{hit.snippet}</p> : null}
+        </article>
+      ))}
+    </>
+  );
+}
+
+export interface SearchIslandProps {
+  initial: WebSearchResponse;
+}
+
+export function SearchIsland({ initial }: SearchIslandProps): preact.JSX.Element {
+  const [response, setResponse] = useState(initial);
+  const [pending, setPending] = useState(false);
+  const [transportError, setTransportError] = useState<string | null>(null);
+  const requestSerial = useRef(0);
+  const activeController = useRef<AbortController | null>(null);
+
+  const beginRequest = useCallback((): { controller: AbortController; serial: number } => {
+    activeController.current?.abort();
+    const controller = new AbortController();
+    const serial = requestSerial.current + 1;
+    requestSerial.current = serial;
+    activeController.current = controller;
+    setPending(true);
+    setTransportError(null);
+    return { controller, serial };
+  }, []);
+
+  const finishRequest = useCallback((serial: number): void => {
+    if (serial !== requestSerial.current) return;
+    activeController.current = null;
+    setPending(false);
+  }, []);
+
+  const replaceFromServer = useCallback(async (
+    url: string,
+    historyMode: 'push' | 'preserve' = 'push',
+  ): Promise<void> => {
+    const { controller, serial } = beginRequest();
+    try {
+      const next = await readSearchResponse(url, controller.signal);
+      if (serial !== requestSerial.current) return;
+      setResponse(next);
+      if (historyMode === 'push') {
+        window.history.pushState({ query_ref: next.request.query_ref }, '', browserPageUrl(url));
+      }
+    } catch (error) {
+      if (serial === requestSerial.current && !isAbortError(error)) {
+        setTransportError(error instanceof Error ? error.message : String(error));
+      }
+    } finally {
+      finishRequest(serial);
+    }
+  }, [beginRequest, finishRequest]);
+
+  useEffect(() => {
+    const restoreBrowserEntry = (): void => {
+      void replaceFromServer(searchApiUrlForBrowserPage(), 'preserve');
+    };
+    window.addEventListener('popstate', restoreBrowserEntry);
+    return () => {
+      window.removeEventListener('popstate', restoreBrowserEntry);
+      activeController.current?.abort();
+    };
+  }, [replaceFromServer]);
+
+  const submitForm = (form: HTMLFormElement): void => {
+    const values = searchFormValues(form, response.request.page_size);
+    void replaceFromServer(buildSearchUrl(values));
+  };
+
+  const appendContinuation = async (): Promise<void> => {
+    const continuation = response.page.continuation;
+    if (!continuation) return;
+    const expectedQueryRef = response.request.query_ref;
+    const expectedResultRef = response.request.result_ref;
+    const { controller, serial } = beginRequest();
+    try {
+      const next = await readSearchResponse(buildContinuationUrl(continuation), controller.signal);
+      if (serial !== requestSerial.current) return;
+      if (next.request.query_ref !== expectedQueryRef || next.request.result_ref !== expectedResultRef) {
+        throw new Error('search continuation changed query identity');
+      }
+      if (next.state.kind !== 'ready' && next.state.kind !== 'empty') {
+        const detail = next.state.detail ? ` ${next.state.detail}` : '';
+        throw new Error(`${next.state.message}${detail}`);
+      }
+      setResponse((current) => {
+        if (current.request.query_ref !== expectedQueryRef || current.page.continuation !== continuation) {
+          return current;
+        }
+        return { ...next, hits: [...current.hits, ...next.hits] };
+      });
+    } catch (error) {
+      if (serial === requestSerial.current && !isAbortError(error)) {
+        setTransportError(error instanceof Error ? error.message : String(error));
+      }
+    } finally {
+      finishRequest(serial);
+    }
+  };
+
+  const formKey = response.request.query_ref;
+  const args = response.request.arguments;
+  return (
+    <>
+      <aside class="search-panel">
+        <form
+          action="/search"
+          method="get"
+          data-search-form=""
+          key={formKey}
+          onSubmit={(event) => {
+            event.preventDefault();
+            submitForm(event.currentTarget);
+          }}
+        >
+          <input type="hidden" name="page_size" value={response.request.page_size} />
+          <fieldset>
+            <legend>Query</legend>
+            <div class="query-row">
+              <input
+                name="q"
+                defaultValue={args.expression}
+                placeholder={response.examples[1]?.expression ?? response.examples[0]?.expression ?? ''}
+                aria-label="Search expression"
+              />
+              <button type="submit" disabled={pending}>Search</button>
+            </div>
+          </fieldset>
+          <fieldset>
+            <legend>Retrieval lane</legend>
+            <select
+              name="retrieval_lane"
+              defaultValue={args.retrieval_lane}
+              onChange={(event) => {
+                const form = event.currentTarget.form;
+                if (form) submitForm(form);
+              }}
+            >
+              {QUERY_RETRIEVAL_LANES.map((lane) => (
+                <option value={lane} key={lane}>{lane}</option>
+              ))}
+            </select>
+          </fieldset>
+          <FacetGroup title="Origin" name="origin" options={response.facets.origin} onChange={submitForm} />
+          <FacetGroup title="Repository" name="repo" options={response.facets.repo} onChange={submitForm} />
+          <FacetGroup title="Time" name="time" options={response.facets.time} radio onChange={submitForm} />
+        </form>
+        <details class="examples">
+          <summary>DSL examples</summary>
+          <ul>{response.examples.map((example) => <li key={example.expression}><code>{example.expression}</code></li>)}</ul>
+        </details>
+      </aside>
+      <section class="search-panel" aria-live="polite" aria-busy={pending ? 'true' : 'false'}>
+        <StateNotice state={response.state} />
+        {transportError ? <p class="search-transport-error" role="alert">{transportError}</p> : null}
+        <div class="results-heading"><h2>Results</h2><span>{coverageLabel(response)}</span></div>
+        <div data-search-results=""><HitList hits={response.hits} /></div>
+        <div class="paging" data-search-paging="">
+            {response.page.continuation ? (
+              <a
+                class="load-more"
+                data-search-continuation=""
+                aria-disabled={pending ? 'true' : undefined}
+                href={`/search?${new URLSearchParams({ continuation: response.page.continuation }).toString()}`}
+                onClick={(event) => {
+                  event.preventDefault();
+                  if (!pending) void appendContinuation();
+                }}
+              >
+                {pending ? 'Loading…' : 'Load more'}
+              </a>
+            ) : null}
+        </div>
+      </section>
+    </>
+  );
+}
