+class _MockServer:
+    auth_token = ""
+    api_host = "127.0.0.1"
+    archive_query_executor = ThreadPoolExecutor(max_workers=2)
+    archive_query_admission = threading.BoundedSemaphore(64)
+
+
+class _MockHeaders:
+    def __init__(self, headers: dict[str, str] | None = None) -> None:
+        self._headers = headers or {}
+
+    def get(self, key: str, default: str | None = None) -> str | None:
+        return self._headers.get(key, default)
+
+
+def _make_handler(path: str) -> DaemonAPIHandler:
+    from polylogue.daemon.http import DaemonAPIHandler
+
+    handler = DaemonAPIHandler.__new__(DaemonAPIHandler)
+    handler.server = cast("DaemonAPIHTTPServer", _MockServer())
+    handler.client_address = ("127.0.0.1", 12345)
+    handler.path = path
+    handler.command = "GET"
+    handler.requestline = f"GET {path} HTTP/1.1"
+    handler.headers = cast("Message[str, str]", _MockHeaders({"Content-Length": "0"}))
+    handler.rfile = BytesIO(b"")
+    handler.wfile = BytesIO()
+    return handler
+
+
+def test_dsl_examples_are_copied_from_parser_tests_and_round_trip() -> None:
+    root = Path(__file__).parents[3]
+    for example in WEB_SEARCH_EXAMPLES:
+        source = (root / example.source).read_text(encoding="utf-8")
+        source_lines = source.splitlines()
+        assert example.expression in source_lines[example.line - 1]
+        assert compile_expression(example.expression) is not None
+
+
+def test_typed_wire_contract_rejects_shape_drift_and_incoherent_paging() -> None:
+    parsed = parse_web_search_request(
+        {"q": ["timeout"]},
+        now=datetime(2026, 7, 17, 12, tzinfo=UTC),
+    )
+    response = _build_response(
+        parsed.request,
+        parsed.result_ref,
+        state=_state("empty", "No sessions matched this query."),
+    )
+    payload = response.to_payload()
+    payload["unexpected"] = True
+
+    with pytest.raises(ValueError, match="Extra inputs are not permitted"):
+        WebSearchResponse.model_validate(payload)
+    with pytest.raises(ValueError, match="continuation must be present"):
+        WebSearchPage(has_more=True, continuation=None)
+    with pytest.raises(ValueError, match="String should match pattern"):
+        WebSearchPage(has_more=True, continuation="private-offset:20")
+    with pytest.raises(ValueError, match="message_ref must identify message_id"):
+        WebSearchHitProvenance(
+            origin="codex-session",
+            session_id="session-one",
+            session_ref="session:session-one",
+            message_id="message-one",
+            message_ref="message:other",
+            message_anchor="message-message-one",
+        )
+
+
+def test_continuation_replays_complete_request_and_rejects_overrides() -> None:
+    initial = parse_web_search_request(
+        {
+            "q": ["repo:polylogue since:7d"],
+            "origin": ["codex-session", "claude-code-session"],
+            "repo": ["polylogue"],
+            "time": ["30d"],
+            "retrieval_lane": ["dialogue"],
+            "page_size": ["7"],
+        },
+        now=datetime(2026, 7, 17, 12, tzinfo=UTC),
+    )
+    token = QueryContinuation(request=initial.request.next(offset=7), result_ref=initial.result_ref).encode()
+
+    resumed = parse_web_search_request({"continuation": [token]})
+
+    assert resumed.request.offset == 7
+    assert resumed.request.arguments == initial.request.arguments
+    assert resumed.request.page_size == 7
+    assert resumed.result_ref == initial.result_ref
+    with pytest.raises(ValueError, match="replayed alone"):
+        parse_web_search_request({"continuation": [token], "q": ["different"]})
+
+
+def test_relative_time_is_anchored_in_complete_request() -> None:
+    parsed = parse_web_search_request(
+        {"q": ["since:7d repo:polylogue"], "time": ["24h"]},
+        now=datetime(2026, 7, 17, 12, tzinfo=UTC),
+    )
+    first = _compile_spec(parsed.request)
+    later = _compile_spec(parsed.request.next(offset=20))
+
+    assert parsed.request.arguments["as_of"] == "2026-07-17T12:00:00Z"
+    assert first.since == "2026-07-16T12:00:00Z"
+    assert later.since == first.since
