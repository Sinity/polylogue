diff --git a/polylogue/daemon/web_search.py b/polylogue/daemon/web_search.py
new file mode 100644
index 0000000000000000000000000000000000000000..6b78fd7751d9c494bff5f2304cbd1712e6baef47
--- /dev/null
+++ b/polylogue/daemon/web_search.py
@@ -0,0 +1,809 @@
+"""SSR-first WebUI v2 search execution and route adapters.
+
+Search semantics remain in the archive query parser, planner, and facade.  This
+module translates the complete shared query request into the typed browser
+projection; HTML rendering lives in :mod:`polylogue.daemon.web_search_page`.
+"""
+
+from __future__ import annotations
+
+import contextlib
+import sqlite3
+from collections.abc import Callable, Mapping, Sequence
+from dataclasses import dataclass, replace
+from datetime import UTC, datetime, timedelta
+from http import HTTPStatus
+from pathlib import Path
+from typing import TYPE_CHECKING, Protocol, cast
+from urllib.parse import quote
+
+from pydantic import ValidationError
+
+from polylogue.archive.query.expression import ExpressionCompileError, compile_expression_into
+from polylogue.archive.query.search_hits import SessionSearchHit, bound_search_snippet
+from polylogue.archive.query.spec import (
+    QuerySpecError,
+    SessionQuerySpec,
+    clamp_query_limit,
+    normalize_retrieval_lane,
+)
+from polylogue.archive.query.transaction import (
+    QueryContinuation,
+    QueryCoverage,
+    QueryResultPage,
+    QueryTransactionRequest,
+    query_result_ref,
+    run_archive_read,
+)
+from polylogue.archive.session.domain_models import SessionSummary
+from polylogue.archive.session.repo_identity import normalize_repo_names
+from polylogue.core.dates import parse_date
+from polylogue.daemon.web_search_contract import (
+    DEFAULT_PAGE_SIZE,
+    MAX_WEB_PAGE_SIZE,
+    WEB_SEARCH_ASSET,
+    WEB_SEARCH_EXAMPLES,
+    WEB_SEARCH_OPERATION,
+    WEB_SEARCH_PROJECTION,
+    WEB_SEARCH_STABLE_ORDER,
+    DSLExample,
+    WebSearchCoverage,
+    WebSearchExecution,
+    WebSearchFacetOption,
+    WebSearchFacets,
+    WebSearchHit,
+    WebSearchHitProvenance,
+    WebSearchLabeledFacetOption,
+    WebSearchPage,
+    WebSearchRequest,
+    WebSearchRequestArguments,
+    WebSearchResponse,
+    WebSearchState,
+    WebSearchStateKind,
+    WebSearchTimeBucket,
+)
+from polylogue.daemon.web_search_page import render_web_search_page
+from polylogue.logging import get_logger
+from polylogue.surfaces.payloads import reader_anchor
+
+if TYPE_CHECKING:
+    from polylogue.api import Polylogue
+    from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore
+
+logger = get_logger(__name__)
+
+_TIME_BUCKETS: tuple[tuple[WebSearchTimeBucket, str, timedelta | None], ...] = (
+    ("24h", "Past 24 hours", timedelta(hours=24)),
+    ("7d", "Past 7 days", timedelta(days=7)),
+    ("30d", "Past 30 days", timedelta(days=30)),
+    ("all", "Any time", None),
+)
+_SEMANTIC_OVERRIDE_KEYS = frozenset(
+    {
+        "q",
+        "expression",
+        "origin",
+        "repo",
+        "time",
+        "retrieval_lane",
+        "lane",
+        "page_size",
+        "limit",
+    }
+)
+
+
+class WebSearchHandler(Protocol):
+    def _sync_run(self, handler: Callable[..., object]) -> object: ...
+
+    def _send_json(
+        self,
+        status: HTTPStatus,
+        payload: object,
+        *,
+        extra_headers: Mapping[str, str] | None = None,
+    ) -> None: ...
+
+    def _send_html(self, status: HTTPStatus, html: str) -> None: ...
+
+
+class WebSearchRequestError(ValueError):
+    """Typed transport/request error rendered by both HTML and JSON routes."""
+
+
+@dataclass(frozen=True, slots=True)
+class ParsedWebSearchRequest:
+    request: QueryTransactionRequest
+    result_ref: str
+
+
+@dataclass(frozen=True, slots=True)
+class _SummaryEvidence:
+    message_id: str | None
+    snippet: str | None
+
+
+def _first(params: Mapping[str, list[str]], *keys: str, default: str = "") -> str:
+    for key in keys:
+        values = params.get(key)
+        if values:
+            return values[0]
+    return default
+
+
+def _tokens(params: Mapping[str, list[str]], key: str) -> tuple[str, ...]:
+    values = params.get(key) or []
+    return tuple(dict.fromkeys(token.strip() for value in values for token in value.split(",") if token.strip()))
+
+
+def _utc_iso(value: datetime) -> str:
+    return value.astimezone(UTC).isoformat().replace("+00:00", "Z")
+
+
+def _request_arguments(request: QueryTransactionRequest) -> WebSearchRequestArguments:
+    try:
+        return WebSearchRequestArguments.model_validate(request.arguments)
+    except ValidationError as exc:
+        error = exc.errors(include_url=False)[0]
+        path = ".".join(str(part) for part in error["loc"])
+        prefix = f"query request {path}" if path else "query request"
+        raise WebSearchRequestError(f"{prefix}: {error['msg']}") from exc
+
+
+def _parse_as_of(value: str) -> datetime:
+    return datetime.fromisoformat(value.replace("Z", "+00:00")).astimezone(UTC)
+
+
+def _validate_request(request: QueryTransactionRequest) -> None:
+    if request.operation != WEB_SEARCH_OPERATION:
+        raise WebSearchRequestError("continuation is not a WebUI query request")
+    if request.projection != WEB_SEARCH_PROJECTION:
+        raise WebSearchRequestError("continuation has the wrong search projection")
+    if request.stable_order != WEB_SEARCH_STABLE_ORDER:
+        raise WebSearchRequestError("continuation has the wrong stable-order contract")
+    if request.page_size > MAX_WEB_PAGE_SIZE:
+        raise WebSearchRequestError("continuation page size exceeds the WebUI limit")
+    _request_arguments(request)
+
+
+def parse_web_search_request(
+    params: Mapping[str, list[str]],
+    *,
+    now: datetime | None = None,
+) -> ParsedWebSearchRequest:
+    """Build or resume the complete transport-neutral query request."""
+    continuation_values = params.get("continuation") or []
+    if continuation_values:
+        conflicting = sorted(
+            key for key in _SEMANTIC_OVERRIDE_KEYS if any(value.strip() for value in params.get(key, []))
+        )
+        if conflicting:
+            raise WebSearchRequestError(
+                "continuation must be replayed alone; remove semantic overrides: " + ", ".join(conflicting)
+            )
+        if len(continuation_values) != 1:
+            raise WebSearchRequestError("exactly one continuation value is required")
+        try:
+            decoded = QueryContinuation.decode(continuation_values[0])
+        except ValueError as exc:
+            raise WebSearchRequestError(str(exc)) from exc
+        _validate_request(decoded.request)
+        expected_ref = query_result_ref(decoded.request)
+        if decoded.result_ref != expected_ref:
+            raise WebSearchRequestError("continuation result identity does not match its query request")
+        return ParsedWebSearchRequest(decoded.request, decoded.result_ref)
+
+    expression = _first(params, "q", "expression").strip()
+    lane = normalize_retrieval_lane(_first(params, "retrieval_lane", "lane", default="auto"))
+    raw_page_size = _first(params, "page_size", "limit", default=str(DEFAULT_PAGE_SIZE))
+    page_size = min(clamp_query_limit(raw_page_size, default=DEFAULT_PAGE_SIZE), MAX_WEB_PAGE_SIZE)
+    time_bucket = _first(params, "time").strip() or None
+    as_of = (now or datetime.now(UTC)).astimezone(UTC)
+    request = QueryTransactionRequest(
+        operation=WEB_SEARCH_OPERATION,
+        arguments={
+            "expression": expression,
+            "facets": {
+                "origin": list(_tokens(params, "origin")),
+                "repo": list(_tokens(params, "repo")),
+                "time": time_bucket,
+            },
+            "retrieval_lane": lane,
+            "as_of": _utc_iso(as_of),
+        },
+        page_size=page_size,
+        offset=0,
+        projection=WEB_SEARCH_PROJECTION,
+        stable_order=WEB_SEARCH_STABLE_ORDER,
+    )
+    _validate_request(request)
+    return ParsedWebSearchRequest(request, query_result_ref(request))
+
+
+def _time_delta(bucket: WebSearchTimeBucket | None) -> timedelta | None:
+    for value, _label, delta in _TIME_BUCKETS:
+        if value == (bucket or "all"):
+            return delta
+    return None
+
+
+def _absolute_query_date(value: str | None, *, as_of: datetime, field: str) -> datetime | None:
+    if value is None:
+        return None
+    parsed = parse_date(value, relative_base=as_of)
+    if parsed is None:
+        raise QuerySpecError(field, value)
+    return parsed.astimezone(UTC)
+
+
+def _compile_spec(
+    request: QueryTransactionRequest,
+    *,
+    time_bucket: WebSearchTimeBucket | None | object = ...,  # explicit override for time-facet counts
+) -> SessionQuerySpec:
+    arguments = _request_arguments(request)
+    selected_time = arguments.facets.time
+    effective_time = selected_time if time_bucket is ... else cast("WebSearchTimeBucket | None", time_bucket)
+    as_of = _parse_as_of(arguments.as_of)
+
+    base = SessionQuerySpec.from_params(
+        {
+            "origin": arguments.facets.origin,
+            "repo": arguments.facets.repo,
+            "retrieval_lane": arguments.retrieval_lane,
+            "limit": request.page_size,
+            "offset": request.offset,
+        },
+        strict=True,
+    )
+    spec = compile_expression_into(arguments.expression, base) if arguments.expression else base
+
+    since = _absolute_query_date(spec.since, as_of=as_of, field="since")
+    until = _absolute_query_date(spec.until, as_of=as_of, field="until")
+    delta = _time_delta(effective_time)
+    if delta is not None:
+        facet_since = as_of - delta
+        since = max(value for value in (since, facet_since) if value is not None)
+    if since is not None and until is not None and since > until:
+        raise QuerySpecError("time", f"since {_utc_iso(since)} is after until {_utc_iso(until)}")
+    return replace(
+        spec,
+        since=_utc_iso(since) if since is not None else None,
+        until=_utc_iso(until) if until is not None else None,
+        limit=request.page_size,
+        offset=request.offset,
+        cursor=None,
+    )
+
+
+def _state(
+    kind: WebSearchStateKind,
+    message: str,
+    *,
+    detail: str | None = None,
+    field: str | None = None,
+    corrected_example: str | None = None,
+    stale_available: bool = False,
+) -> WebSearchState:
+    return WebSearchState(
+        kind=kind,
+        message=message,
+        detail=detail,
+        field=field,
+        corrected_example=corrected_example,
+        stale_available=stale_available,
+    )
+
+
+def _empty_facets(request: QueryTransactionRequest) -> WebSearchFacets:
+    arguments = _request_arguments(request)
+    selected_time = arguments.facets.time or "all"
+    return WebSearchFacets(
+        origin=tuple(WebSearchFacetOption(value=value, count=0, selected=True) for value in arguments.facets.origin),
+        repo=tuple(WebSearchFacetOption(value=value, count=0, selected=True) for value in arguments.facets.repo),
+        time=tuple(
+            WebSearchLabeledFacetOption(
+                value=value,
+                label=label,
+                count=0,
+                selected=value == selected_time,
+            )
+            for value, label, _delta in _TIME_BUCKETS
+        ),
+    )
+
+
+def _build_response(
+    request: QueryTransactionRequest,
+    result_ref: str,
+    *,
+    state: WebSearchState,
+    coverage: QueryCoverage | None = None,
+    facets: WebSearchFacets | None = None,
+    hits: Sequence[WebSearchHit] = (),
+    page: WebSearchPage | None = None,
+    resolved_retrieval_lane: str | None = None,
+    diagnostics: dict[str, object] | None = None,
+) -> WebSearchResponse:
+    """Build the one typed response shape shared by JSON and semantic SSR."""
+    arguments = _request_arguments(request)
+    return WebSearchResponse(
+        generated_at=_utc_iso(datetime.now(UTC)),
+        request=WebSearchRequest.from_transaction(request, result_ref),
+        state=state,
+        coverage=WebSearchCoverage.from_query_coverage(coverage or QueryCoverage.unknown()),
+        hits=tuple(hits),
+        facets=facets or _empty_facets(request),
+        page=page or WebSearchPage(),
+        resolved_retrieval_lane=resolved_retrieval_lane or arguments.retrieval_lane,
+        diagnostics=diagnostics,
+    )
+
+
+def _archive_root(poly: Polylogue) -> Path:
+    from polylogue.paths import archive_file_set_root_for_paths
+
+    return archive_file_set_root_for_paths(
+        archive_root_path=poly.config.archive_root,
+        db_anchor=poly.config.db_path,
+    )
+
+
+def _fts_state(index_db: Path) -> tuple[WebSearchStateKind, str, str | None] | None:
+    from polylogue.daemon.fts_status import fts_readiness_info
+
+    try:
+        readiness = fts_readiness_info(index_db)
+    except (OSError, sqlite3.Error) as exc:
+        logger.warning("FTS readiness probe failed for %s: %s", index_db, exc, exc_info=True)
+        return (
+            "fts_unavailable",
+            "Full-text search is unavailable.",
+            "The daemon could not verify the FTS readiness invariant.",
+        )
+    if bool(readiness.get("messages_ready")) and bool(readiness.get("invariant_ready", True)):
+        return None
+    surfaces = readiness.get("surfaces")
+    message_surface = surfaces.get("messages_fts", {}) if isinstance(surfaces, Mapping) else {}
+    exists = bool(message_surface.get("exists")) if isinstance(message_surface, Mapping) else False
+    coverage = readiness.get("coverage_pct")
+    detail = f"Indexed coverage: {coverage}%." if isinstance(coverage, int | float) else None
+    if exists:
+        return (
+            "fts_lagging",
+            "Full-text search is still converging; results are withheld rather than shown as empty.",
+            detail,
+        )
+    return ("fts_unavailable", "The full-text search index is not available.", detail)
+
+
+def _embeddings_state(index_db: Path) -> tuple[WebSearchStateKind, str, str | None] | None:
+    from polylogue.daemon.embedding_readiness import embedding_readiness_info
+
+    readiness = embedding_readiness_info(index_db)
+    if bool(readiness.get("embedding_retrieval_ready")):
+        return None
+    status = readiness.get("embedding_status")
+    coverage = readiness.get("embedding_coverage_percent")
+    detail = f"Embedding status: {status}; coverage: {coverage}%."
+    return (
+        "embeddings_absent",
+        "Semantic retrieval is unavailable because usable embeddings are absent.",
+        detail,
+    )
+
+
+def _needs_fts(spec: SessionQuerySpec) -> bool:
+    return bool(spec.query_terms or spec.contains_terms) or spec.retrieval_lane == "hybrid"
+
+
+def _needs_embeddings(spec: SessionQuerySpec) -> bool:
+    return bool(spec.similar_text or spec.similar_session_id) or spec.retrieval_lane == "hybrid"
+
+
+def _repo_for_summary(summary: SessionSummary) -> str | None:
+    names = normalize_repo_names(
+        (summary.git_repository_url,) if summary.git_repository_url else (),
+        repo_paths=summary.working_directories,
+    )
+    return names[0] if names else None
+
+
+def _reader_href(session_id: str, anchor: str) -> str:
+    return f"/s/{quote(session_id, safe='')}#{quote(anchor, safe='-_')}"
+
+
+def _provenance(origin: str, session_id: str, message_id: str | None, anchor: str) -> WebSearchHitProvenance:
+    return WebSearchHitProvenance(
+        origin=origin,
+        session_id=session_id,
+        session_ref=f"session:{session_id}",
+        message_id=message_id,
+        message_ref=f"message:{message_id}" if message_id is not None else None,
+        message_anchor=anchor,
+    )
+
+
+def _project_summary(
+    summary: SessionSummary,
+    *,
+    rank: int,
+    lane: str,
+    evidence: _SummaryEvidence | None = None,
+) -> WebSearchHit:
+    session_id = str(summary.id)
+    message_id = evidence.message_id if evidence is not None else None
+    anchor = reader_anchor("message", message_id) if message_id is not None else reader_anchor("session", session_id)
+    return WebSearchHit(
+        rank=rank,
+        title=summary.display_title or "Untitled session",
+        snippet=evidence.snippet if evidence is not None else None,
+        retrieval_lane=lane,
+        occurred_at=_utc_iso(summary.display_date) if summary.display_date is not None else None,
+        repo=_repo_for_summary(summary),
+        reader_href=_reader_href(session_id, anchor),
+        provenance=_provenance(summary.origin.value, session_id, message_id, anchor),
+    )
+
+
+async def _summary_evidence(
+    poly: Polylogue,
+    summaries: Sequence[SessionSummary],
+) -> dict[str, _SummaryEvidence]:
+    """Fetch one bounded representative message for each filter-only hit."""
+    session_ids = tuple(str(summary.id) for summary in summaries)
+    if not session_ids:
+        return {}
+
+    def read(archive: ArchiveStore) -> dict[str, _SummaryEvidence]:
+        return {
+            row.session_id: _SummaryEvidence(
+                message_id=row.message_id,
+                snippet=bound_search_snippet(row.text),
+            )
+            for row in archive.query_session_message_evidence(session_ids)
+        }
+
+    return await run_archive_read(
+        _archive_root(poly),
+        operation="web.search.summary-evidence",
+        arguments={"session_ids": session_ids},
+        work=read,
+        page_size=len(session_ids),
+        projection="web-search.summary-evidence.v1",
+    )
+
+
+def _project_hit(hit: SessionSearchHit) -> WebSearchHit:
+    summary = hit.summary
+    session_id = str(summary.id)
+    message_id = hit.message_id
+    anchor = reader_anchor("message", message_id) if message_id is not None else reader_anchor("session", session_id)
+    return WebSearchHit(
+        rank=hit.rank,
+        title=summary.display_title or "Untitled session",
+        snippet=bound_search_snippet(hit.snippet),
+        retrieval_lane=hit.retrieval_lane,
+        occurred_at=_utc_iso(summary.display_date) if summary.display_date is not None else None,
+        repo=_repo_for_summary(summary),
+        reader_href=_reader_href(session_id, anchor),
+        provenance=_provenance(summary.origin.value, session_id, message_id, anchor),
+    )
+
+
+def _facet_options(
+    counts: Mapping[str, int],
+    selected: Sequence[str],
+) -> tuple[WebSearchFacetOption, ...]:
+    merged = {str(value): int(count) for value, count in counts.items()}
+    for value in selected:
+        merged.setdefault(value, 0)
+    selected_set = set(selected)
+    return tuple(
+        WebSearchFacetOption(value=value, count=count, selected=value in selected_set)
+        for value, count in sorted(merged.items(), key=lambda item: (-item[1], item[0].casefold()))
+    )
+
+
+async def _time_facet_options(
+    poly: Polylogue,
+    request: QueryTransactionRequest,
+) -> tuple[WebSearchLabeledFacetOption, ...]:
+    selected_time = _request_arguments(request).facets.time or "all"
+    options: list[WebSearchLabeledFacetOption] = []
+    for value, label, _delta in _TIME_BUCKETS:
+        spec = replace(_compile_spec(request, time_bucket=value), limit=None, offset=0)
+        count = await spec.count(poly.config)
+        options.append(
+            WebSearchLabeledFacetOption(
+                value=value,
+                label=label,
+                count=count,
+                selected=value == selected_time,
+            )
+        )
+    return tuple(options)
+
+
+def _page_contract(
+    spec: SessionQuerySpec,
+    request: QueryTransactionRequest,
+    *,
+    item_count: int,
+    counted_total: int,
+    fetched_extra: bool,
+) -> tuple[bool, QueryCoverage]:
+    """Return honest continuation/coverage semantics for one projected page."""
+    if fetched_extra and item_count == 0:
+        raise ValueError("an extra result cannot be observed without a projected page item")
+    observed_lower_bound = request.offset + item_count + (1 if fetched_extra else 0) if item_count > 0 else 0
+    if not _needs_embeddings(spec):
+        if counted_total < observed_lower_bound:
+            return (
+                bool(item_count) and (fetched_extra or item_count == request.page_size),
+                QueryCoverage.at_least(observed_lower_bound),
+            )
+        return (
+            bool(item_count) and request.offset + item_count < counted_total,
+            QueryCoverage.exact(counted_total),
+        )
+
+    lower_bound = max(
+        counted_total,
+        request.offset + item_count + (1 if fetched_extra else 0),
+    )
+    coverage = QueryCoverage.at_least(lower_bound) if lower_bound > 0 else QueryCoverage.unknown()
+    has_more = bool(item_count) and (
+        fetched_extra or request.offset + item_count < counted_total or item_count == request.page_size
+    )
+    return has_more, coverage
+
+
+async def execute_web_search(
+    poly: Polylogue,
+    parsed: ParsedWebSearchRequest,
+) -> WebSearchExecution:
+    """Execute one page through canonical parser/planner/facade semantics."""
+    request = parsed.request
+    result_ref = parsed.result_ref
+    try:
+        spec = _compile_spec(request)
+    except (ExpressionCompileError, QuerySpecError) as exc:
+        field = getattr(exc, "field", None)
+        response = _build_response(
+            request,
+            result_ref,
+            state=_state(
+                "parse_error",
+                "The query could not be parsed.",
+                detail=str(exc),
+                field=str(field) if field is not None else None,
+                corrected_example=WEB_SEARCH_EXAMPLES[1].expression,
+            ),
+        )
+        return WebSearchExecution(HTTPStatus.BAD_REQUEST, response)
+
+    root = _archive_root(poly)
+    index_db = root / "index.db"
+    if _needs_fts(spec):
+        degraded = _fts_state(index_db)
+        if degraded is not None:
+            kind, message, detail = degraded
+            response = _build_response(request, result_ref, state=_state(kind, message, detail=detail))
+            status = HTTPStatus.CONFLICT if kind == "fts_lagging" else HTTPStatus.SERVICE_UNAVAILABLE
+            return WebSearchExecution(status, response)
+    if _needs_embeddings(spec):
+        degraded = _embeddings_state(index_db)
+        if degraded is not None:
+            kind, message, detail = degraded
+            response = _build_response(request, result_ref, state=_state(kind, message, detail=detail))
+            return WebSearchExecution(HTTPStatus.CONFLICT, response)
+
+    plan = spec.to_plan()
+    fetched_extra = False
+    hits: list[WebSearchHit]
+    resolved_lane: str
+    if plan.fts_terms or plan.similar_text or plan.similar_session_id:
+        fetch_spec = replace(spec, limit=request.page_size + 1)
+        native_hits = await poly.search_session_hits(fetch_spec)
+        fetched_extra = len(native_hits) > request.page_size
+        hits = [_project_hit(hit) for hit in native_hits[: request.page_size]]
+        resolved_lane = native_hits[0].retrieval_lane if native_hits else spec.retrieval_lane
+    else:
+        summaries = await spec.list_summaries(poly.config)
+        evidence = await _summary_evidence(poly, summaries)
+        hits = [
+            _project_summary(
+                summary,
+                rank=request.offset + index,
+                lane=spec.retrieval_lane,
+                evidence=evidence.get(str(summary.id)),
+            )
+            for index, summary in enumerate(summaries, start=1)
+        ]
+        resolved_lane = spec.retrieval_lane
+
+    count_spec = replace(spec, limit=None, offset=0, cursor=None)
+    total = await count_spec.count(poly.config)
+    facet_response = await poly.facets(count_spec, include_deferred=True)
+    selected_facets = _request_arguments(request).facets
+    facets = WebSearchFacets(
+        origin=_facet_options(facet_response.origins, selected_facets.origin),
+        repo=_facet_options(facet_response.repos, selected_facets.repo),
+        time=await _time_facet_options(poly, request),
+    )
+
+    has_more, coverage = _page_contract(
+        spec,
+        request,
+        item_count=len(hits),
+        counted_total=total,
+        fetched_extra=fetched_extra,
+    )
+    result_page = QueryResultPage(
+        items=tuple(hits),
+        request=request,
+        has_more=has_more,
+        result_ref=result_ref,
+        coverage=coverage,
+    )
+    state_kind: WebSearchStateKind = "empty" if not hits and request.offset == 0 else "ready"
+    state_message = "No sessions matched this query." if state_kind == "empty" else "Search results are ready."
+    diagnostics: dict[str, object] | None = None
+    if not hits and count_spec.has_filters():
+        with contextlib.suppress(Exception):
+            from polylogue.surfaces.payloads import QueryMissDiagnosticsPayload
+
+            raw_diagnostics = await poly.diagnose_query_miss(count_spec)
+            diagnostics = cast(
+                "dict[str, object]",
+                QueryMissDiagnosticsPayload.from_diagnostics(raw_diagnostics).model_dump(mode="json"),
+            )
+    response = _build_response(
+        request,
+        result_ref,
+        state=_state(state_kind, state_message),
+        coverage=result_page.coverage,
+        facets=facets,
+        hits=hits,
+        page=WebSearchPage(has_more=result_page.has_more, continuation=result_page.continuation),
+        resolved_retrieval_lane=resolved_lane,
+        diagnostics=diagnostics,
+    )
+    return WebSearchExecution(HTTPStatus.OK, response)
+
+
+def _invalid_execution(params: Mapping[str, list[str]], exc: Exception) -> WebSearchExecution:
+    try:
+        parsed = parse_web_search_request({key: values for key, values in params.items() if key != "continuation"})
+    except Exception as fallback_exc:
+        logger.warning(
+            "invalid WebUI search request could not be projected for diagnostics; using an empty request",
+            exc_info=fallback_exc,
+        )
+        parsed = parse_web_search_request({})
+    response = _build_response(
+        parsed.request,
+        parsed.result_ref,
+        state=_state(
+            "invalid_request",
+            "The search request is invalid.",
+            detail=str(exc),
+            corrected_example=WEB_SEARCH_EXAMPLES[0].expression,
+        ),
+    )
+    return WebSearchExecution(HTTPStatus.BAD_REQUEST, response)
+
+
+def _failed_execution(
+    parsed: ParsedWebSearchRequest,
+    *,
+    status: HTTPStatus,
+    message: str,
+    detail: str | None = None,
+) -> WebSearchExecution:
+    response = _build_response(
+        parsed.request,
+        parsed.result_ref,
+        state=_state("failed", message, detail=detail),
+    )
+    return WebSearchExecution(status, response)
+
+
+def resolve_web_search(
+    handler: WebSearchHandler,
+    params: Mapping[str, list[str]],
+    archive_root: Path | None,
+) -> WebSearchExecution:
+    try:
+        parsed = parse_web_search_request(params)
+    except (WebSearchRequestError, QuerySpecError) as exc:
+        return _invalid_execution(params, exc)
+    if archive_root is None:
+        response = _build_response(
+            parsed.request,
+            parsed.result_ref,
+            state=_state(
+                "archive_unavailable",
+                "The archive reader is unavailable.",
+                detail="The source and index tiers are missing or have incompatible schema versions.",
+            ),
+        )
+        return WebSearchExecution(HTTPStatus.SERVICE_UNAVAILABLE, response)
+
+    async def run(poly: Polylogue) -> WebSearchExecution:
+        return await execute_web_search(poly, parsed)
+
+    try:
+        result = handler._sync_run(run)
+    except TimeoutError:
+        return _failed_execution(
+            parsed,
+            status=HTTPStatus.SERVICE_UNAVAILABLE,
+            message="The archive query timed out before a complete page was available.",
+            detail="Retry the same request; no partial page was presented as complete.",
+        )
+    except (OSError, sqlite3.Error):
+        logger.exception("archive storage error while resolving WebUI search")
+        return _failed_execution(
+            parsed,
+            status=HTTPStatus.SERVICE_UNAVAILABLE,
+            message="Archive storage could not complete this search.",
+            detail="The result page was withheld because its completeness could not be verified.",
+        )
+    except Exception:
+        logger.exception("unexpected WebUI search execution failure")
+        return _failed_execution(
+            parsed,
+            status=HTTPStatus.INTERNAL_SERVER_ERROR,
+            message="The daemon could not complete this search.",
+            detail="No partial page was presented as a complete result.",
+        )
+    if not isinstance(result, WebSearchExecution):
+        logger.error("WebUI search executor returned %s instead of WebSearchExecution", type(result).__name__)
+        return _failed_execution(
+            parsed,
+            status=HTTPStatus.INTERNAL_SERVER_ERROR,
+            message="The daemon returned an invalid search result.",
+            detail="No partial page was presented as a complete result.",
+        )
+    return result
+
+
+def handle_web_search_json(
+    handler: WebSearchHandler,
+    params: Mapping[str, list[str]],
+    archive_root: Path | None,
+) -> None:
+    execution = resolve_web_search(handler, params, archive_root)
+    handler._send_json(execution.status, execution.payload)
+
+
+def handle_web_search_page(
+    handler: WebSearchHandler,
+    params: Mapping[str, list[str]],
+    archive_root: Path | None,
+) -> None:
+    execution = resolve_web_search(handler, params, archive_root)
+    handler._send_html(execution.status, render_web_search_page(execution.response))
+
+
+__all__ = [
+    "DEFAULT_PAGE_SIZE",
+    "DSLExample",
+    "MAX_WEB_PAGE_SIZE",
+    "ParsedWebSearchRequest",
+    "WEB_SEARCH_ASSET",
+    "WEB_SEARCH_EXAMPLES",
+    "WEB_SEARCH_OPERATION",
+    "WEB_SEARCH_PROJECTION",
+    "WEB_SEARCH_STABLE_ORDER",
+    "WebSearchExecution",
+    "WebSearchRequestError",
+    "execute_web_search",
+    "handle_web_search_json",
+    "handle_web_search_page",
+    "parse_web_search_request",
+    "render_web_search_page",
+    "resolve_web_search",
+]
