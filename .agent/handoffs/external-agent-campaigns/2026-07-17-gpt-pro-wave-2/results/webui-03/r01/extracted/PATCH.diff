@@ -0,0 +1,26 @@
+import { hydrate } from 'preact';
+
+import { SearchIsland } from './SearchIsland';
+import { isWebSearchResponse } from './types';
+
+function boot(): void {
+  const root = document.querySelector<HTMLElement>('[data-web-search-island]');
+  const source = document.getElementById('web-search-initial');
+  if (!root || !source?.textContent) return;
+
+  let payload: unknown;
+  try {
+    payload = JSON.parse(source.textContent);
+  } catch {
+    root.dataset.hydrationState = 'invalid-json';
+    return;
+  }
+  if (!isWebSearchResponse(payload)) {
+    root.dataset.hydrationState = 'invalid-contract';
+    return;
+  }
+  hydrate(<SearchIsland initial={payload} />, root);
+  root.dataset.hydrationState = 'ready';
+}
+
+boot();
