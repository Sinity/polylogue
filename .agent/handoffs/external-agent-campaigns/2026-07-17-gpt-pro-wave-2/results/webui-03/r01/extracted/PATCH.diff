+def test_unexpected_execution_failure_stays_inside_typed_search_contract(tmp_path: Path) -> None:
+    handler = MagicMock()
+    handler._sync_run.side_effect = RuntimeError("implementation detail must not leak")
+
+    execution = resolve_web_search(handler, {"q": ["timeout"]}, tmp_path)
+
+    assert execution.status == HTTPStatus.INTERNAL_SERVER_ERROR
+    assert execution.payload["schema"] == WEB_SEARCH_PROJECTION
+    assert execution.payload["state"] == {
+        "kind": "failed",
+        "message": "The daemon could not complete this search.",
+        "detail": "No partial page was presented as a complete result.",
+        "field": None,
+        "corrected_example": None,
+        "stale_available": False,
+    }
+    assert execution.payload["hits"] == []
+    assert "implementation detail" not in str(execution.payload)
