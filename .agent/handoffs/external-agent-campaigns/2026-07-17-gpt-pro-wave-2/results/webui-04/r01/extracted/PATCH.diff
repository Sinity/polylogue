+  const first = documentFixture([], {
+    messages: [message(0)],
+    page: { offset: 0, limit: 40, returned: 1, total_messages: 2, next_offset: 1 },
+  });
+  const second = validateCardDocument({
+    schema_version: 'semantic-card-document.v1', session_id: SESSION_ID,
+    page: { offset: 1, limit: 40, returned: 1, total_messages: 2, previous_offset: 0 },
+    session_entries: [], messages: [message(1)],
+  });
+  const merged = mergeCardDocumentPage(loadedTranscript(first), second);
+  expect(merged.messages.map((item) => item.message_id)).toEqual(['m0', 'm1']);
+  expect(merged.nextOffset).toBeUndefined();
+  expect(first.page.returned).toBe(1);
+
+  const wrongTotal = structuredClone(second);
+  wrongTotal.page.total_messages = 3;
+  wrongTotal.page.next_offset = 2;
+  expect(() => mergeCardDocumentPage(loadedTranscript(first), wrongTotal)).toThrow(/total changed/);
+
+  const repeated = structuredClone(second);
+  repeated.messages[0] = message(0);
+  expect(() => mergeCardDocumentPage(loadedTranscript(first), repeated)).toThrow(/repeated message/);
+});
