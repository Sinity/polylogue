+            entries_by_message[primary_id].append(entry)
+            independent_message_ids.add(primary_id)
+        if entry.prose is not None:
+            independent_message_ids.add(entry.prose.message_id)
+        elif entry.notice is not None:
+            independent_message_ids.update(source.message_id for source in entry.notice.sources)
+        elif entry.card is not None:
+            result_id = entry.card.source.result_message_id
+            if result_id is not None and result_id != primary_id:
+                paired_result_ids.add(result_id)
+
+    total = len(normalized)
+    bounded_offset = min(max(0, offset), total)
+    bounded_limit = max(1, min(limit, CARD_DOCUMENT_MAX_PAGE_LIMIT))
+    page_messages = normalized[bounded_offset : bounded_offset + bounded_limit]
+    previous_offset = max(0, bounded_offset - bounded_limit) if bounded_offset > 0 else None
+    candidate_next_offset = bounded_offset + len(page_messages)
+    next_offset: int | None = candidate_next_offset if candidate_next_offset < total else None
+
+    rows = tuple(
+        SemanticCardDocumentMessage(
+            message_id=message.id,
+            role=message.role,
+            message_type=message.message_type,
+            material_origin=message.material_origin,
+            provider_family=message.provider_family,
+            origin=message.origin,
+            occurred_at=message.occurred_at,
+            duration_ms=message.duration_ms,
+            parent_message_id=message.parent_id,
+            variant_index=message.variant_index,
+            is_active_path=message.is_active_path,
+            is_active_leaf=message.is_active_leaf,
+            inherited_prefix=message.inherited_prefix,
+            source_session_id=message.source_session_id,
+            semantic_card_suppressed=message.id in (paired_result_ids - independent_message_ids),
+            entries=tuple(
+                _serialize_document_entry(
+                    entry,
+                    session_id=session_id,
+                    message_by_id=message_by_id,
+                )
+                for entry in entries_by_message.get(message.id, ())
+            ),
+        )
+        for message in page_messages
+    )
+    serialized_session_entries = (
+        tuple(
+            _serialize_document_entry(
+                entry,
+                session_id=session_id,
+                message_by_id=message_by_id,
+            )
+            for entry in session_entries
+        )
+        if bounded_offset == 0
+        else ()
+    )
+    return SemanticCardDocument(
+        session_id=session_id,
+        page=SemanticCardDocumentPage(
+            offset=bounded_offset,
+            limit=bounded_limit,
+            returned=len(rows),
+            total_messages=total,
+            next_offset=next_offset,
+            previous_offset=previous_offset,
+        ),
+        session_entries=serialized_session_entries,
+        messages=rows,
+    )
+
+
+def build_semantic_card_detail(
+    messages: Sequence[Mapping[str, object] | object],
+    *,
+    session_id: str,
+    detail_ref: str,
+    part: str,
+    offset: int = 0,
+    limit: int = CARD_DETAIL_DEFAULT_LIMIT,
+    provider_family: str | None = None,
+) -> SemanticCardDetailChunk:
+    """Return one exact, server-bounded disclosure chunk.
+
+    Invalid refs/parts are ``unknown``; valid-but-unavailable coordinates are
+    ``missing``.  The function never falls back to a tool id, name, or fuzzy
+    text search.
+    """
+
+    bounded_offset = max(0, offset)
+    bounded_limit = max(1, min(limit, CARD_DETAIL_MAX_LIMIT))
+    try:
+        detail_part = SemanticCardDetailPart(part)
+    except ValueError:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=detail_ref,
+            part=part,
+            state=SemanticCardDetailState.UNKNOWN,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="unsupported detail part",
+        )
+    try:
+        parsed_ref = EvidenceRef.parse(detail_ref)
+    except ValueError as exc:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=detail_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.UNKNOWN,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason=str(exc),
+        )
+    canonical_ref = parsed_ref.format()
+    if parsed_ref.session_id != session_id:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=canonical_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.MISSING,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="evidence ref addresses another session",
+        )
+    if parsed_ref.message_id is None:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=canonical_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.MISSING,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="detail part requires a message coordinate",
+        )
+
+    normalized = _normalize_renderable_messages(
+        messages,
+        session_id=session_id,
+        provider_family=provider_family,
+    )
+    message = next((item for item in normalized if item.id == parsed_ref.message_id), None)
+    if message is None:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=canonical_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.MISSING,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="message evidence is unavailable",
+        )
+
+    block: RenderableBlock | None = None
+    if parsed_ref.block_index is not None:
+        if parsed_ref.block_index >= len(message.blocks):
+            return _detail_unavailable(
+                session_id=session_id,
+                detail_ref=canonical_ref,
+                part=detail_part.value,
+                state=SemanticCardDetailState.MISSING,
+                offset=bounded_offset,
+                limit=bounded_limit,
+                reason="block evidence is unavailable",
+            )
+        block = message.blocks[parsed_ref.block_index]
+
+    text: str | None
+    if detail_part is SemanticCardDetailPart.MESSAGE_TEXT:
+        if parsed_ref.block_index is not None:
+            return _detail_unavailable(
+                session_id=session_id,
+                detail_ref=canonical_ref,
+                part=detail_part.value,
+                state=SemanticCardDetailState.MISSING,
+                offset=bounded_offset,
+                limit=bounded_limit,
+                reason="message_text requires an exact message ref without a block coordinate",
+            )
+        text = message.text
+    elif block is None:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=canonical_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.MISSING,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="detail part requires a block coordinate",
+        )
+    elif detail_part is SemanticCardDetailPart.BLOCK_TEXT:
+        text = block.text
+    elif detail_part is SemanticCardDetailPart.TOOL_INPUT:
+        text = (
+            json.dumps(block.tool_input, indent=2, sort_keys=True, ensure_ascii=False)
+            if block.tool_input is not None
+            else None
+        )
+    elif detail_part is SemanticCardDetailPart.TOOL_INPUT_RAW:
+        text = block.tool_input_raw
+    else:
+        path = _first_scalar(block.tool_input, ("file_path", "path", "filename", "target"))
+        text = _edit_diff(block.tool_input, path=path)
+
+    if text is None:
+        return _detail_unavailable(
+            session_id=session_id,
+            detail_ref=canonical_ref,
+            part=detail_part.value,
+            state=SemanticCardDetailState.MISSING,
+            offset=bounded_offset,
+            limit=bounded_limit,
+            reason="addressed evidence does not contain the requested detail part",
+        )
+
+    total = len(text)
+    chunk = text[bounded_offset : bounded_offset + bounded_limit]
+    next_offset = bounded_offset + len(chunk)
+    complete = next_offset >= total
+    return SemanticCardDetailChunk(
+        session_id=session_id,
+        detail_ref=canonical_ref,
+        part=detail_part.value,
+        state=SemanticCardDetailState.AVAILABLE,
+        offset=bounded_offset,
+        limit=bounded_limit,
+        returned_characters=len(chunk),
+        encoding_replacements=chunk.count("\ufffd"),
+        text=chunk,
+        total_characters=total,
+        next_offset=None if complete else next_offset,
+        complete=complete,
+    )
+
+
+def _detail_unavailable(
+    *,
+    session_id: str,
+    detail_ref: str,
+    part: str,
+    state: SemanticCardDetailState,
+    offset: int,
+    limit: int,
+    reason: str,
+) -> SemanticCardDetailChunk:
+    return SemanticCardDetailChunk(
+        session_id=session_id,
+        detail_ref=detail_ref,
+        part=part,
+        state=state,
+        offset=offset,
+        limit=limit,
+        returned_characters=0,
+        encoding_replacements=0,
+        reason=reason,
+    )
+
+
+def _serialize_document_entry(
+    entry: SemanticTranscriptEntry,
+    *,
+    session_id: str,
+    message_by_id: Mapping[str, RenderableMessage],
+) -> JSONDocument:
+    if entry.card is not None:
+        return {
+            "entry_type": "card",
+            "card": _serialize_document_card(entry.card, session_id=session_id, message_by_id=message_by_id),
+        }
+    if entry.prose is not None:
+        return {
+            "entry_type": "prose",
+            "prose": _serialize_document_prose(entry.prose, session_id=session_id),
+        }
+    assert entry.notice is not None
+    sources: list[JSONDocument] = []
+    for source in entry.notice.sources:
+        source_doc = source.to_document()
+        source_doc["evidence_ref"] = _evidence_ref(session_id, source.message_id, source.block_index)
+        sources.append(source_doc)
+    return {
+        "entry_type": "notice",
+        "notice": {
+            "kind": entry.notice.kind.value,
+            "count": entry.notice.count,
+            "sources": cast(list[JSONValue], sources),
+        },
+    }
+
+
+def _serialize_document_prose(prose: TranscriptProse, *, session_id: str) -> JSONDocument:
+    evidence_ref = _evidence_ref(session_id, prose.message_id, prose.block_index)
+    detail_part = (
+        SemanticCardDetailPart.BLOCK_TEXT if prose.block_index is not None else SemanticCardDetailPart.MESSAGE_TEXT
+    )
+    preview = _bounded_preview(
+        prose.text,
+        kind=prose.block_type or "prose",
+        encoding_replacements=prose.text.count("\ufffd"),
+    ).to_document()
+    if bool(preview.get("truncated")):
+        preview["detail"] = SemanticCardDisclosure(evidence_ref, detail_part).to_document()
+    result = prose.to_document()
+    result.pop("text", None)
+    result["evidence_ref"] = evidence_ref
+    result["preview"] = preview
+    return result
+
+
+def _serialize_document_card(
+    card: SemanticCard,
+    *,
+    session_id: str,
+    message_by_id: Mapping[str, RenderableMessage],
+) -> JSONDocument:
+    source = card.source
+    source_message = message_by_id.get(source.message_id or "")
+    result_message = message_by_id.get(source.result_message_id or "")
+    evidence_ref = _evidence_ref(session_id, source.message_id, source.block_index)
+    result_ref = (
+        _evidence_ref(session_id, source.result_message_id, source.result_block_index)
+        if source.result_message_id is not None
+        else None
+    )
+    source_block = _block_at(source_message, source.block_index)
+    source_is_result = source_block is not None and source_block.type == BlockType.TOOL_RESULT.value
+    if result_ref is not None or source_is_result:
+        result_state = SemanticCardResultEvidenceState.PRESENT
+        effective_result_ref = result_ref or evidence_ref
+    elif source.tool_id is not None and card.kind not in {SemanticCardKind.LINEAGE, SemanticCardKind.ATTACHMENT}:
+        result_state = SemanticCardResultEvidenceState.MISSING
+        effective_result_ref = None
+    else:
+        result_state = SemanticCardResultEvidenceState.UNKNOWN
+        effective_result_ref = None
+
+    source_doc = _bounded_source_document(source.to_document())
+    source_doc["evidence_ref"] = evidence_ref
+    source_doc["result_evidence_state"] = result_state.value
+    if effective_result_ref is not None:
+        source_doc["result_evidence_ref"] = effective_result_ref
+    if source_message is not None:
+        source_doc["role"] = source_message.role
+        source_doc["message_type"] = source_message.message_type
+    if result_message is not None:
+        source_doc["result_role"] = result_message.role
+        source_doc["result_message_type"] = result_message.message_type
+
+    input_part = _tool_input_detail_part(source_block)
+    input_disclosure = SemanticCardDisclosure(evidence_ref, input_part) if input_part is not None else None
+    fields: list[JSONDocument] = []
+    for field in card.fields:
+        field_disclosure = input_disclosure if field.label.casefold() in _INPUT_DERIVED_FIELD_LABELS else None
+        fields.append(_bounded_field_document(field.label, field.value, field_disclosure))
+    previews = [
+        _preview_document(
+            preview,
+            use_ref=evidence_ref,
+            result_ref=effective_result_ref,
+            source_block=source_block,
+        )
+        for preview in card.previews
+    ]
+    title_doc = _bounded_text_value(
+        card.title,
+        None,
+        max_characters=CARD_DOCUMENT_INLINE_MAX_CHARS,
+    )
+    result: JSONDocument = {
+        "schema_version": card.schema_version,
+        "kind": card.kind.value,
+        "title": str(title_doc.pop("value")),
+        "source": source_doc,
+        "fields": cast(list[JSONValue], fields),
+        "previews": cast(list[JSONValue], previews),
+        "caveats": list(card.caveats),
+    }
+    if title_doc:
+        result["title_disclosure"] = title_doc
+    if card.summary is not None:
+        summary_disclosure = input_disclosure if card.kind in _SUMMARY_INPUT_FAMILIES else None
+        summary_doc = _bounded_text_value(card.summary, summary_disclosure)
+        result["summary"] = str(summary_doc.pop("value"))
+        if summary_doc:
+            result["summary_disclosure"] = summary_doc
+    if card.outcome is not None:
+        result["outcome"] = card.outcome.to_document()
+    raw = _bounded_raw_evidence_document(
+        card.raw_evidence,
+        use_ref=evidence_ref,
+        result_ref=effective_result_ref,
+        source_block=source_block,
+    )
+    _drop_duplicate_raw_previews(raw, previews)
+    if raw:
+        result["raw_evidence"] = raw
+    return result
+
+
+def _bounded_source_document(source: JSONDocument) -> JSONDocument:
+    """Bound provider metadata that is not needed for exact addressing."""
+
+    result = dict(source)
+    truncations: list[JSONDocument] = []
+    for key in _SOURCE_BOUNDED_FIELDS:
+        value = result.get(key)
+        if not isinstance(value, str) or len(value) <= CARD_DOCUMENT_SOURCE_VALUE_MAX_CHARS:
+            continue
+        result[key] = value[:CARD_DOCUMENT_SOURCE_VALUE_MAX_CHARS]
+        truncations.append(
+            {
+                "field": key,
+                "omitted_characters": len(value) - CARD_DOCUMENT_SOURCE_VALUE_MAX_CHARS,
+            }
+        )
+    if truncations:
+        result["truncations"] = cast(list[JSONValue], truncations)
+    return result
+
+
+def _bounded_raw_evidence_document(
+    evidence: SemanticCardRawEvidence | None,
+    *,
+    use_ref: str,
+    result_ref: str | None,
+    source_block: RenderableBlock | None,
+) -> JSONDocument:
+    if evidence is None:
+        return {}
+    result: JSONDocument = {}
+    if evidence.tool_input is not None:
+        rendered = json.dumps(evidence.tool_input, indent=2, sort_keys=True, ensure_ascii=False)
+        preview = _bounded_preview(rendered, kind="input", encoding_replacements=rendered.count("\ufffd"))
+        result["input_preview"] = _preview_document(
+            preview,
+            use_ref=use_ref,
+            result_ref=result_ref,
+            source_block=source_block,
+        )
+    elif evidence.tool_input_raw is not None:
+        preview = _bounded_preview(
+            evidence.tool_input_raw,
+            kind="raw_input",
+            encoding_replacements=evidence.tool_input_raw.count("\ufffd"),
+        )
+        result["input_preview"] = _preview_document(
+            preview,
+            use_ref=use_ref,
+            result_ref=result_ref,
+            source_block=source_block,
+        )
+    if evidence.result_preview is not None:
+        result["result_preview"] = _preview_document(
+            evidence.result_preview,
+            use_ref=use_ref,
+            result_ref=result_ref,
+            source_block=source_block,
+        )
+    return result
+
+
+def _drop_duplicate_raw_previews(raw: JSONDocument, previews: Sequence[JSONDocument]) -> None:
+    """Avoid repeating evidence already represented by a canonical card preview."""
+
+    preview_fingerprints = {_preview_fingerprint(preview) for preview in previews}
+    for key in ("input_preview", "result_preview"):
+        candidate = raw.get(key)
+        if isinstance(candidate, dict) and _preview_fingerprint(candidate) in preview_fingerprints:
+            raw.pop(key, None)
+
+
+def _preview_fingerprint(preview: Mapping[str, object]) -> tuple[object, ...]:
+    detail = preview.get("detail")
+    detail_ref = detail.get("ref") if isinstance(detail, dict) else None
+    detail_part = detail.get("part") if isinstance(detail, dict) else None
+    return (
+        preview.get("kind"),
+        preview.get("text"),
+        preview.get("line_count"),
+        preview.get("omitted_lines"),
+        preview.get("omitted_characters"),
+        preview.get("truncated"),
+        preview.get("strategy"),
+        preview.get("encoding_replacements"),
+        detail_ref,
+        detail_part,
+    )
+
+
+def _preview_document(
+    preview: SemanticCardPreview,
+    *,
+    use_ref: str,
+    result_ref: str | None,
+    source_block: RenderableBlock | None,
+) -> JSONDocument:
+    document = preview.to_document()
+    disclosure: SemanticCardDisclosure | None = None
+    if preview.kind == "diff":
+        disclosure = SemanticCardDisclosure(use_ref, SemanticCardDetailPart.DERIVED_DIFF)
+    elif preview.kind == "raw_input":
+        disclosure = SemanticCardDisclosure(use_ref, SemanticCardDetailPart.TOOL_INPUT_RAW)
+    elif preview.kind == "input":
+        disclosure = SemanticCardDisclosure(use_ref, SemanticCardDetailPart.TOOL_INPUT)
+    elif result_ref is not None and preview.kind in {
+        "output",
+        "content",
+        "matches",
+        "result",
+        "raw_result",
+    }:
+        disclosure = SemanticCardDisclosure(result_ref, SemanticCardDetailPart.BLOCK_TEXT)
+    elif source_block is not None and source_block.text is not None:
+        disclosure = SemanticCardDisclosure(use_ref, SemanticCardDetailPart.BLOCK_TEXT)
+    if preview.truncated and disclosure is not None:
+        document["detail"] = disclosure.to_document()
+    return document
+
+
+def _bounded_field_document(
+    label: str,
+    value: str,
+    disclosure: SemanticCardDisclosure | None,
+) -> JSONDocument:
+    bounded = _bounded_text_value(value, disclosure)
+    result: JSONDocument = {"label": label, "value": str(bounded.pop("value"))}
+    result.update(bounded)
+    return result
+
+
+def _bounded_text_value(
+    value: str,
+    disclosure: SemanticCardDisclosure | None,
+    *,
+    max_characters: int = CARD_DOCUMENT_FIELD_MAX_CHARS,
+) -> JSONDocument:
+    if len(value) <= max_characters:
+        return {"value": value}
+    result: JSONDocument = {
+        "value": value[:max_characters],
+        "truncated": True,
+        "omitted_characters": len(value) - max_characters,
+    }
+    if disclosure is not None:
+        result["detail"] = disclosure.to_document()
+    return result
+
+
+def _tool_input_detail_part(block: RenderableBlock | None) -> SemanticCardDetailPart | None:
+    if block is None:
+        return None
+    if block.tool_input is not None:
+        return SemanticCardDetailPart.TOOL_INPUT
+    if block.tool_input_raw is not None:
+        return SemanticCardDetailPart.TOOL_INPUT_RAW
+    return None
+
+
+def _block_at(message: RenderableMessage | None, block_index: int | None) -> RenderableBlock | None:
+    if message is None or block_index is None or block_index < 0 or block_index >= len(message.blocks):
+        return None
+    return message.blocks[block_index]
+
+
+def _evidence_ref(session_id: str, message_id: str | None, block_index: int | None) -> str:
+    return EvidenceRef(session_id=session_id, message_id=message_id, block_index=block_index).format()
+
