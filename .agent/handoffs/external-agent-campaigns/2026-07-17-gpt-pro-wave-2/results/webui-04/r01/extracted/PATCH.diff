+    session_entries: sessionEntries,
+    messages,
+  };
+}
+
+export function validateCardDetail(value: unknown): CardDetail {
+  const root = objectAt(value, '$');
+  assertKeys(root, [
+    'schema_version', 'session_id', 'detail_ref', 'part', 'state', 'offset', 'limit', 'returned_characters',
+    'encoding_replacements', 'text', 'total_characters', 'next_offset', 'complete', 'reason',
+  ], [
+    'schema_version', 'session_id', 'detail_ref', 'part', 'state', 'offset', 'limit', 'returned_characters',
+    'encoding_replacements',
+  ], '$');
+  if (root.schema_version !== DETAIL_SCHEMA) fail('$.schema_version', 'unsupported schema');
+  const sessionId = nonEmptyStringAt(root.session_id, '$.session_id');
+  const detailRef = nonEmptyStringAt(root.detail_ref, '$.detail_ref');
+  validateEvidenceRef(detailRef, sessionId, '$.detail_ref');
+  const part = boundedStringAt(root.part, '$.part', 128, false);
+  const state = stringAt(root.state, '$.state') as DetailState;
+  if (!['available', 'missing', 'unknown'].includes(state)) fail('$.state', 'invalid detail state');
+  if (state === 'available' && !DETAIL_PARTS.has(part as DetailPart)) fail('$.part', 'unsupported available detail part');
+  const result: CardDetail = {
+    schema_version: DETAIL_SCHEMA,
+    session_id: sessionId,
+    detail_ref: detailRef,
+    part,
+    state,
+    offset: nonNegativeIntegerAt(root.offset, '$.offset'),
+    limit: positiveIntegerAt(root.limit, '$.limit'),
+    returned_characters: nonNegativeIntegerAt(root.returned_characters, '$.returned_characters'),
+    encoding_replacements: nonNegativeIntegerAt(root.encoding_replacements, '$.encoding_replacements'),
+  };
+  const text = optionalString(root, 'text', '$');
+  if (text !== undefined) result.text = text;
+  const total = optionalNonNegativeInteger(root, 'total_characters', '$');
+  if (total !== undefined) result.total_characters = total;
+  const nextOffset = optionalNonNegativeInteger(root, 'next_offset', '$');
+  if (nextOffset !== undefined) result.next_offset = nextOffset;
+  const complete = optionalBoolean(root, 'complete', '$');
+  if (complete !== undefined) result.complete = complete;
+  const reason = optionalString(root, 'reason', '$');
+  if (reason !== undefined) result.reason = boundedStringAt(reason, '$.reason', CARD_DOCUMENT_MAX_FIELD_CHARS, false);
+  if (result.limit > CARD_DETAIL_MAX_LIMIT) fail('$.limit', 'exceeds server detail limit');
+  if (result.encoding_replacements > result.returned_characters) fail('$.encoding_replacements', 'exceeds returned characters');
+
+  if (state === 'available') {
+    if (text === undefined || total === undefined || complete === undefined || reason !== undefined) fail('$', 'incoherent available detail');
+    if (Array.from(text).length !== result.returned_characters) fail('$.returned_characters', 'does not match text');
+    if (result.returned_characters > result.limit) fail('$.returned_characters', 'exceeds requested limit');
+    const end = result.offset + result.returned_characters;
+    if (end > total) fail('$', 'detail chunk exceeds total characters');
+    if (complete) {
+      if (nextOffset !== undefined || end < total) fail('$', 'incoherent complete detail');
+    } else if (result.returned_characters === 0 || nextOffset !== end || nextOffset >= total) {
+      fail('$', 'incoherent detail continuation');
+    }
+  } else if (
+    text !== undefined || total !== undefined || nextOffset !== undefined || complete !== undefined ||
+    result.returned_characters !== 0 || result.encoding_replacements !== 0 || reason === undefined
+  ) {
+    fail('$', 'incoherent unavailable detail');
+  }
+  return result;
+}
diff --git a/webui/src/transcript/virtual.tsx b/webui/src/transcript/virtual.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..e0bd8af50bcaa297ebfe09415b925c915cbafd3d
--- /dev/null
+++ b/webui/src/transcript/virtual.tsx
@@ -0,0 +1,122 @@
+import { ComponentChildren } from 'preact';
+import { useCallback, useLayoutEffect, useMemo, useRef, useState } from 'preact/hooks';
+
+interface VirtualListProps<T> {
+  items: readonly T[];
+  keyFor: (item: T) => string;
+  renderRow: (item: T, index: number) => ComponentChildren;
+  estimate?: number;
+  overscanPixels?: number;
+}
+
+interface MeasuredRowProps {
+  rowKey: string;
+  index: number;
+  top: number;
+  onMeasure: (index: number, height: number) => void;
+  children: ComponentChildren;
+}
+
+function MeasuredRow({ rowKey, index, top, onMeasure, children }: MeasuredRowProps) {
+  const ref = useRef<HTMLDivElement>(null);
+  useLayoutEffect(() => {
+    const node = ref.current;
+    if (!node) return;
+    const report = () => onMeasure(index, Math.max(1, Math.ceil(node.getBoundingClientRect().height)));
+    report();
+    if (typeof ResizeObserver === 'undefined') return;
+    const observer = new ResizeObserver(report);
+    observer.observe(node);
+    return () => observer.disconnect();
+  }, [index, onMeasure, rowKey]);
+  return <div ref={ref} class="pl-virtual-row" data-row-key={rowKey} style={{ position: 'absolute', top, left: 0, right: 0 }}>{children}</div>;
+}
+
+function lowerBound(offsets: readonly number[], value: number): number {
+  let low = 0;
+  let high = Math.max(0, offsets.length - 1);
+  while (low < high) {
+    const middle = Math.floor((low + high) / 2);
+    if ((offsets[middle] ?? 0) < value) low = middle + 1;
+    else high = middle;
+  }
+  return Math.max(0, low - 1);
+}
+
+export function MeasuredVirtualList<T>({
+  items,
+  keyFor,
+  renderRow,
+  estimate = 280,
+  overscanPixels = 900,
+}: VirtualListProps<T>) {
+  const viewportRef = useRef<HTMLDivElement>(null);
+  const startRef = useRef(0);
+  const [heights, setHeights] = useState<ReadonlyMap<string, number>>(new Map());
+  const [viewport, setViewport] = useState({ scrollTop: 0, height: 800 });
+
+  const geometry = useMemo(() => {
+    const offsets = new Array<number>(items.length + 1);
+    offsets[0] = 0;
+    for (let index = 0; index < items.length; index += 1) {
+      const item = items[index];
+      const key = item === undefined ? String(index) : keyFor(item);
+      offsets[index + 1] = (offsets[index] ?? 0) + (heights.get(key) ?? estimate);
+    }
+    return { offsets, total: offsets[items.length] ?? 0 };
+  }, [estimate, heights, items, keyFor]);
+
+  useLayoutEffect(() => {
+    const node = viewportRef.current;
+    if (!node) return;
+    const read = () => setViewport({ scrollTop: node.scrollTop, height: node.clientHeight });
+    read();
+    node.addEventListener('scroll', read, { passive: true });
+    const observer = typeof ResizeObserver === 'undefined' ? null : new ResizeObserver(read);
+    observer?.observe(node);
+    return () => {
+      node.removeEventListener('scroll', read);
+      observer?.disconnect();
+    };
+  }, []);
+
+  const start = Math.max(0, lowerBound(geometry.offsets, Math.max(0, viewport.scrollTop - overscanPixels)));
+  let end = Math.min(items.length, start + 1);
+  const target = viewport.scrollTop + viewport.height + overscanPixels;
+  while (end < items.length && (geometry.offsets[end] ?? 0) < target) end += 1;
+  startRef.current = start;
+
+  const onMeasure = useCallback((index: number, height: number) => {
+    const item = items[index];
+    if (item === undefined) return;
+    const key = keyFor(item);
+    setHeights((current) => {
+      const previous = current.get(key) ?? estimate;
+      if (previous === height) return current;
+      const next = new Map(current);
+      next.set(key, height);
+      if (index < startRef.current && viewportRef.current) {
+        viewportRef.current.scrollTop += height - previous;
+      }
+      return next;
+    });
+  }, [estimate, items, keyFor]);
+
+  const visible = [];
+  for (let index = start; index < end; index += 1) {
+    const item = items[index];
+    if (item === undefined) continue;
+    const key = keyFor(item);
+    visible.push(
+      <MeasuredRow key={key} rowKey={key} index={index} top={geometry.offsets[index] ?? 0} onMeasure={onMeasure}>
+        {renderRow(item, index)}
+      </MeasuredRow>,
+    );
+  }
+
+  return (
+    <div ref={viewportRef} class="pl-virtual-viewport" data-virtualized="measured-variable-height">
+      <div class="pl-virtual-spacer" style={{ position: 'relative', height: geometry.total }}>{visible}</div>
+    </div>
+  );
+}
