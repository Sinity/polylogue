+    source = cast(dict[str, object], unknown_card["source"])
+    tool_field = next(
+        field for field in cast(list[dict[str, object]], unknown_card["fields"]) if field["label"] == "tool"
+    )
+
+    assert len(cast(str, unknown_card["title"])) == 512
+    assert cast(dict[str, object], unknown_card["title_disclosure"])["omitted_characters"] == 49_512
+    assert len(cast(str, source["tool_name"])) == CARD_DOCUMENT_SOURCE_VALUE_MAX_CHARS
+    assert source["truncations"] == [
+        {"field": "tool_name", "omitted_characters": 45_912},
+        {"field": "tool_id", "omitted_characters": 45_909},
+    ]
+    assert "detail" not in tool_field
+
+    long_command = "printf " + ("x" * 50_000)
+    shell_document = build_semantic_card_document(
+        [
+            {
+                "id": "m-shell",
+                "role": "assistant",
+                "message_type": "tool_use",
+                "blocks": [
+                    {
+                        "id": "b-shell",
+                        "type": "tool_use",
+                        "tool_name": "exec_command",
+                        "tool_id": "shell-1",
+                        "tool_input": {"cmd": long_command},
+                    }
+                ],
+            }
+        ],
