+        command = _string(command_field.get("value"), "command unavailable") if command_field else "command unavailable"
+        command_omitted = _integer(command_field.get("omitted_characters"), 0) if command_field else 0
+        command_omission = f"<small>{command_omitted} command characters omitted</small>" if command_omitted else ""
+        command_disclosure = (
+            _render_disclosure(command_field.get("detail"), label="Expand exact command") if command_field else ""
+        )
+        exit_code = outcome.get("exit_code") if outcome else None
+        prominent = (
+            '<div class="pl-shell-command"><div class="pl-shell-command-value">'
+            f"<code>{html.escape(command)}</code>{command_omission}{command_disclosure}</div>"
+            f"<strong>exit {html.escape(str(exit_code)) if exit_code is not None else 'unknown'}</strong></div>"
+        )
+    elif kind in {"file_read", "file_edit"}:
+        path = _field_value(fields, "path")
+        if path:
+            prominent = f'<div class="pl-target-path">{html.escape(path)}</div>'
+    return (
+        f'<section class="{html.escape(classes, quote=True)}" data-card-family="{html.escape(kind, quote=True)}" '
+        f'data-outcome="{html.escape(state, quote=True)}" data-evidence-ref="{html.escape(_string(source.get("evidence_ref"), ""), quote=True)}">'
+        '<header class="pl-card-header">'
+        f'<span class="pl-family">{html.escape(_CARD_FAMILY_LABELS.get(kind, kind))}</span>'
+        f'<div class="pl-card-title"><h3>{html.escape(title)}</h3>{title_omission}</div>'
+        f'<span class="pl-outcome state-{html.escape(state, quote=True)}">{html.escape(" · ".join(outcome_bits))}</span>'
+        "</header>"
+        f"{prominent}{summary_html}<dl>{''.join(field_rows)}</dl>{previews_html}{raw_html}{caveat_html}{evidence}"
+        "</section>"
+    )
+
+
+def _render_source_evidence(source: Mapping[str, object]) -> str:
+    evidence_ref = _string(source.get("evidence_ref"), "")
+    result_state = _string(source.get("result_evidence_state"), "unknown")
+    lines = [f"ref={evidence_ref}", f"result_evidence={result_state}"]
+    result_ref = source.get("result_evidence_ref")
+    if isinstance(result_ref, str):
+        lines.append(f"result_ref={result_ref}")
+    for key, value in source.items():
+        if key in {"evidence_ref", "result_evidence_state", "result_evidence_ref", "truncations"} or value is None:
+            continue
+        lines.append(f"{key}={value}")
+    truncations = source.get("truncations")
+    if isinstance(truncations, Sequence) and not isinstance(truncations, (str, bytes)):
+        for item in truncations:
+            if isinstance(item, Mapping):
+                field = _string(item.get("field"), "metadata")
+                omitted = _integer(item.get("omitted_characters"), 0)
+                lines.append(f"{field}: {omitted} metadata characters omitted")
+    return (
+        '<details class="pl-evidence"><summary>exact evidence</summary>'
+        f"<pre>{html.escape(chr(10).join(lines))}</pre></details>"
+    )
+
+
+def _render_prose(prose: Mapping[str, object]) -> str:
+    block_type = _string(prose.get("block_type"), "text")
+    material = _string(prose.get("material_origin"), "unknown")
+    preview = prose.get("preview")
+    preview_html = _render_preview(preview) if isinstance(preview, Mapping) else ""
+    evidence_ref = _string(prose.get("evidence_ref"), "")
+    return (
+        f'<section class="pl-prose pl-prose-{html.escape(block_type, quote=True)}" '
+        f'data-evidence-ref="{html.escape(evidence_ref, quote=True)}">'
+        f"<header>{html.escape(block_type)} · material: {html.escape(material)}</header>"
+        f"{preview_html}</section>"
+    )
+
+
+def _render_notice(notice: Mapping[str, object]) -> str:
+    kind = _string(notice.get("kind"), "notice")
+    count = _integer(notice.get("count"), 0)
+    refs: list[str] = []
+    sources = notice.get("sources")
+    if isinstance(sources, Sequence) and not isinstance(sources, (str, bytes)):
+        refs = [_string(source.get("evidence_ref"), "") for source in sources if isinstance(source, Mapping)]
+    details = (
+        f"<details><summary>exact coordinates</summary><pre>{html.escape(chr(10).join(refs))}</pre></details>"
+        if refs
+        else ""
+    )
+    return (
+        f'<aside class="pl-notice" data-notice-kind="{html.escape(kind, quote=True)}">'
+        f"<strong>{html.escape(kind)}</strong> · {count} typed source block(s){details}</aside>"
+    )
+
+
+def _render_preview(preview: Mapping[str, object]) -> str:
+    kind = _string(preview.get("kind"), "evidence")
+    text = _string(preview.get("text"), "")
+    line_count = _integer(preview.get("line_count"), 0)
+    omitted_lines = _integer(preview.get("omitted_lines"), 0)
+    omitted_characters = _integer(preview.get("omitted_characters"), 0)
+    replacements = _integer(preview.get("encoding_replacements"), 0)
+    metadata = [f"{line_count} lines"]
+    if omitted_lines:
+        metadata.append(f"{omitted_lines} lines omitted")
+    if omitted_characters:
+        metadata.append(f"{omitted_characters} characters omitted")
+    if replacements:
+        metadata.append(f"{replacements} encoding replacements")
+    return (
+        f'<figure class="pl-preview pl-preview-{html.escape(kind, quote=True)}" '
+        f'data-preview-kind="{html.escape(kind, quote=True)}"><figcaption>'
+        f"{html.escape(kind)} · {html.escape(' · '.join(metadata))}</figcaption><pre>{html.escape(text)}</pre>"
+        f"{_render_disclosure(preview.get('detail'))}</figure>"
+    )
+
+
+def _render_omission(value: object, label: str, *, allow_detail: bool) -> str:
+    if not isinstance(value, Mapping):
+        return ""
+    omitted = _integer(value.get("omitted_characters"), 0)
+    if omitted <= 0:
+        return ""
+    detail = _render_disclosure(value.get("detail")) if allow_detail else ""
+    return f"<small>{omitted} {html.escape(label)} characters omitted</small>{detail}"
+
+
+def _render_disclosure(value: object, *, label: str = "Load exact detail") -> str:
+    if not isinstance(value, Mapping):
+        return ""
+    ref = value.get("ref")
+    part = value.get("part")
+    if not isinstance(ref, str) or not isinstance(part, str):
+        return ""
+    return (
+        '<button type="button" class="pl-disclose" '
+        f'data-detail-ref="{html.escape(ref, quote=True)}" '
+        f'data-detail-part="{html.escape(part, quote=True)}">{html.escape(label)}</button>'
+    )
+
+
+def _field(fields: object, label: str) -> Mapping[str, object] | None:
+    if not isinstance(fields, Sequence) or isinstance(fields, (str, bytes)):
+        return None
+    return next(
+        (field for field in fields if isinstance(field, Mapping) and field.get("label") == label),
+        None,
+    )
+
+
+def _field_value(fields: object, label: str) -> str | None:
+    field = _field(fields, label)
+    if field is None:
+        return None
+    value = field.get("value")
+    return value if isinstance(value, str) else None
+
+
+def _script_json(value: object) -> str:
+    return (
+        json.dumps(value, ensure_ascii=False, separators=(",", ":"))
+        .replace("&", "\\u0026")
+        .replace("<", "\\u003c")
+        .replace(">", "\\u003e")
+        .replace("\u2028", "\\u2028")
+        .replace("\u2029", "\\u2029")
+    )
+
+
+def _string(value: object, default: str) -> str:
+    return value if isinstance(value, str) else default
+
+
+def _integer(value: object, default: int) -> int:
+    return value if isinstance(value, int) and not isinstance(value, bool) else default
+
+
