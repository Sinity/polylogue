+export const DOCUMENT_SCHEMA = 'semantic-card-document.v1' as const;
+export const DETAIL_SCHEMA = 'semantic-card-detail.v1' as const;
+
+export const CARD_DOCUMENT_MAX_PAGE_LIMIT = 200;
+export const CARD_DOCUMENT_MAX_FIELD_CHARS = 4_096;
+export const CARD_DOCUMENT_MAX_PREVIEW_CHARS = 16_000;
+export const CARD_DOCUMENT_MAX_SOURCE_VALUE_CHARS = 4_096;
+export const CARD_DOCUMENT_MAX_TITLE_CHARS = 512;
+export const CARD_DOCUMENT_MAX_FIELD_LABEL_CHARS = 256;
+export const CARD_DOCUMENT_MAX_PREVIEW_KIND_CHARS = 256;
+export const CARD_DETAIL_MAX_LIMIT = 64_000;
+
+export type CardFamily =
+  | 'shell' | 'file_read' | 'file_edit' | 'search' | 'web'
+  | 'task' | 'mcp' | 'lineage' | 'attachment' | 'fallback';
+export type OutcomeState = 'succeeded' | 'failed' | 'unknown';
+export type ResultEvidenceState = 'present' | 'missing' | 'unknown';
+export type DetailPart = 'message_text' | 'block_text' | 'tool_input' | 'tool_input_raw' | 'derived_diff';
+export type DetailState = 'available' | 'missing' | 'unknown';
+export type SourceTruncationField =
+  | 'origin' | 'block_id' | 'tool_name' | 'tool_id' | 'attachment_id'
+  | 'occurred_at' | 'parent_message_id' | 'result_block_id';
+
+export interface Disclosure {
+  ref: string;
+  part: DetailPart;
+}
+
+export interface TruncationDisclosure {
+  truncated: true;
+  omitted_characters: number;
+  detail?: Disclosure;
+}
+
+export interface CardOutcome {
+  state: OutcomeState;
+  is_error?: boolean;
+  exit_code?: number;
+}
+
+export interface SourceTruncation {
+  field: SourceTruncationField;
+  omitted_characters: number;
+}
+
+export interface CardSource {
+  session_id: string;
+  provider_family: string;
+  evidence_ref: string;
+  result_evidence_state: ResultEvidenceState;
+  result_evidence_ref?: string;
+  origin?: string;
+  message_id?: string;
+  block_id?: string;
+  block_index?: number;
+  tool_name?: string;
+  tool_id?: string;
+  attachment_id?: string;
+  material_origin?: string;
+  occurred_at?: string;
+  duration_ms?: number;
+  parent_message_id?: string;
+  variant_index?: number;
+  is_active_path?: boolean;
+  is_active_leaf?: boolean;
+  inherited_prefix?: boolean;
+  result_message_id?: string;
+  result_block_id?: string;
+  result_block_index?: number;
+  result_duration_ms?: number;
+  result_material_origin?: string;
+  result_inherited_prefix?: boolean;
+  role?: string;
+  message_type?: string;
+  result_role?: string;
+  result_message_type?: string;
+  truncations?: SourceTruncation[];
+}
+
+export interface CardField {
+  label: string;
+  value: string;
+  truncated?: true;
+  omitted_characters?: number;
+  detail?: Disclosure;
+}
+
+export interface CardPreview {
+  kind: string;
+  text: string;
+  line_count: number;
+  omitted_lines: number;
+  omitted_characters: number;
+  truncated: boolean;
+  strategy: 'full' | 'head_tail' | 'character_bounded';
+  encoding_replacements: number;
+  detail?: Disclosure;
+}
+
+export interface SemanticCard {
+  schema_version: 'semantic-card.v1';
+  kind: CardFamily;
+  title: string;
+  title_disclosure?: TruncationDisclosure;
+  source: CardSource;
+  fields: CardField[];
+  previews: CardPreview[];
+  caveats: string[];
+  summary?: string;
+  summary_disclosure?: TruncationDisclosure;
+  outcome?: CardOutcome;
+  raw_evidence?: {
+    input_preview?: CardPreview;
+    result_preview?: CardPreview;
+  };
+}
+
+export interface TranscriptProse {
+  message_id: string;
+  role: string;
+  message_type: string;
+  provider_family: string;
+  material_origin: string;
+  evidence_ref: string;
+  preview: CardPreview;
+  origin?: string;
+  block_id?: string;
+  block_index?: number;
+  block_type?: string;
+  language?: string;
+  occurred_at?: string;
+  duration_ms?: number;
+  parent_message_id?: string;
+  variant_index?: number;
+  is_active_path?: boolean;
+  is_active_leaf?: boolean;
+  inherited_prefix?: boolean;
+}
+
+export interface NoticeSource {
+  message_id: string;
+  block_index: number;
+  block_type: string;
+  evidence_ref: string;
+  block_id?: string;
+  role: string;
+  message_type: string;
+  provider_family: string;
+  origin?: string;
+  material_origin: string;
+  occurred_at?: string;
+  duration_ms?: number;
+  parent_message_id?: string;
+  variant_index?: number;
+  is_active_path?: boolean;
+  is_active_leaf?: boolean;
+  inherited_prefix?: boolean;
+}
+
+export interface TranscriptNotice {
+  kind: string;
+  count: number;
+  sources: NoticeSource[];
+}
+
+export type TranscriptEntry =
+  | { entry_type: 'card'; card: SemanticCard }
+  | { entry_type: 'prose'; prose: TranscriptProse }
+  | { entry_type: 'notice'; notice: TranscriptNotice };
+
+export interface CardDocumentMessage {
+  message_id: string;
+  role: string;
+  message_type: string;
+  material_origin: string;
+  provider_family: string;
+  semantic_card_suppressed: boolean;
+  entries: TranscriptEntry[];
+  origin?: string;
+  occurred_at?: string;
+  duration_ms?: number;
+  parent_message_id?: string;
+  variant_index?: number;
+  is_active_path?: boolean;
+  is_active_leaf?: boolean;
+  inherited_prefix?: boolean;
+  source_session_id?: string;
+}
+
+export interface CardDocumentPage {
+  offset: number;
+  limit: number;
+  returned: number;
+  total_messages: number;
+  next_offset?: number;
+  previous_offset?: number;
+}
+
+export interface CardDocument {
+  schema_version: typeof DOCUMENT_SCHEMA;
+  session_id: string;
+  page: CardDocumentPage;
+  session_entries: TranscriptEntry[];
+  messages: CardDocumentMessage[];
+}
+
+export interface CardDetail {
+  schema_version: typeof DETAIL_SCHEMA;
+  session_id: string;
+  detail_ref: string;
+  part: string;
+  state: DetailState;
+  offset: number;
+  limit: number;
+  returned_characters: number;
+  encoding_replacements: number;
+  text?: string;
+  total_characters?: number;
+  next_offset?: number;
+  complete?: boolean;
+  reason?: string;
+}
+
+const CARD_FAMILIES = new Set<CardFamily>([
+  'shell', 'file_read', 'file_edit', 'search', 'web',
+  'task', 'mcp', 'lineage', 'attachment', 'fallback',
+]);
+const DETAIL_PARTS = new Set<DetailPart>([
+  'message_text', 'block_text', 'tool_input', 'tool_input_raw', 'derived_diff',
+]);
+const SOURCE_TRUNCATION_FIELDS = new Set<SourceTruncationField>([
+  'origin', 'block_id', 'tool_name', 'tool_id', 'attachment_id',
+  'occurred_at', 'parent_message_id', 'result_block_id',
+]);
+const SOURCE_BOUNDED_FIELDS = [...SOURCE_TRUNCATION_FIELDS] as const;
+
+function fail(path: string, message: string): never {
+  throw new Error(`${path}: ${message}`);
+}
+
+function objectAt(value: unknown, path: string): Record<string, unknown> {
+  if (typeof value !== 'object' || value === null || Array.isArray(value)) fail(path, 'expected object');
+  return value as Record<string, unknown>;
+}
+
+function stringAt(value: unknown, path: string): string {
+  if (typeof value !== 'string') fail(path, 'expected string');
+  return value;
+}
+
+function nonEmptyStringAt(value: unknown, path: string): string {
+  const result = stringAt(value, path);
+  if (result.length === 0) fail(path, 'expected non-empty string');
+  return result;
+}
+
+function boundedStringAt(value: unknown, path: string, maxCharacters: number, allowEmpty = true): string {
+  const result = stringAt(value, path);
+  if (!allowEmpty && result.length === 0) fail(path, 'expected non-empty string');
+  if (Array.from(result).length > maxCharacters) fail(path, `exceeds ${maxCharacters} characters`);
+  return result;
+}
+
+function integerAt(value: unknown, path: string): number {
+  if (typeof value !== 'number' || !Number.isInteger(value)) fail(path, 'expected integer');
+  return value;
+}
+
+function nonNegativeIntegerAt(value: unknown, path: string): number {
+  const result = integerAt(value, path);
+  if (result < 0) fail(path, 'expected non-negative integer');
+  return result;
+}
+
+function positiveIntegerAt(value: unknown, path: string): number {
+  const result = integerAt(value, path);
+  if (result <= 0) fail(path, 'expected positive integer');
+  return result;
+}
+
+function booleanAt(value: unknown, path: string): boolean {
+  if (typeof value !== 'boolean') fail(path, 'expected boolean');
+  return value;
+}
+
+function arrayAt(value: unknown, path: string): unknown[] {
+  if (!Array.isArray(value)) fail(path, 'expected array');
+  return value;
+}
+
+function optionalString(obj: Record<string, unknown>, key: string, path: string): string | undefined {
+  return obj[key] === undefined ? undefined : stringAt(obj[key], `${path}.${key}`);
+}
+
+function optionalInteger(obj: Record<string, unknown>, key: string, path: string): number | undefined {
