+"""Server-rendered WebUI v2 transcript projection tests."""
+
+from __future__ import annotations
+
+import json
+from typing import cast
+
+from polylogue.core.json import JSONDocument, JSONValue
+from polylogue.daemon.web_shell_semantic_cards import (
+    render_semantic_card_document_html,
+    render_semantic_card_page,
+)
+from polylogue.rendering.semantic_cards import build_semantic_card_document
+
+CARD_FAMILIES = (
+    "shell",
+    "file_read",
+    "file_edit",
+    "search",
+    "web",
+    "task",
+    "mcp",
+    "lineage",
+    "attachment",
+    "fallback",
+)
+
+
+def _card(kind: str) -> JSONDocument:
+    fields: list[JSONValue] = [{"label": "tool", "value": f"{kind}-tool"}]
+    if kind == "shell":
+        fields.append({"label": "command", "value": "false"})
+    if kind in {"file_read", "file_edit"}:
+        fields.append({"label": "path", "value": "/tmp/example.txt"})
+    if kind == "task":
+        fields.append({"label": "child session", "value": "codex-session:child"})
+    card: JSONDocument = {
+        "schema_version": "semantic-card.v1",
+        "kind": kind,
+        "title": f"{kind} title",
+        "source": {
+            "session_id": "fixture:ssr",
+            "provider_family": "codex",
+            "message_id": "m1",
+            "block_index": 0,
+            "evidence_ref": "fixture:ssr::m1::0",
+            "result_evidence_state": "missing",
+            "role": "assistant",
+            "message_type": "message",
+        },
+        "fields": fields,
+        "previews": [],
+        "caveats": [],
+    }
+    if kind == "shell":
+        card["outcome"] = {"state": "failed", "is_error": True, "exit_code": 1}
+    return card
+
+
+def _document(cards: tuple[JSONDocument, ...] | list[JSONDocument]) -> JSONDocument:
+    return {
+        "schema_version": "semantic-card-document.v1",
+        "session_id": "fixture:ssr",
+        "page": {"offset": 0, "limit": 40, "returned": 1, "total_messages": 1},
+        "session_entries": [],
+        "messages": [
+            {
+                "message_id": "m1",
+                "role": "assistant",
+                "message_type": "message",
+                "material_origin": "assistant_authored",
+                "provider_family": "codex",
+                "semantic_card_suppressed": False,
+                "entries": [{"entry_type": "card", "card": card} for card in cards],
+            }
+        ],
+    }
+
+
+def test_ssr_projects_all_closed_card_families_without_reclassification() -> None:
+    """Deleting any family projection makes a typed registry card disappear visibly."""
+
+    rendered = render_semantic_card_document_html(_document([_card(kind) for kind in CARD_FAMILIES]))
+
+    for kind in CARD_FAMILIES:
+        assert f'data-card-family="{kind}"' in rendered
+    assert rendered.count('data-card-family="') == len(CARD_FAMILIES)
+
+
+def test_ssr_makes_shell_failure_command_exit_file_target_and_task_child_prominent() -> None:
+    rendered = render_semantic_card_document_html(_document([_card("shell"), _card("file_edit"), _card("task")]))
+
+    assert "pl-card-shell is-failed" in rendered
+    assert '<div class="pl-shell-command"><div class="pl-shell-command-value"><code>false</code>' in rendered
+    assert "<strong>exit 1</strong>" in rendered
+    assert "failed · is_error=true · exit=1" in rendered
+
+    bounded_shell = _card("shell")
+    bounded_fields = cast(list[dict[str, object]], bounded_shell["fields"])
+    command = next(field for field in bounded_fields if field["label"] == "command")
+    command.update(
+        {
+            "truncated": True,
+            "omitted_characters": 12,
+            "detail": {"ref": "fixture:ssr::m1::0", "part": "tool_input"},
+        }
+    )
+    bounded_shell_html = render_semantic_card_document_html(_document([bounded_shell]))
+    assert "12 command characters omitted" in bounded_shell_html
+    assert 'data-detail-part="tool_input">Expand exact command</button>' in bounded_shell_html
+    assert "pl-field-command" not in bounded_shell_html
+
+    assert '<div class="pl-target-path">/tmp/example.txt</div>' in rendered
+    assert 'href="/v2/s/codex-session%3Achild"' in rendered
+
+    task = _card("task")
+    fields = cast(list[dict[str, object]], task["fields"])
+    child = next(field for field in fields if field["label"] == "child session")
+    child.update(
+        {
+            "value": "truncated-child",
+            "truncated": True,
+            "omitted_characters": 9,
+            "detail": {"ref": "fixture:ssr::m1::0", "part": "tool_input"},
+        }
+    )
+    truncated = render_semantic_card_document_html(_document([task]))
+    assert "data-child-session=" not in truncated
+    assert "9 characters omitted" in truncated
+    assert 'data-detail-part="tool_input"' in truncated
+
