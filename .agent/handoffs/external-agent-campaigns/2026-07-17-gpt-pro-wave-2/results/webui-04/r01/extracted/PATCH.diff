+
+
+def test_document_paginates_rows_clamps_limits_and_emits_session_entries_once() -> None:
+    messages = [
+        {
+            "id": f"m-{index}",
+            "role": "user",
+            "message_type": "message",
+            "material_origin": "human_authored",
+            "text": f"message {index}",
+            "blocks": [],
+        }
+        for index in range(250)
+    ]
+    lineage = LineageDescriptor(session_id="s", relation="fork")
+    document = build_semantic_card_document(
+        messages, session_id="s", offset=25, limit=999, lineage=lineage
+    ).to_document()
+    page = cast(dict[str, object], document["page"])
+
+    assert page == {
+        "offset": 25,
+        "limit": CARD_DOCUMENT_MAX_PAGE_LIMIT,
+        "returned": CARD_DOCUMENT_MAX_PAGE_LIMIT,
+        "total_messages": 250,
+        "next_offset": 225,
+        "previous_offset": 0,
+    }
+    assert len(cast(list[object], document["messages"])) == CARD_DOCUMENT_MAX_PAGE_LIMIT
+    assert document["session_entries"] == []
+
+    first = build_semantic_card_document(messages, session_id="s", offset=0, limit=40, lineage=lineage).to_document()
+    assert cast(list[object], first["session_entries"])
+
+    past_end = build_semantic_card_document(messages, session_id="s", offset=999, limit=40).to_document()
+    assert past_end["page"] == {
+        "offset": 250,
+        "limit": 40,
+        "returned": 0,
+        "total_messages": 250,
+        "previous_offset": 210,
+    }
+    jsonschema.validate(past_end, DOCUMENT_SCHEMA)
+
+
+def test_detail_is_exact_typed_chunked_and_unicode_code_point_coherent() -> None:
+    text = "A😀B" * 30_000
+    messages = [
+        {
+            "id": "m",
+            "role": "assistant",
+            "message_type": "tool_use",
+            "text": "message body",
+            "blocks": [
+                {
+                    "id": "b",
+                    "type": "tool_use",
+                    "tool_name": "unknown",
+                    "tool_id": "t",
+                    "tool_input": {"payload": text},
+                }
+            ],
+        }
+    ]
+    first = build_semantic_card_detail(
+        messages,
+        session_id="s",
+        detail_ref="s::m::0",
+        part="tool_input",
+        offset=0,
+        limit=999_999,
+    ).to_document()
+    jsonschema.validate(first, DETAIL_SCHEMA)
+    assert first["state"] == "available"
+    assert first["limit"] == CARD_DETAIL_MAX_LIMIT
+    assert first["returned_characters"] == CARD_DETAIL_MAX_LIMIT
+    assert first["next_offset"] == CARD_DETAIL_MAX_LIMIT
+    assert len(cast(str, first["text"])) == CARD_DETAIL_MAX_LIMIT
+
+    second = build_semantic_card_detail(
+        messages,
+        session_id="s",
+        detail_ref="s::m::0",
+        part="tool_input",
+        offset=cast(int, first["next_offset"]),
+        limit=CARD_DETAIL_MAX_LIMIT,
+    ).to_document()
+    jsonschema.validate(second, DETAIL_SCHEMA)
+    assert cast(str, first["text"]) + cast(str, second["text"]) == json.dumps(
+        {"payload": text}, indent=2, sort_keys=True, ensure_ascii=False
+    )
+    assert second["complete"] is True
+
+    missing = build_semantic_card_detail(
+        messages, session_id="s", detail_ref="s::other::0", part="tool_input"
+    ).to_document()
+    unknown = build_semantic_card_detail(
+        messages,
+        session_id="s",
+        detail_ref="not-an-evidence-ref::too::many::parts",
+        part="guessed-output",
+    ).to_document()
+    widened = build_semantic_card_detail(
+        messages, session_id="s", detail_ref="s::m::0", part="message_text"
+    ).to_document()
+    exact_message = build_semantic_card_detail(
+        messages, session_id="s", detail_ref="s::m", part="message_text"
+    ).to_document()
+    for detail in (missing, unknown, widened, exact_message):
+        jsonschema.validate(detail, DETAIL_SCHEMA)
+
+    assert missing["state"] == "missing"
+    assert unknown["state"] == "unknown"
+    assert "text" not in missing and "complete" not in missing
+    assert "text" not in unknown and "complete" not in unknown
+    assert widened["state"] == "missing"
+    assert widened["reason"] == "message_text requires an exact message ref without a block coordinate"
+    assert exact_message["state"] == "available"
+    assert exact_message["text"] == "message body"
+
+
+def test_provider_override_normalizes_transcript_and_document_rows_consistently() -> None:
+    document = build_semantic_card_document(
+        [
+            {
+                "id": "m",
+                "role": "assistant",
+                "message_type": "tool_use",
+                "blocks": [
+                    {
+                        "id": "b",
+                        "type": "tool_use",
+                        "tool_name": "exec_command",
+                        "tool_id": "t",
+                        "tool_input": {"cmd": "true"},
+                    }
+                ],
+            }
+        ],
+        session_id="s",
+        provider_family="codex-session",
+    ).to_document()
+    row = cast(list[dict[str, object]], document["messages"])[0]
+    card = _web_cards(document)[0]
+    assert row["provider_family"] == "codex"
+    assert cast(dict[str, object], card["source"])["provider_family"] == "codex"
+
+
+def test_role_and_material_origin_remain_independent_in_document() -> None:
+    document = build_semantic_card_document(
+        [
+            {
+                "id": "protocol-user-row",
+                "role": "user",
+                "message_type": "protocol",
+                "material_origin": "runtime_protocol",
+                "text": "runtime envelope",
+                "blocks": [],
+            }
+        ],
+        session_id="s",
+    ).to_document()
+    row = cast(list[dict[str, object]], document["messages"])[0]
+    assert row["role"] == "user"
+    assert row["material_origin"] == "runtime_protocol"
