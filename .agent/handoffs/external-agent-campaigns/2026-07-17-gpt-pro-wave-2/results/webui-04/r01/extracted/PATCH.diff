--- /dev/null
+++ b/docs/schemas/semantic-card-detail-v1.schema.json
@@ -0,0 +1,172 @@
+{
+  "$schema": "https://json-schema.org/draft/2020-12/schema",
+  "$id": "https://polylogue.local/schemas/semantic-card-detail-v1.schema.json",
+  "title": "Polylogue exact semantic card detail chunk",
+  "description": "Server-bounded character chunk selected by one exact EvidenceRef and declared detail part.",
+  "type": "object",
+  "required": [
+    "schema_version",
+    "session_id",
+    "detail_ref",
+    "part",
+    "state",
+    "offset",
+    "limit",
+    "returned_characters",
+    "encoding_replacements"
+  ],
+  "additionalProperties": false,
+  "properties": {
+    "schema_version": {
+      "const": "semantic-card-detail.v1"
+    },
+    "session_id": {
+      "type": "string",
+      "minLength": 1
+    },
+    "detail_ref": {
+      "type": "string",
+      "minLength": 1,
+      "maxLength": 65536
+    },
+    "part": {
+      "type": "string",
+      "minLength": 1,
+      "maxLength": 128
+    },
+    "state": {
+      "enum": [
+        "available",
+        "missing",
+        "unknown"
+      ]
+    },
+    "offset": {
+      "type": "integer",
+      "minimum": 0
+    },
+    "limit": {
+      "type": "integer",
+      "minimum": 1,
+      "maximum": 64000
+    },
+    "returned_characters": {
+      "type": "integer",
+      "minimum": 0,
+      "maximum": 64000
+    },
+    "encoding_replacements": {
+      "type": "integer",
+      "minimum": 0
+    },
+    "text": {
+      "type": "string",
+      "maxLength": 64000
+    },
+    "total_characters": {
+      "type": "integer",
+      "minimum": 0
+    },
+    "next_offset": {
+      "type": "integer",
+      "minimum": 0
+    },
+    "complete": {
+      "type": "boolean"
+    },
+    "reason": {
+      "type": "string",
+      "minLength": 1,
+      "maxLength": 4096
+    }
+  },
+  "allOf": [
+    {
+      "if": {
+        "properties": {
+          "state": {
+            "const": "available"
+          }
+        },
+        "required": [
+          "state"
+        ]
+      },
+      "then": {
+        "required": [
+          "text",
+          "total_characters",
+          "complete"
+        ],
+        "not": {
+          "required": [
+            "reason"
+          ]
+        },
+        "properties": {
+          "part": {
+            "enum": [
+              "message_text",
+              "block_text",
+              "tool_input",
+              "tool_input_raw",
+              "derived_diff"
+            ]
+          }
+        }
+      }
+    },
+    {
+      "if": {
+        "properties": {
+          "state": {
+            "enum": [
+              "missing",
+              "unknown"
+            ]
+          }
+        },
+        "required": [
+          "state"
+        ]
+      },
+      "then": {
+        "required": [
+          "reason"
+        ],
+        "properties": {
+          "returned_characters": {
+            "const": 0
+          },
+          "encoding_replacements": {
+            "const": 0
+          }
+        },
+        "not": {
+          "anyOf": [
+            {
+              "required": [
+                "text"
+              ]
+            },
+            {
+              "required": [
+                "total_characters"
+              ]
+            },
+            {
+              "required": [
+                "next_offset"
+              ]
+            },
+            {
+              "required": [
+                "complete"
+              ]
+            }
+          ]
+        }
+      }
+    }
+  ]
+}
