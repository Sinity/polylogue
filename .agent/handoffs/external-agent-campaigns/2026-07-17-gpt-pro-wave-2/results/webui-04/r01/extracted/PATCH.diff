+"""Shared semantic-card transport, exact-disclosure, and terminal parity tests."""
+
+from __future__ import annotations
+
+import json
+import re
+from pathlib import Path
+from typing import cast
+
+import jsonschema
+import pytest
+from jsonschema import Draft202012Validator
+
+from devtools.render_semantic_card_fixtures import _load_case, _materialize_messages, build_case_transcript
+from polylogue.core.json import JSONDocument
+from polylogue.rendering.semantic_card_models import LineageDescriptor, SemanticCard
+from polylogue.rendering.semantic_card_placement import semantic_card_placement_from_transcript
+from polylogue.rendering.semantic_cards import (
+    CARD_DETAIL_MAX_LIMIT,
+    CARD_DOCUMENT_FIELD_MAX_CHARS,
+    CARD_DOCUMENT_MAX_PAGE_LIMIT,
+    CARD_DOCUMENT_SOURCE_VALUE_MAX_CHARS,
+    DEFAULT_PREVIEW_MAX_CHARS,
+    build_semantic_card_detail,
+    build_semantic_card_document,
+)
+from polylogue.rendering.semantic_markdown import render_semantic_card_markdown
+
+ROOT = Path(__file__).resolve().parents[3]
+CASES = ROOT / "tests/data/semantic_cards/cases"
+DOCUMENT_SCHEMA_PATH = ROOT / "docs/schemas/semantic-card-document-v1.schema.json"
+DETAIL_SCHEMA_PATH = ROOT / "docs/schemas/semantic-card-detail-v1.schema.json"
+DOCUMENT_SCHEMA = cast(dict[str, object], json.loads(DOCUMENT_SCHEMA_PATH.read_text(encoding="utf-8")))
+DETAIL_SCHEMA = cast(dict[str, object], json.loads(DETAIL_SCHEMA_PATH.read_text(encoding="utf-8")))
+PARITY_CASES = (
+    CASES / "codex-exec-failure-ten-thousand-lines.json",
+    CASES / "fork-compaction-family.json",
+    CASES / "hermes-truncated-unknown-input.json",
+)
+ALL_CASES = tuple(sorted(CASES.glob("*.json")))
+
+
+def _case_inputs(path: Path) -> tuple[dict[str, object], list[dict[str, object]], LineageDescriptor | None]:
+    case = _load_case(path)
+    messages = _materialize_messages(case.get("messages"), case_path=path)
+    raw_lineage = case.get("lineage")
+    lineage = LineageDescriptor(**cast(dict[str, object], raw_lineage)) if isinstance(raw_lineage, dict) else None  # type: ignore[arg-type]
+    return case, messages, lineage
+
+
+def _web_cards(document: JSONDocument) -> list[dict[str, object]]:
+    cards: list[dict[str, object]] = []
+    entries: list[object] = list(cast(list[object], document["session_entries"]))
+    for message in cast(list[dict[str, object]], document["messages"]):
+        entries.extend(cast(list[object], message["entries"]))
+    for raw_entry in entries:
+        entry = cast(dict[str, object], raw_entry)
+        if entry.get("entry_type") == "card":
+            cards.append(cast(dict[str, object], entry["card"]))
+    return cards
+
+
+def _projection(card: SemanticCard | dict[str, object]) -> tuple[object, object]:
+    if isinstance(card, SemanticCard):
+        return card.kind.value, card.outcome.state.value if card.outcome is not None else None
+    outcome = card.get("outcome")
+    return card.get("kind"), cast(dict[str, object], outcome).get("state") if isinstance(outcome, dict) else None
+
+
+def _validate_schemas() -> None:
+    Draft202012Validator.check_schema(DOCUMENT_SCHEMA)
+    Draft202012Validator.check_schema(DETAIL_SCHEMA)
+
+
+@pytest.mark.parametrize("case_path", PARITY_CASES, ids=lambda path: path.stem)
+def test_card_document_and_terminal_projection_match_canonical_registry(case_path: Path) -> None:
+    """Route-local classification or dropped fallback/lineage/outcome data breaks this test."""
+
+    case, messages, lineage = _case_inputs(case_path)
+    canonical = build_case_transcript(case, case_path=case_path)
+    document = build_semantic_card_document(
+        messages,
+        session_id=str(case["session_id"]),
+        provider_family=str(case.get("provider_family", "unknown")),
+        lineage=lineage,
+        limit=CARD_DOCUMENT_MAX_PAGE_LIMIT,
+    ).to_document()
+    web_cards = _web_cards(document)
+
+    assert [_projection(card) for card in web_cards] == [_projection(card) for card in canonical.cards]
+    assert len(web_cards) == len(canonical.cards)
+    for card in canonical.cards:
+        terminal = render_semantic_card_markdown(card)
+        assert f"- card family: `{card.kind.value}`" in terminal
+        if card.outcome is not None:
+            assert re.search(rf"- structural outcome: `{re.escape(card.outcome.state.value)}`", terminal)
+
+
+@pytest.mark.parametrize("case_path", ALL_CASES, ids=lambda path: path.stem)
+def test_every_canonical_fixture_serializes_to_the_strict_document_schema(case_path: Path) -> None:
+    """Every registry family and entry shape must cross the public v1 transport seam."""
+
+    _validate_schemas()
+    case, messages, lineage = _case_inputs(case_path)
+    document = build_semantic_card_document(
+        messages,
+        session_id=str(case["session_id"]),
+        provider_family=str(case.get("provider_family", "unknown")),
+        lineage=lineage,
+        limit=CARD_DOCUMENT_MAX_PAGE_LIMIT,
+    ).to_document()
+    jsonschema.validate(document, DOCUMENT_SCHEMA)
+
+
+def test_document_schema_preserves_exact_identities_and_complete_message_entries() -> None:
+    """Display bounds must never truncate exact coordinates or silently drop entries."""
+
+    message_id = "m-" + ("x" * 5_000)
+    parent_id = "parent-" + ("y" * 5_000)
+    block_id = "block-" + ("z" * 5_000)
+    document = build_semantic_card_document(
+        [
+            {
+                "id": message_id,
+                "parent_message_id": parent_id,
+                "role": "assistant",
+                "message_type": "message",
+                "material_origin": "assistant_authored",
+                "blocks": [
+                    {
+                        "id": block_id if index == 0 else f"block-{index}",
+                        "type": "text",
+                        "text": f"entry {index}",
+                    }
+                    for index in range(300)
+                ],
+            }
+        ],
+        session_id="s",
+    ).to_document()
+
+    jsonschema.validate(document, DOCUMENT_SCHEMA)
+    row = cast(list[dict[str, object]], document["messages"])[0]
+    entries = cast(list[dict[str, object]], row["entries"])
+    assert row["message_id"] == message_id
+    assert row["parent_message_id"] == parent_id
+    assert len(entries) == 300
+    first_prose = cast(dict[str, object], entries[0]["prose"])
+    assert first_prose["block_id"] == block_id
+
+
+def test_document_row_ownership_and_suppression_match_shared_placement() -> None:
+    """Removing paired-result suppression or changing entry ownership breaks surface parity."""
+
+    case_path = CASES / "mixed-tool-result-context.json"
+    case, messages, lineage = _case_inputs(case_path)
+    transcript = build_case_transcript(case, case_path=case_path)
+    placement = semantic_card_placement_from_transcript(transcript)
+    document = build_semantic_card_document(
+        messages,
+        session_id=str(case["session_id"]),
+        provider_family=str(case.get("provider_family", "unknown")),
+        lineage=lineage,
+    ).to_document()
+
+    rows = cast(list[dict[str, object]], document["messages"])
+    for row in rows:
+        message_id = cast(str, row["message_id"])
+        assert row["semantic_card_suppressed"] is placement.is_suppressed(message_id)
+        assert len(cast(list[object], row["entries"])) == len(placement.entries_for(message_id))
+    assert len(cast(list[object], document["session_entries"])) == len(placement.session_entries)
+
+
+def test_document_is_bounded_and_unknown_tool_keeps_exact_raw_evidence() -> None:
+    raw_input = "x" * 50_000
+    document = build_semantic_card_document(
+        [
+            {
+                "id": "m-use",
+                "role": "assistant",
+                "message_type": "tool_use",
+                "blocks": [
+                    {
+                        "id": "b-use",
+                        "type": "tool_use",
+                        "tool_name": "mystery_tool",
+                        "tool_id": "h1",
+                        "tool_input": raw_input,
+                    }
+                ],
+            }
+        ],
+        session_id="fixture:unknown",
+        provider_family="hermes",
+    ).to_document()
+    jsonschema.validate(document, DOCUMENT_SCHEMA)
+    card = _web_cards(document)[0]
+    previews = cast(list[dict[str, object]], card["previews"])
+    preview = next(item for item in previews if item["kind"] == "raw_input")
+
+    assert card["kind"] == "fallback"
+    raw = cast(dict[str, object], card.get("raw_evidence", {}))
+    assert "tool_input" not in raw and "tool_input_raw" not in raw
+    assert preview["truncated"] is True
+    assert len(cast(str, preview["text"])) == DEFAULT_PREVIEW_MAX_CHARS
+    assert cast(dict[str, object], preview["detail"]) == {
+        "ref": "fixture:unknown::m-use::0",
+        "part": "tool_input_raw",
+    }
+    assert len(json.dumps(document, ensure_ascii=False)) < 30_000
+
+
+def test_preview_marker_is_inside_declared_character_budget() -> None:
+    """The head/tail omission marker must not make a nominal 16k preview exceed 16k."""
+
+    document = build_semantic_card_document(
+        [
+            {
+                "id": "m-shell",
+                "role": "assistant",
+                "message_type": "tool_use",
+                "blocks": [
+                    {
+                        "id": "b-shell",
+                        "type": "tool_use",
+                        "tool_name": "exec_command",
+                        "tool_id": "shell-1",
+                        "tool_input": {"cmd": "printf " + ("x" * 50_000)},
+                    }
+                ],
+            }
+        ],
+        session_id="fixture:preview-budget",
+        provider_family="codex",
+    ).to_document()
+    preview = cast(dict[str, object], cast(dict[str, object], _web_cards(document)[0]["raw_evidence"])["input_preview"])
+
+    rendered = cast(str, preview["text"])
+    marker = "\n… [character-bounded preview] …\n"
+    assert len(rendered) == DEFAULT_PREVIEW_MAX_CHARS
+    assert marker in rendered
+    source_text = json.dumps({"cmd": "printf " + ("x" * 50_000)}, indent=2, sort_keys=True, ensure_ascii=False)
+    assert cast(int, preview["omitted_characters"]) + (len(rendered) - len(marker)) == len(source_text)
+    jsonschema.validate(document, DOCUMENT_SCHEMA)
+
