diff --git a/webui/src/transcript/api.ts b/webui/src/transcript/api.ts
new file mode 100644
index 0000000000000000000000000000000000000000..6547f79b7b26783a0475a8c3b96193d0f9ec259b
--- /dev/null
+++ b/webui/src/transcript/api.ts
@@ -0,0 +1,77 @@
+import { type CardDetail, type CardDocument, type DetailPart, validateCardDetail, validateCardDocument } from './types';
+
+const WEB_HEADERS = { 'X-Polylogue-Web-Client': '1', Accept: 'application/json' } as const;
+
+async function bootstrapCredential(): Promise<void> {
+  const response = await fetch('/api/web-auth/session', {
+    method: 'POST',
+    credentials: 'same-origin',
+    cache: 'no-store',
+    referrerPolicy: 'no-referrer',
+    headers: WEB_HEADERS,
+  });
+  if (!response.ok) throw new Error(`web credential bootstrap failed (${response.status})`);
+}
+
+function sameOriginPath(path: string): string {
+  const target = new URL(path, window.location.origin);
+  if (target.origin !== window.location.origin) throw new Error('cross-origin transcript endpoint rejected');
+  return target.pathname + target.search;
+}
+
+async function requestJson(path: string, retry = true): Promise<unknown> {
+  const response = await fetch(sameOriginPath(path), {
+    credentials: 'same-origin',
+    cache: 'no-store',
+    referrerPolicy: 'no-referrer',
+    headers: WEB_HEADERS,
+  });
+  if (response.status === 401 && retry) {
+    await bootstrapCredential();
+    return requestJson(path, false);
+  }
+  if (!response.ok) throw new Error(`transcript request failed (${response.status})`);
+  return response.json() as Promise<unknown>;
+}
+
+export async function establishReadAuthority(): Promise<void> {
+  await bootstrapCredential();
+}
+
+export async function fetchCardDocument(
+  baseUrl: string,
+  offset: number,
+  limit: number,
+  expectedSessionId?: string,
+): Promise<CardDocument> {
+  const target = new URL(sameOriginPath(baseUrl), window.location.origin);
+  target.searchParams.set('offset', String(offset));
+  target.searchParams.set('limit', String(limit));
+  target.searchParams.set('format', 'json');
+  const document = validateCardDocument(await requestJson(target.pathname + target.search));
+  if (document.page.offset !== offset) throw new Error('card-document offset does not match request');
+  if (expectedSessionId !== undefined && document.session_id !== expectedSessionId) {
+    throw new Error('card-document session does not match request');
+  }
+  return document;
+}
+
+export async function fetchCardDetail(
+  baseUrl: string,
+  sessionId: string,
+  ref: string,
+  part: DetailPart,
+  offset: number,
+  limit: number,
+): Promise<CardDetail> {
+  const target = new URL(sameOriginPath(baseUrl), window.location.origin);
+  target.searchParams.set('ref', ref);
+  target.searchParams.set('part', part);
+  target.searchParams.set('offset', String(offset));
+  target.searchParams.set('limit', String(limit));
+  const detail = validateCardDetail(await requestJson(target.pathname + target.search));
+  if (detail.session_id !== sessionId || detail.detail_ref !== ref || detail.part !== part || detail.offset !== offset) {
+    throw new Error('card-detail response does not match exact request');
+  }
+  return detail;
+}
diff --git a/webui/src/transcript/components.tsx b/webui/src/transcript/components.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..83e4722e65c2fc9cfdf91f2b242ee4a6561dfa5e
--- /dev/null
+++ b/webui/src/transcript/components.tsx
@@ -0,0 +1,408 @@
+import { type ComponentChildren, type ComponentType } from 'preact';
+import { useCallback, useMemo, useRef, useState } from 'preact/hooks';
+
+import { fetchCardDetail, fetchCardDocument } from './api';
+import { MeasuredVirtualList } from './virtual';
+import {
+  type CardDocument,
+  type CardDocumentMessage,
+  type CardField,
+  type CardPreview,
+  type Disclosure,
+  type SemanticCard,
+  type TranscriptEntry,
+} from './types';
+
+const PAGE_LIMIT = 40;
+const DETAIL_CHUNK = 16_000;
+const CLIENT_DETAIL_CAP = 256_000;
+
+interface LoadedTranscript {
+  sessionId: string;
+  totalMessages: number;
+  nextOffset: number | undefined;
+  sessionEntries: TranscriptEntry[];
+  messages: CardDocumentMessage[];
+}
+
+interface CardProps {
+  card: SemanticCard;
+  sessionId: string;
+}
+
+export function loadedTranscript(document: CardDocument): LoadedTranscript {
+  if (document.page.offset !== 0) throw new Error('initial card-document page must start at offset zero');
+  return {
+    sessionId: document.session_id,
+    totalMessages: document.page.total_messages,
+    nextOffset: document.page.next_offset,
+    sessionEntries: document.session_entries,
+    messages: document.messages,
+  };
+}
+
+export function mergeCardDocumentPage(current: LoadedTranscript, page: CardDocument): LoadedTranscript {
+  if (page.session_id !== current.sessionId) throw new Error('cannot merge a different transcript session');
+  if (current.nextOffset === undefined) throw new Error('cannot merge after the transcript is complete');
+  if (page.page.offset !== current.nextOffset || page.page.offset !== current.messages.length) {
+    throw new Error('card-document page is not contiguous');
+  }
+  if (page.page.total_messages !== current.totalMessages) throw new Error('card-document total changed during pagination');
+  if (page.session_entries.length !== 0) throw new Error('later card-document page repeated session entries');
+  const existing = new Set(current.messages.map((message) => message.message_id));
+  for (const message of page.messages) {
+    if (existing.has(message.message_id)) throw new Error(`card-document repeated message ${message.message_id}`);
+    existing.add(message.message_id);
+  }
+  return {
+    ...current,
+    nextOffset: page.page.next_offset,
+    messages: [...current.messages, ...page.messages],
+  };
+}
+
+function documentUrl(sessionId: string): string {
+  return `/api/sessions/${encodeURIComponent(sessionId)}/card-document`;
+}
+
+function detailUrl(sessionId: string): string {
+  return `/api/sessions/${encodeURIComponent(sessionId)}/card-detail`;
+}
+
+function authoredness(role: string, materialOrigin: string): string {
+  if (materialOrigin === 'human_authored') return 'human-authored';
+  if (materialOrigin === 'assistant_authored') return 'assistant-authored';
+  if (materialOrigin === 'operator_command') return 'operator command';
+  if (
+    role === 'user' &&
+    ['runtime_protocol', 'runtime_context', 'generated_context_pack', 'generated_analysis_pack', 'tool_result'].includes(materialOrigin)
+  ) {
+    return 'protocol/runtime row — not human-authored';
+  }
+  return materialOrigin.replaceAll('_', ' ') || 'authorship unknown';
+}
+
+export function TranscriptApp({ initial }: { initial: CardDocument }) {
+  const [transcript, setTranscript] = useState<LoadedTranscript>(() => loadedTranscript(initial));
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const pageRequestInFlight = useRef(false);
+
+  const loadNext = useCallback(async () => {
+    if (loading || transcript.nextOffset === undefined || pageRequestInFlight.current) return;
+    pageRequestInFlight.current = true;
+    setLoading(true);
+    setError(null);
+    try {
+      const page = await fetchCardDocument(
+        documentUrl(transcript.sessionId),
+        transcript.nextOffset,
+        PAGE_LIMIT,
+        transcript.sessionId,
+      );
+      setTranscript((current) => mergeCardDocumentPage(current, page));
+    } catch (caught) {
+      setError(caught instanceof Error ? caught.message : String(caught));
+    } finally {
+      pageRequestInFlight.current = false;
+      setLoading(false);
+    }
+  }, [loading, transcript.nextOffset, transcript.sessionId]);
+
+  return (
+    <section class="pl-transcript" data-schema={initial.schema_version} data-session-id={transcript.sessionId}>
+      <header class="pl-transcript-header">
+        <div>
+          <strong>{transcript.sessionId}</strong>
+          <span class="pl-page-fact">{transcript.messages.length} of {transcript.totalMessages} source messages loaded</span>
+        </div>
+        <span class="pl-contract-badge">{initial.schema_version}</span>
+      </header>
+      {transcript.sessionEntries.length > 0 && <div class="pl-session-entries">
+        {transcript.sessionEntries.map((entry, index) => (
+          <SemanticEntryView key={`session-${index}`} entry={entry} sessionId={transcript.sessionId} />
+        ))}
+      </div>}
+      <MeasuredVirtualList
+        items={transcript.messages}
+        keyFor={(message) => message.message_id}
+        renderRow={(message) => <MessageView message={message} sessionId={transcript.sessionId} />}
+      />
+      <footer class="pl-transcript-footer">
+        {transcript.nextOffset !== undefined
+          ? <button type="button" onClick={() => { void loadNext(); }} disabled={loading}>{loading ? 'Loading…' : 'Load next page'}</button>
+          : <span>Transcript page sequence complete.</span>}
+        {error && <strong role="alert">{error}</strong>}
+      </footer>
+    </section>
+  );
+}
+
+export function MessageView({ message, sessionId }: { message: CardDocumentMessage; sessionId: string }) {
+  const authorship = authoredness(message.role, message.material_origin);
+  const protocolWarning = message.role === 'user' && message.material_origin === 'runtime_protocol';
+  const anchor = `message-${encodeURIComponent(message.message_id)}`;
+  return (
+    <article class="pl-message" id={anchor} data-message-id={message.message_id} data-role={message.role} data-material-origin={message.material_origin}>
+      <header class="pl-message-header">
+        <span class="pl-role">{message.role}</span><span>{message.message_type}</span>
+        <span class="pl-material">material_origin={message.material_origin}</span>
+        <span class="pl-authoredness">{authorship}</span>
+        {message.inherited_prefix === true && <span>inherited prefix</span>}
+        {protocolWarning && <span class="pl-authorship-warning">provider user envelope; runtime protocol material</span>}
+        <a href={`#${anchor}`} aria-label="link to message">#</a>
+      </header>
+      <div class="pl-message-entries">
+        {message.entries.map((entry, index) => (
+          <SemanticEntryView key={`${message.message_id}-${entry.entry_type}-${index}`} entry={entry} sessionId={sessionId} />
+        ))}
+        {message.entries.length === 0 && message.semantic_card_suppressed && (
+          <p class="pl-suppressed">Paired tool-result row; exact evidence is attached to its invocation card.</p>
+        )}
+      </div>
+    </article>
+  );
+}
+
+export function SemanticEntryView({ entry, sessionId }: { entry: TranscriptEntry; sessionId: string }) {
+  if (entry.entry_type === 'card') {
+    const Component = CARD_COMPONENTS[entry.card.kind];
+    return <Component card={entry.card} sessionId={sessionId} />;
+  }
+  if (entry.entry_type === 'prose') {
+    return (
+      <section class={`pl-prose pl-prose-${entry.prose.block_type ?? 'text'}`} data-evidence-ref={entry.prose.evidence_ref}>
+        <header>{entry.prose.block_type ?? 'text'} · material: {entry.prose.material_origin}</header>
+        <PreviewView preview={entry.prose.preview} sessionId={sessionId} />
+      </section>
+    );
+  }
+  return (
+    <aside class="pl-notice" data-notice-kind={entry.notice.kind}>
+      <strong>{entry.notice.kind}</strong> · {entry.notice.count} typed source block(s)
+      <details><summary>exact coordinates</summary><pre>{entry.notice.sources.map((source) => source.evidence_ref).join('\n')}</pre></details>
+    </aside>
+  );
+}
+
+function ShellCard(props: CardProps) {
+  const commandField = props.card.fields.find((field) => field.label === 'command');
+  const command = commandField?.value ?? 'command unavailable';
+  const exitCode = props.card.outcome?.exit_code;
+  return <FamilyCard {...props} label="Shell" prominent={
+    <div class="pl-shell-command">
+      <div class="pl-shell-command-value">
+        <code>{command}</code>
+        {commandField?.truncated && <small>{commandField.omitted_characters} command characters omitted</small>}
+        {commandField?.detail && <DetailDisclosure disclosure={commandField.detail} sessionId={props.sessionId} label="Expand exact command" />}
+      </div>
+      <strong>exit {exitCode ?? 'unknown'}</strong>
+    </div>
+  } skipFieldLabels={new Set(['command'])} />;
+}
+
+function FileReadCard(props: CardProps) {
+  const path = fieldValue(props.card.fields, 'path');
+  return <FamilyCard {...props} label="Read" prominent={path ? <div class="pl-target-path">{path}</div> : undefined} />;
+}
+
+function FileEditCard(props: CardProps) {
+  const path = fieldValue(props.card.fields, 'path');
+  return <FamilyCard {...props} label="Edit / write" prominent={path ? <div class="pl-target-path">{path}</div> : undefined} />;
+}
+
+const SearchCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Search" />;
+const WebCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Web" />;
+const TaskCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Task / delegation" />;
+const McpCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="MCP" />;
+const LineageCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Lineage" banner />;
+const AttachmentCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Attachment" />;
+const FallbackCard: ComponentType<CardProps> = (props) => <FamilyCard {...props} label="Unknown tool evidence" />;
+
+const CARD_COMPONENTS: Record<SemanticCard['kind'], ComponentType<CardProps>> = {
+  shell: ShellCard,
+  file_read: FileReadCard,
+  file_edit: FileEditCard,
+  search: SearchCard,
+  web: WebCard,
+  task: TaskCard,
+  mcp: McpCard,
+  lineage: LineageCard,
+  attachment: AttachmentCard,
+  fallback: FallbackCard,
+};
+
+function FamilyCard({
+  card,
+  sessionId,
+  label,
+  banner = false,
+  prominent,
+  skipFieldLabels = new Set<string>(),
+}: CardProps & {
+  label: string;
+  banner?: boolean;
+  prominent?: ComponentChildren;
+  skipFieldLabels?: ReadonlySet<string>;
+}) {
+  const outcome = card.outcome ?? { state: 'unknown' as const };
+  const outcomeBits: string[] = [outcome.state];
+  if (outcome.is_error !== undefined) outcomeBits.push(`is_error=${outcome.is_error}`);
+  if (outcome.exit_code !== undefined) outcomeBits.push(`exit=${outcome.exit_code}`);
+  return (
+    <section
+      class={`pl-card pl-card-${card.kind}${outcome.state === 'failed' ? ' is-failed' : ''}${banner ? ' pl-card-banner' : ''}`}
+      data-card-family={card.kind}
+      data-outcome={outcome.state}
+      data-evidence-ref={card.source.evidence_ref}
+    >
+      <header class="pl-card-header">
+        <span class="pl-family">{label}</span>
+        <div class="pl-card-title"><h3>{card.title}</h3>{card.title_disclosure && (
+          <OmissionView omission={card.title_disclosure} sessionId={sessionId} label="title" />
+        )}</div>
+        <span class={`pl-outcome state-${outcome.state}`}>{outcomeBits.join(' · ')}</span>
+      </header>
+      {prominent}
+      {card.summary !== undefined && <div class="pl-card-summary"><pre>{card.summary}</pre>
+        {card.summary_disclosure && <OmissionView omission={card.summary_disclosure} sessionId={sessionId} label="summary" />}
+      </div>}
+      <dl>{card.fields.filter((field) => !skipFieldLabels.has(field.label)).map((field, index) => (
+        <FieldView key={`${field.label}-${index}`} field={field} card={card} sessionId={sessionId} />
+      ))}</dl>
+      {card.previews.map((preview, index) => <PreviewView key={`${preview.kind}-${index}`} preview={preview} sessionId={sessionId} />)}
+      {card.raw_evidence && <details class="pl-raw"><summary>raw retained evidence</summary>
+        {card.raw_evidence.input_preview && <PreviewView preview={card.raw_evidence.input_preview} sessionId={sessionId} />}
+        {card.raw_evidence.result_preview && <PreviewView preview={card.raw_evidence.result_preview} sessionId={sessionId} />}
+      </details>}
+      {card.caveats.length > 0 && <ul class="pl-caveats">{card.caveats.map((caveat, index) => <li key={`${index}-${caveat}`}>{caveat}</li>)}</ul>}
+      <SourceEvidence card={card} />
+    </section>
+  );
+}
+
+function SourceEvidence({ card }: { card: SemanticCard }) {
+  const source = card.source;
+  const lines: string[] = [
+    `ref=${source.evidence_ref}`,
+    `result_evidence=${source.result_evidence_state}`,
+  ];
+  if (source.result_evidence_ref) lines.push(`result_ref=${source.result_evidence_ref}`);
+  for (const [key, value] of Object.entries(source)) {
+    if (['evidence_ref', 'result_evidence_state', 'result_evidence_ref', 'truncations'].includes(key) || value === undefined) continue;
+    lines.push(`${key}=${String(value)}`);
+  }
+  for (const item of source.truncations ?? []) lines.push(`${item.field}: ${item.omitted_characters} metadata characters omitted`);
+  return <details class="pl-evidence"><summary>exact evidence</summary><pre>{lines.join('\n')}</pre></details>;
+}
+
+function FieldView({ field, card, sessionId }: { field: CardField; card: SemanticCard; sessionId: string }) {
+  const childSession = card.kind === 'task' && !field.truncated && ['child session', 'child_session', 'session'].includes(field.label.toLowerCase());
+  return <div class={`pl-field pl-field-${field.label.replaceAll(' ', '-')}`}><dt>{field.label}</dt><dd>
+    {childSession ? <a href={`/v2/s/${encodeURIComponent(field.value)}`} data-child-session={field.value}>{field.value}</a> : field.value}
+    {field.truncated && <small>{field.omitted_characters} characters omitted</small>}
+    {field.detail && <DetailDisclosure disclosure={field.detail} sessionId={sessionId} label="Expand exact field" />}
+  </dd></div>;
+}
+
+function PreviewView({ preview, sessionId }: { preview: CardPreview; sessionId: string }) {
+  const omitted = [
+    `${preview.line_count} lines`,
+    preview.omitted_lines ? `${preview.omitted_lines} lines omitted` : '',
+    preview.omitted_characters ? `${preview.omitted_characters} characters omitted` : '',
+    preview.encoding_replacements ? `${preview.encoding_replacements} encoding replacements` : '',
+  ].filter(Boolean).join(' · ');
+  return <figure class={`pl-preview pl-preview-${preview.kind}`} data-preview-kind={preview.kind}><figcaption>{preview.kind} · {omitted}</figcaption>
+    <pre>{preview.text}</pre>
+    {preview.detail && <DetailDisclosure disclosure={preview.detail} sessionId={sessionId} />}
+  </figure>;
+}
+
+function OmissionView({ omission, sessionId, label }: { omission: NonNullable<SemanticCard['summary_disclosure']>; sessionId: string; label: string }) {
+  return <div class="pl-omission"><small>{omission.omitted_characters} {label} characters omitted</small>
+    {omission.detail && <DetailDisclosure disclosure={omission.detail} sessionId={sessionId} />}
+  </div>;
+}
+
+export function DetailDisclosure({ disclosure, sessionId, label = 'Load exact detail' }: { disclosure: Disclosure; sessionId: string; label?: string }) {
+  const [text, setText] = useState('');
+  const [nextOffset, setNextOffset] = useState<number | undefined>(0);
+  const [state, setState] = useState<'idle' | 'loading' | 'available' | 'missing' | 'unknown' | 'error'>('idle');
+  const [reason, setReason] = useState<string | null>(null);
+  const expectedTotal = useRef<number | undefined>(undefined);
+  const requestInFlight = useRef(false);
+  const loadedCharacters = useMemo(() => Array.from(text).length, [text]);
+
+  const load = useCallback(async () => {
+    if (nextOffset === undefined || state === 'loading' || requestInFlight.current) return;
+    if (loadedCharacters >= CLIENT_DETAIL_CAP) {
+      setReason(`client disclosure cap reached (${CLIENT_DETAIL_CAP} characters)`);
+      setNextOffset(undefined);
+      return;
+    }
+    requestInFlight.current = true;
+    setState('loading');
+    setReason(null);
+    try {
+      const remaining = CLIENT_DETAIL_CAP - loadedCharacters;
+      const detail = await fetchCardDetail(
+        detailUrl(sessionId),
+        sessionId,
+        disclosure.ref,
+        disclosure.part,
+        nextOffset,
+        Math.min(DETAIL_CHUNK, remaining),
+      );
+      if (detail.state !== 'available') {
+        setState(detail.state);
+        setReason(detail.reason ?? detail.state);
+        setNextOffset(undefined);
+        return;
+      }
+      if (expectedTotal.current !== undefined && detail.total_characters !== expectedTotal.current) {
+        throw new Error('detail total changed during disclosure');
+      }
+      expectedTotal.current = detail.total_characters;
+      setText((current) => current + (detail.text ?? ''));
+      const projectedLength = loadedCharacters + detail.returned_characters;
+      if (detail.next_offset !== undefined && projectedLength >= CLIENT_DETAIL_CAP) {
+        setReason(`client disclosure cap reached (${CLIENT_DETAIL_CAP} characters)`);
+        setNextOffset(undefined);
+      } else {
+        setNextOffset(detail.next_offset);
+      }
+      setState('available');
+    } catch (caught) {
+      setState('error');
+      setReason(caught instanceof Error ? caught.message : String(caught));
+    } finally {
+      requestInFlight.current = false;
+    }
+  }, [disclosure.part, disclosure.ref, loadedCharacters, nextOffset, sessionId, state]);
+
+  const buttonLabel = state === 'idle'
+    ? label
+    : state === 'loading'
+      ? 'Loading…'
+      : state === 'missing' || state === 'unknown'
+        ? 'Detail unavailable'
+        : state === 'error'
+          ? 'Retry exact detail'
+          : nextOffset !== undefined
+            ? 'Load next bounded chunk'
+            : reason?.startsWith('client disclosure cap reached')
+              ? 'Client disclosure cap reached'
+              : 'Detail complete';
+
+  return <div class="pl-disclosure" data-detail-state={state}>
+    <button type="button" onClick={() => { void load(); }} disabled={state === 'loading' || nextOffset === undefined}>
+      {buttonLabel}
+    </button>
+    {text && <pre class="pl-detail-text">{text}</pre>}
+    {reason && <span role={state === 'error' ? 'alert' : 'status'}>{reason}</span>}
+  </div>;
+}
+
+function fieldValue(fields: readonly CardField[], label: string): string | undefined {
+  return fields.find((field) => field.label === label)?.value;
+}
diff --git a/webui/src/transcript/main.tsx b/webui/src/transcript/main.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..85c45376e016bce6d374c0cd85da28369a4533ac
--- /dev/null
+++ b/webui/src/transcript/main.tsx
@@ -0,0 +1,82 @@
+import { render } from 'preact';
+
+import { fetchCardDocument } from './api';
+import { TranscriptApp } from './components';
+import { type CardDocument, validateCardDocument } from './types';
+import './transcript.css';
+
+interface TranscriptConfig {
+  session_id: string;
+  document_embedded: boolean;
+  document_url: string;
+}
+
+function parseScript(id: string): unknown {
+  const node = document.getElementById(id);
+  if (!node?.textContent) throw new Error(`missing ${id}`);
+  return JSON.parse(node.textContent) as unknown;
+}
+
+function parseConfig(value: unknown): TranscriptConfig {
+  if (typeof value !== 'object' || value === null || Array.isArray(value)) throw new Error('invalid transcript config');
+  const candidate = value as Record<string, unknown>;
+  const keys = Object.keys(candidate).sort().join(',');
+  if (keys !== ['document_embedded', 'document_url', 'session_id'].sort().join(',')) {
+    throw new Error('invalid transcript config');
+  }
+  if (
+    typeof candidate.session_id !== 'string' || !candidate.session_id ||
+    typeof candidate.document_embedded !== 'boolean' ||
+    typeof candidate.document_url !== 'string'
+  ) {
+    throw new Error('invalid transcript config');
+  }
+  return {
+    session_id: candidate.session_id,
+    document_embedded: candidate.document_embedded,
+    document_url: candidate.document_url,
+  };
+}
+
+export function readEmbeddedDocument(node: Document = document): CardDocument | null {
+  const state = node.getElementById('polylogue-card-document');
+  if (!state?.textContent) return null;
+  try {
+    return validateCardDocument(JSON.parse(state.textContent) as unknown);
+  } catch {
+    return null;
+  }
+}
+
+async function boot(): Promise<void> {
+  const root = document.getElementById('polylogue-transcript-root');
+  if (!(root instanceof HTMLElement)) throw new Error('missing transcript root');
+  const config = parseConfig(parseScript('polylogue-transcript-config'));
+  let initial: CardDocument;
+  if (config.document_embedded) {
+    const embedded = readEmbeddedDocument();
+    if (embedded === null) throw new Error('embedded card document is missing');
+    if (embedded.session_id !== config.session_id) throw new Error('embedded card document belongs to another session');
+    initial = embedded;
+    root.replaceChildren();
+    render(<TranscriptApp initial={initial} />, root);
+    return;
+  }
+  initial = await fetchCardDocument(config.document_url, 0, 40);
+  root.replaceChildren();
+  render(<TranscriptApp initial={initial} />, root);
+}
+
+if (typeof document !== 'undefined') {
+  void boot().catch((caught: unknown) => {
+    const root = document.getElementById('polylogue-transcript-root');
+    if (root) {
+      root.replaceChildren();
+      const failure = document.createElement('section');
+      failure.className = 'pl-fatal';
+      failure.setAttribute('role', 'alert');
+      failure.textContent = caught instanceof Error ? caught.message : String(caught);
+      root.append(failure);
+    }
+  });
+}
