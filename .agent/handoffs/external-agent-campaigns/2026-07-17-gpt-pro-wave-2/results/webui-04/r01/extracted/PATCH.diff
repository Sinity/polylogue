diff --git a/tests/unit/daemon/test_semantic_card_http.py b/tests/unit/daemon/test_semantic_card_http.py
new file mode 100644
index 0000000000000000000000000000000000000000..afdaaaa67d6f00fbcaed916c4f2a6e206ace07b0
--- /dev/null
+++ b/tests/unit/daemon/test_semantic_card_http.py
@@ -0,0 +1,260 @@
+"""Archive-backed HTTP tests for the WebUI v2 semantic-card vertical.
+
+These tests intentionally cross the production reader boundary: ``ArchiveStore``
+materializes sanitized source records, ``DaemonAPIHTTPServer`` resolves and reads
+the archive, the shared renderer builds ``semantic-card-document.v1`` and exact
+detail chunks, and the HTTP handler emits JSON/SSR/local assets.  No document or
+detail loader is replaced with a test double.
+"""
+
+from __future__ import annotations
+
+import json
+import threading
+from collections.abc import Iterator, Mapping
+from contextlib import contextmanager
+from email.message import Message
+from http import HTTPStatus
+from pathlib import Path
+from typing import cast
+from urllib.error import HTTPError
+from urllib.parse import quote, urlencode
+from urllib.request import Request, urlopen
+
+import pytest
+
+from polylogue.archive.message.roles import Role
+from polylogue.core.enums import BlockType, MaterialOrigin, MessageType, Provider
+from polylogue.core.json import JSONDocument
+from polylogue.daemon.http import DaemonAPIHandler, DaemonAPIHTTPServer
+from polylogue.sources.parsers.base import ParsedContentBlock, ParsedMessage, ParsedSession
+from polylogue.storage.sqlite.archive_tiers.archive import ArchiveStore
+
+pytestmark = pytest.mark.xdist_group("web-reader")
+
+_TOKEN = "semantic-card-http-token"
+_NATIVE_ID = "webui-v2-real-route"
+_CANONICAL_ID = f"codex-session:{_NATIVE_ID}"
+_COMMAND = "printf '</script><img src=x>'"
+
+
+def _seed_semantic_card_session(archive_root: Path) -> str:
+    """Write a failed shell action through the normal parsed-session writer."""
+
+    with ArchiveStore(archive_root) as archive:
+        return archive.write_parsed(
+            ParsedSession(
+                source_name=Provider.CODEX,
+                provider_session_id=_NATIVE_ID,
+                title="Sanitized WebUI v2 route fixture",
+                messages=[
+                    ParsedMessage(
+                        provider_message_id="m-use",
+                        role=Role.ASSISTANT,
+                        message_type=MessageType.TOOL_USE,
+                        material_origin=MaterialOrigin.ASSISTANT_AUTHORED,
+                        blocks=[
+                            ParsedContentBlock(
+                                type=BlockType.TOOL_USE,
+                                tool_name="exec_command",
+                                tool_id="call-1",
+                                tool_input={"cmd": _COMMAND},
+                            )
+                        ],
+                    ),
+                    ParsedMessage(
+                        provider_message_id="m-result",
+                        role=Role.TOOL,
+                        message_type=MessageType.TOOL_RESULT,
+                        material_origin=MaterialOrigin.TOOL_RESULT,
+                        blocks=[
+                            ParsedContentBlock(
+                                type=BlockType.TOOL_RESULT,
+                                tool_id="call-1",
+                                text="permission denied",
+                                is_error=True,
+                                exit_code=4,
+                            )
+                        ],
+                    ),
+                ],
+            )
+        )
+
+
+@contextmanager
+def _running_server() -> Iterator[str]:
+    server = DaemonAPIHTTPServer(
+        ("127.0.0.1", 0),
+        DaemonAPIHandler,
+        auth_token=_TOKEN,
+        api_host="127.0.0.1",
+    )
+    port = int(server.server_address[1])
+    thread = threading.Thread(target=server.serve_forever, name="semantic-card-http-test", daemon=True)
+    thread.start()
+    try:
+        yield f"http://127.0.0.1:{port}"
+    finally:
+        server.shutdown()
+        server.server_close()
+        thread.join(timeout=2.0)
+
+
+def _request(
+    url: str,
+    *,
+    authorized: bool = False,
+) -> tuple[int, Message[str, str], bytes]:
+    headers = {"Authorization": f"Bearer {_TOKEN}"} if authorized else {}
+    request = Request(url, headers=headers)
+    try:
+        with urlopen(request, timeout=5.0) as response:
+            return response.status, response.headers, response.read()
+    except HTTPError as exc:
+        return exc.code, exc.headers, exc.read()
+
+
+def _json(body: bytes) -> JSONDocument:
+    value = json.loads(body)
+    assert isinstance(value, dict)
+    return cast(JSONDocument, value)
+
+
+def _first_card(document: Mapping[str, object]) -> Mapping[str, object]:
+    messages = document.get("messages")
+    assert isinstance(messages, list)
+    for message in messages:
+        assert isinstance(message, dict)
+        entries = message.get("entries")
+        assert isinstance(entries, list)
+        for entry in entries:
+            assert isinstance(entry, dict)
+            card = entry.get("card")
+            if entry.get("entry_type") == "card" and isinstance(card, dict):
+                return card
+    raise AssertionError("fixture document did not contain a semantic card")
+
+
+def test_archive_backed_document_detail_ssr_and_local_assets(
+    workspace_env: dict[str, Path],
+) -> None:
+    """Exercise the complete production route from archive rows to browser payloads.
+
+    Production dependencies: archive ID resolution and hydration, structural
+    tool-use/result pairing, provider-reported outcome fields, exact
+    ``EvidenceRef`` disclosure, authenticated parameterized GET dispatch,
+    data-free shell bootstrap, SSR projection, and package-local asset serving.
+
+    Mutation control: bypassing ``ArchiveStore``, pairing by prose, widening an
+    exact ref, embedding archive data before authorization, rendering through a
+    legacy message classifier, or deleting the local Vite bundle breaks this
+    test at a distinct assertion.
+    """
+
+    assert _seed_semantic_card_session(workspace_env["archive_root"]) == _CANONICAL_ID
+    alias = quote(_NATIVE_ID, safe="")
+    canonical = quote(_CANONICAL_ID, safe="")
+
+    with _running_server() as base_url:
+        # Loopback shell bootstrap is intentionally data-free before the
+        # configured read credential has been established.
+        status, headers, body = _request(f"{base_url}/v2/s/{alias}")
+        anonymous_html = body.decode("utf-8")
+        assert status == HTTPStatus.OK
+        assert headers.get_content_type() == "text/html"
+        assert 'data-credential-state="bootstrap-required"' in anonymous_html
+        assert 'id="polylogue-card-document"' not in anonymous_html
+        assert "permission denied" not in anonymous_html
+        assert _COMMAND not in anonymous_html
+
+        # The authenticated page resolves the native-id alias to canonical
+        # archive identity before SSR and island configuration.
+        status, headers, body = _request(f"{base_url}/v2/s/{alias}", authorized=True)
+        authorized_html = body.decode("utf-8")
+        assert status == HTTPStatus.OK
+        assert headers.get_content_type() == "text/html"
+        assert f'data-session-id="{_CANONICAL_ID}"' in authorized_html
+        assert 'data-card-family="shell"' in authorized_html
+        assert 'data-outcome="failed"' in authorized_html
+        assert "exit=4" in authorized_html
+        assert 'id="polylogue-card-document"' in authorized_html
+        assert "\\u003c/script\\u003e\\u003cimg" in authorized_html
+        assert "</script><img" not in authorized_html
+
+        endpoint = f"{base_url}/api/sessions/{canonical}/card-document?offset=0&limit=1"
+        status, _headers, _body = _request(endpoint)
+        assert status == HTTPStatus.UNAUTHORIZED
+
+        status, headers, body = _request(endpoint, authorized=True)
+        assert status == HTTPStatus.OK
+        assert headers.get_content_type() == "application/json"
+        assert headers["Cache-Control"] == "no-store"
+        assert headers["Referrer-Policy"] == "no-referrer"
+        assert headers["X-Content-Type-Options"] == "nosniff"
+        document = _json(body)
+        assert document["schema_version"] == "semantic-card-document.v1"
+        assert document["session_id"] == _CANONICAL_ID
+        page = cast(dict[str, object], document["page"])
+        assert page == {
+            "offset": 0,
+            "limit": 1,
+            "returned": 1,
+            "total_messages": 2,
+            "next_offset": 1,
+        }
+        card = _first_card(document)
+        assert card["kind"] == "shell"
+        assert card["outcome"] == {"state": "failed", "is_error": True, "exit_code": 4}
+        source = cast(dict[str, object], card["source"])
+        assert source["result_evidence_state"] == "present"
+        assert isinstance(source["evidence_ref"], str)
+        assert isinstance(source["result_evidence_ref"], str)
+
+        # HTML format must project this same card document, not classify raw
+        # archive messages a second time.
+        status, headers, body = _request(endpoint + "&format=html", authorized=True)
+        fragment = body.decode("utf-8")
+        assert status == HTTPStatus.OK
+        assert headers.get_content_type() == "text/html"
+        assert 'data-card-family="shell"' in fragment
+        assert 'data-outcome="failed"' in fragment
+
+        detail_query = urlencode(
+            {
+                "ref": source["evidence_ref"],
+                "part": "tool_input",
+                "offset": 2,
+                "limit": 7,
+            }
+        )
+        status, headers, body = _request(
+            f"{base_url}/api/sessions/{canonical}/card-detail?{detail_query}",
+            authorized=True,
+        )
+        detail = _json(body)
+        assert status == HTTPStatus.OK
+        assert headers.get_content_type() == "application/json"
+        assert headers["Cache-Control"] == "no-store"
+        assert headers["Referrer-Policy"] == "no-referrer"
+        assert headers["X-Content-Type-Options"] == "nosniff"
+        assert detail["schema_version"] == "semantic-card-detail.v1"
+        assert detail["session_id"] == _CANONICAL_ID
+        assert detail["detail_ref"] == source["evidence_ref"]
+        assert detail["part"] == "tool_input"
+        assert detail["state"] == "available"
+        assert detail["offset"] == 2
+        assert cast(int, detail["returned_characters"]) <= 7
+        assert isinstance(detail["text"], str)
+
+        for filename, content_type in (
+            ("transcript.js", "text/javascript"),
+            ("transcript.css", "text/css"),
+        ):
+            status, headers, asset = _request(f"{base_url}/assets/webui-v2/{filename}")
+            assert status == HTTPStatus.OK
+            assert headers.get_content_type() == content_type
+            assert headers["X-Content-Type-Options"] == "nosniff"
+            assert headers["Referrer-Policy"] == "no-referrer"
+            assert asset
+            assert b"https://" not in asset
