+
+def _process_fingerprint(proc_root: Path = Path("/proc")) -> str:
+    """Hash the process evidence source without projecting command lines.
+
+    Only identity-bearing fields are sampled. Volatile CPU/accounting fields
+    are deliberately excluded so a stable process tree does not invalidate on
+    every scheduler tick. Races with short-lived processes are represented as
+    ordinary source changes, never as fingerprint failures.
+    """
+
+    digest = hashlib.blake2s(digest_size=16)
+    try:
+        entries = sorted(
+            (entry.name for entry in os.scandir(proc_root) if entry.name.isdigit()),
+            key=int,
+        )
+    except OSError as exc:
+        return f"proc-unavailable:{exc.errno or type(exc).__name__}"
+
+    for pid in entries:
+        base = proc_root / pid
+        digest.update(pid.encode())
+        for name, limit in (("status", 16_384), ("cmdline", 8_192), ("cgroup", 4_096)):
+            try:
+                data = (base / name).read_bytes()[:limit]
+            except OSError:
+                continue
+            if name == "status":
+                data = b"\n".join(
+                    line for line in data.splitlines() if line.startswith((b"Name:", b"PPid:", b"NSpid:"))
+                )
+            digest.update(name.encode())
+            digest.update(len(data).to_bytes(4, "big"))
+            digest.update(data)
+        try:
+            cwd = os.readlink(base / "cwd")
+        except OSError:
+            continue
+        digest.update(b"cwd")
+        digest.update(cwd.encode(errors="surrogateescape"))
+    return digest.hexdigest()
