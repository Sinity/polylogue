+            "raw_validation_failures": _int_value(failures.get("validation_failures")),
+            "raw_quarantined": _int_value(failures.get("quarantined")),
+            "raw_maintenance_failures": _int_value(failures.get("maintenance_failures")),
+            "raw_detection_warnings": _int_value(failures.get("detection_warnings")),
+            "raw_failure_samples": [sample.model_dump(mode="json") for sample in samples],
