+    frozen_clock.advance(0.501)
+    components = _components(registry)
+    assert components["fast"]["state"] == "fresh"
+    assert components["hanging"]["state"] == "timed_out"
+    assert components["hanging"]["deadline_s"] == 0.5
+    assert "exceeded 0.5s deadline" in str(components["hanging"]["reason"])
+
+    # Completing a collector after its budget expired cannot overwrite the
+    # timeout evidence observed by request paths.
+    starter.callbacks["status:test:hanging"]()
