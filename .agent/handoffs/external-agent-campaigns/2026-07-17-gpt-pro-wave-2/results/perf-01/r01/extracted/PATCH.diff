+"""Coordination projections assembled from the shared component registry."""
+
+from __future__ import annotations
+
+from pathlib import Path
+
+import pytest
+
+from polylogue.coordination import status_snapshot
+from polylogue.coordination.payloads import (
+    CoordinationProvenancePayload,
+    CoordinationRepoPayload,
+    CoordinationSelfPayload,
+    CoordinationWorkItemPayload,
+)
+
+
+def _provenance() -> CoordinationProvenancePayload:
+    return CoordinationProvenancePayload(source="test", confidence=1.0, freshness="fixture")
+
+
+def test_request_projection_never_invokes_coordination_collectors(
+    tmp_path: Path,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    status_snapshot.configure_coordination_snapshot(cwd=tmp_path)
+    for dependency in (
+        "_repo_payload",
+        "_process_snapshot",
+        "_work_item_payload",
+        "_beads_payload",
+        "_archive_payload",
+        "_handoff_payloads",
+        "_overlap_payloads",
+    ):
+        monkeypatch.setattr(
+            status_snapshot,
+            dependency,
+            lambda *_args, _dependency=dependency, **_kwargs: (_ for _ in ()).throw(
+                AssertionError(f"request projection invoked {_dependency}")
+            ),
+        )
+
+    payload = status_snapshot.get_coordination_snapshot_payload(view="status", limit=10, detail=False)
+
+    assert payload.status_snapshot is not None
+    assert payload.status_snapshot["protocol"] == "polylogue.status-snapshot.v1"
+    components = payload.status_snapshot["components"]
+    assert isinstance(components, dict)
+    assert set(components) == {
+        "repo",
+        "process",
+        "work_item",
+        "beads",
+        "archive",
+        "handoff_evidence",
+        "derived_overlap",
+    }
+    assert {component["state"] for component in components.values()} == {"unavailable"}
+    assert len(payload.to_json(exclude_none=True).encode()) < 7_600
+
+
+def test_seeded_fragments_assemble_typed_fresh_envelope(tmp_path: Path) -> None:
+    status_snapshot.configure_coordination_snapshot(cwd=tmp_path)
+    provenance = _provenance()
+    registry = status_snapshot._component_registry()
+    registry.seed(
+        "repo",
+        {
+            "repo": CoordinationRepoPayload(
+                cwd=str(tmp_path),
+                root=str(tmp_path),
+                branch="feature/status",
+                provenance=provenance,
+            ).model_dump(mode="json")
+        },
+    )
+    registry.seed(
+        "process",
+        {
+            "self": CoordinationSelfPayload(
+                identity_status="resolved",
+                agent_kind="codex",
+                logical_id="codex:test",
+                owner_pid=10,
+                invocation_pid=11,
+                cwd=str(tmp_path),
+                branch="feature/status",
+                provenance=provenance,
+            ).model_dump(mode="json"),
+            "peers": [],
+            "resource_episodes": [],
+            "process_rows": [],
+            "process_result": {"args": [], "returncode": 0, "stderr": ""},
+        },
+    )
+    registry.seed(
+        "work_item",
+        {
+            "work_item": CoordinationWorkItemPayload(
+                source="beads",
+                ref="polylogue-20d.17",
+                confidence=1.0,
+                provenance=provenance,
+            ).model_dump(mode="json")
+        },
+    )
+    registry.seed("beads", {"beads": None})
+    registry.seed("archive", {"archive": None})
+    registry.seed(
+        "handoff_evidence",
+        {
+            "handoff": [],
+            "session_trees": [],
+            "activity_episodes": [],
+            "subagent_exchanges": [],
+            "proof_refs": [],
+            "context_flow_refs": [],
+        },
+    )
+    registry.seed("derived_overlap", {"overlaps": [], "advisories": ["snapshot-backed"]})
+
+    payload = status_snapshot.get_coordination_snapshot_payload(view="work-item", limit=5, detail=False)
+
+    assert payload.repo.branch == "feature/status"
+    assert payload.self.logical_id == "codex:test"
+    assert payload.work_item.ref == "polylogue-20d.17"
+    assert payload.advisories == ("snapshot-backed",)
+    assert payload.status_snapshot is not None
+    assert payload.status_snapshot["state"] == "fresh"
+    assert payload.status_snapshot["state_counts"] == {"fresh": 7}
+
+
+def test_component_inventory_declares_independent_cost_and_trigger_contracts() -> None:
+    specs = {spec.component_id: spec for spec in status_snapshot.coordination_component_specs()}
+
+    assert tuple(specs) == (
+        "repo",
+        "process",
+        "work_item",
+        "beads",
+        "archive",
+        "handoff_evidence",
+        "derived_overlap",
+    )
+    assert specs["process"].deadline_s == 0.9
+    assert specs["process"].refresh_trigger == "source_fingerprint"
+    assert specs["process"].source_fingerprint is status_snapshot._process_fingerprint
+    assert specs["beads"].cost_class == "expensive"
+    assert specs["beads"].refresh_trigger == "source_fingerprint"
+    assert specs["handoff_evidence"].dependencies == ("repo", "process", "archive")
+    assert specs["derived_overlap"].dependencies == (
+        "repo",
+        "process",
+        "work_item",
+        "archive",
+        "handoff_evidence",
+    )
+
+
+def test_repo_fingerprint_tracks_linked_worktree_branch_ref(tmp_path: Path) -> None:
+    repo = tmp_path / "repo"
+    common = tmp_path / "admin"
+    worktree_admin = common / "worktrees" / "status"
+    branch_ref = common / "refs" / "heads" / "feature"
+    repo.mkdir()
+    worktree_admin.mkdir(parents=True)
+    branch_ref.parent.mkdir(parents=True)
+    (repo / ".git").write_text("gitdir: ../admin/worktrees/status\n", encoding="utf-8")
+    (worktree_admin / "commondir").write_text("../..\n", encoding="utf-8")
+    (worktree_admin / "HEAD").write_text("ref: refs/heads/feature\n", encoding="utf-8")
+    (worktree_admin / "index").write_bytes(b"index")
+    branch_ref.write_text("one\n", encoding="utf-8")
+    status_snapshot.configure_coordination_snapshot(cwd=repo)
+
+    first = status_snapshot._repo_fingerprint()
+    branch_ref.write_text("a-longer-second-value\n", encoding="utf-8")
+    second = status_snapshot._repo_fingerprint()
+
+    assert first != second
+
+
+def test_process_fingerprint_tracks_identity_sources_without_disclosing_commands(tmp_path: Path) -> None:
+    proc_root = tmp_path / "proc"
+    process = proc_root / "101"
+    process.mkdir(parents=True)
+    (process / "status").write_text("Name:\tcodex\nPPid:\t1\nVmRSS:\t10 kB\n", encoding="utf-8")
+    (process / "cmdline").write_bytes(b"codex\0run\0secret-project")
+    (process / "cgroup").write_text("0::/user.slice/agent.scope\n", encoding="utf-8")
+    (process / "cwd").symlink_to(tmp_path)
+
+    first = status_snapshot._process_fingerprint(proc_root)
+    (process / "cmdline").write_bytes(b"codex\0run\0changed-project")
+    second = status_snapshot._process_fingerprint(proc_root)
+
+    assert first != second
+    assert len(first) == 32
+    assert "secret-project" not in first
+    assert "changed-project" not in second
+
+
+def test_beads_and_handoff_fingerprints_include_wal_and_scratch_sources(
+    tmp_path: Path,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    status_snapshot.configure_coordination_snapshot(cwd=tmp_path)
+    beads = tmp_path / ".beads"
+    beads.mkdir()
+    beads_wal = beads / "beads.db-wal"
+    beads_wal.write_bytes(b"one")
+
+    archive = tmp_path / "archive" / "index.db"
+    archive.parent.mkdir()
+    archive.write_bytes(b"index")
+    monkeypatch.setattr(status_snapshot, "active_index_db_path", lambda: archive)
+    scratch = tmp_path / ".agent" / "scratch"
+    scratch.mkdir(parents=True)
+    handoff = scratch / "worker-handoff.md"
+    handoff.write_text("one", encoding="utf-8")
+
+    beads_first = status_snapshot._beads_fingerprint()
+    handoff_first = status_snapshot._handoff_fingerprint()
+    beads_wal.write_bytes(b"a-longer-wal-generation")
+    handoff.write_text("a longer handoff generation", encoding="utf-8")
+
+    assert status_snapshot._beads_fingerprint() != beads_first
+    assert status_snapshot._handoff_fingerprint() != handoff_first
