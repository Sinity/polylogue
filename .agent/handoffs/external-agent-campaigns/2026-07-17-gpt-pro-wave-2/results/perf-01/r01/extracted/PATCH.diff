+def _archive_debt_rows_for_kind(
+    kind: ArchiveDebtKind,
+    *,
+    archive_root: Path,
+    index_db: Path,
+) -> list[ArchiveDebtRowPayload]:
+    if kind == "archive-tier":
+        return _tier_rows(archive_root)
+    if kind == "provider-usage":
+        return _provider_usage_rows(index_db)
+    if kind == "convergence":
+        return _convergence_rows(index_db)
+    if kind == "embedding":
+        return _embedding_rows(index_db)
+    if kind == "fts":
+        return _fts_rows(index_db, exact=False)
