+def _status_path_fingerprint(*paths: Path) -> str:
+    """Return a cheap scheduler-only fingerprint for status source files."""
+
+    parts: list[str] = []
+    for path in paths:
+        try:
+            stat = path.stat()
+        except OSError:
+            parts.append(f"{path}:missing")
+        else:
