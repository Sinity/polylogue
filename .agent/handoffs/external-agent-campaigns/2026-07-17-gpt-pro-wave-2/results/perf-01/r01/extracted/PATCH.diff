+"""Budgeted, independently refreshed status component snapshots.
+
+The protocol is surface-neutral: daemon, CLI, HTTP, MCP, and coordination
+adapters consume the same immutable component projection.  Collectors are
+started only by scheduler calls; read-side projection never evaluates a source
+fingerprint and never invokes a collector.
+"""
+
+from __future__ import annotations
+
+import threading
+import time
+from collections import Counter, defaultdict
+from collections.abc import Callable, Iterable, Mapping, Sequence
+from dataclasses import dataclass, field, replace
+from datetime import UTC, datetime
+from types import MappingProxyType
+from typing import Literal, TypeAlias, cast
+
+from polylogue.core.json import JSONDocument, JSONValue, json_document, require_json_document
+
+StatusComponentState: TypeAlias = Literal[
+    "fresh",
+    "stale",
+    "refreshing",
+    "timed_out",
+    "unavailable",
+    "degraded",
+]
+StatusCostClass: TypeAlias = Literal["cheap", "bounded", "expensive"]
+StatusDetailClass: TypeAlias = Literal["summary", "standard", "detail", "exact"]
+StatusPrivacyClass: TypeAlias = Literal["public", "operator", "sensitive"]
+StatusRefreshTrigger: TypeAlias = Literal["interval", "source_fingerprint", "manual"]
+
+StatusMonotonicClock: TypeAlias = Callable[[], float]
+StatusWallClock: TypeAlias = Callable[[], datetime]
+StatusSourceFingerprint: TypeAlias = Callable[[], str | None]
+StatusThreadStarter: TypeAlias = Callable[[Callable[[], None], str], None]
+
+_PROTOCOL = "polylogue.status-snapshot.v1"
+STATUS_SNAPSHOT_FRESHNESS_MAX_AGE_S = 30.0
+_DETAIL_RANK: dict[StatusDetailClass, int] = {
+    "summary": 0,
+    "standard": 1,
+    "detail": 2,
+    "exact": 3,
+}
+_PRIVACY_RANK: dict[StatusPrivacyClass, int] = {
+    "public": 0,
+    "operator": 1,
+    "sensitive": 2,
+}
+
+
+def _utc_now() -> datetime:
+    return datetime.now(UTC)
+
+
+def _start_daemon_thread(call: Callable[[], None], name: str) -> None:
+    threading.Thread(target=call, name=name, daemon=True).start()
+
+
+def _iso(value: datetime) -> str:
+    return value.astimezone(UTC).isoformat()
+
+
+def _number(value: object) -> float:
+    if isinstance(value, bool):
+        return 0.0
+    if isinstance(value, int | float):
+        return float(value)
+    if isinstance(value, str):
+        try:
+            return float(value)
+        except ValueError:
+            return 0.0
+    return 0.0
+
+
+def format_status_component_lines(payload: Mapping[str, object]) -> list[str]:
+    """Render the stable mixed-state component grid used by status CLIs."""
+
+    raw_components = payload.get("status_components")
+    if not isinstance(raw_components, Mapping):
+        return []
+    lines = ["Status components:"]
+    for component_id, raw in raw_components.items():
+        if not isinstance(raw, Mapping):
+            continue
+        state = str(raw.get("state") or "unavailable")
+        deadline = _number(raw.get("deadline_s"))
+        age = raw.get("age_s")
+        age_text = f" age={float(age):.1f}s" if isinstance(age, int | float) and not isinstance(age, bool) else ""
+        reason = str(raw.get("reason") or "").strip()
+        reason_text = f" — {reason}" if reason else ""
+        detail_ref = str(raw.get("detail_ref") or "").strip()
+        detail_text = f"; detail={detail_ref}" if detail_ref and state != "fresh" else ""
+        last_good = raw.get("last_good")
+        last_good_text = ""
+        if isinstance(last_good, Mapping):
+            last_good_age = last_good.get("age_s")
+            if isinstance(last_good_age, int | float) and not isinstance(last_good_age, bool):
+                last_good_text = f"; last-good={float(last_good_age):.1f}s"
+            else:
+                last_good_text = "; last-good retained"
+        lines.append(
+            f"  {str(component_id):<22} {state:<11} deadline={deadline:g}s{age_text}{last_good_text}{detail_text}{reason_text}"
+        )
+    return lines
+
+
+@dataclass(frozen=True, slots=True)
+class StatusCollectionContext:
+    """Immutable evidence supplied to one component collector.
+
+    ``collection_limit`` constrains diagnostic work, not merely rendering.
+    ``previous_value`` lets an explicitly refreshed component resume a bounded
+    diagnostic after a partial result. ``cancel_requested`` is set when the
+    scheduler deadline expires or the registry is reset; cooperative collectors
+    should stop at their next safe boundary.
+    """
+
+    component_id: str
+    dependency_values: Mapping[str, JSONDocument]
+    detail_class: StatusDetailClass
+    deadline_s: float
+    started_at: str
+    collection_limit: int | None = None
+    previous_value: JSONDocument | None = None
+    cancel_requested: Callable[[], bool] = lambda: False
+
+
+@dataclass(frozen=True, slots=True)
+class StatusCollectionResult:
+    """JSON evidence returned by a component collector."""
+
+    value: JSONDocument = field(default_factory=dict)
+    state: Literal["fresh", "degraded", "unavailable"] = "fresh"
+    observed_at: str | None = None
+    reason: str | None = None
+    evidence_refs: tuple[str, ...] = ()
+    detail_ref: str | None = None
+
+    @classmethod
+    def fresh(
+        cls,
+        value: Mapping[str, JSONValue],
+        *,
+        observed_at: str | None = None,
+        evidence_refs: Sequence[str] = (),
+        detail_ref: str | None = None,
+    ) -> StatusCollectionResult:
+        return cls(
+            value=require_json_document(dict(value), context="status component result"),
+            observed_at=observed_at,
+            evidence_refs=tuple(evidence_refs),
+            detail_ref=detail_ref,
+        )
+
+    @classmethod
+    def unavailable(
+        cls,
+        reason: str,
+        *,
+        value: Mapping[str, JSONValue] | None = None,
+        detail_ref: str | None = None,
+    ) -> StatusCollectionResult:
+        return cls(
+            value=require_json_document(dict(value or {}), context="status component result"),
+            state="unavailable",
+            reason=reason,
+            detail_ref=detail_ref,
+        )
+
+
+StatusCollector: TypeAlias = Callable[[StatusCollectionContext], StatusCollectionResult | Mapping[str, JSONValue]]
+
+
+@dataclass(frozen=True, slots=True)
+class StatusComponentSpec:
+    """Declaration for one independently budgeted status component.
+
+    ``projection_fields`` names the compatibility payload fields owned by the
+    component. ``detail_ref`` identifies the explicit route or command that can
+    perform a richer diagnostic without changing the compact status contract.
+    """
+
+    component_id: str
+    collector: StatusCollector
+    dependencies: tuple[str, ...] = ()
+    cost_class: StatusCostClass = "cheap"
+    detail_class: StatusDetailClass = "standard"
+    deadline_s: float = 0.25
+    refresh_interval_s: float = 10.0
+    stale_after_s: float = 30.0
+    refresh_trigger: StatusRefreshTrigger = "interval"
+    source_fingerprint: StatusSourceFingerprint | None = None
+    privacy_class: StatusPrivacyClass = "public"
+    projection_fields: tuple[str, ...] = ()
+    detail_ref: str | None = None
+    default_enabled: bool = True
+
+    def __post_init__(self) -> None:
+        if not self.component_id or self.component_id.strip() != self.component_id:
+            raise ValueError("component_id must be a non-empty canonical string")
+        if self.component_id in self.dependencies:
+            raise ValueError(f"component {self.component_id!r} cannot depend on itself")
+        if len(set(self.dependencies)) != len(self.dependencies):
+            raise ValueError(f"component {self.component_id!r} has duplicate dependencies")
+        if self.deadline_s <= 0:
+            raise ValueError("deadline_s must be positive")
+        if self.refresh_interval_s < 0:
+            raise ValueError("refresh_interval_s must be non-negative")
+        if self.stale_after_s <= 0:
+            raise ValueError("stale_after_s must be positive")
+        if self.refresh_trigger == "source_fingerprint" and self.source_fingerprint is None:
+            raise ValueError("source_fingerprint trigger requires a source_fingerprint callable")
+
+
+@dataclass(frozen=True, slots=True)
+class StatusSnapshot:
+    """One component observation and its refresh lifecycle."""
+
+    component_id: str
+    state: StatusComponentState
+    value: JSONDocument | None
+    observed_at: str | None
+    refresh_started_at: str | None
+    refresh_finished_at: str | None
+    captured_monotonic: float | None
+    refresh_started_monotonic: float | None
+    refresh_finished_monotonic: float | None
+    source_fingerprint: str | None
+    reason: str | None = None
+    evidence_refs: tuple[str, ...] = ()
+    detail_ref: str | None = None
+    attempt: int = 0
+
+
+@dataclass(slots=True)
+class _StatusRecord:
+    current: StatusSnapshot | None = None
+    last_good: StatusSnapshot | None = None
+    resume_value: JSONDocument | None = None
+    resume_source_fingerprint: str | None = None
+    active_attempt: int | None = None
+    # A timed-out worker remains alive. Keep its attempt separately so the
+    # scheduler never starts an unbounded pile of replacement threads.
+    worker_attempt: int | None = None
+    next_attempt: int = 1
+    last_finished_monotonic: float | None = None
+    last_source_fingerprint: str | None = None
+    cancel_event: threading.Event | None = None
+
+
+class StatusSnapshotRegistry:
+    """Thread-safe scheduler and memory-only status projection.
+
+    Scheduler methods (``refresh_due`` and ``refresh_component``) may inspect
+    fingerprints and start daemon threads. Read methods (``project``,
+    ``component_values``, and ``snapshot``) only inspect memory and account for
+    elapsed deadlines/staleness; they never run production probes.
+    """
+
+    def __init__(
+        self,
+        *,
+        scope: str,
+        specs: Iterable[StatusComponentSpec],
+        monotonic_clock: StatusMonotonicClock = time.monotonic,
+        wall_clock: StatusWallClock = _utc_now,
+        thread_starter: StatusThreadStarter = _start_daemon_thread,
+    ) -> None:
+        declared = tuple(specs)
+        by_id = {spec.component_id: spec for spec in declared}
+        if len(by_id) != len(declared):
+            raise ValueError("status component ids must be unique")
+        for spec in declared:
+            unknown = sorted(set(spec.dependencies) - by_id.keys())
+            if unknown:
+                raise ValueError(f"component {spec.component_id!r} has unknown dependencies: {unknown}")
+        self._validate_acyclic(by_id)
+        self._scope = scope
+        self._specs = by_id
+        self._ordered_ids = self._topological_ids(declared, by_id)
+        dependents: dict[str, list[str]] = defaultdict(list)
+        for spec in declared:
+            for dependency in spec.dependencies:
+                dependents[dependency].append(spec.component_id)
+        self._dependents = {key: tuple(value) for key, value in dependents.items()}
+        self._records = {component_id: _StatusRecord() for component_id in by_id}
+        self._monotonic = monotonic_clock
+        self._wall_clock = wall_clock
+        self._thread_starter = thread_starter
+        self._lock = threading.RLock()
+
+    @property
+    def scope(self) -> str:
+        return self._scope
+
+    @property
+    def specs(self) -> tuple[StatusComponentSpec, ...]:
+        return tuple(self._specs[component_id] for component_id in self._ordered_ids)
+
+    def refresh_due(
+        self,
+        *,
+        detail_class: StatusDetailClass = "standard",
+        component_ids: Iterable[str] | None = None,
+        force: bool = False,
+        collection_limit: int | None = None,
+    ) -> tuple[str, ...]:
+        """Start eligible collectors and return immediately."""
+
+        if collection_limit is not None and collection_limit <= 0:
+            raise ValueError("collection_limit must be positive")
+        requested = set(component_ids) if component_ids is not None else None
+        selected = self._with_dependencies(requested) if requested is not None else None
+        started: list[str] = []
+        for component_id in self._ordered_ids:
+            if selected is not None and component_id not in selected:
+                continue
+            spec = self._specs[component_id]
+            selected_for_refresh = selected is not None and component_id in selected
+            if not spec.default_enabled and not selected_for_refresh:
+                continue
+            if _DETAIL_RANK[spec.detail_class] > _DETAIL_RANK[detail_class] and not selected_for_refresh:
+                continue
+            fingerprint, fingerprint_error = self._read_fingerprint(spec)
+            if fingerprint_error is not None:
+                self.mark_unavailable(component_id, fingerprint_error, source_fingerprint=fingerprint)
+                continue
+            if self._start_if_due(
+                spec,
+                fingerprint=fingerprint,
+                force=force,
+                collection_limit=collection_limit,
+            ):
+                started.append(component_id)
+        return tuple(started)
+
+    def refresh_component(
+        self,
+        component_id: str,
+        *,
+        force: bool = True,
+        collection_limit: int | None = None,
+    ) -> bool:
+        """Start one collector without waiting for its result."""
+
+        if collection_limit is not None and collection_limit <= 0:
+            raise ValueError("collection_limit must be positive")
+        spec = self._require_spec(component_id)
+        fingerprint, fingerprint_error = self._read_fingerprint(spec)
+        if fingerprint_error is not None:
+            self.mark_unavailable(component_id, fingerprint_error, source_fingerprint=fingerprint)
+            return False
+        return self._start_if_due(
+            spec,
+            fingerprint=fingerprint,
+            force=force,
+            collection_limit=collection_limit,
+        )
+
+    def seed(
+        self,
+        component_id: str,
+        value: Mapping[str, JSONValue],
+        *,
+        state: StatusComponentState = "fresh",
+        observed_at: str | None = None,
+        captured_monotonic: float | None = None,
+        reason: str | None = None,
+        evidence_refs: Sequence[str] = (),
+        source_fingerprint: str | None = None,
+    ) -> StatusSnapshot:
+        """Install a deterministic observation (startup migration and tests)."""
+
+        spec = self._require_spec(component_id)
+        now_mono = self._monotonic() if captured_monotonic is None else captured_monotonic
+        now_iso = observed_at or _iso(self._wall_clock())
+        snapshot = StatusSnapshot(
+            component_id=component_id,
+            state=state,
+            value=require_json_document(dict(value), context=f"status seed {component_id}"),
+            observed_at=now_iso,
+            refresh_started_at=now_iso,
+            refresh_finished_at=now_iso,
+            captured_monotonic=now_mono,
+            refresh_started_monotonic=now_mono,
+            refresh_finished_monotonic=now_mono,
+            source_fingerprint=source_fingerprint,
+            reason=reason,
+            evidence_refs=tuple(evidence_refs),
+            detail_ref=spec.detail_ref,
+            attempt=0,
+        )
+        with self._lock:
+            record = self._records[component_id]
+            record.current = snapshot
+            record.active_attempt = None
+            # Do not forget an already-running worker. Its eventual result is
+            # ignored because ``active_attempt`` no longer matches, but keeping
+            # the worker id prevents a seeded test/startup observation from
+            # spawning duplicate collectors while that worker is still alive.
+            record.last_finished_monotonic = now_mono
+            record.last_source_fingerprint = source_fingerprint
+            if record.cancel_event is not None:
+                record.cancel_event.set()
+            record.cancel_event = None
+            if state in {"fresh", "degraded"}:
+                record.resume_value = snapshot.value
+                record.resume_source_fingerprint = source_fingerprint
+            if state == "fresh":
+                record.last_good = snapshot
+        return snapshot
+
+    def mark_unavailable(
+        self,
+        component_id: str,
+        reason: str,
+        *,
+        source_fingerprint: str | None = None,
+    ) -> StatusSnapshot:
+        """Record explicit unavailable evidence without invoking a collector."""
+
+        spec = self._require_spec(component_id)
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        with self._lock:
+            record = self._records[component_id]
+            worker_attempt = record.worker_attempt
+            if record.cancel_event is not None:
+                record.cancel_event.set()
+            snapshot = StatusSnapshot(
+                component_id=component_id,
+                state="unavailable",
+                value=None,
+                observed_at=None,
+                refresh_started_at=now_iso,
+                refresh_finished_at=now_iso,
+                captured_monotonic=None,
+                refresh_started_monotonic=now_mono,
+                refresh_finished_monotonic=now_mono,
+                source_fingerprint=source_fingerprint,
+                reason=reason,
+                detail_ref=spec.detail_ref,
+                attempt=record.next_attempt,
+            )
+            record.next_attempt += 1
+            record.current = snapshot
+            record.active_attempt = None
+            # A fingerprint failure must not lose track of a collector that is
+            # already running; otherwise repeated scheduler ticks could create
+            # an unbounded pile of replacement workers.
+            record.worker_attempt = worker_attempt
+            record.last_finished_monotonic = now_mono
+            record.last_source_fingerprint = source_fingerprint
+            return snapshot
+
+    def project(
+        self,
+        *,
+        detail_class: StatusDetailClass = "standard",
+        privacy_class: StatusPrivacyClass = "operator",
+        component_ids: Iterable[str] | None = None,
+        include_values: bool = True,
+        include_last_good_values: bool = True,
+    ) -> JSONDocument:
+        """Return a stable JSON projection without running any probe."""
+
+        selected = set(component_ids) if component_ids is not None else None
+        now_mono = self._monotonic()
+        generated_at = _iso(self._wall_clock())
+        components: dict[str, JSONValue] = {}
+        states: list[StatusComponentState] = []
+        with self._lock:
+            self._expire_deadlines_locked(now_mono, generated_at)
+            for component_id in self._ordered_ids:
+                if selected is not None and component_id not in selected:
+                    continue
+                spec = self._specs[component_id]
+                if _DETAIL_RANK[spec.detail_class] > _DETAIL_RANK[detail_class]:
+                    continue
+                if _PRIVACY_RANK[spec.privacy_class] > _PRIVACY_RANK[privacy_class]:
+                    continue
+                record = self._records[component_id]
+                current = self._effective_snapshot_locked(spec, record, now_mono)
+                states.append(current.state if current is not None else "unavailable")
+                components[component_id] = self._project_component_locked(
+                    spec,
+                    record,
+                    current,
+                    now_mono=now_mono,
+                    include_value=include_values,
+                    include_last_good_value=include_last_good_values,
+                )
+        counts = Counter(states)
+        return json_document(
+            {
+                "protocol": _PROTOCOL,
+                "scope": self._scope,
+                "state": self._overall_state(states),
+                "generated_at": generated_at,
+                "component_count": len(components),
+                "state_counts": dict(sorted(counts.items())),
+                "components": components,
+            }
+        )
+
+    def component_values(
+        self,
+        *,
+        component_ids: Iterable[str] | None = None,
+        detail_class: StatusDetailClass | None = None,
+        use_last_good: bool = True,
+    ) -> Mapping[str, JSONDocument]:
+        """Return compatibility fragments from memory only.
+
+        Fresh and stale values are returned directly. A degraded observation may
+        carry a value; otherwise its last-good value is returned when requested.
+        Timed-out, refreshing, and unavailable components contribute only their
+        retained last-good value.
+        """
+
+        selected = set(component_ids) if component_ids is not None else None
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        values: dict[str, JSONDocument] = {}
+        with self._lock:
+            self._expire_deadlines_locked(now_mono, now_iso)
+            for component_id in self._ordered_ids:
+                if selected is not None and component_id not in selected:
+                    continue
+                spec = self._specs[component_id]
+                if detail_class is not None and _DETAIL_RANK[spec.detail_class] > _DETAIL_RANK[detail_class]:
+                    continue
+                record = self._records[component_id]
+                current = self._effective_snapshot_locked(spec, record, now_mono)
+                value = current.value if current is not None and current.value is not None else None
+                if value is None and use_last_good and record.last_good is not None:
+                    value = record.last_good.value
+                if value is not None:
+                    values[component_id] = value
+        return MappingProxyType(values)
+
+    def snapshot(self, component_id: str) -> StatusSnapshot | None:
+        """Return one effective immutable snapshot without probing."""
+
+        spec = self._require_spec(component_id)
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        with self._lock:
+            self._expire_deadlines_locked(now_mono, now_iso)
+            return self._effective_snapshot_locked(spec, self._records[component_id], now_mono)
+
+    def reset(self) -> None:
+        """Clear observations and invalidate every in-flight generation.
+
+        An uncooperative worker may outlive the reset. Preserve its generation
+        guard until it exits so repeated reconfiguration cannot create a pile
+        of replacement threads for the same component.
+        """
+
+        with self._lock:
+            records: dict[str, _StatusRecord] = {}
+            for component_id, old in self._records.items():
+                if old.cancel_event is not None:
+                    old.cancel_event.set()
+                next_attempt = max(old.next_attempt, (old.worker_attempt or 0) + 1)
+                records[component_id] = _StatusRecord(
+                    worker_attempt=old.worker_attempt,
+                    next_attempt=next_attempt,
+                    cancel_event=old.cancel_event,
+                )
+            self._records = records
+
+    def _start_if_due(
+        self,
+        spec: StatusComponentSpec,
+        *,
+        fingerprint: str | None,
+        force: bool,
+        collection_limit: int | None,
+    ) -> bool:
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        with self._lock:
+            self._expire_deadlines_locked(now_mono, now_iso)
+            record = self._records[spec.component_id]
+            if record.worker_attempt is not None:
+                return False
+            if not force and not self._is_due_locked(spec, record, now_mono=now_mono, fingerprint=fingerprint):
+                return False
+            dependency_values: dict[str, JSONDocument] = {}
+            for dependency_id in spec.dependencies:
+                dependency_spec = self._specs[dependency_id]
+                dependency_record = self._records[dependency_id]
+                dependency = self._effective_snapshot_locked(dependency_spec, dependency_record, now_mono)
+                if dependency is None or dependency.state != "fresh" or dependency.value is None:
+                    dependency_state = dependency.state if dependency is not None else "missing"
+                    self._set_unavailable_locked(
+                        spec,
+                        record,
+                        reason=f"dependency {dependency_id} is {dependency_state}",
+                        now_mono=now_mono,
+                        now_iso=now_iso,
+                        source_fingerprint=fingerprint,
+                    )
+                    # Retry immediately after the prerequisite completes.
+                    record.last_finished_monotonic = None
+                    return False
+                dependency_values[dependency_id] = dependency.value
+            attempt = record.next_attempt
+            record.next_attempt += 1
+            record.active_attempt = attempt
+            record.worker_attempt = attempt
+            cancel_event = threading.Event()
+            record.cancel_event = cancel_event
+            previous_value = record.resume_value if record.resume_source_fingerprint == fingerprint else None
+            record.current = StatusSnapshot(
+                component_id=spec.component_id,
+                state="refreshing",
+                value=None,
+                observed_at=None,
+                refresh_started_at=now_iso,
+                refresh_finished_at=None,
+                captured_monotonic=None,
+                refresh_started_monotonic=now_mono,
+                refresh_finished_monotonic=None,
+                source_fingerprint=fingerprint,
+                detail_ref=spec.detail_ref,
+                attempt=attempt,
+            )
+            context = StatusCollectionContext(
+                component_id=spec.component_id,
+                dependency_values=MappingProxyType(dependency_values),
+                detail_class=spec.detail_class,
+                deadline_s=spec.deadline_s,
+                started_at=now_iso,
+                collection_limit=collection_limit,
+                previous_value=previous_value,
+                cancel_requested=cancel_event.is_set,
+            )
+
+        def collect() -> None:
+            try:
+                raw_result = spec.collector(context)
+                result = self._coerce_result(raw_result)
+            except Exception as exc:
+                self._finish_exception(spec, attempt, fingerprint, exc)
+                return
+            self._finish_result(spec, attempt, fingerprint, result)
+
+        try:
+            self._thread_starter(collect, f"status:{self._scope}:{spec.component_id}")
+        except Exception as exc:
+            self._finish_exception(spec, attempt, fingerprint, exc)
+            return False
+        return True
+
+    def _finish_result(
+        self,
+        spec: StatusComponentSpec,
+        attempt: int,
+        fingerprint: str | None,
+        result: StatusCollectionResult,
+    ) -> None:
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        value = require_json_document(dict(result.value), context=f"status component {spec.component_id}")
+        with self._lock:
+            record = self._records[spec.component_id]
+            if record.worker_attempt == attempt:
+                record.worker_attempt = None
+                record.cancel_event = None
+            current = record.current
+            if record.active_attempt != attempt or current is None:
+                if (
+                    current is not None
+                    and current.attempt == attempt
+                    and current.state == "timed_out"
+                    and result.state in {"fresh", "degraded"}
+                ):
+                    record.resume_value = value
+                    record.resume_source_fingerprint = fingerprint
+                return
+            started_mono = current.refresh_started_monotonic
+            elapsed = 0.0 if started_mono is None else max(0.0, now_mono - started_mono)
+            if elapsed > spec.deadline_s:
+                self._set_timeout_locked(spec, record, current, now_mono=now_mono, now_iso=now_iso)
+                if result.state in {"fresh", "degraded"}:
+                    record.resume_value = value
+                    record.resume_source_fingerprint = fingerprint
+                return
+            observed_at = result.observed_at or now_iso
+            snapshot = StatusSnapshot(
+                component_id=spec.component_id,
+                state=cast(StatusComponentState, result.state),
+                value=value,
+                observed_at=observed_at,
+                refresh_started_at=current.refresh_started_at,
+                refresh_finished_at=now_iso,
+                captured_monotonic=now_mono,
+                refresh_started_monotonic=current.refresh_started_monotonic,
+                refresh_finished_monotonic=now_mono,
+                source_fingerprint=fingerprint,
+                reason=result.reason,
+                evidence_refs=tuple(result.evidence_refs),
+                detail_ref=result.detail_ref or spec.detail_ref,
+                attempt=attempt,
+            )
+            record.active_attempt = None
+            record.current = snapshot
+            record.last_finished_monotonic = now_mono
+            record.last_source_fingerprint = fingerprint
+            if result.state in {"fresh", "degraded"}:
+                record.resume_value = value
+                record.resume_source_fingerprint = fingerprint
+            if result.state == "fresh":
+                record.last_good = snapshot
+
+    def _finish_exception(
+        self,
+        spec: StatusComponentSpec,
+        attempt: int,
+        fingerprint: str | None,
+        exc: Exception,
+    ) -> None:
+        now_mono = self._monotonic()
+        now_iso = _iso(self._wall_clock())
+        with self._lock:
+            record = self._records[spec.component_id]
+            if record.worker_attempt == attempt:
+                record.worker_attempt = None
+                record.cancel_event = None
+            current = record.current
+            if record.active_attempt != attempt or current is None:
+                return
+            state: StatusComponentState = "degraded" if record.last_good is not None else "unavailable"
+            record.current = StatusSnapshot(
+                component_id=spec.component_id,
+                state=state,
+                value=None,
+                observed_at=None,
+                refresh_started_at=current.refresh_started_at,
+                refresh_finished_at=now_iso,
+                captured_monotonic=None,
+                refresh_started_monotonic=current.refresh_started_monotonic,
+                refresh_finished_monotonic=now_mono,
+                source_fingerprint=fingerprint,
+                reason=f"{type(exc).__name__}: {exc}",
+                detail_ref=spec.detail_ref,
+                attempt=attempt,
+            )
+            record.active_attempt = None
+            record.last_finished_monotonic = now_mono
+            record.last_source_fingerprint = fingerprint
+
+    def _expire_deadlines_locked(self, now_mono: float, now_iso: str) -> None:
+        for component_id in self._ordered_ids:
+            spec = self._specs[component_id]
+            record = self._records[component_id]
+            current = record.current
+            if current is None or current.state != "refreshing" or record.active_attempt is None:
+                continue
+            started = current.refresh_started_monotonic
+            if started is not None and now_mono - started > spec.deadline_s:
+                self._set_timeout_locked(spec, record, current, now_mono=now_mono, now_iso=now_iso)
+
+    def _set_timeout_locked(
+        self,
+        spec: StatusComponentSpec,
+        record: _StatusRecord,
+        current: StatusSnapshot,
+        *,
+        now_mono: float,
+        now_iso: str,
+    ) -> None:
+        if record.cancel_event is not None:
+            record.cancel_event.set()
+        record.current = StatusSnapshot(
+            component_id=spec.component_id,
+            state="timed_out",
+            value=None,
+            observed_at=None,
+            refresh_started_at=current.refresh_started_at,
+            refresh_finished_at=now_iso,
+            captured_monotonic=None,
+            refresh_started_monotonic=current.refresh_started_monotonic,
+            refresh_finished_monotonic=now_mono,
+            source_fingerprint=current.source_fingerprint,
+            reason=f"collector exceeded {spec.deadline_s:g}s deadline",
+            detail_ref=spec.detail_ref,
+            attempt=current.attempt,
+        )
+        record.active_attempt = None
+        record.last_finished_monotonic = now_mono
+        record.last_source_fingerprint = current.source_fingerprint
+
+    def _set_unavailable_locked(
+        self,
+        spec: StatusComponentSpec,
+        record: _StatusRecord,
+        *,
+        reason: str,
+        now_mono: float,
+        now_iso: str,
+        source_fingerprint: str | None,
+    ) -> None:
+        record.current = StatusSnapshot(
+            component_id=spec.component_id,
+            state="unavailable",
+            value=None,
+            observed_at=None,
+            refresh_started_at=now_iso,
+            refresh_finished_at=now_iso,
+            captured_monotonic=None,
+            refresh_started_monotonic=now_mono,
+            refresh_finished_monotonic=now_mono,
+            source_fingerprint=source_fingerprint,
+            reason=reason,
+            detail_ref=spec.detail_ref,
+            attempt=record.next_attempt,
+        )
+        record.next_attempt += 1
+        record.active_attempt = None
+        record.last_finished_monotonic = now_mono
+        record.last_source_fingerprint = source_fingerprint
+
+    def _is_due_locked(
+        self,
+        spec: StatusComponentSpec,
+        record: _StatusRecord,
+        *,
+        now_mono: float,
+        fingerprint: str | None,
+    ) -> bool:
+        if spec.refresh_trigger == "manual":
+            return False
+        if record.current is None:
+            return True
+        if spec.refresh_trigger == "source_fingerprint" and fingerprint != record.last_source_fingerprint:
+            return True
+        if record.last_finished_monotonic is None:
+            return True
+        for dependency_id in spec.dependencies:
+            dependency_finished = self._records[dependency_id].last_finished_monotonic
+            if dependency_finished is not None and dependency_finished > record.last_finished_monotonic:
+                return True
+        return now_mono - record.last_finished_monotonic >= spec.refresh_interval_s
+
+    def _effective_snapshot_locked(
+        self,
+        spec: StatusComponentSpec,
+        record: _StatusRecord,
+        now_mono: float,
+    ) -> StatusSnapshot | None:
+        current = record.current
+        if current is None:
+            return None
+        if current.state == "fresh" and current.captured_monotonic is not None:
+            age_s = max(0.0, now_mono - current.captured_monotonic)
+            if age_s > spec.stale_after_s:
+                return replace(
+                    current,
+                    state="stale",
+                    reason=f"evidence age {age_s:.3f}s exceeds {spec.stale_after_s:g}s policy",
+                )
+        return current
+
+    def _project_component_locked(
+        self,
+        spec: StatusComponentSpec,
+        record: _StatusRecord,
+        current: StatusSnapshot | None,
+        *,
+        now_mono: float,
+        include_value: bool,
+        include_last_good_value: bool,
+    ) -> JSONDocument:
+        if current is None:
+            state: StatusComponentState = "unavailable"
+            age_s: float | None = None
+            payload: dict[str, JSONValue] = {
+                "component_id": spec.component_id,
+                "state": state,
+                "reason": "not collected yet",
+                "observed_at": None,
+                "refresh_started_at": None,
+                "refresh_finished_at": None,
+                "refresh_duration_s": None,
+                "age_s": None,
+                "source_fingerprint": None,
+                "evidence_refs": [],
+                "value": None,
+            }
+        else:
+            age_s = max(0.0, now_mono - current.captured_monotonic) if current.captured_monotonic is not None else None
+            duration_end = current.refresh_finished_monotonic
+            if duration_end is None and current.state == "refreshing":
+                duration_end = now_mono
+            refresh_duration_s = (
+                max(0.0, duration_end - current.refresh_started_monotonic)
+                if duration_end is not None and current.refresh_started_monotonic is not None
+                else None
+            )
+            payload = {
+                "component_id": spec.component_id,
+                "state": current.state,
+                "reason": current.reason,
+                "observed_at": current.observed_at,
+                "refresh_started_at": current.refresh_started_at,
+                "refresh_finished_at": current.refresh_finished_at,
+                "refresh_duration_s": round(refresh_duration_s, 3) if refresh_duration_s is not None else None,
+                "age_s": round(age_s, 3) if age_s is not None else None,
+                "source_fingerprint": current.source_fingerprint,
+                "evidence_refs": list(current.evidence_refs),
+                "value": current.value if include_value else None,
+            }
+        payload.update(
+            {
+                "cost_class": spec.cost_class,
+                "detail_class": spec.detail_class,
+                "deadline_s": spec.deadline_s,
+                "refresh_interval_s": spec.refresh_interval_s,
+                "stale_after_s": spec.stale_after_s,
+                "refresh_trigger": spec.refresh_trigger,
+                "privacy_class": spec.privacy_class,
+                "dependencies": list(spec.dependencies),
+                "projection_fields": list(spec.projection_fields),
+                "detail_ref": (current.detail_ref if current is not None else None) or spec.detail_ref,
+            }
+        )
+        last_good = record.last_good
+        if last_good is None or (current is not None and last_good == current and current.state == "fresh"):
+            payload["last_good"] = None
+        else:
+            last_good_age = (
+                max(0.0, now_mono - last_good.captured_monotonic) if last_good.captured_monotonic is not None else None
+            )
+            payload["last_good"] = {
+                "observed_at": last_good.observed_at,
+                "age_s": round(last_good_age, 3) if last_good_age is not None else None,
+                "source_fingerprint": last_good.source_fingerprint,
+                "refresh_duration_s": (
+                    round(last_good.refresh_finished_monotonic - last_good.refresh_started_monotonic, 3)
+                    if last_good.refresh_finished_monotonic is not None
+                    and last_good.refresh_started_monotonic is not None
+                    else None
+                ),
+                "evidence_refs": list(last_good.evidence_refs),
+                "value": last_good.value if include_last_good_value else None,
+            }
+        return json_document(payload)
+
+    @staticmethod
+    def _coerce_result(
+        raw_result: StatusCollectionResult | Mapping[str, JSONValue],
+    ) -> StatusCollectionResult:
+        if isinstance(raw_result, StatusCollectionResult):
+            return raw_result
+        return StatusCollectionResult.fresh(raw_result)
+
+    def _read_fingerprint(self, spec: StatusComponentSpec) -> tuple[str | None, str | None]:
+        if spec.source_fingerprint is None:
+            return None, None
+        try:
+            return spec.source_fingerprint(), None
+        except Exception as exc:
+            return None, f"source fingerprint failed: {type(exc).__name__}: {exc}"
+
+    def _with_dependencies(self, requested: set[str]) -> set[str]:
+        """Validate and expand a refresh selection with transitive prerequisites."""
+
+        for component_id in requested:
+            self._require_spec(component_id)
+        expanded = set(requested)
+        pending = list(requested)
+        while pending:
+            component_id = pending.pop()
+            for dependency_id in self._specs[component_id].dependencies:
+                if dependency_id in expanded:
+                    continue
+                expanded.add(dependency_id)
+                pending.append(dependency_id)
+        return expanded
+
+    def _require_spec(self, component_id: str) -> StatusComponentSpec:
+        try:
+            return self._specs[component_id]
+        except KeyError as exc:
+            raise KeyError(f"unknown status component: {component_id}") from exc
+
+    @staticmethod
+    def _overall_state(states: Sequence[StatusComponentState]) -> StatusComponentState:
+        if not states:
+            return "unavailable"
+        if all(state == "fresh" for state in states):
+            return "fresh"
+        if all(state == "unavailable" for state in states):
+            return "unavailable"
+        if "timed_out" in states:
+            return "timed_out"
+        if "degraded" in states or "unavailable" in states:
+            return "degraded"
+        if "refreshing" in states:
+            return "refreshing"
+        if "stale" in states:
+            return "stale"
+        return "degraded"
+
+    @staticmethod
+    def _validate_acyclic(specs: Mapping[str, StatusComponentSpec]) -> None:
+        visiting: set[str] = set()
+        visited: set[str] = set()
+
+        def visit(component_id: str) -> None:
+            if component_id in visited:
+                return
+            if component_id in visiting:
+                raise ValueError(f"status component dependency cycle includes {component_id!r}")
+            visiting.add(component_id)
+            for dependency in specs[component_id].dependencies:
+                visit(dependency)
+            visiting.remove(component_id)
+            visited.add(component_id)
+
+        for component_id in specs:
+            visit(component_id)
+
+    @staticmethod
+    def _topological_ids(
+        declared: Sequence[StatusComponentSpec],
+        specs: Mapping[str, StatusComponentSpec],
+    ) -> tuple[str, ...]:
+        ordered: list[str] = []
+        visited: set[str] = set()
+
+        def visit(component_id: str) -> None:
+            if component_id in visited:
+                return
+            for dependency in specs[component_id].dependencies:
+                visit(dependency)
+            visited.add(component_id)
+            ordered.append(component_id)
+
+        for spec in declared:
+            visit(spec.component_id)
+        return tuple(ordered)
+
+
+__all__ = [
+    "STATUS_SNAPSHOT_FRESHNESS_MAX_AGE_S",
+    "StatusCollectionContext",
+    "StatusCollectionResult",
+    "StatusComponentSpec",
+    "StatusComponentState",
+    "StatusCostClass",
+    "StatusDetailClass",
+    "StatusPrivacyClass",
+    "StatusRefreshTrigger",
+    "StatusSnapshot",
+    "StatusSnapshotRegistry",
+    "format_status_component_lines",
+]
