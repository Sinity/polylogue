+
+    def collect(context: StatusCollectionContext) -> StatusCollectionResult:
+        observed.append((context.collection_limit, context.previous_value))
+        page = len(observed)
+        value: dict[str, JSONValue] = {"page": page, "complete": page == 2}
+        if page == 1:
+            return StatusCollectionResult(value=value, state="degraded", reason="more pages")
+        return StatusCollectionResult.fresh(value)
+
+    registry = _registry(
+        frozen_clock,
+        [
+            StatusComponentSpec(
+                "exact",
+                collect,
+                detail_class="exact",
