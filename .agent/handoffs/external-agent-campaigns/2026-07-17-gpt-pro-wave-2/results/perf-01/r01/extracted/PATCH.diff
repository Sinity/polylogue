+def _convergence_component_fragment(context: StatusCollectionContext) -> StatusCollectionResult:
+    from polylogue.daemon.catchup_status import catchup_status_info
+    from polylogue.daemon.convergence_debt_status import convergence_debt_summary_info
+    from polylogue.daemon.cursor_lag_status import cursor_lag_summary_info
+    from polylogue.daemon.status import LiveIngestAttemptSummary, _active_status_db_path
+
+    attempts_fragment = context.dependency_values["live_ingest"]
+    raw_attempts = attempts_fragment.get("live_ingest_attempts")
+    attempts = LiveIngestAttemptSummary.model_validate(raw_attempts if isinstance(raw_attempts, dict) else {})
+    active_db = _active_status_db_path()
+    convergence = convergence_debt_summary_info(active_db)
+    cursor_lag = cursor_lag_summary_info(active_db)
+    catchup = catchup_status_info(
+        active_db,
+        latest_attempt=attempts.recent[0] if attempts.recent else None,
+        convergence=convergence,
+    )
+    return StatusCollectionResult.fresh(
+        {
+            "convergence": convergence.model_dump(mode="json"),
+            "cursor_lag": cursor_lag.model_dump(mode="json"),
+            "catchup": catchup.model_dump(mode="json"),
+        },
+        detail_ref="polylogued health --format json",
+    )
+
+
