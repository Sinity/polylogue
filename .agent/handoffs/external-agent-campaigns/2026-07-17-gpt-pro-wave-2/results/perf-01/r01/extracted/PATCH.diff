+def _git_admin_dirs(cwd: Path) -> tuple[Path, Path]:
+    """Resolve normal repositories and linked-worktree ``.git`` files."""
+
+    marker = cwd / ".git"
+    admin = marker
+    if marker.is_file():
+        declaration = _read_small_text(marker)
+        if declaration.startswith("gitdir:"):
+            candidate = Path(declaration.removeprefix("gitdir:").strip())
+            admin = candidate if candidate.is_absolute() else (cwd / candidate).resolve()
+    common = admin
+    common_declaration = _read_small_text(admin / "commondir")
+    if common_declaration:
+        candidate = Path(common_declaration)
+        common = candidate if candidate.is_absolute() else (admin / candidate).resolve()
+    return admin, common
