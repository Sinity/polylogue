+    CoordinationWorkItemPayload,
+)
+from polylogue.core.json import json_document
+from polylogue.operations import status_client
+from polylogue.operations.status_client import DaemonSnapshotResponse
+
+
+class _Response:
+    def __init__(self, payload: object) -> None:
+        self._raw = json.dumps(payload).encode()
+
+    def __enter__(self) -> _Response:
+        return self
+
+    def __exit__(self, *_args: object) -> None:
+        return None
+
+    def read(self) -> bytes:
+        return self._raw
+
+
+def test_snapshot_import_path_does_not_load_rich_status_graph() -> None:
+    """The cold CLI path must not import collectors it never executes."""
+
+    script = """
+import sys
+import polylogue.operations.status_client
+
+for name in (
+    "polylogue.insights.registry",
+    "polylogue.coordination.envelope",
+    "polylogue.daemon.cli",
+):
+    assert name not in sys.modules, name
+
+import polylogue.daemon.status_snapshot
+
+for name in (
+    "polylogue.insights.registry",
+    "polylogue.coordination.envelope",
+    "polylogue.daemon.cli",
+    "polylogue.readiness.capability",
+):
+    assert name not in sys.modules, name
+"""
+    repo_root = Path(__file__).resolve().parents[3]
+    result = subprocess.run(
+        [sys.executable, "-c", script],
+        cwd=repo_root,
+        check=False,
+        capture_output=True,
+        text=True,
+    )
+
+    assert result.returncode == 0, result.stderr
+
+
