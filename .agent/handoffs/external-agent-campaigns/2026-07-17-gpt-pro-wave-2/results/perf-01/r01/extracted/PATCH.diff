+def _retain_archive_debt_rows(
+    retained: list[ArchiveDebtRowPayload],
+    totals: ArchiveDebtTotalsPayload,
+    omitted_count: int,
+    new_rows: Sequence[ArchiveDebtRowPayload],
+    *,
+    row_limit: int,
+) -> tuple[list[ArchiveDebtRowPayload], ArchiveDebtTotalsPayload, int]:
+    if not new_rows:
+        return retained, totals, omitted_count
+    combined = sorted([*retained, *new_rows], key=_row_sort_key)
+    newly_omitted = max(0, len(combined) - row_limit)
+    return (
+        combined[:row_limit],
+        _sum_archive_debt_totals(totals, _totals(list(new_rows))),
+        omitted_count + newly_omitted,
+    )
+
+
+def _sum_archive_debt_totals(
+    left: ArchiveDebtTotalsPayload,
+    right: ArchiveDebtTotalsPayload,
+) -> ArchiveDebtTotalsPayload:
+    left_values = left.model_dump(mode="python")
+    right_values = right.model_dump(mode="python")
+    return ArchiveDebtTotalsPayload.model_validate(
+        {key: int(left_values.get(key, 0)) + int(right_values.get(key, 0)) for key in left_values}
+    )
