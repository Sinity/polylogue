index 0000000000000000000000000000000000000000..8c007a6e96120ec87e482bdf7717386205cc1d53
--- /dev/null
+++ b/polylogue/operations/status_client.py
@@ -0,0 +1,377 @@
+"""Bounded clients and projections for daemon-owned status snapshots."""
+
+from __future__ import annotations
+
+import json
+import os
+from collections.abc import Callable
+from dataclasses import asdict, dataclass
+from datetime import UTC, datetime
+from pathlib import Path
+from typing import TYPE_CHECKING, Any, cast
+from urllib.parse import urlencode
+from urllib.request import Request, urlopen
+
+from polylogue.core.json import JSONDocument, json_document
+
+if TYPE_CHECKING:
+    from polylogue.coordination.payloads import AgentCoordinationPayload, CoordinationView
+
+_DEFAULT_DAEMON_URL = "http://127.0.0.1:8766"
+SnapshotUrlOpener = Callable[..., Any]
+
+# Static unavailable metadata keeps the no-daemon path independent from the
+# coordination collector graph. A contract test compares these fields with the
+# authoritative StatusComponentSpec inventory so declaration drift fails loud.
+_COORDINATION_UNAVAILABLE_COMPONENTS: tuple[tuple[str, float, float, str], ...] = (
+    ("repo", 0.75, 15.0, "polylogue agents status --detail --format json"),
+    ("process", 0.9, 15.0, "polylogue agents self --detail --format json"),
+    ("work_item", 0.75, 30.0, "bd list --status=in_progress --json"),
+    ("beads", 1.5, 60.0, "polylogue agents work-item --detail --format json"),
+    ("archive", 1.0, 60.0, "polylogue agents status --detail --format json"),
+    ("handoff_evidence", 1.5, 90.0, "polylogue agents handoff --detail --format json"),
+    ("derived_overlap", 0.25, 15.0, "polylogue agents conflicts --detail --format json"),
+)
+
+_COORDINATION_EMPTY_COUNTS = {
+    "activity_episodes": 0,
+    "activity_refs": 0,
+    "advisories": 0,
+    "changed_paths": 0,
+    "context_evidence_refs": 0,
+    "context_flow_refs": 0,
+    "context_segment_refs": 0,
+    "handoff": 0,
+    "overlaps": 0,
+    "peer_components": 0,
+    "peers": 0,
+    "proof_evidence_refs": 0,
+    "proof_refs": 0,
+    "provenance": 3,
+    "resource_components": 0,
+    "resource_episodes": 0,
+    "resource_refs": 0,
+    "session_tree_edges": 0,
+    "session_tree_nodes": 0,
+    "session_trees": 0,
+    "subagent_exchanges": 0,
+    "work_item_fields": 0,
+}
+
+
+@dataclass(frozen=True, slots=True)
+class DaemonSnapshotResponse:
+    """Result of one bounded daemon snapshot read."""
+
+    payload: JSONDocument | None
+    url: str
+    error: str | None = None
+
+    @property
+    def available(self) -> bool:
+        return self.payload is not None
+
+
+def daemon_base_url(explicit_url: str | None = None) -> str:
+    """Resolve the single authoritative daemon endpoint without process scans."""
+
+    return (explicit_url or os.environ.get("POLYLOGUE_DAEMON_URL") or _DEFAULT_DAEMON_URL).rstrip("/")
+
+
+def fetch_daemon_snapshot(
+    path: str,
+    *,
+    daemon_url: str | None = None,
+    timeout_s: float = 0.5,
+    params: dict[str, str | int | bool] | None = None,
+    opener: SnapshotUrlOpener | None = None,
+) -> DaemonSnapshotResponse:
+    """Fetch one JSON snapshot under a strict transport deadline.
+
+    This function never retries or discovers processes. Callers therefore have
+    one predictable upper bound, and a stopped or wedged daemon cannot turn a
+    status command into a multi-second probe cascade.
+    """
+
+    base = daemon_base_url(daemon_url)
+    normalized_path = path if path.startswith("/") else f"/{path}"
+    query = ""
+    if params:
+        encoded = {
+            key: "1" if value is True else "0" if value is False else str(value) for key, value in params.items()
+        }
+        query = f"?{urlencode(encoded)}"
+    url = f"{base}{normalized_path}{query}"
+    open_url = opener or urlopen
+    try:
+        request = Request(url, headers={"Accept": "application/json"}, method="GET")
+        with open_url(request, timeout=timeout_s) as response:
+            raw = json.loads(response.read())
+    except (OSError, ValueError, json.JSONDecodeError) as exc:
+        return DaemonSnapshotResponse(payload=None, url=url, error=f"{type(exc).__name__}: {exc}")
+    if not isinstance(raw, dict):
+        return DaemonSnapshotResponse(payload=None, url=url, error="daemon returned non-object JSON")
+    return DaemonSnapshotResponse(payload=json_document(cast(dict[str, Any], raw)), url=url)
+
+
+def daemon_status_snapshot(*, fresh: bool = False) -> JSONDocument:
+    """Return the daemon snapshot or the bounded direct-mode contract."""
+
+    response = fetch_daemon_snapshot(
+        "/api/status",
+        timeout_s=0.5,
+        params={"fresh": fresh} if fresh else None,
+    )
+    if response.payload is not None:
+        return response.payload
+    from polylogue.daemon.status_snapshot import direct_status_snapshot_payload
+
+    payload = direct_status_snapshot_payload()
+    snapshot = payload.get("status_snapshot")
+    if isinstance(snapshot, dict):
+        snapshot["refresh_error"] = response.error or "daemon status unavailable"
+    return payload
+
+
+def readiness_snapshot_payload(*, fresh: bool = False) -> JSONDocument:
+    """Project readiness from cached component lifecycle evidence."""
+
+    status = daemon_status_snapshot(fresh=fresh)
+    raw_components = status.get("status_components")
+    checks: list[dict[str, object]] = []
+    if isinstance(raw_components, dict):
+        for component_id, raw in raw_components.items():
+            if not isinstance(raw, dict):
+                continue
+            checks.append(
+                {
+                    "name": str(component_id),
+                    "status": str(raw.get("state") or "unavailable"),
+                    "detail": raw.get("reason"),
+                    "age_s": raw.get("age_s"),
+                    "refresh_duration_s": raw.get("refresh_duration_s"),
+                    "deadline_s": raw.get("deadline_s"),
+                    "last_good": raw.get("last_good"),
+                    "detail_ref": raw.get("detail_ref"),
+                }
+            )
+    raw_snapshot = status.get("status_snapshot")
+    state_counts = raw_snapshot.get("state_counts") if isinstance(raw_snapshot, dict) else None
+    summary = state_counts if isinstance(state_counts, dict) else {}
+    raw_mcp_delivery = status.get("mcp_call_delivery")
+    if isinstance(raw_mcp_delivery, dict):
+        mcp_call_delivery: dict[str, object] = dict(raw_mcp_delivery)
+    else:
+        from polylogue.mcp.call_log import mcp_call_outbox_status_snapshot
+
+        mcp_call_delivery = asdict(mcp_call_outbox_status_snapshot())
+    return json_document(
+        {
+            "source": "daemon_status_snapshot",
+            "summary": summary,
+            "checks": checks,
+            "status_snapshot": status.get("status_snapshot"),
+            "component_readiness": status.get("component_readiness"),
+            "claim_guard": status.get("claim_guard"),
+            "raw_frontier_integrity": status.get("raw_frontier_integrity"),
+            "mcp_call_delivery": mcp_call_delivery,
+        }
+    )
+
+
+def embedding_snapshot_payload(*, detail: bool = False, fresh: bool = False) -> JSONDocument:
+    """Return embedding evidence already collected by the daemon scheduler."""
+
+    response = fetch_daemon_snapshot(
+        "/api/status",
+        timeout_s=0.5,
+        params={"components": "embeddings", "fresh": fresh} if fresh else {"components": "embeddings"},
+    )
+    if response.payload is not None:
+        status = response.payload
+    else:
+        from polylogue.daemon.status_snapshot import direct_status_snapshot_payload
+
+        status = direct_status_snapshot_payload()
+    components = status.get("status_components")
+    component = components.get("embeddings") if isinstance(components, dict) else None
+    result: dict[str, Any] = {}
+    embedding = status.get("embedding_readiness")
+    if isinstance(embedding, dict):
+        result.update(embedding)
+    result["status_snapshot"] = component
+    if detail:
+        result["detail_ref"] = component.get("detail_ref") if isinstance(component, dict) else None
+        result["diagnostic_note"] = "detail=true expands retained evidence; it does not run a request-time probe"
+    return json_document(result)
+
+
+def _coordination_scope_matches(payload: AgentCoordinationPayload, cwd: Path | None) -> bool:
+    if cwd is None:
+        return True
+    requested = cwd.expanduser().resolve()
+    raw_root = payload.repo.root or payload.repo.cwd
+    if not raw_root:
+        return False
+    try:
+        root = Path(raw_root).expanduser().resolve()
+        requested.relative_to(root)
+    except (OSError, ValueError):
+        return False
+    return True
+
+
+def _unavailable_coordination_payload(
+    *,
+    view: CoordinationView,
+    cwd: Path | None,
+    limit: int,
+    detail: bool,
+    transport_error: str,
+) -> AgentCoordinationPayload:
+    """Build the bounded no-daemon coordination contract without collectors."""
+
+    from polylogue.coordination.payloads import (
+        AgentCoordinationPayload,
+        CoordinationLimitsPayload,
+        CoordinationProjectionPayload,
+        CoordinationProvenancePayload,
+        CoordinationRepoPayload,
+        CoordinationSelfPayload,
+        CoordinationWorkItemPayload,
+    )
+
+    bounded_limit = max(1, min(limit, 50))
+    resolved_cwd = (cwd or Path.cwd()).expanduser().resolve()
+    generated_at = datetime.now(UTC).isoformat()
+    unavailable = CoordinationProvenancePayload(
+        source="status-snapshot",
+        confidence=0.0,
+        freshness="unavailable",
+    )
+    work_item_provenance = unavailable.model_copy(update={"note": "work-item snapshot unavailable"})
+    components = {
+        component_id: {
+            "state": "unavailable",
+            "reason": "daemon not running",
+            "observed_at": None,
+            "refresh_started_at": None,
+            "refresh_finished_at": None,
+            "refresh_duration_s": None,
+            "age_s": None,
+            "deadline_s": deadline_s,
+            "stale_after_s": stale_after_s,
+            "detail_ref": detail_ref,
+            "last_good": None,
+        }
+        for component_id, deadline_s, stale_after_s, detail_ref in _COORDINATION_UNAVAILABLE_COMPONENTS
+    }
+    snapshot: dict[str, object] = {
+        "protocol": "polylogue.status-snapshot.v1",
+        "scope": "agent-coordination",
+        "state": "unavailable",
+        "generated_at": generated_at,
+        "component_count": len(components),
+        "state_counts": {"unavailable": len(components)},
+        "components": components,
+        "transport_error": transport_error,
+    }
+    provenance = (unavailable, work_item_provenance, unavailable) if detail else ()
+    projection = CoordinationProjectionPayload(
+        detail=detail,
+        byte_budget=None if detail else 7_600,
+        serialized_bytes=0,
+        total_counts=dict(_COORDINATION_EMPTY_COUNTS),
+        omitted_counts={} if detail else {"provenance": 3},
+        detail_hint=None if detail else "CLI: --detail; MCP: detail=true",
+    )
+    payload = AgentCoordinationPayload(
+        view=view,
+        generated_at=generated_at,
+        status_snapshot=snapshot,
+        repo=CoordinationRepoPayload(cwd=str(resolved_cwd), provenance=unavailable),
+        self=CoordinationSelfPayload(
+            identity_status="unknown",
+            agent_kind="unknown",
+            invocation_pid=os.getpid(),
+            cwd=str(resolved_cwd),
+            provenance=unavailable,
+        ),
+        work_item=CoordinationWorkItemPayload(
+            source="none",
+            confidence=0.0,
+            provenance=work_item_provenance,
+        ),
+        limits=CoordinationLimitsPayload(
+            peer_limit=bounded_limit,
+            resource_limit=bounded_limit,
+            changed_path_limit=40,
+            command_chars=220,
+        ),
+        projection=projection,
+        provenance=provenance,
+    )
+    for _ in range(3):
+        size = len(payload.to_json(exclude_none=True).encode())
+        if payload.projection.serialized_bytes == size:
+            break
+        payload = payload.model_copy(
+            update={"projection": payload.projection.model_copy(update={"serialized_bytes": size})}
+        )
+    return payload
+
+
+def coordination_snapshot_payload(
+    *,
+    view: CoordinationView,
+    cwd: Path | None,
+    limit: int,
+    detail: bool,
+    fresh: bool,
+) -> AgentCoordinationPayload:
+    """Read the daemon-owned coordination snapshot under a transport deadline."""
+
+    from polylogue.coordination.payloads import AgentCoordinationPayload
+
+    response = fetch_daemon_snapshot(
+        "/api/agents/coordination",
+        timeout_s=0.5,
+        params={
+            "view": view,
+            "limit": max(1, min(limit, 50)),
+            "detail": detail,
+            "fresh": fresh,
+        },
+    )
+    transport_error = response.error
+    if response.payload is not None:
+        try:
+            daemon_payload = AgentCoordinationPayload.model_validate(response.payload)
+        except ValueError as exc:
+            transport_error = f"invalid daemon coordination snapshot: {exc}"
+        else:
+            if _coordination_scope_matches(daemon_payload, cwd):
+                return daemon_payload
+            transport_error = f"daemon coordination snapshot does not cover requested cwd: {cwd}"
+
+    # A standalone process has no background scheduler. Publish the same
+    # unavailable component protocol without importing Git/process/archive
+    # collectors into the request path.
+    return _unavailable_coordination_payload(
+        view=view,
+        cwd=cwd,
+        limit=limit,
+        detail=detail,
+        transport_error=transport_error or "daemon coordination snapshot unavailable",
+    )
+
+
+__all__ = [
+    "DaemonSnapshotResponse",
+    "coordination_snapshot_payload",
+    "daemon_base_url",
+    "daemon_status_snapshot",
+    "embedding_snapshot_payload",
+    "fetch_daemon_snapshot",
+    "readiness_snapshot_payload",
+]
