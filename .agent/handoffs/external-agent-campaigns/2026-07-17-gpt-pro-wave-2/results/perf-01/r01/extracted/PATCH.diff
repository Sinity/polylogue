+def _claim_guard_component_fragment(context: StatusCollectionContext) -> StatusCollectionResult:
+    from polylogue.daemon.fts_status import FTSReadiness
+    from polylogue.daemon.status import (
+        ArchiveStorageStatus,
+        LiveIngestAttemptSummary,
+        RawFrontierIntegrity,
+        RawMaterializationReadiness,
+        _component_from_archive_storage,
+        _daemon_claim_guard,
+    )
+    from polylogue.storage.archive_readiness import raw_materialization_ready
+
+    storage_raw = context.dependency_values["storage"].get("archive_storage")
+    materialization_raw = context.dependency_values["raw_materialization"].get("raw_materialization_readiness")
+    frontier_raw = context.dependency_values["raw_frontier"].get("raw_frontier_integrity")
+    fts_raw = context.dependency_values["fts"].get("fts_readiness")
+    attempts_raw = context.dependency_values["live_ingest"].get("live_ingest_attempts")
+    storage = ArchiveStorageStatus.model_validate(storage_raw if isinstance(storage_raw, dict) else {})
+    materialization = RawMaterializationReadiness.model_validate(
+        materialization_raw if isinstance(materialization_raw, dict) else {}
+    )
+    frontier = RawFrontierIntegrity.model_validate(frontier_raw if isinstance(frontier_raw, dict) else {})
+    fts = FTSReadiness.model_validate(fts_raw if isinstance(fts_raw, dict) else {})
+    attempts = LiveIngestAttemptSummary.model_validate(attempts_raw if isinstance(attempts_raw, dict) else {})
+    materialization_ok = storage.archive_materialization_ready and raw_materialization_ready(
+        materialization.model_dump(mode="json")
+    )
+    storage = storage.model_copy(
+        update={
+            "archive_materialization_ready": materialization_ok,
+            "archive_ready": storage.archive_ready and materialization_ok,
+        }
+    )
+    return StatusCollectionResult.fresh(
+        json_document(
+            {
+                "archive_storage": storage.model_dump(mode="json"),
+                "component_readiness": {"archive_storage": _component_from_archive_storage(storage).to_dict()},
+                "claim_guard": _daemon_claim_guard(
+                    archive_storage=storage,
+                    raw_materialization_readiness=materialization,
+                    raw_frontier_integrity=frontier,
+                    fts_readiness=fts,
+                    live_ingest_attempts=attempts,
+                ),
+            }
+        ),
+        detail_ref="polylogue ops readiness --deep",
+    )
+
