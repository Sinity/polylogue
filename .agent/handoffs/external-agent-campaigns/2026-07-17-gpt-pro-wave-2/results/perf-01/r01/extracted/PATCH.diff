+def direct_status_snapshot_payload() -> JSONDocument:
+    """Return the bounded shared projection used when no daemon answers.
+
+    This path does not open SQLite and never invokes a declared collector. It
+    observes only filesystem descriptors; daemon/DB-backed facts remain
+    explicit unavailable evidence under the same component protocol.
+    """
+    from polylogue.paths import archive_root
+
+    checked_at = datetime.now(UTC).isoformat()
+    root = Path(archive_root())
+    db = active_index_db_path()
+    wal = db.with_name(f"{db.name}-wal")
+    try:
+        db_size = db.stat().st_size
+    except OSError:
+        db_size = 0
+    try:
+        wal_size = wal.stat().st_size
+    except OSError:
+        wal_size = 0
+    disk_free = _disk_free_bytes(db)
+
+    components: dict[str, object] = {}
+    for spec in status_component_specs():
+        if spec.component_id == "runtime":
+            state = "fresh"
+            reason = "bounded direct observation"
+            value: dict[str, object] | None = {
+                "daemon_liveness": False,
+                "component_state": {
+                    "watcher": "stopped",
+                    "api": "stopped",
+                    "browser_capture": "stopped",
+                },
+            }
+            observed_at: str | None = checked_at
+            age_s: float | None = 0.0
+        elif spec.component_id == "storage":
+            state = "fresh"
+            reason = "bounded filesystem descriptors"
+            value = {
+                "db_path": str(db),
+                "db_size_bytes": db_size,
+                "wal_size_bytes": wal_size,
+                "disk_free_bytes": disk_free,
+            }
+            observed_at = checked_at
+            age_s = 0.0
+        else:
+            state = "unavailable"
+            reason = "daemon not running"
+            value = None
+            observed_at = None
+            age_s = None
+        components[spec.component_id] = {
+            "component_id": spec.component_id,
+            "state": state,
+            "reason": reason,
+            "observed_at": observed_at,
+            "refresh_started_at": None,
+            "refresh_finished_at": observed_at,
+            "refresh_duration_s": 0.0 if observed_at is not None else None,
+            "age_s": age_s,
+            "source_fingerprint": None,
+            "evidence_refs": [],
+            "value": value,
+            "cost_class": spec.cost_class,
+            "detail_class": spec.detail_class,
+            "deadline_s": spec.deadline_s,
+            "refresh_interval_s": spec.refresh_interval_s,
+            "stale_after_s": spec.stale_after_s,
+            "refresh_trigger": spec.refresh_trigger,
+            "privacy_class": spec.privacy_class,
+            "dependencies": list(spec.dependencies),
