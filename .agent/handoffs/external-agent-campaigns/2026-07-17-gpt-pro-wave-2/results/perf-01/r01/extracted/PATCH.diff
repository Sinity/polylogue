+                default_enabled=False,
+            )
+        ],
+    )
+
+    assert registry.refresh_due(component_ids=("exact",), force=True, collection_limit=7) == ("exact",)
+    assert observed == [(7, None)]
+    first = registry.snapshot("exact")
+    assert first is not None
+    assert first.state == "degraded"
+
+    assert registry.refresh_due(component_ids=("exact",), force=True, collection_limit=7) == ("exact",)
+    assert observed[1] == (7, {"page": 1, "complete": False})
+    second = registry.snapshot("exact")
+    assert second is not None
+    assert second.state == "fresh"
