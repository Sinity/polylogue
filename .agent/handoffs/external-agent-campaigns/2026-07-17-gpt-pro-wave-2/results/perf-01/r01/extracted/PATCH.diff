+def _normalize_archive_debt_progress(progress: Mapping[str, object] | None) -> dict[str, Any]:
+    if not progress or progress.get("schema") != _ARCHIVE_DEBT_COLLECTION_PROGRESS_SCHEMA:
+        return {
+            "kind_index": 0,
+            "assertion_offset": 0,
+            "raw_cursor": None,
+            "raw_groups": {},
+            "rows": [],
+            "totals": ArchiveDebtTotalsPayload(),
+            "omitted_row_count": 0,
+            "processed_count": 0,
+        }
+
+    raw_kind_index = progress.get("kind_index")
+    kind_index = (
+        min(max(int(raw_kind_index), 0), len(_ARCHIVE_DEBT_COLLECTION_KINDS))
+        if isinstance(raw_kind_index, int | float) and not isinstance(raw_kind_index, bool)
+        else 0
+    )
+    raw_assertion_offset = progress.get("assertion_offset")
+    assertion_offset = (
+        max(int(raw_assertion_offset), 0)
+        if isinstance(raw_assertion_offset, int | float) and not isinstance(raw_assertion_offset, bool)
+        else 0
+    )
+    raw_cursor_value = progress.get("raw_cursor")
+    raw_cursor = str(raw_cursor_value) if isinstance(raw_cursor_value, str) and raw_cursor_value else None
+    raw_groups_value = progress.get("raw_groups")
+    raw_groups = _normalize_raw_materialization_groups(raw_groups_value)
+    rows: list[ArchiveDebtRowPayload] = []
+    raw_rows = progress.get("rows")
+    if isinstance(raw_rows, list):
+        for raw_row in raw_rows:
+            if not isinstance(raw_row, Mapping):
+                continue
+            try:
+                rows.append(ArchiveDebtRowPayload.model_validate(raw_row))
+            except ValueError:
+                continue
+    raw_totals = progress.get("totals")
+    try:
+        totals = ArchiveDebtTotalsPayload.model_validate(raw_totals if isinstance(raw_totals, Mapping) else {})
+    except ValueError:
+        totals = ArchiveDebtTotalsPayload()
+    raw_omitted = progress.get("omitted_row_count")
+    omitted = (
+        max(int(raw_omitted), 0) if isinstance(raw_omitted, int | float) and not isinstance(raw_omitted, bool) else 0
+    )
+    raw_processed = progress.get("processed_count")
+    processed = (
+        max(int(raw_processed), 0)
+        if isinstance(raw_processed, int | float) and not isinstance(raw_processed, bool)
+        else 0
+    )
+    return {
+        "kind_index": kind_index,
+        "assertion_offset": assertion_offset,
+        "raw_cursor": raw_cursor,
+        "raw_groups": raw_groups,
+        "rows": rows,
+        "totals": totals,
+        "omitted_row_count": omitted,
+        "processed_count": processed,
+    }
+
