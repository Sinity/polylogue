+assert payload.status_snapshot["state"] == "unavailable"
+for name in (
+    "polylogue.coordination.envelope",
+    "polylogue.coordination.status_snapshot",
+):
+    assert name not in sys.modules, name
+"""
+    repo_root = Path(__file__).resolve().parents[3]
