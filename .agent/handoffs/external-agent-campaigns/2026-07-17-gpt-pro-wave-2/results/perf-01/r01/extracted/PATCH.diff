+"""Contracts for the lightweight ``polylogued status`` console dispatch."""
+
+from __future__ import annotations
+
+import subprocess
+import sys
+from pathlib import Path
+from typing import Any
+
+import pytest
+
+from polylogue.daemon import entrypoint
+
+
+def test_entrypoint_import_does_not_load_daemon_service_graph() -> None:
+    """Importing the console target must not recreate the cold-status delay."""
+
+    script = """
+import sys
+import polylogue.daemon.entrypoint
+
+for name in (
+    "polylogue.api",
+    "polylogue.daemon.cli",
+    "polylogue.daemon.health",
+    "polylogue.sources.live",
+):
+    assert name not in sys.modules, name
+"""
+    repo_root = Path(__file__).resolve().parents[3]
+    result = subprocess.run(
+        [sys.executable, "-c", script],
+        cwd=repo_root,
+        check=False,
+        capture_output=True,
+        text=True,
+    )
+
+    assert result.returncode == 0, result.stderr
+
+
+def test_status_argv_dispatches_without_importing_full_cli(monkeypatch: pytest.MonkeyPatch) -> None:
+    calls: list[dict[str, Any]] = []
+
+    def fake_main(**kwargs: Any) -> None:
+        calls.append(kwargs)
+
+    monkeypatch.setattr(entrypoint.status_command, "main", fake_main)
+
+    entrypoint.main(["status", "--format", "json"])
+
+    assert calls == [{"args": ["--format", "json"], "prog_name": "pytest status"}]
