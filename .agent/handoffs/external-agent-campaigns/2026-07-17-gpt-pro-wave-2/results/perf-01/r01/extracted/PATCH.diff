diff --git a/tests/benchmarks/test_status_snapshots.py b/tests/benchmarks/test_status_snapshots.py
new file mode 100644
index 0000000000000000000000000000000000000000..def4733a87c5092757cb5ab296dd4a6545f6d7b8
--- /dev/null
+++ b/tests/benchmarks/test_status_snapshots.py
@@ -0,0 +1,197 @@
+"""SLO benchmarks for budgeted status snapshot projections.
+
+These benchmarks exercise the production read paths after collectors have
+published evidence.  They deliberately never call ``refresh_due``: the product
+contract under test is that a request performs only in-memory selection,
+compatibility assembly, and serialization.
+"""
+
+from __future__ import annotations
+
+import json
+import random
+import time
+from collections.abc import Callable, Mapping
+from pathlib import Path
+from typing import TypeVar, cast
+
+import pytest
+
+from polylogue.core.json import JSONDocument
+from polylogue.core.status_snapshots import StatusSnapshotRegistry
+from tests.benchmarks.helpers import BenchmarkFixture
+
+_T = TypeVar("_T")
+_DAEMON_PROJECTION_P95_MS = 25.0
+_COORDINATION_PROJECTION_P95_MS = 25.0
+_DIRECT_PROJECTION_P95_MS = 25.0
+_COORDINATION_COMPACT_MAX_BYTES = 8 * 1024
+
+
+def _sample_distribution(operation: Callable[[], _T], *, samples: int = 600) -> tuple[_T, dict[str, float]]:
+    """Measure a deterministic local distribution without wall-clock sleeps."""
+
+    result = operation()
+    for _ in range(24):
+        result = operation()
+    durations_ms: list[float] = []
+    for _ in range(samples):
+        started_ns = time.perf_counter_ns()
+        result = operation()
+        durations_ms.append((time.perf_counter_ns() - started_ns) / 1_000_000)
+    durations_ms.sort()
+    p50_index = min(len(durations_ms) - 1, int(len(durations_ms) * 0.50))
+    p95_index = min(len(durations_ms) - 1, int(len(durations_ms) * 0.95))
+    return result, {
+        "samples": float(samples),
+        "p50_ms": durations_ms[p50_index],
+        "p95_ms": durations_ms[p95_index],
+        "max_ms": durations_ms[-1],
+    }
+
+
+def _seed_daemon_registry() -> StatusSnapshotRegistry:
+    from polylogue.daemon.status_snapshot import status_component_specs
+
+    registry = StatusSnapshotRegistry(scope="daemon", specs=status_component_specs())
+    for spec in registry.specs:
+        if spec.detail_class == "exact":
+            continue
+        registry.seed(spec.component_id, {})
+    registry.seed("embeddings", {}, state="stale", reason="benchmark stale evidence")
+    registry.mark_unavailable("raw_failures", "benchmark unavailable evidence")
+    return registry
+
+
+def _seed_coordination_registry() -> StatusSnapshotRegistry:
+    from polylogue.coordination.status_snapshot import coordination_component_specs
+
+    registry = StatusSnapshotRegistry(scope="agent-coordination", specs=coordination_component_specs())
+    for spec in registry.specs:
+        registry.seed(spec.component_id, {})
+    registry.seed("derived_overlap", {}, state="stale", reason="benchmark stale evidence")
+    registry.mark_unavailable("beads", "benchmark unavailable evidence")
+    return registry
+
+
+@pytest.mark.benchmark
+def test_daemon_status_snapshot_projection_p95(
+    benchmark: BenchmarkFixture,
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """Actual daemon status assembly stays far below the interactive budget.
+
+    Production dependency: ``daemon.status_snapshot.get_status_snapshot_payload``.
+    Removing snapshot assembly and calling a rich collector from that function
+    makes this benchmark exceed the budget or block on archive state.
+    """
+
+    from polylogue.daemon import status_snapshot
+
+    registry = _seed_daemon_registry()
+    monkeypatch.setattr(status_snapshot, "_COMPONENT_REGISTRY", registry)
+    monkeypatch.setattr(status_snapshot, "_SNAPSHOT", None)
+    component_ids = tuple(spec.component_id for spec in registry.specs if spec.detail_class != "exact")
+    rng = random.Random(20_017)
+    selections = [tuple(sorted(rng.sample(component_ids, rng.randint(1, len(component_ids))))) for _ in range(600)]
+    selection_index = 0
+
+    def randomized_projection() -> JSONDocument:
+        nonlocal selection_index
+        selected = selections[selection_index]
+        selection_index = (selection_index + 1) % len(selections)
+        return status_snapshot.get_status_snapshot_payload(component_ids=selected)
+
+    payload, stats = _sample_distribution(randomized_projection)
+    benchmark(lambda: status_snapshot.get_status_snapshot_payload())
+    if hasattr(benchmark, "extra_info"):
+        benchmark.extra_info.update(
+            {
+                **stats,
+                "component_count": len(component_ids),
+                "random_seed": 20_017,
+                "serialized_bytes": len(json.dumps(payload, separators=(",", ":")).encode()),
+            }
+        )
+    assert stats["p95_ms"] < _DAEMON_PROJECTION_P95_MS, stats
+
+
+@pytest.mark.benchmark
+def test_coordination_snapshot_projection_p95_and_compact_bound(
+    benchmark: BenchmarkFixture,
+    monkeypatch: pytest.MonkeyPatch,
+    tmp_path: Path,
+) -> None:
+    """Warm coordination assembly remains sub-second and below 8 KiB.
+
+    Production dependency: ``coordination.status_snapshot.get_coordination_snapshot_payload``.
+    Restoring the old synchronous whole-envelope builder causes this test to
+    execute Git/process/Beads/archive/handoff probes and violate the SLO.
+    """
+
+    from polylogue.coordination import status_snapshot
+    from polylogue.coordination.payloads import AgentCoordinationPayload, CoordinationView
+
+    registry = _seed_coordination_registry()
+    monkeypatch.setattr(status_snapshot, "_COMPONENT_REGISTRY", registry)
+    status_snapshot.configure_coordination_snapshot(cwd=tmp_path, collection_limit=50)
+    rng = random.Random(20_017)
+    views: tuple[CoordinationView, ...] = ("status", "self", "work-item", "conflicts", "handoff")
+    requests = [(rng.choice(views), rng.randint(1, 50)) for _ in range(600)]
+    request_index = 0
+
+    def randomized_projection() -> AgentCoordinationPayload:
+        nonlocal request_index
+        view, limit = requests[request_index]
+        request_index = (request_index + 1) % len(requests)
+        return status_snapshot.get_coordination_snapshot_payload(view=view, limit=limit, detail=False)
+
+    payload, stats = _sample_distribution(randomized_projection)
+    benchmark(lambda: status_snapshot.get_coordination_snapshot_payload(view="status", limit=10, detail=False))
+    encoded = json.dumps(payload.model_dump(mode="json", exclude_none=True), separators=(",", ":")).encode()
+    if hasattr(benchmark, "extra_info"):
+        benchmark.extra_info.update(
+            {
+                **stats,
+                "component_count": len(registry.specs),
+                "random_seed": 20_017,
+                "serialized_bytes": len(encoded),
+            }
+        )
+    assert stats["p95_ms"] < _COORDINATION_PROJECTION_P95_MS, stats
+    assert len(encoded) < _COORDINATION_COMPACT_MAX_BYTES
+
+
+@pytest.mark.benchmark
+def test_direct_status_snapshot_projection_p95(
+    benchmark: BenchmarkFixture,
+    monkeypatch: pytest.MonkeyPatch,
+    tmp_path: Path,
+) -> None:
+    """No-daemon fallback uses descriptors only and remains interactive.
+
+    Production dependency: ``daemon.status_snapshot.direct_status_snapshot_payload``.
+    Reintroducing direct SQLite readiness/debt/embedding probes makes this
+    benchmark scale with archive contents and violate the fixed budget.
+    """
+
+    from polylogue.daemon import status_snapshot
+
+    archive_root = tmp_path / "archive"
+    archive_root.mkdir()
+    index_db = archive_root / "index.db"
+    index_db.write_bytes(b"descriptor-only benchmark")
+    monkeypatch.setattr("polylogue.paths.archive_root", lambda: archive_root)
+    monkeypatch.setattr(status_snapshot, "active_index_db_path", lambda: index_db)
+
+    payload, stats = _sample_distribution(status_snapshot.direct_status_snapshot_payload)
+    benchmark(status_snapshot.direct_status_snapshot_payload)
+    if hasattr(benchmark, "extra_info"):
+        benchmark.extra_info.update(
+            {
+                **stats,
+                "component_count": len(cast(Mapping[str, object], payload.get("status_components", {}))),
+                "serialized_bytes": len(json.dumps(payload, separators=(",", ":")).encode()),
+            }
+        )
+    assert stats["p95_ms"] < _DIRECT_PROJECTION_P95_MS, stats
