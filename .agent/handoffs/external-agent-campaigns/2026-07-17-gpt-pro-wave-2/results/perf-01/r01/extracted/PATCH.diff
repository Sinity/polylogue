+        totals=visible_totals,
+        caveats=(
+            "Collection is a bounded partial diagnostic; refresh the exact component again to resume.",
+            "Rows are composed from existing readiness projections; exact FTS reconciliation is a separate detail query.",
+        )
+        if not complete
