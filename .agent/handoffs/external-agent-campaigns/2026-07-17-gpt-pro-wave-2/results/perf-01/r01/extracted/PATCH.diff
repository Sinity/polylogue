+def test_periodic_status_refresh_offloads_scheduler_fingerprints(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    """The daemon event loop must not execute source-fingerprint providers."""
+
+    from polylogue import coordination
+    from polylogue.daemon import cli as daemon_cli
+    from polylogue.daemon import status_snapshot
+
+    loop_thread_id = threading.get_ident()
+    scheduler_threads: list[int] = []
+
+    def record_scheduler_thread() -> tuple[str, ...]:
+        scheduler_threads.append(threading.get_ident())
+        return ()
+
+    class StopLoopError(Exception):
+        pass
+
+    async def stop_after_first_tick(_delay: float) -> None:
+        raise StopLoopError
+
+    monkeypatch.setattr(status_snapshot, "refresh_status_components", record_scheduler_thread)
+    monkeypatch.setattr(coordination, "refresh_coordination_components", record_scheduler_thread)
+    monkeypatch.setattr(asyncio, "sleep", stop_after_first_tick)
+
+    with pytest.raises(StopLoopError):
+        asyncio.run(daemon_cli._periodic_status_snapshot_refresh())
+
+    assert len(scheduler_threads) == 2
+    assert all(thread_id != loop_thread_id for thread_id in scheduler_threads)
+
