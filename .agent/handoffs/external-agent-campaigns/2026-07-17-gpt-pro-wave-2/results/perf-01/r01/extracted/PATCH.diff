+
+def configure_coordination_snapshot(*, cwd: Path | None = None, collection_limit: int = 50) -> None:
+    """Configure scheduler-only collection scope and invalidate old evidence."""
+
+    global _SETTINGS, _COMPONENT_REGISTRY
+    settings = CoordinationSnapshotSettings(
+        cwd=(cwd or Path.cwd()).resolve(),
+        collection_limit=max(1, min(collection_limit, 50)),
+    )
+    with _SETTINGS_LOCK:
+        if settings == _SETTINGS:
+            return
+        _SETTINGS = settings
+    with _COMPONENT_REGISTRY_LOCK:
+        _COMPONENT_REGISTRY = None
