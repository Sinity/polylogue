+"""Canonical archive operations shared across facade, CLI, and MCP surfaces.
+
+The package root preserves its historical public exports lazily.  Lightweight
+clients such as ``polylogue.operations.status_client`` must not import the
+archive insight registry merely to perform one bounded loopback request.
+"""
+
+from __future__ import annotations
+
+from importlib import import_module
+from typing import TYPE_CHECKING, Any
+
+if TYPE_CHECKING:
+    from .archive import (
+        ArchiveDebtInsight as ArchiveDebtInsight,
+    )
+    from .archive import (
+        ArchiveStats as ArchiveStats,
+    )
+    from .archive import (
+        CompletionAggregate as CompletionAggregate,
+    )
+    from .import_contracts import (
+        ImportOperation as ImportOperation,
+    )
+    from .import_contracts import (
+        RawFailureSample as RawFailureSample,
+    )
+    from .import_contracts import (
+        bounded_failure_samples as bounded_failure_samples,
+    )
+    from .import_operations import (
+        ImportAck as ImportAck,
+    )
+    from .import_operations import (
+        ImportRequest as ImportRequest,
+    )
+    from .operation_contract import (
+        OperationFollowUp as OperationFollowUp,
+    )
+    from .operation_contract import (
+        OperationStatus as OperationStatus,
+    )
+    from .specs import (
+        OperationCatalog as OperationCatalog,
+    )
+    from .specs import (
+        OperationKind as OperationKind,
+    )
+    from .specs import (
+        OperationSpec as OperationSpec,
+    )
+    from .specs import (
+        SafetyGuard as SafetyGuard,
+    )
+    from .specs import (
+        build_declared_operation_catalog as build_declared_operation_catalog,
+    )
+    from .specs import (
+        build_runtime_operation_catalog as build_runtime_operation_catalog,
+    )
+
+_EXPORT_MODULES = {
+    "ArchiveDebtInsight": "polylogue.operations.archive",
+    "ArchiveStats": "polylogue.operations.archive",
+    "CompletionAggregate": "polylogue.operations.archive",
+    "ImportAck": "polylogue.operations.import_operations",
+    "ImportOperation": "polylogue.operations.import_contracts",
+    "ImportRequest": "polylogue.operations.import_operations",
+    "OperationCatalog": "polylogue.operations.specs",
+    "OperationFollowUp": "polylogue.operations.operation_contract",
+    "OperationKind": "polylogue.operations.specs",
+    "OperationSpec": "polylogue.operations.specs",
+    "OperationStatus": "polylogue.operations.operation_contract",
+    "RawFailureSample": "polylogue.operations.import_contracts",
+    "SafetyGuard": "polylogue.operations.specs",
+    "bounded_failure_samples": "polylogue.operations.import_contracts",
+    "build_declared_operation_catalog": "polylogue.operations.specs",
+    "build_runtime_operation_catalog": "polylogue.operations.specs",
+}
+
+
+def __getattr__(name: str) -> Any:
+    """Load a public operation only when a caller requests it."""
+
+    module_name = _EXPORT_MODULES.get(name)
+    if module_name is None:
+        raise AttributeError(f"module {__name__!r} has no attribute {name!r}")
+    value = getattr(import_module(module_name), name)
+    globals()[name] = value
+    return value
+
+
+def __dir__() -> list[str]:
+    return sorted({*globals(), *__all__})
+
 
