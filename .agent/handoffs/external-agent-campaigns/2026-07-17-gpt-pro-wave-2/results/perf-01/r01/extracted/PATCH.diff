+++ b/polylogue/daemon/entrypoint.py
@@ -0,0 +1,144 @@
+"""Lightweight console dispatch for ``polylogued``.
+
+The status command is an interactive read surface. Importing the complete
+long-running daemon composition before dispatch made a no-daemon status read
+spend seconds loading services it never used. This module keeps that one route
+on the bounded snapshot dependency graph and delegates every other command to
+the established Click group unchanged.
+"""
+
+from __future__ import annotations
+
+import sys
+from collections.abc import Mapping, Sequence
+from pathlib import Path
+
+import click
+
+from polylogue.core.json import JSONDocument
+from polylogue.core.status_snapshots import format_status_component_lines
+
+
+def format_daemon_snapshot_lines(payload: Mapping[str, object]) -> list[str]:
+    """Render the compact operator projection without importing collectors."""
+
+    lines = ["Polylogue daemon"]
+    lifecycle = payload.get("daemon_lifecycle")
+    if payload.get("daemon_liveness"):
+        age = lifecycle.get("heartbeat_age_s") if isinstance(lifecycle, Mapping) else None
+        suffix = f" (heartbeat {age}s ago)" if isinstance(age, int | float) and not isinstance(age, bool) else ""
+        lines.append(f"  Status: running{suffix}")
+    elif isinstance(lifecycle, Mapping):
+        lines.append(f"  Status: {lifecycle.get('state', 'absent')} heartbeat")
+    else:
+        lines.append("  Status: not running")
+
+    storage = payload.get("archive_storage")
+    if isinstance(storage, Mapping):
+        present = storage.get("present_tiers", [])
+        missing = storage.get("missing_tiers", [])
+        present_text = ", ".join(str(item) for item in present) if isinstance(present, list) else str(present)
+        missing_text = ", ".join(str(item) for item in missing) if isinstance(missing, list) else str(missing)
+        line = f"Storage: {storage.get('active_store', 'unknown')}"
+        if present_text:
+            line += f" ({present_text})"
+        if missing_text:
+            line += f"; missing {missing_text}"
+        elif storage.get("final_shape_ready"):
+            line += "; final split complete"
+        schema_mismatches = storage.get("schema_mismatches", [])
+        if isinstance(schema_mismatches, list) and schema_mismatches:
+            line += f"; schema mismatch {', '.join(str(item) for item in schema_mismatches)}"
+        if storage.get("archive_root_matches_configured") is False:
+            line += f"; active root {storage.get('archive_root', 'unknown')}"
+        lines.append(line)
+
+    live = payload.get("live")
+    if isinstance(live, Mapping):
+        lines.append(f"Live sources: {live.get('existing_source_count', 0)}/{live.get('source_count', 0)} available")
+        sources = live.get("sources", [])
+        if isinstance(sources, list):
+            for source in sources:
+                if not isinstance(source, Mapping):
+                    continue
+                state = "available" if source.get("exists") else "missing"
+                lines.append(f"  {source.get('name')}: {source.get('root')} ({state})")
+
+    browser_capture = payload.get("browser_capture")
+    if isinstance(browser_capture, Mapping):
+        spool_state = "ready" if browser_capture.get("spool_ready") else "unavailable"
+        lines.append(f"Browser capture spool: {spool_state}")
+        origins = browser_capture.get("allowed_origins", [])
+        origin_text = ", ".join(str(item) for item in origins) if isinstance(origins, list) else str(origins)
+        lines.append(f"Browser capture origins: {origin_text}")
+
+    snapshot = payload.get("status_snapshot")
+    if isinstance(snapshot, Mapping):
+        state = str(snapshot.get("state") or "unavailable")
+        age = snapshot.get("age_s")
+        age_text = f", age {float(age):.1f}s" if isinstance(age, int | float) and not isinstance(age, bool) else ""
+        lines.append(f"Snapshot: {state}{age_text}")
+
+    lines.extend(format_status_component_lines(payload))
+    return lines
+
+
+@click.command("status", help="Show configured daemon component status.")
+@click.option(
+    "--spool",
+    "spool_path",
+    type=click.Path(path_type=Path),
+    default=None,
+)
+@click.option(
+    "--format",
+    "output_format",
+    type=click.Choice(["json"]),
+    default=None,
+    help="Output format.",
+)
+def status_command(spool_path: Path | None, output_format: str | None) -> None:
+    """Read the daemon-owned snapshot; never rebuild rich status here."""
+
+    # Keep imports specific to the selected command. In particular, neither the
+    # daemon service graph nor the legacy whole-status collector belongs on this
+    # path.
+    from polylogue.core.json import dumps
+    from polylogue.daemon.status_snapshot import direct_status_snapshot_payload
+    from polylogue.logging import configure_logging
+    from polylogue.operations.status_client import fetch_daemon_snapshot
+
+    del spool_path  # Compatibility option; the daemon snapshot owns its spool evidence.
+    configure_logging()
+    response = fetch_daemon_snapshot("/api/status", timeout_s=0.5)
+    payload: JSONDocument = response.payload if response.payload is not None else direct_status_snapshot_payload()
+    if response.payload is None:
+        snapshot = payload.get("status_snapshot")
+        if isinstance(snapshot, dict):
+            snapshot["refresh_error"] = response.error or "daemon status unavailable"
+    if output_format == "json":
+        click.echo(dumps(payload))
+        return
+    for line in format_daemon_snapshot_lines(payload):
+        click.echo(line)
+
+
+def main(argv: Sequence[str] | None = None) -> None:
+    """Dispatch status lightly and preserve the established daemon CLI otherwise."""
+
+    args = list(sys.argv[1:] if argv is None else argv)
+    program = Path(sys.argv[0]).name or "polylogued"
+    if args[:1] == ["status"]:
+        status_command.main(args=args[1:], prog_name=f"{program} status")
+        return
+
+    from polylogue.daemon.cli import main as daemon_main
+
+    daemon_main.main(args=args, prog_name=program)
+
+
+if __name__ == "__main__":  # pragma: no cover - exercised through the console script
+    main()
+
+
+__all__ = ["format_daemon_snapshot_lines", "main", "status_command"]
