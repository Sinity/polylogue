+    with sqlite3.connect(tmp_path / "source.db") as conn:
+        conn.execute(
+            """
+            CREATE TABLE raw_sessions (
+                raw_id TEXT PRIMARY KEY, origin TEXT, validation_status TEXT,
+                parse_error TEXT, parsed_at_ms INTEGER
+            )
+            """
+        )
+        conn.executemany(
+            "INSERT INTO raw_sessions VALUES (?, 'codex-session', 'valid', 'decode failed', NULL)",
+            [("raw-1",), ("raw-2",), ("raw-3",)],
+        )
+    with sqlite3.connect(tmp_path / "index.db") as conn:
+        conn.execute("CREATE TABLE sessions (session_id TEXT PRIMARY KEY, raw_id TEXT)")
+
+    first = raw_materialization_replay_backlog_page(tmp_path, limit=2)
+    first_progress = cast(Mapping[str, object], first["classification_progress"])
+
+    assert first["available"] is True
+    assert first["precision"] == "bounded_raw_gap_classification"
+    assert first["candidate_count_exact"] is False
+    assert first_progress["processed_count"] == 2
+    assert first_progress["complete"] is False
+
+    second = raw_materialization_replay_backlog_page(tmp_path, limit=2, progress=first_progress)
+    second_progress = cast(Mapping[str, object], second["classification_progress"])
+    assert second["candidate_count_exact"] is True
+    assert second_progress["processed_count"] == 3
+    assert second_progress["complete"] is True
