+        initialize_archive_tier(conn, ArchiveTier.USER)
+        upsert_assertion(
+            conn,
+            assertion_id=assertion_id,
+            target_ref=f"session:{assertion_id}",
+            kind=AssertionKind.TRANSFORM_CANDIDATE,
+            value={"candidate_kind": "summary", "source": "transform"},
+            body_text=f"Candidate {assertion_id}",
+            evidence_refs=(f"message:{assertion_id}",),
+            status="candidate",
+            context_policy={"inject": False, "promotion_required": True},
+            now_ms=now_ms,
+        )
+        conn.commit()
+
+
+def test_archive_debt_page_bounds_work_and_resumes_candidate_scan(tmp_path: Path) -> None:
+    """The production page collector spends at most its declared work budget."""
+
+    _write_current_tier_files(tmp_path)
+    user_db = tmp_path / "user.db"
+    for index in range(3):
+        _write_archive_debt_candidate(
+            user_db,
+            assertion_id=f"page-candidate-{index}",
+            now_ms=1_765_584_000_000 + index,
+        )
+
+    progress: Mapping[str, object] | None = None
+    pages: list[dict[str, object]] = []
+    for _ in range(12):
+        payload = module.archive_debt_page(
+            archive_root=tmp_path,
+            limit=2,
+            progress=progress,
+            row_limit=20,
+        )
+        pages.append(payload)
+        raw_progress = payload["collection_progress"]
+        assert isinstance(raw_progress, dict)
+        assert int(raw_progress["work_units_this_page"]) <= 2
+        assert len(payload["rows"]) <= 20  # type: ignore[arg-type]
+        assert payload["endpoint"] == "/api/archive-debt"
+        assert payload["available"] is True
+        progress = raw_progress
+        if raw_progress["complete"] is True:
+            break
+    else:
+        pytest.fail("bounded archive-debt collection did not converge")
+
+    assert len(pages) >= 3
+    assert progress is not None
+    assert progress["complete"] is True
+    final_rows = pages[-1]["rows"]
+    assert isinstance(final_rows, list)
+    refs = {row["debt_ref"] for row in final_rows if isinstance(row, dict)}
+    assert {
+        "debt:assertion-candidate:page-candidate-0",
+        "debt:assertion-candidate:page-candidate-1",
+        "debt:assertion-candidate:page-candidate-2",
+    }.issubset(refs)
+
+
+def test_archive_debt_page_honours_cancellation_before_probe(tmp_path: Path) -> None:
+    payload = module.archive_debt_page(
+        archive_root=tmp_path,
+        limit=5,
+        cancel_requested=lambda: True,
+    )
+
+    progress = payload["collection_progress"]
+    assert isinstance(progress, dict)
+    assert progress["cancelled"] is True
+    assert progress["complete"] is False
+    assert progress["work_units_this_page"] == 0
+    assert progress["processed_count"] == 0
