+
+def raw_materialization_replay_backlog_page(
+    active_archive: Path,
+    *,
+    limit: int,
+    progress: Mapping[str, object] | None = None,
+    cancel_requested: Callable[[], bool] | None = None,
+) -> dict[str, object]:
+    """Return a bounded, resumable replay-oriented raw-gap projection.
+
+    This status diagnostic deliberately shares the exact raw-gap classifier
+    instead of invoking the unbounded weighted replay planner.  Aggregate raw
+    counts are read in SQLite, while at most ``limit`` individual gaps are
+    inspected for alias, parser, and authority classification.  The full
+    weighted replay planner remains available through the explicit detail ref.
