+        detail_ref="polylogue agents conflicts --detail --format json",
+    )
+
+
+def coordination_component_specs() -> tuple[StatusComponentSpec, ...]:
+    """Return the complete independently budgeted coordination inventory."""
+
+    return (
+        StatusComponentSpec(
+            "repo",
+            _repo_component,
+            cost_class="bounded",
+            deadline_s=0.75,
+            refresh_interval_s=2.0,
+            stale_after_s=15.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_repo_fingerprint,
+            privacy_class="operator",
+            projection_fields=("repo",),
+            detail_ref="polylogue agents status --detail --format json",
+        ),
+        StatusComponentSpec(
+            "process",
+            _process_component,
+            dependencies=("repo",),
+            cost_class="bounded",
+            deadline_s=0.9,
+            refresh_interval_s=2.0,
+            stale_after_s=15.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_process_fingerprint,
+            privacy_class="operator",
+            projection_fields=("self", "peers", "resource_episodes"),
+            detail_ref="polylogue agents self --detail --format json",
+        ),
+        StatusComponentSpec(
+            "work_item",
+            _work_item_component,
+            dependencies=("repo",),
+            cost_class="bounded",
+            deadline_s=0.75,
+            refresh_interval_s=5.0,
+            stale_after_s=30.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_beads_fingerprint,
+            privacy_class="operator",
+            projection_fields=("work_item",),
+            detail_ref="bd list --status=in_progress --json",
+        ),
+        StatusComponentSpec(
+            "beads",
+            _beads_component,
+            dependencies=("repo",),
+            cost_class="expensive",
+            deadline_s=1.5,
+            refresh_interval_s=10.0,
+            stale_after_s=60.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_beads_fingerprint,
+            privacy_class="operator",
+            projection_fields=("beads",),
+            detail_ref="polylogue agents work-item --detail --format json",
+        ),
+        StatusComponentSpec(
+            "archive",
+            _archive_component,
+            dependencies=("process",),
+            cost_class="bounded",
+            deadline_s=1.0,
+            refresh_interval_s=10.0,
+            stale_after_s=60.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_archive_fingerprint,
+            privacy_class="operator",
+            projection_fields=("archive",),
+            detail_ref="polylogue agents status --detail --format json",
+        ),
+        StatusComponentSpec(
+            "handoff_evidence",
+            _handoff_evidence_component,
+            dependencies=("repo", "process", "archive"),
+            cost_class="expensive",
+            deadline_s=1.5,
+            refresh_interval_s=15.0,
+            stale_after_s=90.0,
+            refresh_trigger="source_fingerprint",
+            source_fingerprint=_handoff_fingerprint,
+            privacy_class="operator",
+            projection_fields=(
+                "handoff",
+                "session_trees",
+                "activity_episodes",
+                "subagent_exchanges",
+                "proof_refs",
+                "context_flow_refs",
+            ),
+            detail_ref="polylogue agents handoff --detail --format json",
+        ),
+        StatusComponentSpec(
+            "derived_overlap",
+            _derived_component,
+            dependencies=("repo", "process", "work_item", "archive", "handoff_evidence"),
+            deadline_s=0.25,
+            refresh_interval_s=2.0,
+            stale_after_s=15.0,
+            privacy_class="operator",
+            projection_fields=("overlaps", "advisories"),
+            detail_ref="polylogue agents conflicts --detail --format json",
+        ),
+    )
+
+
+def _component_registry() -> StatusSnapshotRegistry:
+    global _COMPONENT_REGISTRY
+    with _COMPONENT_REGISTRY_LOCK:
+        if _COMPONENT_REGISTRY is None:
+            _COMPONENT_REGISTRY = StatusSnapshotRegistry(
+                scope="agent-coordination",
+                specs=coordination_component_specs(),
+            )
+        return _COMPONENT_REGISTRY
+
+
+def refresh_coordination_components(
+    *,
+    component_ids: Iterable[str] | None = None,
+    force: bool = False,
+) -> tuple[str, ...]:
+    """Start due coordination collectors and return without waiting."""
+
+    return _component_registry().refresh_due(
+        detail_class="standard",
+        component_ids=component_ids,
+        force=force,
+    )
+
+
+def request_coordination_refresh(*, component_ids: Iterable[str] | None = None) -> None:
+    """Queue an explicit refresh without making the caller wait."""
+
+    selected_ids = tuple(component_ids) if component_ids is not None else None
+    threading.Thread(
+        target=lambda: refresh_coordination_components(component_ids=selected_ids, force=True),
+        name="status:coordination:explicit-refresh",
+        daemon=True,
+    ).start()
+
+
+def get_coordination_status_projection() -> JSONDocument:
+    """Return component lifecycle evidence only; no collector can run here."""
+
+    return _component_registry().project(
+        detail_class="standard",
+        privacy_class="operator",
+        include_values=False,
+        include_last_good_values=False,
+    )
+
+
+def _fallback_provenance(note: str) -> CoordinationProvenancePayload:
+    return CoordinationProvenancePayload(
+        source="status-snapshot",
+        confidence=0.0,
+        freshness="unavailable",
+        note=note,
+    )
+
+
+def _fallback_repo(cwd: Path) -> CoordinationRepoPayload:
+    return CoordinationRepoPayload(cwd=str(cwd), provenance=_fallback_provenance("repo snapshot unavailable"))
+
+
+def _fallback_self(cwd: Path) -> CoordinationSelfPayload:
+    return CoordinationSelfPayload(
+        identity_status="unknown",
+        agent_kind="unknown",
+        invocation_pid=os.getpid(),
+        cwd=str(cwd),
+        provenance=_fallback_provenance("process snapshot unavailable"),
+    )
+
+
+def _fallback_work_item() -> CoordinationWorkItemPayload:
+    return CoordinationWorkItemPayload(
+        source="none",
+        confidence=0.0,
+        provenance=_fallback_provenance("work-item snapshot unavailable"),
+    )
+
+
+def _models(raw: JSONValue | None, model: Any) -> tuple[Any, ...]:
+    if not isinstance(raw, list):
+        return ()
+    return tuple(model.model_validate(item) for item in raw if isinstance(item, dict))
+
+
+def _compact_snapshot_contract(projection: Mapping[str, Any]) -> dict[str, object]:
+    raw_components = projection.get("components")
+    components: dict[str, object] = {}
+    if isinstance(raw_components, Mapping):
+        for component_id, raw in raw_components.items():
+            if not isinstance(raw, Mapping):
+                continue
+            last_good = raw.get("last_good")
+            components[str(component_id)] = {
+                "state": raw.get("state"),
+                "reason": raw.get("reason"),
+                "observed_at": raw.get("observed_at"),
+                "refresh_started_at": raw.get("refresh_started_at"),
+                "refresh_finished_at": raw.get("refresh_finished_at"),
+                "refresh_duration_s": raw.get("refresh_duration_s"),
+                "age_s": raw.get("age_s"),
+                "deadline_s": raw.get("deadline_s"),
+                "stale_after_s": raw.get("stale_after_s"),
+                "detail_ref": raw.get("detail_ref"),
+                "last_good": (
+                    {
+                        "observed_at": last_good.get("observed_at"),
+                        "age_s": last_good.get("age_s"),
+                        "refresh_duration_s": last_good.get("refresh_duration_s"),
+                    }
+                    if isinstance(last_good, Mapping)
+                    else None
+                ),
+            }
+    return {
+        "protocol": projection.get("protocol"),
+        "scope": projection.get("scope"),
+        "state": projection.get("state"),
+        "generated_at": projection.get("generated_at"),
+        "component_count": projection.get("component_count"),
+        "state_counts": projection.get("state_counts"),
+        "components": components,
+    }
+
+
+def get_coordination_snapshot_payload(
+    *,
+    view: CoordinationView = "status",
+    limit: int = 10,
+    detail: bool = False,
+) -> AgentCoordinationPayload:
+    """Assemble one typed coordination envelope from cached fragments only."""
+
+    settings = _settings()
+    bounded_limit = max(1, min(limit, 50))
+    registry = _component_registry()
+    projection = registry.project(
+        detail_class="standard",
+        privacy_class="operator",
+        include_values=False,
+        include_last_good_values=False,
+    )
+    values = registry.component_values(use_last_good=True)
+
+    repo_fragment = values.get("repo", {})
+    repo_raw = repo_fragment.get("repo")
+    repo = (
+        CoordinationRepoPayload.model_validate(repo_raw) if isinstance(repo_raw, dict) else _fallback_repo(settings.cwd)
+    )
+
+    process = values.get("process", {})
+    self_raw = process.get("self")
+    self_payload = (
+        CoordinationSelfPayload.model_validate(self_raw) if isinstance(self_raw, dict) else _fallback_self(settings.cwd)
+    )
+    all_peers = _models(process.get("peers"), CoordinationPeerPayload)
+    all_resources = _models(process.get("resource_episodes"), CoordinationResourceEpisodePayload)
+
+    work_fragment = values.get("work_item", {})
+    work_raw = work_fragment.get("work_item")
+    work_item = (
+        CoordinationWorkItemPayload.model_validate(work_raw) if isinstance(work_raw, dict) else _fallback_work_item()
+    )
+
+    beads_raw = values.get("beads", {}).get("beads")
+    beads = CoordinationBeadsPayload.model_validate(beads_raw) if isinstance(beads_raw, dict) else None
+    archive_raw = values.get("archive", {}).get("archive")
+    archive = CoordinationArchivePayload.model_validate(archive_raw) if isinstance(archive_raw, dict) else None
+
+    evidence = values.get("handoff_evidence", {})
+    handoff = _models(evidence.get("handoff"), CoordinationHandoffPayload)
+    session_trees = _models(evidence.get("session_trees"), CoordinationSessionTreePayload)
+    activity = _models(evidence.get("activity_episodes"), CoordinationActivityEpisodePayload)
+    exchanges = _models(evidence.get("subagent_exchanges"), CoordinationSubagentExchangePayload)
+    proofs = _models(evidence.get("proof_refs"), CoordinationProofRefPayload)
+    context_refs = _models(evidence.get("context_flow_refs"), CoordinationContextFlowRefPayload)
+
+    derived = values.get("derived_overlap", {})
+    overlaps = _models(derived.get("overlaps"), CoordinationOverlapPayload)
+    advisories_raw = derived.get("advisories")
+    advisories = tuple(str(item) for item in advisories_raw) if isinstance(advisories_raw, list) else ()
+
+    peers = all_peers[:bounded_limit]
+    resources = all_resources[:bounded_limit]
+    base = AgentCoordinationPayload(
+        view=view,
+        generated_at=str(projection.get("generated_at") or datetime.now(UTC).isoformat()),
+        status_snapshot=_compact_snapshot_contract(projection),
+        repo=repo,
+        self=self_payload,
+        work_item=work_item,
+        peers=peers,
+        resource_episodes=resources,
+        overlaps=overlaps,
+        handoff=handoff,
+        archive=archive,
+        session_trees=session_trees,
+        activity_episodes=activity,
+        subagent_exchanges=exchanges,
+        proof_refs=proofs,
+        context_flow_refs=context_refs,
+        beads=beads,
+        advisories=advisories,
+        limits=CoordinationLimitsPayload(
+            peer_limit=bounded_limit,
+            resource_limit=bounded_limit,
+            changed_path_limit=40,
+            command_chars=220,
+        ),
+        projection=CoordinationProjectionPayload(detail=detail),
+        provenance=(repo.provenance, work_item.provenance, self_payload.provenance),
+    )
+    projected = project_coordination_envelope(base, view)
+    total_counts = _coordination_counts(projected)
+    total_counts["peers"] = len(all_peers)
+    total_counts["resource_episodes"] = len(all_resources)
+    total_counts["peer_components"] = sum(item.component_count for item in all_peers)
+    total_counts["resource_components"] = sum(item.component_count for item in all_resources)
+    total_counts["resource_refs"] = sum(item.resource_count for item in all_resources)
+    if detail:
+        return _finalize_projection(projected, total_counts=total_counts, detail=True)
+    return _compact_coordination_payload(projected, total_counts=total_counts)
+
+
+def reset_coordination_snapshot() -> None:
+    """Clear coordination snapshot evidence for deterministic tests."""
+
+    global _COMPONENT_REGISTRY
+    with _COMPONENT_REGISTRY_LOCK:
+        registry = _COMPONENT_REGISTRY
+        _COMPONENT_REGISTRY = None
+    if registry is not None:
+        registry.reset()
+
+
+__all__ = [
+    "configure_coordination_snapshot",
+    "coordination_component_specs",
+    "get_coordination_snapshot_payload",
+    "get_coordination_status_projection",
+    "refresh_coordination_components",
+    "request_coordination_refresh",
+    "reset_coordination_snapshot",
+]
