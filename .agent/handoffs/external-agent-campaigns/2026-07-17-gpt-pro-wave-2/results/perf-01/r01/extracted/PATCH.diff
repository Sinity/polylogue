+def _normalize_raw_materialization_groups(value: object) -> dict[str, dict[str, object]]:
+    if not isinstance(value, Mapping):
+        return {}
+    groups: dict[str, dict[str, object]] = {}
+    for raw_key, raw_group in value.items():
+        if not isinstance(raw_key, str) or not isinstance(raw_group, Mapping):
+            continue
+        origin = raw_group.get("origin")
+        category = raw_group.get("category")
+        if not isinstance(origin, str) or not isinstance(category, str):
+            continue
+        key = f"{origin}{_RAW_GROUP_SEPARATOR}{category}"
+        raw_count = raw_group.get("count")
+        count = max(int(raw_count), 0) if isinstance(raw_count, int | float) and not isinstance(raw_count, bool) else 0
+        raw_max = raw_group.get("max_blob_size")
+        max_blob_size = (
+            max(int(raw_max), 0) if isinstance(raw_max, int | float) and not isinstance(raw_max, bool) else 0
+        )
+        raw_oversized = raw_group.get("oversized_count")
+        oversized_count = (
+            max(int(raw_oversized), 0)
+            if isinstance(raw_oversized, int | float) and not isinstance(raw_oversized, bool)
+            else 0
+        )
+        raw_stream_safe = raw_group.get("stream_safe_oversized_count")
+        stream_safe_count = (
+            max(int(raw_stream_safe), 0)
+            if isinstance(raw_stream_safe, int | float) and not isinstance(raw_stream_safe, bool)
+            else 0
+        )
+        validation_counts: dict[str, int] = {}
+        raw_validation = raw_group.get("validation_counts")
+        if isinstance(raw_validation, Mapping):
+            for validation, raw_validation_count in raw_validation.items():
+                if isinstance(raw_validation_count, int | float) and not isinstance(raw_validation_count, bool):
+                    validation_counts[str(validation)] = max(int(raw_validation_count), 0)
+        sample_rows: list[dict[str, object]] = []
+        raw_samples = raw_group.get("sample_rows")
+        if isinstance(raw_samples, list):
+            for raw_sample in raw_samples[:5]:
+                if isinstance(raw_sample, Mapping):
+                    sample_rows.append({str(k): v for k, v in raw_sample.items()})
+        embedded_coverage: dict[str, list[int]] = {}
+        raw_coverage = raw_group.get("embedded_coverage")
+        if isinstance(raw_coverage, Mapping):
+            for raw_id, coverage in raw_coverage.items():
+                if (
+                    isinstance(raw_id, str)
+                    and isinstance(coverage, list | tuple)
+                    and len(coverage) == 2
+                    and all(isinstance(item, int | float) and not isinstance(item, bool) for item in coverage)
+                ):
+                    embedded_coverage[raw_id] = [max(int(coverage[0]), 0), max(int(coverage[1]), 0)]
+        groups[key] = {
+            "origin": origin,
+            "category": category,
+            "count": count,
+            "max_blob_size": max_blob_size,
+            "oversized_count": oversized_count,
+            "stream_safe_oversized_count": stream_safe_count,
+            "validation_counts": validation_counts,
+            "source_available": bool(raw_group.get("source_available", False)),
+            "sample_rows": sample_rows,
+            "embedded_coverage": embedded_coverage,
+        }
+    return groups
+
+
+def _raw_materialization_accumulator_page(
+    archive_root: Path,
+    *,
+    limit: int,
+    after_raw_id: str | None,
+    groups: Mapping[str, Mapping[str, object]],
+    cancel_requested: Callable[[], bool] | None,
+) -> tuple[dict[str, dict[str, object]], str | None, int, bool, bool]:
+    """Inspect at most ``limit`` raw debt rows and update grouped evidence."""
+
+    normalized_groups = _normalize_raw_materialization_groups(groups)
+    source_db = archive_root / "source.db"
+    index_db = archive_root / "index.db"
+    if not source_db.exists() or not index_db.exists():
+        return normalized_groups, after_raw_id, 0, True, False
+    conn: sqlite3.Connection | None = None
+    try:
+        conn = sqlite3.connect(f"file:{source_db}?mode=ro", uri=True)
+        conn.row_factory = sqlite3.Row
+        conn.execute("ATTACH DATABASE ? AS index_tier", (str(index_db),))
+        cursor_predicate = "AND r.raw_id > ?" if after_raw_id is not None else ""
+        cursor_parameters: tuple[object, ...] = (after_raw_id,) if after_raw_id is not None else ()
+        candidate_rows = list(
+            conn.execute(
+                f"""
+                SELECT
+                    r.origin,
+                    r.raw_id,
+                    r.native_id,
+                    r.source_path,
+                    r.blob_hash,
+                    r.blob_size,
+                    r.parsed_at_ms,
+                    r.parse_error,
+                    r.validation_status,
+                    r.validation_error
+                FROM raw_sessions AS r
+                LEFT JOIN index_tier.sessions AS s_by_raw ON s_by_raw.raw_id = r.raw_id
+                WHERE s_by_raw.raw_id IS NULL
+                  AND NOT (
+                    r.validation_status = 'skipped'
+                    AND r.parsed_at_ms IS NOT NULL
+                    AND r.parse_error IS NULL
+                  )
+                  {cursor_predicate}
+                ORDER BY r.raw_id
+                LIMIT ?
+                """,
+                (*cursor_parameters, limit + 1),
+            )
+        )
+        page_rows = candidate_rows[:limit]
+        processed = 0
+        next_cursor = after_raw_id
+        cancelled = False
+        for row in page_rows:
+            if cancel_requested is not None and cancel_requested():
+                cancelled = True
+                break
+            category = "parse-pending"
+            can_reconcile_alias = not row["parse_error"] or _retryable_decode_missing_blob_error(row["parse_error"])
+            if can_reconcile_alias and (
+                _raw_materialized_by_native_id(conn, row) or _raw_materialized_by_source_path_native(conn, row)
+            ):
+                category = "materialized-alias"
+            elif _raw_materialized_by_embedded_session_ids(conn, row):
+                processed += 1
+                next_cursor = str(row["raw_id"])
+                continue
+            else:
+                category = _raw_materialization_category(conn, row, archive_root)
+            embedded_coverage: tuple[int, int] | None = None
+            if category == "aggregate-partial-materialization":
+                embedded_ids = _embedded_source_path_session_ids(row)
+                embedded_coverage = _embedded_session_materialization_counts(
+                    conn,
+                    str(row["origin"] or ""),
+                    embedded_ids,
+                )
+            _update_raw_materialization_group(
+                normalized_groups,
+                archive_root=archive_root,
+                row=row,
+                category=category,
+                embedded_coverage=embedded_coverage,
+            )
+            processed += 1
+            next_cursor = str(row["raw_id"])
+        complete = not cancelled and processed == len(page_rows) and len(candidate_rows) <= limit
+        return normalized_groups, next_cursor, processed, complete, cancelled
+    except sqlite3.Error:
+        return normalized_groups, after_raw_id, 0, True, False
+    finally:
+        if conn is not None:
+            conn.close()
+
+
+def _update_raw_materialization_group(
+    groups: dict[str, dict[str, object]],
+    *,
+    archive_root: Path,
+    row: sqlite3.Row,
+    category: str,
+    embedded_coverage: tuple[int, int] | None,
+) -> None:
+    origin = str(row["origin"] or "")
+    key = f"{origin}{_RAW_GROUP_SEPARATOR}{category}"
+    group = groups.setdefault(
+        key,
+        {
+            "origin": origin,
+            "category": category,
+            "count": 0,
+            "max_blob_size": 0,
+            "oversized_count": 0,
+            "stream_safe_oversized_count": 0,
+            "validation_counts": {},
+            "source_available": False,
+            "sample_rows": [],
+            "embedded_coverage": {},
+        },
+    )
+    group["count"] = max(_int_value(group.get("count")) or 0, 0) + 1
+    blob_size = _int_value(row["blob_size"]) or 0
+    group["max_blob_size"] = max(_int_value(group.get("max_blob_size")) or 0, blob_size)
+    if blob_size > RAW_MATERIALIZATION_EXECUTE_BLOB_LIMIT_BYTES:
+        group["oversized_count"] = max(_int_value(group.get("oversized_count")) or 0, 0) + 1
+        if _raw_materialization_row_stream_safe(origin=origin, row=row):
+            group["stream_safe_oversized_count"] = max(_int_value(group.get("stream_safe_oversized_count")) or 0, 0) + 1
+    raw_validation_counts = group.get("validation_counts")
+    validation_counts = raw_validation_counts if isinstance(raw_validation_counts, dict) else {}
+    validation_key = str(row["validation_status"]) if row["validation_status"] is not None else "unknown"
+    validation_counts[validation_key] = int(validation_counts.get(validation_key, 0)) + 1
+    group["validation_counts"] = validation_counts
+    if _source_artifact_exists(str(row["source_path"] or "")):
+        group["source_available"] = True
+    raw_samples = group.get("sample_rows")
+    samples = raw_samples if isinstance(raw_samples, list) else []
+    if len(samples) < 5:
+        sample = _serialize_raw_materialization_row(row)
+        samples.append(sample)
+        group["sample_rows"] = samples
+        if embedded_coverage is not None:
+            raw_coverage = group.get("embedded_coverage")
+            coverage = raw_coverage if isinstance(raw_coverage, dict) else {}
+            coverage[str(row["raw_id"])] = [embedded_coverage[0], embedded_coverage[1]]
+            group["embedded_coverage"] = coverage
+
+
+def _serialize_raw_materialization_row(row: sqlite3.Row) -> dict[str, object]:
+    blob_hash = row["blob_hash"]
+    if isinstance(blob_hash, bytes):
+        blob_hash = blob_hash.hex()
+    return {
+        "origin": str(row["origin"] or ""),
+        "raw_id": str(row["raw_id"]),
+        "native_id": row["native_id"],
+        "source_path": str(row["source_path"] or ""),
+        "blob_hash": str(blob_hash or ""),
+        "blob_size": _int_value(row["blob_size"]) or 0,
+        "parsed_at_ms": row["parsed_at_ms"],
+        "parse_error": row["parse_error"],
+        "validation_status": row["validation_status"],
+        "validation_error": row["validation_error"],
+    }
+
+
+def _raw_materialization_rows_from_accumulators(
+    archive_root: Path,
+    groups: Mapping[str, Mapping[str, object]],
+) -> list[ArchiveDebtRowPayload]:
+    rows: list[ArchiveDebtRowPayload] = []
+    for group in _normalize_raw_materialization_groups(groups).values():
+        samples_raw = group.get("sample_rows")
+        samples = (
+            [sample for sample in samples_raw if isinstance(sample, Mapping)] if isinstance(samples_raw, list) else []
+        )
+        coverage_raw = group.get("embedded_coverage")
+        coverage: dict[str, tuple[int, int]] = {}
+        if isinstance(coverage_raw, Mapping):
+            for raw_id, raw_counts in coverage_raw.items():
+                if (
+                    isinstance(raw_id, str)
+                    and isinstance(raw_counts, list | tuple)
+                    and len(raw_counts) == 2
+                    and all(isinstance(item, int | float) and not isinstance(item, bool) for item in raw_counts)
+                ):
+                    coverage[raw_id] = (int(raw_counts[0]), int(raw_counts[1]))
+        validation_raw = group.get("validation_counts")
+        validation_counts = (
+            {str(key): max(_int_value(value) or 0, 0) for key, value in validation_raw.items()}
+            if isinstance(validation_raw, Mapping)
+            else {}
+        )
+        rows.append(
+            _raw_materialization_debt_row(
+                archive_root,
+                origin=str(group["origin"]),
+                category=str(group["category"]),
+                rows=list(samples),
+                embedded_coverage=coverage,
+                total_count=max(_int_value(group.get("count")) or 0, 0),
+                max_blob_size=max(_int_value(group.get("max_blob_size")) or 0, 0),
+                oversized_count=max(_int_value(group.get("oversized_count")) or 0, 0),
+                stream_safe_oversized_count=max(
+                    _int_value(group.get("stream_safe_oversized_count")) or 0,
+                    0,
+                ),
+                validation_counts=validation_counts,
+                source_available=bool(group.get("source_available", False)),
+            )
+        )
+    return rows
+
