+def _archive_debt_component_fragment(context: StatusCollectionContext) -> StatusCollectionResult:
+    from polylogue.operations.archive_debt import archive_debt_page
+    from polylogue.paths import archive_root
+
+    previous_progress: Mapping[str, object] | None = None
+    if context.previous_value is not None:
+        previous_debt = context.previous_value.get("archive_debt")
+        if isinstance(previous_debt, dict):
+            raw_progress = previous_debt.get("collection_progress")
+            if isinstance(raw_progress, dict):
+                previous_progress = raw_progress
+
+    payload = archive_debt_page(
+        archive_root=Path(archive_root()),
+        limit=min(max(context.collection_limit or 50, 1), 1_000),
+        progress=previous_progress,
+        cancel_requested=context.cancel_requested,
+        row_limit=50,
+    )
+    value = json_document({"archive_debt": json_document(payload)})
+    debt_progress_obj: object = payload.get("collection_progress")
+    complete = isinstance(debt_progress_obj, dict) and bool(debt_progress_obj.get("complete", False))
+    if complete:
+        return StatusCollectionResult.fresh(
+            value,
+            detail_ref="polylogue archive-debt --limit 50",
+        )
+    processed = _int_value(debt_progress_obj.get("processed_count")) if isinstance(debt_progress_obj, dict) else 0
+    cancelled = bool(debt_progress_obj.get("cancelled", False)) if isinstance(debt_progress_obj, dict) else False
+    reason = (
+        f"bounded archive-debt diagnostic cancelled after {processed} work units"
+        if cancelled
+        else f"bounded archive-debt diagnostic partial after {processed} work units; refresh again to resume"
+    )
+    return StatusCollectionResult(
+        value=value,
+        state="degraded",
+        reason=reason,
+        detail_ref="polylogue archive-debt --limit 50",
+    )
+
+
+def _raw_replay_component_fragment(context: StatusCollectionContext) -> StatusCollectionResult:
+    from polylogue.paths import archive_root
+    from polylogue.storage.archive_readiness import raw_materialization_replay_backlog_page
+
+    previous_progress: Mapping[str, object] | None = None
+    if context.previous_value is not None:
+        previous_backlog = context.previous_value.get("raw_replay_backlog")
+        if isinstance(previous_backlog, dict):
+            raw_progress = previous_backlog.get("classification_progress")
+            if isinstance(raw_progress, dict):
+                previous_progress = raw_progress
+    raw = raw_materialization_replay_backlog_page(
+        Path(archive_root()),
+        limit=min(max(context.collection_limit or 50, 1), 1_000),
+        progress=previous_progress,
+        cancel_requested=context.cancel_requested,
+    )
+    value = json_document({"raw_replay_backlog": json_document(raw)})
+    if not bool(raw.get("available", False)):
+        return StatusCollectionResult.unavailable(
+            str(raw.get("reason") or "raw replay diagnostic unavailable"),
+            value=value,
+            detail_ref="polylogue ops readiness --deep",
+        )
+    progress = raw.get("classification_progress")
+    complete = isinstance(progress, dict) and bool(progress.get("complete", False))
+    if complete:
+        return StatusCollectionResult.fresh(value, detail_ref="polylogue ops readiness --deep")
+    processed = _int_value(progress.get("processed_count")) if isinstance(progress, dict) else 0
+    total = _int_value(progress.get("total_gap_count")) if isinstance(progress, dict) else 0
+    cancelled = bool(progress.get("cancelled", False)) if isinstance(progress, dict) else False
+    reason = (
+        f"bounded replay classification cancelled after {processed}/{total} gaps"
+        if cancelled
+        else f"bounded replay classification partial after {processed}/{total} gaps; refresh again to resume"
+    )
+    return StatusCollectionResult(
+        value=value,
+        state="degraded",
+        reason=reason,
+        detail_ref="polylogue ops readiness --deep",
+    )
