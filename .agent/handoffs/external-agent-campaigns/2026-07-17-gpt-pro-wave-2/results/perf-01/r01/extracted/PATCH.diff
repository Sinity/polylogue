@@ -0,0 +1,475 @@
+"""Deterministic contracts for the shared status component scheduler."""
+
+from __future__ import annotations
+
+from collections.abc import Callable, Mapping
+from datetime import UTC
+from typing import Any
+
+from polylogue.core.json import JSONValue
+from polylogue.core.status_snapshots import (
+    StatusCollectionContext,
+    StatusCollectionResult,
+    StatusComponentSpec,
+    StatusSnapshotRegistry,
+)
+from tests.infra.frozen_clock import FrozenClock
+
+
+class _ControlledStarter:
+    """Run selected component workers now and retain the rest as hung workers."""
+
+    def __init__(self) -> None:
+        self.held_suffixes: set[str] = set()
+        self.callbacks: dict[str, Callable[[], None]] = {}
+
+    def __call__(self, callback: Callable[[], None], name: str) -> None:
+        if any(name.endswith(suffix) for suffix in self.held_suffixes):
+            self.callbacks[name] = callback
+            return
+        callback()
+
+
+def _registry(
+    clock: FrozenClock,
+    specs: list[StatusComponentSpec],
+    starter: _ControlledStarter | None = None,
+) -> StatusSnapshotRegistry:
+    return StatusSnapshotRegistry(
+        scope="test",
+        specs=specs,
+        monotonic_clock=clock.monotonic,
+        wall_clock=lambda: clock.now(UTC),
+        thread_starter=starter or _ControlledStarter(),
+    )
+
+
+def _components(registry: StatusSnapshotRegistry) -> dict[str, dict[str, Any]]:
+    projection = registry.project()
+    raw = projection["components"]
+    assert isinstance(raw, dict)
+    return raw  # type: ignore[return-value]
+
+
+def test_hanging_collector_isolated_and_projection_stays_sub_deadline(frozen_clock: FrozenClock) -> None:
+    starter = _ControlledStarter()
+    starter.held_suffixes.add(":hanging")
+    collector_calls: list[str] = []
+
+    def collect(context: StatusCollectionContext) -> dict[str, JSONValue]:
+        collector_calls.append(context.component_id)
+        return {"component": context.component_id}
+
+    registry = _registry(
+        frozen_clock,
+        [
+            StatusComponentSpec("fast", collect, deadline_s=0.2, stale_after_s=10.0),
+            StatusComponentSpec("hanging", collect, deadline_s=0.5, stale_after_s=10.0),
+        ],
+        starter,
+    )
+
+    assert registry.refresh_due(force=True) == ("fast", "hanging")
+    assert collector_calls == ["fast"]
+
+    before = frozen_clock.monotonic()
+    components = _components(registry)
+    after = frozen_clock.monotonic()
+    assert after - before < 0.5
+    assert components["fast"]["state"] == "fresh"
+    assert components["hanging"]["state"] == "refreshing"
