-SELECT v.url
-FROM commands c
-JOIN visits v ON v.ts BETWEEN c.ts AND c.ts + interval '5 min'
-WHERE c.command LIKE 'cargo test%'
-  AND c.exit_code = 1
-  AND v.domain = 'stackoverflow.com';
