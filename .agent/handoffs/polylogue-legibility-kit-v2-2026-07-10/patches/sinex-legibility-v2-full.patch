-//! sessions; the `session_id` provides the stable external key.
+//! `(content_hash, session_id)` — sufficient for de-duplicating this thin
+//! notification. It is not the ultimate identity model for transcript storage:
+//! stable Polylogue object IDs, revisions, Sinex interpretation IDs, and exact
+//! material occurrence refs must remain separate.
 
 use sinex_macros::SourceMeta;
 use sinex_primitives::privacy::ProcessingContext;
