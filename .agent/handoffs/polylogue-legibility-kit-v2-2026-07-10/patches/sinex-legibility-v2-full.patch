+    sqlite_role: offline-replica-outbox
+    rebuildable: false
+  context_images:
+    backed_authority: sinex-material-plane
+    sqlite_role: local-cache
+    rebuildable: false
+  context_delivery_occurrences:
+    backed_authority: sinex-durable-history
+    sqlite_role: audit-projection
+    rebuildable: false
