{
  "name": "polylogue-browser-capture",
  "version": "0.1.0",
  "private": true,
  "description": "Polylogue browser extension for capturing web LLM sessions",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "validate": "node scripts/validate-manifest.mjs",
    "dev-loop-smoke": "node scripts/dev-loop-smoke.mjs",
    "dev-loop-browser-smoke": "node scripts/dev-loop-browser-smoke.mjs",
    "dev-loop-provider-smoke": "node scripts/dev-loop-provider-smoke.mjs",
    "dev-loop-live-provider-proof": "node scripts/dev-loop-live-provider-proof.mjs",
    "build": "node scripts/build.mjs",
    "screenshots": "node scripts/screenshots.mjs",
    "sync-version": "node scripts/build.mjs --sync-only"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "vitest": "^3.0.0"
  }
}
